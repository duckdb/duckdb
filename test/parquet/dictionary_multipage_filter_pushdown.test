# ROLLUP form matching the original q27 shape (single dictionary group key).
query I
SELECT count(*) FROM (
    SELECT k, count(*) FROM 'data/parquet-testing/dictionary_multipage.parquet'
    WHERE f < 500 GROUP BY ROLLUP(k)
)
----
41
