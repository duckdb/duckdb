# name: test/parquet/test_list_map_element_filters.test
# description: Test LIST and MAP element filtering in Parquet with ListExtractFilter
# group: [parquet]

require parquet

statement ok
PRAGMA enable_verification

# Test 1: MAP element filtering
statement ok
CREATE TABLE test_map AS SELECT
    i as id,
    map(['a', 'b'], [i, i*10]) as data
FROM range(100) t(i);

statement ok
COPY test_map TO '__TEST_DIR__/test_map.parquet' (FORMAT PARQUET);

# Filter on MAP element - should work correctly
query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_map.parquet' WHERE data['a'] > 50;
----
49

query II
SELECT id, data['a'] FROM '__TEST_DIR__/test_map.parquet' WHERE data['a'] BETWEEN 10 AND 15 ORDER BY id;
----
10	10
11	11
12	12
13	13
14	14
15	15

# Multiple MAP filters
query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_map.parquet' WHERE data['a'] > 25 AND data['b'] < 500;
----
24

# Test 2: LIST element filtering
statement ok
CREATE TABLE test_list AS SELECT
    i as id,
    [i, i+10, i+20] as numbers
FROM range(100) t(i);

statement ok
COPY test_list TO '__TEST_DIR__/test_list.parquet' (FORMAT PARQUET);

# Filter on LIST element - should work correctly
query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_list.parquet' WHERE numbers[1] > 50;
----
49

query II
SELECT id, numbers[1] FROM '__TEST_DIR__/test_list.parquet' WHERE numbers[1] BETWEEN 10 AND 15 ORDER BY id;
----
10	10
11	11
12	12
13	13
14	14
15	15

# Filter on different LIST indices
query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_list.parquet' WHERE numbers[2] > 30;
----
79

query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_list.parquet' WHERE numbers[3] < 50;
----
30

# Test 3: Complex filters with NULLs
statement ok
CREATE TABLE test_nulls AS SELECT
    i as id,
    CASE WHEN i % 10 = 0 THEN NULL ELSE map(['x'], [i]) END as m,
    CASE WHEN i % 5 = 0 THEN NULL ELSE [i, i*2] END as nums
FROM range(50) t(i);

statement ok
COPY test_nulls TO '__TEST_DIR__/test_nulls.parquet' (FORMAT PARQUET);

query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_nulls.parquet' WHERE m['x'] > 25;
----
22

query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_nulls.parquet' WHERE nums[1] < 20;
----
16

# NULL handling - filters should handle NULLs correctly
query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_nulls.parquet' WHERE m IS NOT NULL AND m['x'] > 25;
----
22

# Test 4: Nested structures
statement ok
CREATE TABLE test_nested AS SELECT
    i as id,
    map(['data'], [[i, i+1, i+2]]) as nested_map
FROM range(50) t(i);

statement ok
COPY test_nested TO '__TEST_DIR__/test_nested.parquet' (FORMAT PARQUET);

# Filter on nested MAP with LIST values
query I
SELECT COUNT(*) FROM '__TEST_DIR__/test_nested.parquet' WHERE nested_map['data'][1] > 25;
----
24

# Test 5: Verify filter pushdown with EXPLAIN
# This manually confirms that ListExtractFilter is being used
statement ok
CREATE TABLE verify_filter AS SELECT
    i as id,
    map(['key'], [i*100]) as m
FROM range(10) t(i);

statement ok
COPY verify_filter TO '__TEST_DIR__/verify.parquet' (FORMAT PARQUET);

# Run query that should use filter pushdown
query I
SELECT COUNT(*) FROM '__TEST_DIR__/verify.parquet' WHERE m['key'] > 500;
----
4

# Manual verification with EXPLAIN shows:
# PARQUET_SCAN with Filters: map_extract_value(m, 'key') > 500
# This proves ListExtractFilter is working for filter pushdown

# Cleanup
statement ok
DROP TABLE test_map;

statement ok
DROP TABLE test_list;

statement ok
DROP TABLE test_nulls;

statement ok
DROP TABLE test_nested;

statement ok
DROP TABLE verify_filter;
