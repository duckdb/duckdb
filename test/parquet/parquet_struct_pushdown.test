# name: test/parquet/parquet_struct_pushdown.test
# group: [parquet]

require parquet

load {TEST_DIR}/struct_filter_pushdown.parquet.test readwrite v1.5.0

statement ok
SET variant_minimum_shredding_size = 0;

statement ok
COPY (
SELECT
	{
		'x': i,
		'y': i * 100,
		'z': i * 10000
	} v
FROM range(100) t(i)
) TO '{TEST_DIR}/struct_filter_pushdown.parquet';

query I
SELECT COUNT(*) FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x=5
----
1

query I
SELECT v.x FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x=5
----
5

query I
SELECT v.x::UTINYINT FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x=5
----
5

query I
SELECT v.y FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x=5
----
500

query I
SELECT COUNT(*) FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x=5 AND v.y=500
----
1

query I
SELECT v.x FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x=5 AND v.y=500
----
5

query I
SELECT v.z FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x=5 AND v.y=500
----
50000

query I
SELECT COUNT(*) FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x + v.y = 505
----
1

query I
SELECT v.x FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x + v.y = 505
----
5

query I
SELECT v.z FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x + v.y = 505
----
50000


query I
SELECT COUNT(*) FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x = 5 OR v.y = 400
----
2

query I
SELECT v.x FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x = 5 OR v.y = 400 ORDER BY ALL
----
4
5

query I
SELECT v.z FROM '{TEST_DIR}/struct_filter_pushdown.parquet' WHERE v.x = 5 OR v.y = 400 ORDER BY ALL
----
40000
50000
