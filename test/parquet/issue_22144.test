# name: test/parquet/issue_22144.test
# description: COPY to Parquet should preserve NOT NULL column constraints
# group: [parquet]

require parquet

statement ok
CREATE TABLE t (a INTEGER NOT NULL, b VARCHAR, c DOUBLE NOT NULL);

statement ok
INSERT INTO t VALUES (1, 'hello', 3.14), (2, NULL, 2.71);

# COPY from a table
statement ok
COPY t TO '{TEST_DIR}/not_null.parquet';

query II
SELECT name, repetition_type
FROM parquet_schema('{TEST_DIR}/not_null.parquet')
WHERE name != 'duckdb_schema'
ORDER BY name;
----
a	REQUIRED
b	OPTIONAL
c	REQUIRED

# COPY from a view: NOT NULL stats propagate through the trivial projection
statement ok
CREATE VIEW v AS SELECT * FROM t;

statement ok
COPY v TO '{TEST_DIR}/not_null_view.parquet';

query II
SELECT name, repetition_type
FROM parquet_schema('{TEST_DIR}/not_null_view.parquet')
WHERE name != 'duckdb_schema'
ORDER BY name;
----
a	REQUIRED
b	OPTIONAL
c	REQUIRED

# COPY from a subquery
statement ok
COPY (FROM t) TO '{TEST_DIR}/not_null_subquery.parquet';

query II
SELECT name, repetition_type
FROM parquet_schema('{TEST_DIR}/not_null_subquery.parquet')
WHERE name != 'duckdb_schema'
ORDER BY name;
----
a	REQUIRED
b	OPTIONAL
c	REQUIRED
