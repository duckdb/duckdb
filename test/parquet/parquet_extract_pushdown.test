# name: test/parquet/parquet_extract_pushdown.test
# group: [parquet]

require parquet

foreach logical_type struct variant

onlyif logical_type=struct
statement ok
COPY (
SELECT
	{
		'x': i,
		'y': i * 100,
		'z': i * 10000
	} v
FROM range(100) t(i)
) TO '{TEST_DIR}/{logical_type}_filter_pushdown.parquet';

onlyif logical_type=variant
statement ok
COPY (
SELECT
	{
		'x': i,
		'y': i * 100,
		'z': i * 10000
	}::VARIANT v
FROM range(100) t(i)
) TO '{TEST_DIR}/{logical_type}_filter_pushdown.parquet';

query I
SELECT COUNT(*) FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x=5
----
1

query I
SELECT v.x FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x=5
----
5

query I
SELECT v.x::UTINYINT FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x=5
----
5

query I
SELECT v.y FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x=5
----
500

query I
SELECT COUNT(*) FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x=5 AND v.y=500
----
1

query I
SELECT v.x FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x=5 AND v.y=500
----
5

query I
SELECT v.z FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x=5 AND v.y=500
----
50000

query I
SELECT COUNT(*) FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x + v.y = 505
----
1

query I
SELECT v.x FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x + v.y = 505
----
5

query I
SELECT v.z FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x + v.y = 505
----
50000


query I
SELECT COUNT(*) FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x = 5 OR v.y = 400
----
2

query I
SELECT v.x FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x = 5 OR v.y = 400 ORDER BY ALL
----
4
5

query I
SELECT v.z FROM '{TEST_DIR}/{logical_type}_filter_pushdown.parquet' WHERE v.x = 5 OR v.y = 400 ORDER BY ALL
----
40000
50000

endloop

statement ok
COPY (
	SELECT
		{
			'x': i,
			'y': i * 100,
			'z': i * 10000
		}::VARIANT v
	FROM range(100) t(i)
	UNION ALL VALUES (
		({
			'x': 'test',
			'y': 'hello',
			'z': 'world'
		}::VARIANT)
	)
) TO '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet';

statement error
SELECT COUNT(*) FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE v.x=5
----
Invalid Input Error: Can't compare values of type VARCHAR (test) and type INTEGER (5) - an explicit cast is required

query I
SELECT COUNT(*) FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND v.x=5
----
1

query I
SELECT v.x FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND v.x=5
----
5

statement error
SELECT v.x::UTINYINT FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE v.x=5
----
Invalid Input Error: Can't compare values of type VARCHAR (test) and type INTEGER (5) - an explicit cast is required

# FIXME: this should not be erroring
# What likely happens is that the cast is pushed beyond the filter
statement error
SELECT v.x::UTINYINT FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND v.x=5
----
Conversion Error: Can't convert VARIANT(VARCHAR) value 'test' to 'UTINYINT'

query I
SELECT v.y FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND v.x=5
----
500

query I
SELECT COUNT(*) FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND v.x=5 AND variant_typeof(v.y) == 'INT64' AND v.y=500
----
1

query I
SELECT v.x FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND v.x=5 AND variant_typeof(v.y) == 'INT64' AND v.y=500
----
5

query I
SELECT v.z FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND v.x=5 AND variant_typeof(v.y) == 'INT64' AND v.y=500
----
50000

# FIXME: the first filters should fix this????
statement error
SELECT COUNT(*) FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND variant_typeof(v.y) == 'INT64' AND v.x + v.y = 505
----
Conversion Error: Can't convert VARIANT(VARCHAR) value 'test' to 'BIGINT'

# FIXME: the first filters should fix this????
statement error
SELECT v.x FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND variant_typeof(v.y) == 'INT64' AND v.x + v.y = 505
----
Conversion Error: Can't convert VARIANT(VARCHAR) value 'test' to 'BIGINT'

# FIXME: the first filters should fix this????
statement error
SELECT v.z FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND variant_typeof(v.y) == 'INT64' AND v.x + v.y = 505
----
Conversion Error: Can't convert VARIANT(VARCHAR) value 'test' to 'BIGINT'

query I
SELECT COUNT(*) FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND variant_typeof(v.y) == 'INT64' AND (v.x = 5 OR v.y = 400)
----
2

query I
SELECT v.x FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND variant_typeof(v.y) == 'INT64' AND (v.x = 5 OR v.y = 400) ORDER BY ALL
----
4
5

query I
SELECT v.z FROM '{TEST_DIR}/variant_unshredded_filter_pushdown.parquet' WHERE variant_typeof(v.x) == 'INT64' AND variant_typeof(v.y) == 'INT64' AND (v.x = 5 OR v.y = 400) ORDER BY ALL
----
40000
50000
