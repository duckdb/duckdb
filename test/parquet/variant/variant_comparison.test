# name: test/parquet/variant/variant_comparison.test
# group: [variant]

require parquet

statement ok
create table tbl(col VARIANT);

statement ok
insert into tbl select * from (VALUES
	('test'::VARIANT),
	('99'::VARIANT),
	('1'::VARIANT),
	('101'::VARIANT),
	(-123::VARIANT),
	((-100.5::decimal(5,1))::VARIANT),
	((100.5::decimal(5,1))::VARIANT)
) t(col)

# VARIANT comparison uses a total, type-first sort-key order (via variant_sort_key) instead of
# throwing on incompatible types. Integers, decimals and bignums fold into one NUMBER rank and
# compare by numeric value; FLOAT/DOUBLE fold into REAL; the remaining types order by type rank
# first, value second. Here the VARCHAR values rank above NUMBER, so they sort after 100.5.
query I
select col from tbl where col > 100 order by col
----
100.5
1
101
99
test

# col > 0 : the NUMBER fold compares decimals and integers by numeric value
query I
select col from tbl where variant_typeof(col) != 'VARCHAR' and col > 0
----
100.5

# the NUMBER fold makes -123 (stored as BIGINT) compare equal to the INTEGER literal -123
query I
select col from tbl where variant_typeof(col) != 'VARCHAR' and col == -123
----
-123

# regression: a VARIANT comparison in a WHERE clause is subject to filter pushdown, which copies the
# cast-to-VARIANT bind data - this must not re-shred the (already shredded) cast target type
query I
select * from range(-10, 10) t(i) where i::variant = -10 order by all
----
-10

query I
select i from range(-3, 3) t(i) where i::variant > 0 order by i::variant
----
1
2

statement ok
delete from tbl;

statement ok
insert into tbl select * from (VALUES
	({'a': 21, 'b': 42}::VARIANT),
	([1::VARIANT, 2, {'this is a long string': 'test'}])
)

# OBJECT and ARRAY have their own ranks (above all scalar types), so comparing them to an
# integer no longer errors - they simply sort above it
query I
select col > 100 from tbl
----
true
true

query I
select col.a > 100 from tbl
----
false
NULL

query I
select col[1] > 100 from tbl
----
NULL
false

query I
select col[1] > 0 from tbl
----
NULL
true
