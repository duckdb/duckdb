# name: test/issues/general/test_21890.test
# description: Issue 21890 - correlated HAVING subquery with TRY() should not leave stale delim join bindings
# group: [general]

statement ok
CREATE TABLE tbl(val INT);

statement ok
INSERT INTO tbl VALUES (1), (2);

query I
SELECT val
FROM tbl
GROUP BY val
HAVING (
  SELECT COUNT(*)
  FROM tbl tbl2
  WHERE TRY(tbl.val) > 0
) > 0
ORDER BY val
----
1
2

statement ok
CREATE OR REPLACE MACRO test_21890_macro(q) AS TABLE
  WITH sel AS (
    SELECT unnest(string_split(q, ',')) AS tag,
           row_number() OVER () AS node_id
  )
  SELECT s.tag, s.node_id
  FROM sel s
  WHERE s.tag = 'a'
    AND NOT EXISTS (
        SELECT 1 FROM sel args
        WHERE args.tag = 'b'
          AND s.node_id > args.node_id
    );

query TI
SELECT * FROM test_21890_macro('a,b,a,b');
----
a	1
a	1

query TTI
WITH inputs(q) AS (VALUES ('a,b,a,b'), ('b,a'))
SELECT i.q, m.* FROM inputs i, test_21890_macro(i.q) m ORDER BY i.q, m.tag, m.node_id;
----
a,b,a,b	a	1
a,b,a,b	a	1
b,a	a	1

statement ok
PRAGMA disable_optimizer

query I
SELECT val
FROM tbl
GROUP BY val
HAVING (
  SELECT COUNT(*)
  FROM tbl tbl2
  WHERE TRY(tbl.val) > 0
) > 0
ORDER BY val
----
1
2

query TTI
WITH inputs(q) AS (VALUES ('a,b,a,b'), ('b,a'))
SELECT i.q, m.* FROM inputs i, test_21890_macro(i.q) m ORDER BY i.q, m.tag, m.node_id;
----
a,b,a,b	a	1
a,b,a,b	a	1
b,a	a	1

query I
SELECT val FROM tbl GROUP BY val HAVING (SELECT COUNT(*) FROM tbl tbl2 WHERE TRY(tbl.val) > 0) > 0 ORDER BY val;
----
1
2

statement error
SELECT val+1 FROM tbl GROUP BY val+1 HAVING (SELECT COUNT(*) FROM tbl tbl2 WHERE TRY(tbl.val) > 0) > 0 ORDER BY val+1;
----
must appear in the GROUP BY clause

statement error
SELECT CAST(val AS BIGINT) FROM tbl GROUP BY CAST(val AS BIGINT) HAVING (SELECT COUNT(*) FROM tbl tbl2 WHERE TRY(tbl.val) > 0) > 0 ORDER BY 1;
----
must appear in the GROUP BY clause
