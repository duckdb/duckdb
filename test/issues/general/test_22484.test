# name: test/issues/general/test_22484.test
# description: Issue 22484 - TRY_CAST bare integer string to INTERVAL returns NULL without trailing whitespace
# group: [general]

query IIII
SELECT
	TRY_CAST('42 seconds' AS INTERVAL),
	TRY_CAST('42 ' AS INTERVAL),
	TRY_CAST('42' AS INTERVAL),
	TRY_CAST(' 42' AS INTERVAL);
----
00:00:42	00:00:42	00:00:42	00:00:42

query I
SELECT
	TRY_CAST('42x' AS INTERVAL)
----
NULL