# name: test/issues/general/test_9399.test_slow
# description: Issue 9399: Incorrect query output from group by query (regression in 0.9.0)
# group: [general]

# happened with > 8 threads
statement ok
SET threads=10

# create table that's has just one row group, and just a few duplicates
statement ok
CREATE TABLE test AS
SELECT CASE WHEN hash_to_unit([range, 0]) < 0.002 THEN range ELSE 100000 - range END c0,
    hash_to_unit([range, 1]) c1,
    hash_to_unit([range, 2]) c2
FROM range(100000)

# should return 99792 rows (regression check from issue 9399; specific count depends on random seed)
query III
WITH cte AS (SELECT c0,
avg(c1) AS c1_avg,
avg(c2) AS c2_avg
FROM test GROUP BY c0)
SELECT * FROM cte
ORDER BY c0
----
