# name: test/remote_pushdown/remote_pushdown_mixed.test
# description: Queries mixing local DuckDB tables with remote MySQL tables must not be fully pushed down
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.remote_tbl AS SELECT i, i * 10 AS v FROM range(10) t(i)

statement ok
CREATE OR REPLACE TABLE local_tbl AS SELECT i FROM range(5) t(i)

# JOIN between a local DuckDB table and a remote MySQL table
# remote_tbl has i=0..9; local_tbl has i=0..4 → joined rows have i=0,1,2,3,4
# SUM(v) = 0+10+20+30+40 = 100
query I
SELECT SUM(s.remote_tbl.v) FROM s.remote_tbl JOIN local_tbl ON (s.remote_tbl.i = local_tbl.i)
----
100

query II
explain SELECT SUM(s.remote_tbl.v) FROM s.remote_tbl JOIN local_tbl ON (s.remote_tbl.i = local_tbl.i)
----
physical_plan	<REGEX>:.*AGGREGATE.*

# local table on the left side
query I
SELECT SUM(s.remote_tbl.v) FROM local_tbl JOIN s.remote_tbl ON (local_tbl.i = s.remote_tbl.i)
----
100

# IN subquery over a local table
query I
SELECT SUM(v) FROM s.remote_tbl WHERE i IN (SELECT i FROM local_tbl)
----
100

query II
explain SELECT SUM(v) FROM s.remote_tbl WHERE i IN (SELECT i FROM local_tbl)
----
physical_plan	<REGEX>:.*AGGREGATE.*

# NOT IN subquery over a local table -- i NOT IN {0..4} → i=5..9 → v=50+60+70+80+90=350
query I
SELECT SUM(v) FROM s.remote_tbl WHERE i NOT IN (SELECT i FROM local_tbl)
----
350

# EXISTS correlated subquery referencing local table
query I
SELECT SUM(v) FROM s.remote_tbl WHERE EXISTS (SELECT 1 FROM local_tbl WHERE local_tbl.i = s.remote_tbl.i)
----
100

query II
explain SELECT SUM(v) FROM s.remote_tbl WHERE EXISTS (
    SELECT 1 FROM local_tbl WHERE local_tbl.i = s.remote_tbl.i)
----
physical_plan	<REGEX>:.*AGGREGATE.*

# scalar subquery over a local table used in SELECT list
# returns max(local_tbl.i) = 4 for every row
query I
SELECT COUNT(*) FROM s.remote_tbl WHERE v > (SELECT MAX(i) * 10 FROM local_tbl)
----
5

# mixed source in UNION -- remote side would be pushed, but unified result is handled locally
statement ok
CREATE OR REPLACE TABLE local_extra AS SELECT i + 100 AS i, i * 10 AS v FROM range(5) t(i)

query I
SELECT SUM(v) FROM (SELECT v FROM s.remote_tbl UNION ALL SELECT v FROM local_extra) t
----
550
