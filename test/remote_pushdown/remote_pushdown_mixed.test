# name: test/remote_pushdown/remote_pushdown_mixed.test
# description: Mixed local/remote scenarios, lateral joins, SET_RETURNING_FUNCTION neutrality
# group: [remote_pushdown]

require quack

require httpfs

statement ok db1:con1
call quack_serve('quack:localhost', token='asdf');

statement ok db1:con1
create table t1(i int);

statement ok db1:con1
insert into t1 from range(10);

statement ok
attach 'quack:localhost' as rpc (token 'asdf')

statement ok
create table local_t(local_col int);

statement ok
insert into local_t from range(10);

# --- Mixed UNION ALL ---

# Mixed: UNION operator stays in local plan
query II
explain (select * from rpc.t1 limit 5) union all select * from local_t
----
physical_plan	<REGEX>:.*UNION.*

# The pushed remote side (LIMIT 5) is not visible as a LIMIT in the local plan
query II
explain (select * from rpc.t1 limit 5) union all select * from local_t
----
physical_plan	<!REGEX>:.*LIMIT.*

# Functional: 5 from remote + 10 from local = 15 rows
query I
select count(*) from ((select * from rpc.t1 limit 5) union all select * from local_t)
----
15

# --- Mixed JOIN ---

# Mixed JOIN: stays in local plan (JOIN operator visible)
query II
explain select * from rpc.t1 join local_t on (i = local_col)
----
physical_plan	<REGEX>:.*JOIN.*

# local_t={0..9}, rpc.t1={0..9}: all 10 values match -> 10 rows
query I
select count(*) from rpc.t1 join local_t on (i = local_col)
----
10

# Catalog-qualified column ref in mixed JOIN condition: "rpc.t1.i" must be stripped to "t1.i"
# after rpc.t1 is replaced by quack_query_by_name(...) AS t1 in FROM, otherwise the binder
# fails with "Referenced table rpc.t1 not found".
query I
select count(*) from rpc.t1 join local_t on (rpc.t1.i = local_t.local_col)
----
10

# Catalog-qualified ref in WHERE clause with mixed join: "rpc.t1.i" must be stripped too
query I
select count(*) from rpc.t1 join local_t on (i = local_col) where rpc.t1.i > 5
----
4

# Catalog-qualified ref in SELECT list with mixed join
query I
select count(rpc.t1.i) from rpc.t1 join local_t on (i = local_col)
----
10

# --- SET_RETURNING_FUNCTION neutrality ---

# range() is neutral: doesn't block pushdown of adjacent remote refs
query II
explain select count(*) from rpc.t1, range(0, 10) r(n) where i = n
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

# t1={0..9}, range(0,10)={0..9}: all 10 match
query I
select count(*) from rpc.t1, range(0, 10) r(n) where i = n
----
10

# generate_series() is also neutral: whole query pushed
query II
explain select count(*) from rpc.t1, generate_series(0, 9) gs(n) where i = n
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

query I
select count(*) from rpc.t1, generate_series(0, 9) gs(n) where i = n
----
10

# range() with local table: local table blocks full pushdown; local scan visible
query II
explain select count(*) from local_t, range(0, 10) r(n) where local_col = n
----
physical_plan	<REGEX>:.*SEQ_SCAN.*

# Local range scan still produces correct result
query I
select count(*) from local_t, range(0, 10) r(n) where local_col = n
----
10

# range() in UNION with local: UNION stays local
query II
explain (select * from rpc.t1 limit 3) union all select * from range(0, 3) r(i)
----
physical_plan	<REGEX>:.*UNION.*

# --- Local macros ---

statement ok
create macro my_add(x, y) as x + y;

# Local macro used on remote table: macro stays local, remote scan is pushed individually
# rpc.t1={0..9}; my_add(i,0) > 5 -> i > 5 -> {6,7,8,9} -> 4 rows
query I
select count(*) from rpc.t1 where my_add(i, 0) > 5
----
4

# Table-qualified column ref (t1.i) in WHERE with local macro: rpc.t1 is pushed individually
# as quack_query_by_name(...) AS t1 so t1.i in the outer WHERE still resolves.
# my_add(t1.i, 0) > 5 -> i > 5 -> {6,7,8,9} -> 4 rows
query I
select count(*) from rpc.t1 where my_add(t1.i, 0) > 5
----
4

# Scalar macro result is correct via local evaluation
query I
select my_add(10, 5)
----
15

statement ok
drop macro my_add;

# After dropping macro, built-in expressions are pushed again
query II
explain select i + 1 from rpc.t1 where i > 5
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

query I
select count(*) from rpc.t1 where i + 1 > 6
----
4

# --- Lateral joins ---

# Lateral: local outer table + remote inner -> NOT pushed (outer must stay local)
# local_t={0..9}, rpc.t1={0..9}: i = local_col always matches -> 10 rows
query I
select count(*) from local_t, lateral (select * from rpc.t1 where i = local_col) sub
----
10

# Same with explicit catalog prefix on local table: column names must still be tracked
# (Rewrite(BaseTableRef) Case 1 now does a catalog lookup to populate column names)
query I
select count(*) from memory.main.local_t, lateral (select * from rpc.t1 where i = local_col) sub
----
10

# Lateral: local outer with no matching remote rows
# local_col+100 won't be in t1={0..9} -> 0 rows
query I
select count(*) from local_t, lateral (select * from rpc.t1 where i = local_col + 100) sub
----
0

# Correlated ORDER BY in lateral subquery: outer local_col reference in ORDER BY must block push.
# Without the fix, HasLocalTableReference missed modifiers and the subquery was pushed to the
# remote, which then failed because local_col is not a column on the remote server.
# With the fix, the correlation is detected and the lateral executes locally:
# 10 outer rows (local_t) x 1 inner row (LIMIT 1 from rpc.t1) = 10 rows
query I
select count(*) from local_t, lateral (select i from rpc.t1 order by local_col limit 1) sub
----
10

# Correlated JOIN ON in lateral from_table: HasLocalTableReference must check from_table
# expressions (join condition and table function args). Without the fix, local_col in
# the ON clause is missed and the lateral is pushed to remote where it fails with a
# "column not found" error. With the fix the correlation is detected, pushdown is blocked,
# and the query falls back to local execution — which hits the documented "Multiple streaming
# scans" limitation because the inner 2-table join needs two simultaneous quack connections.
statement error
select count(*) from local_t,
    lateral (select a.i from rpc.t1 a join rpc.t1 b on a.i = local_col and b.i = local_col) sub
----
Multiple streaming scans

# Correlated SubqueryRef inside JoinRef in lateral: HasLocalTableReference(TableRef&) must
# recurse into SubqueryRef children of a JoinRef, not just into JOIN conditions. Without the
# fix, the SubqueryRef case fell through to default (return false), so the correlated
# local_col ref inside the nested subquery was missed and the lateral was incorrectly pushed
# to the remote where it failed with a "column not found" error.
# With the fix, the correlation is detected and the query falls back to local execution,
# which hits the documented "Multiple streaming scans" limitation.
statement error
select count(*) from local_t,
    lateral (
        select a.i from rpc.t1 a
        join (select * from rpc.t1 where i = local_col) sq on a.i = sq.i
    ) sub
----
Multiple streaming scans

# Lateral: all remote outer + remote inner -> pushed (no SEQ_SCAN)
query II
explain select t1a.i from rpc.t1 t1a, lateral (select * from rpc.t1 t1b where t1b.i = t1a.i) sub
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

# Each of the 10 rows in t1 has exactly 1 match via lateral -> 10 rows
query I
select count(*) from rpc.t1 t1a, lateral (select * from rpc.t1 t1b where t1b.i = t1a.i) sub
----
10

# --- Subquery wrapping remote (nested levels) ---

# Double-wrapped subquery: all remote -> pushed
query II
explain select count(*) from (select * from (select i from rpc.t1 where i > 5) sub1) sub2
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

query I
select count(*) from (select * from (select i from rpc.t1 where i > 5) sub1) sub2
----
4

statement ok
drop table local_t

statement ok db1:con1
call quack_stop('quack:localhost')
