# name: test/remote_pushdown/remote_pushdown_transactions.test
# description: Pushed-down queries must see uncommitted changes made in the same transaction
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.txn_tbl AS SELECT i FROM range(5) t(i)

statement ok
BEGIN

statement ok
INSERT INTO s.txn_tbl VALUES (100)

# the pushed-down aggregate must run on the transaction's connection and see the uncommitted row
query I
SELECT COUNT(*) FROM s.txn_tbl
----
6

query I
SELECT SUM(i) FROM s.txn_tbl
----
110

statement ok
ROLLBACK

# after the rollback the row is gone
query I
SELECT COUNT(*) FROM s.txn_tbl
----
5

# commit path
statement ok
BEGIN

statement ok
INSERT INTO s.txn_tbl VALUES (200)

query I
SELECT MAX(i) FROM s.txn_tbl
----
200

statement ok
COMMIT

query I
SELECT MAX(i) FROM s.txn_tbl
----
200

# mixing pushed-down queries and regular scans within one transaction
statement ok
BEGIN

statement ok
INSERT INTO s.txn_tbl VALUES (300)

# pushed aggregate
query I
SELECT MAX(i) FROM s.txn_tbl
----
300

# regular scan (not pushed - local table function blocks the pushdown)
query I
SELECT COUNT(*) FROM s.txn_tbl, range(1) t(x)
----
7

statement ok
ROLLBACK
