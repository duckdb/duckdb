# name: test/remote_pushdown/remote_pushdown_join.test
# description: Test remote pushdown of joins into MySQL
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

# create a table
statement ok
CREATE OR REPLACE TABLE s.tbl1 AS SELECT i, i%2 v1 FROM range(10) t(i)

statement ok
CREATE OR REPLACE TABLE s.tbl2 AS SELECT i, i*100 v2 FROM range(10) t(i)

# joins are pushed down
query II
SELECT SUM(v1), SUM(v2) FROM s.tbl1 JOIN s.tbl2 USING (i)
----
5.0	4500.0

query II
explain SELECT SUM(v1), SUM(v2) FROM s.tbl1 JOIN s.tbl2 USING (i)
----
physical_plan	<!REGEX>:.*JOIN.*

# join conditions that are not supported in MySQL
query II
SELECT SUM(v1), SUM(v2) FROM s.tbl1 JOIN s.tbl2 ON (CAST(s.tbl1.i AS VARCHAR) = CAST(s.tbl2.i AS VARCHAR))
----
5.0	4500.0
