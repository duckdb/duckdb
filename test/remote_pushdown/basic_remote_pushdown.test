# name: test/remote_pushdown/basic_remote_pushdown.test
# description: Test basic remote pushdown into MySQL
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

# create a table
statement ok
CREATE OR REPLACE TABLE s.small_tbl AS FROM range(10) t(i)

# basic aggregates are pushed down
query I
SELECT SUM(i) FROM s.small_tbl
----
45

query II
explain SELECT SUM(i) FROM s.small_tbl
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# unsupported aggregates are executed DuckDB side
query I
SELECT median(i) FROM s.small_tbl
----
4.5

query II
explain SELECT MEDIAN(i) FROM s.small_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*
