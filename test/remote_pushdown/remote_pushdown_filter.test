# name: test/remote_pushdown/remote_pushdown_filter.test
# description: FILTER (WHERE ...) on aggregates must not be pushed to MySQL -- MySQL cannot parse this syntax
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.filter_tbl AS SELECT i FROM range(10) t(i)

# SUM with FILTER -- MySQL has no FILTER syntax on aggregates
# i > 5 matches i=6,7,8,9 → 6+7+8+9 = 30
query I
SELECT SUM(i) FILTER (WHERE i > 5) FROM s.filter_tbl
----
30

query II
explain SELECT SUM(i) FILTER (WHERE i > 5) FROM s.filter_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# COUNT with FILTER -- even numbers 0,2,4,6,8 → 5
query I
SELECT COUNT(*) FILTER (WHERE i % 2 = 0) FROM s.filter_tbl
----
5

query II
explain SELECT COUNT(*) FILTER (WHERE i % 2 = 0) FROM s.filter_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# multiple filtered aggregates in one query
# i > 7 → 8,9 (sum=17); i < 3 → 0,1,2 (sum=3)
query II
SELECT SUM(i) FILTER (WHERE i > 7), SUM(i) FILTER (WHERE i < 3) FROM s.filter_tbl
----
17	3

# FILTER combined with a regular aggregate
query II
SELECT SUM(i), SUM(i) FILTER (WHERE i % 2 = 0) FROM s.filter_tbl
----
45	20

query II
explain SELECT SUM(i), SUM(i) FILTER (WHERE i % 2 = 0) FROM s.filter_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# AVG with FILTER
query I
SELECT AVG(i) FILTER (WHERE i >= 5) FROM s.filter_tbl
----
7.0
