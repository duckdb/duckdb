# name: test/remote_pushdown/remote_pushdown_macro.test
# description: Queries using local DuckDB macros must not be pushed to MySQL
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.macro_tbl AS SELECT i FROM range(10) t(i)

# scalar macro -- calling a local macro prevents the whole query from being pushed
statement ok
CREATE OR REPLACE MACRO double_val(x) AS x * 2

# 2 * (0+1+...+9) = 90
query I
SELECT SUM(double_val(i)) FROM s.macro_tbl
----
90

query II
explain SELECT SUM(double_val(i)) FROM s.macro_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# macro used in WHERE clause
# double_val(i) = 2*i > 10 → i=6,7,8,9 → 4 rows
query I
SELECT COUNT(*) FROM s.macro_tbl WHERE double_val(i) > 10
----
4

# macro used in GROUP BY expression
query II
SELECT double_val(i % 2), SUM(i) FROM s.macro_tbl GROUP BY 1 ORDER BY 1
----
0	20
2	25

# multi-argument macro
statement ok
CREATE OR REPLACE MACRO clamp(v, lo, hi) AS LEAST(GREATEST(v, lo), hi)

# clamp i to [3, 7]: values 0..2 → 3, 3..7 → unchanged, 8..9 → 7
# sum = 3+3+3+3+4+5+6+7+7+7 = 48
query I
SELECT SUM(clamp(i, 3, 7)) FROM s.macro_tbl
----
48

query II
explain SELECT SUM(clamp(i, 3, 7)) FROM s.macro_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# macro invoked with a qualified name should also be blocked
statement ok
CREATE OR REPLACE MACRO memory.main.triple_val(x) AS x * 3

query I
SELECT SUM(memory.main.triple_val(i)) FROM s.macro_tbl
----
135

query II
explain SELECT SUM(memory.main.triple_val(i)) FROM s.macro_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*
