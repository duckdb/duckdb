# name: test/remote_pushdown/remote_pushdown.test
# description: test pushdown into quack
# group: [remote_pushdown]

require quack

require httpfs

statement ok db1:con1
call quack_serve('quack:localhost', token='asdf');

statement ok db1:con1
create table t1(i int);

statement ok db1:con1
insert into t1 from range(10);

# we can attach with a straight token
statement ok
attach 'quack:localhost' as rpc (token 'asdf')

# this is pushed down into quack_query
query II
explain select * from rpc.t1 LIMIT 5;
----
physical_plan	<!REGEX>:.*LIMIT.*

# this is pushed down into quack_query
query II
explain select count(*) from rpc.t1 join rpc.t1 using (i)
----
physical_plan	<!REGEX>:.*JOIN.*

# subquery is pushed down into quack_query
query II
explain select * from (select i from rpc.t1) subq
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

# UNION ALL of two remote tables is pushed down into quack_query
query II
explain select * from rpc.t1 union all select * from rpc.t1
----
physical_plan	<!REGEX>:.*UNION.*

# INSERT INTO remote table from remote source is pushed down
statement ok
insert into rpc.t1 select i + 10 from rpc.t1

query I
select count(*) from rpc.t1
----
20

# DELETE from remote table is pushed down
statement ok
delete from rpc.t1 where i >= 10

query I
select count(*) from rpc.t1
----
10

# UPDATE on remote table is pushed down
statement ok
update rpc.t1 set i = i + 100

query II
select min(i), max(i) from rpc.t1
----
100	109

statement ok
create table local_tbl(local_col int);

statement ok
insert into local_tbl from range(10);

# Mixed: (remote LIMIT) UNION ALL local - LIMIT is part of pushed child, no LIMIT in local plan
query II
explain (select * from rpc.t1 limit 5) union all select * from local_tbl;
----
physical_plan	<!REGEX>:.*LIMIT.*

# Mixed UNION ALL - verify UNION stays in local plan (not fully pushed)
query II
explain (select * from rpc.t1 limit 5) union all select * from local_tbl;
----
physical_plan	<REGEX>:.*UNION.*

# Mixed: remote-local JOIN stays local but remote side is individually pushed
query II
explain select * from rpc.t1 join local_tbl on (i=local_col);
----
physical_plan	<REGEX>:.*JOIN.*

# Functional: mixed UNION ALL returns correct row count (5 from remote + 10 from local)
query I
select count(*) from ((select * from rpc.t1 limit 5) union all select * from local_tbl);
----
15

# Subquery expression pushdown: fully remote (both outer and subquery use rpc.t1)
# The whole SELECT including the IN subquery should be pushed to the remote
query II
explain select * from rpc.t1 where i in (select i from rpc.t1)
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

query I
select count(*) from rpc.t1 where i in (select i from rpc.t1)
----
10

# Subquery expression pushdown: mixed - local outer, remote subquery
# Only the inner subquery is pushed; outer SELECT stays local
# local_tbl has 0-9, rpc.t1 has 100-109 → no overlap → 0 results
query I
select count(*) from local_tbl where local_col in (select i from rpc.t1)
----
0

# correlated subquery that refers to local tbl - must NOT be pushed to remote
# (the remote has no local_tbl; if incorrectly pushed, the server returns an error)
# semantics: for each local_tbl row, the subquery returns that row's i value repeated for each rpc.t1 row
# so WHERE i IN (...) is trivially true for all 10 local rows → count = 10
query I
select count(*) from local_tbl where local_col in (select local_tbl.local_col from rpc.t1)
----
10

query I
select count(*) from local_tbl where local_col in (select local_col from rpc.t1)
----
10

# Scalar subquery: no FROM clause, fully pushed (scalar subquery is the only reference)
query I
select (select count(*) from rpc.t1)
----
10

# Scalar subquery: fully remote - pushed along with the outer SELECT
# rpc.t1 has 100-109; min(i) = 100, so WHERE i = 100 → 1 row
query I
select count(*) from rpc.t1 where i = (select min(i) from rpc.t1)
----
1

# Scalar subquery: mixed - local outer table, remote scalar subquery in WHERE
# Only the scalar subquery is pushed; outer SELECT stays local
# min(i) from rpc.t1 = 100; 100 - 100 = 0; local_tbl has 0-9 → WHERE i = 0 → 1 row
query I
select count(*) from local_tbl where local_col = (select min(i) - 100 from rpc.t1)
----
1

# --- Issue 1 & 2: schema-qualified table refs and catalog-qualified column refs ---

# Schema-qualified: rpc.main.t1 is pushed (rpc is identified as remote, main is the schema)
query II
explain select * from rpc.main.t1
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

query I
select count(*) from rpc.main.t1
----
10

# Catalog-qualified column reference: rpc.t1.i → stripped to t1.i before sending to remote
query I
select count(*) from rpc.t1 where rpc.t1.i > 105
----
4

# Schema + table column: rpc.main.t1.i → stripped to t1.i
query I
select count(*) from rpc.main.t1 where rpc.main.t1.i > 105
----
4

# Fully qualified column reference in ORDER BY: rpc.t1.i stripped to t1.i, all pushed
query II
explain select rpc.t1.i from rpc.t1 order by rpc.t1.i
----
physical_plan	<!REGEX>:.*SEQ_SCAN.*

query I
select rpc.t1.i from rpc.t1 order by rpc.t1.i limit 3
----
100
101
102

statement ok db1:con1
call quack_stop('quack:localhost')
