# name: test/remote_pushdown/remote_pushdown_cte.test
# description: CTEs referencing only remote tables should be pushed; CTEs backed by local data must not
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.cte_tbl AS SELECT i, i * 10 AS v FROM range(10) t(i)

# fully-remote CTE: the whole query -- CTE and outer -- should be pushed to MySQL
# i < 5 → i=0,1,2,3,4 → v=0,10,20,30,40 → SUM(v)=100
query I
WITH remote_cte AS (SELECT i, v FROM s.cte_tbl WHERE i < 5)
SELECT SUM(v) FROM remote_cte
----
100

query II
explain WITH remote_cte AS (SELECT i, v FROM s.cte_tbl WHERE i < 5)
SELECT SUM(v) FROM remote_cte
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# chained fully-remote CTEs
# doubled: v * 2; filtered to i >= 5 → v=50,60,70,80,90 → SUM(doubled)=700
query I
WITH
  base AS (SELECT i, v FROM s.cte_tbl),
  doubled AS (SELECT i, v * 2 AS v FROM base)
SELECT SUM(v) FROM doubled WHERE i >= 5
----
700

query II
explain
WITH
  base AS (SELECT i, v FROM s.cte_tbl),
  doubled AS (SELECT i, v * 2 AS v FROM base)
SELECT SUM(v) FROM doubled WHERE i >= 5
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# CTE backed by a local DuckDB table: must NOT be pushed to MySQL
statement ok
CREATE OR REPLACE TABLE local_ids AS SELECT i FROM range(4) t(i)

# JOIN remote_tbl with a local-backed CTE: aggregate must execute in DuckDB
# SUM(v) for i=0,1,2,3 → 0+10+20+30=60
query I
WITH local_cte AS (SELECT i FROM local_ids)
SELECT SUM(s.cte_tbl.v) FROM s.cte_tbl JOIN local_cte ON (s.cte_tbl.i = local_cte.i)
----
60

query II
explain
WITH local_cte AS (SELECT i FROM local_ids)
SELECT SUM(s.cte_tbl.v) FROM s.cte_tbl JOIN local_cte ON (s.cte_tbl.i = local_cte.i)
----
physical_plan	<REGEX>:.*AGGREGATE.*

# CTE backed by a range() table function: also local, must NOT be pushed
query I
WITH range_cte AS (SELECT * FROM range(5) t(i))
SELECT SUM(s.cte_tbl.v) FROM s.cte_tbl JOIN range_cte ON (s.cte_tbl.i = range_cte.i)
----
100

query II
explain
WITH range_cte AS (SELECT * FROM range(5) t(i))
SELECT SUM(s.cte_tbl.v) FROM s.cte_tbl JOIN range_cte ON (s.cte_tbl.i = range_cte.i)
----
physical_plan	<REGEX>:.*AGGREGATE.*

# recursive CTE can be pushed
query I
WITH RECURSIVE cnt(i) AS (
    SELECT 0
    UNION ALL
    SELECT i + 1 FROM cnt WHERE i < 9
)
SELECT SUM(s.cte_tbl.v) FROM s.cte_tbl JOIN cnt ON (s.cte_tbl.i = cnt.i)
----
450

query II
explain
WITH RECURSIVE cnt(i) AS (
    SELECT 0
    UNION ALL
    SELECT i + 1 FROM cnt WHERE i < 9
)
SELECT SUM(s.cte_tbl.v) FROM s.cte_tbl JOIN cnt ON (s.cte_tbl.i = cnt.i)
----
physical_plan	<!REGEX>:.*CTE.*
