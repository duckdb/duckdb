# name: test/remote_pushdown/remote_pushdown_identifiers.test
# description: Quoted / keyword identifiers must survive pushdown
#              DuckDB serializes quoted identifiers with double quotes - without ANSI_QUOTES
#              MySQL would silently treat them as string literals
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

# "name" and "order" are keywords and serialize quoted; the NULL ensures that COUNT("name")
# evaluated as a string literal (3) differs from COUNT of the column (2)
statement ok
CREATE OR REPLACE TABLE s.ident_tbl AS
    SELECT CASE WHEN i = 0 THEN NULL ELSE 'x' END AS "name", i AS "order" FROM range(3) t(i)

query I
SELECT COUNT("name") FROM s.ident_tbl
----
2

query II
explain SELECT COUNT("name") FROM s.ident_tbl
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# aggregate over a quoted keyword column
query I
SELECT SUM("order") FROM s.ident_tbl
----
3

query II
explain SELECT SUM("order") FROM s.ident_tbl
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# mixed-case identifiers
statement ok
CREATE OR REPLACE TABLE s.case_ident_tbl AS SELECT i AS "MyColumn" FROM range(5) t(i)

query I
SELECT SUM("MyColumn") FROM s.case_ident_tbl
----
10

query II
explain SELECT SUM("MyColumn") FROM s.case_ident_tbl
----
physical_plan	<!REGEX>:.*AGGREGATE.*
