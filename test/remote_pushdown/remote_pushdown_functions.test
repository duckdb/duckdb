# name: test/remote_pushdown/remote_pushdown_functions.test
# description: DuckDB-only functions and semantic-mismatch functions must not be pushed to MySQL
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.func_tbl AS SELECT i FROM range(10) t(i)

# approx_count_distinct is DuckDB-only -- MySQL has no equivalent
query I
SELECT approx_count_distinct(i) FROM s.func_tbl
----
10

query II
explain SELECT approx_count_distinct(i) FROM s.func_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# bool_and / bool_or are DuckDB/Postgres extensions not available in MySQL
query I
SELECT bool_and(i >= 0) FROM s.func_tbl
----
true

query I
SELECT bool_and(i > 5) FROM s.func_tbl
----
false

query I
SELECT bool_or(i > 5) FROM s.func_tbl
----
true

query I
SELECT bool_or(i > 100) FROM s.func_tbl
----
false

query II
explain SELECT bool_and(i >= 0) FROM s.func_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# mode() is DuckDB-only
# i % 3: value 0 appears 4 times (i=0,3,6,9), values 1 and 2 appear 3 times each
query I
SELECT mode(i % 3) FROM s.func_tbl
----
0

query II
explain SELECT mode(i % 3) FROM s.func_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# levenshtein() is DuckDB-only
statement ok
CREATE OR REPLACE TABLE s.word_tbl AS
    SELECT CASE i WHEN 0 THEN 'duck' WHEN 1 THEN 'ducks' WHEN 2 THEN 'lucky' ELSE 'truck' END AS word
    FROM range(4) t(i)

query I
SELECT MIN(levenshtein(word, 'duck')) FROM s.word_tbl
----
0

# levenshtein('duck','duck')=0, ('ducks','duck')=1, ('lucky','duck')=2, ('truck','duck')=2 → sum=5
query I
SELECT SUM(levenshtein(word, 'duck')) FROM s.word_tbl
----
5

query II
explain SELECT MIN(levenshtein(word, 'duck')) FROM s.word_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# log() domain mismatch: MySQL returns NULL on domain errors (log(0), log(-1)) where DuckDB
# yields -inf / nan -- log must be evaluated locally
statement ok
CREATE OR REPLACE TABLE s.log_tbl AS SELECT 100 AS v

query I
SELECT ROUND(MIN(log(v))::DOUBLE, 4) FROM s.log_tbl
----
2.0

query II
explain SELECT ROUND(MIN(log(v))::DOUBLE, 4) FROM s.log_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# length() semantic mismatch: DuckDB counts characters, MySQL counts bytes
# chr(233) is 'é', which is 1 character but 2 bytes in UTF-8
# the pushdown serializes DuckDB's length() as char_length(), so the query can be pushed
statement ok
CREATE OR REPLACE TABLE s.mb_tbl AS SELECT chr(233) AS c

query I
SELECT SUM(length(c)) FROM s.mb_tbl
----
1

query II
explain SELECT SUM(length(c)) FROM s.mb_tbl
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# random() is named rand() in MySQL -- pushing would cause a MySQL "function not found" error
# verify the query runs correctly (DuckDB evaluates it locally)
query I
SELECT COUNT(*) FROM s.func_tbl WHERE random() >= 0
----
10

# string_split / str_split has no MySQL equivalent
query I
SELECT SUM(len(string_split(word, 'u'))) FROM s.word_tbl
----
8
