# name: test/remote_pushdown/remote_pushdown_dml.test
# description: DML statements are not pushed through mysql_query but must keep working;
#              the SELECT part of an INSERT can still be pushed separately
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.dml_tbl (i INTEGER, v INTEGER)

statement ok
INSERT INTO s.dml_tbl SELECT i, i * 10 FROM range(5) t(i)

query I
SELECT COUNT(*) FROM s.dml_tbl
----
5

# UPDATE on a remote table
statement ok
UPDATE s.dml_tbl SET v = v + 1

query I
SELECT SUM(v) FROM s.dml_tbl
----
105

# UPDATE with a WHERE clause
statement ok
UPDATE s.dml_tbl SET v = 0 WHERE i >= 3

query I
SELECT SUM(v) FROM s.dml_tbl
----
33

# DELETE on a remote table
statement ok
DELETE FROM s.dml_tbl WHERE i = 0

query I
SELECT COUNT(*) FROM s.dml_tbl
----
4

# DELETE everything
statement ok
DELETE FROM s.dml_tbl

query I
SELECT COUNT(*) FROM s.dml_tbl
----
0

# INSERT from a remote aggregation: the SELECT part is pushed down
statement ok
CREATE OR REPLACE TABLE s.dml_src AS SELECT i, i % 2 AS g FROM range(10) t(i)

statement ok
INSERT INTO s.dml_tbl SELECT g, SUM(i) FROM s.dml_src GROUP BY g ORDER BY g

query II
SELECT i, v FROM s.dml_tbl ORDER BY i
----
0	20
1	25

# the SELECT part of the INSERT is pushed into a single remote query
query II
explain INSERT INTO s.dml_tbl SELECT g, SUM(i) FROM s.dml_src GROUP BY g
----
physical_plan	<REGEX>:(?s).*MYSQL_QUERY.*

query II
explain INSERT INTO s.dml_tbl SELECT g, SUM(i) FROM s.dml_src GROUP BY g
----
physical_plan	<!REGEX>:.*GROUP_BY.*

# INSERT ... VALUES on a remote table
statement ok
INSERT INTO s.dml_tbl VALUES (7, 70), (8, 80)

query I
SELECT COUNT(*) FROM s.dml_tbl
----
4

# INSERT BY NAME
statement ok
INSERT INTO s.dml_tbl BY NAME SELECT 9 AS i, 90 AS v

query II
SELECT i, v FROM s.dml_tbl WHERE i = 9
----
9	90
