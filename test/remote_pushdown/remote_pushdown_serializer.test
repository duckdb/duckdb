# name: test/remote_pushdown/remote_pushdown_serializer.test
# description: Constructs enabled by the MySQL serializer - function remapping, identifier
#              quoting, string escaping and derived table aliasing
# group: [sql]

require mysql_scanner

require-env MYSQL_TEST_DATABASE_AVAILABLE

statement ok
ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)

statement ok
CREATE OR REPLACE TABLE s.ser_tbl AS SELECT i, 'w' || i AS w FROM range(4) t(i)

# ---- || is serialized as concat() (both propagate NULLs) ----
query I
SELECT MIN(w || 'x') FROM s.ser_tbl
----
w0x

# concatenating NULL yields NULL even when evaluated remotely
query I
SELECT COUNT(*) FROM s.ser_tbl WHERE (w || NULL) IS NULL
----
4

query II
explain SELECT MIN(w || 'x') FROM s.ser_tbl
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# ---- ln() / log() are evaluated locally: MySQL returns NULL on domain errors (ln(0)) ----
query II
SELECT ROUND(MAX(ln(i + 1))::DOUBLE, 6), MAX(log(2, i + 1)) FROM s.ser_tbl
----
1.386294	2.0

query II
explain SELECT MAX(ln(i + 1)), MAX(log(2, i + 1)) FROM s.ser_tbl
----
physical_plan	<REGEX>:.*AGGREGATE.*

# ---- string literals with backslashes and quotes are escaped for MySQL ----
query I
SELECT MIN(concat(w, 'x\y')) FROM s.ser_tbl
----
w0x\y

query II
explain SELECT MIN(concat(w, 'x\y')) FROM s.ser_tbl
----
physical_plan	<!REGEX>:.*AGGREGATE.*

query I
SELECT MIN(w || 'a''b') FROM s.ser_tbl
----
w0a'b

# ---- unnamed derived tables get a generated alias (required by MySQL) ----
query I
SELECT COUNT(*) FROM (SELECT i FROM s.ser_tbl)
----
4

query II
explain SELECT COUNT(*) FROM (SELECT i FROM s.ser_tbl)
----
physical_plan	<!REGEX>:.*AGGREGATE.*

# nested unnamed derived tables
query I
SELECT SUM(i) FROM (SELECT i FROM (SELECT i FROM s.ser_tbl) WHERE i > 0)
----
6

# ---- qualified stars keep their qualifier ----
query III
SELECT a.*, b.i + 10 FROM s.ser_tbl a JOIN s.ser_tbl b USING (i) WHERE a.i = 1
----
1	w1	11

query II
explain SELECT a.* FROM s.ser_tbl a JOIN s.ser_tbl b USING (i)
----
physical_plan	<!REGEX>:.*JOIN.*

# ---- avg as a window function (serialized with a DOUBLE cast) ----
query I
SELECT MAX(a) FROM (SELECT AVG(i) OVER (ORDER BY i) AS a FROM s.ser_tbl) t
----
1.5

query II
explain SELECT AVG(i) OVER (ORDER BY i) FROM s.ser_tbl
----
physical_plan	<!REGEX>:.*WINDOW.*
