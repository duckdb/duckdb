# name: test/tmp3.test
# description: stable-rowid vacuum merging dense live row groups
# group: [test]

# Even when indexes require stable rowids, vacuum can still merge row groups
# that already form a dense live rowid interval. No rowids are remapped because
# every input row group is fully live and starts where the previous one ends.

statement ok
ATTACH '{TEST_DIR}/rowid_gap_dense_vacuum_indexed.db' AS rowid_gap_dense_vacuum (ROW_GROUP_SIZE 4096);

statement ok
PRAGMA force_checkpoint;

statement ok
SET max_vacuum_tasks = 0;

statement ok
CREATE TABLE rowid_gap_dense_vacuum.t(i INTEGER);

statement ok
INSERT INTO rowid_gap_dense_vacuum.t SELECT i FROM range(1000) tbl(i);

statement ok
CHECKPOINT rowid_gap_dense_vacuum;

statement ok
INSERT INTO rowid_gap_dense_vacuum.t SELECT i FROM range(1000, 2000) tbl(i);

statement ok
CHECKPOINT rowid_gap_dense_vacuum;

statement ok
INSERT INTO rowid_gap_dense_vacuum.t SELECT i FROM range(2000, 3000) tbl(i);

statement ok
CHECKPOINT rowid_gap_dense_vacuum;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('rowid_gap_dense_vacuum.t');
----
3

statement ok
CREATE INDEX t_i_idx ON rowid_gap_dense_vacuum.t(i);

statement ok
SET max_vacuum_tasks = 99;

statement ok
FORCE CHECKPOINT rowid_gap_dense_vacuum;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('rowid_gap_dense_vacuum.t');
----
1

query II
SELECT i, rowid FROM rowid_gap_dense_vacuum.t WHERE i IN (0, 999, 1000, 1999, 2000, 2999) ORDER BY i;
----
0	0
999	999
1000	1000
1999	1999
2000	2000
2999	2999

query II
EXPLAIN ANALYZE SELECT i, rowid FROM rowid_gap_dense_vacuum.t WHERE i = 2000;
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*
