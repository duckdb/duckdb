# name: test/sql/storage/temp_directory/test_default_temp_directory.test
# group: [temp_directory]

# FIXME: This is a significant regression because we no longer evict "tiny buffers", of which we're
# FIXME: allocating plenty here.
require vector_size 2048

load {TEST_DIR}/test_default_temp_dir.db

statement ok
SET memory_limit='3MB';

statement ok
RESET temp_directory

statement ok
CREATE TEMPORARY TABLE t AS FROM range(1_000_000);
