# name: test/sql/storage/vacuum/vacuum_rebuild_indexes.test_slow
# description: Test that vacuum correctly rebuilds indexes when empty row groups are dropped
# group: [vacuum]

load __TEST_DIR__/experimental_vacuum_rebuild_indexes.db

statement ok
SET wal_autocheckpoint='100GB'

statement ok
CREATE TABLE t(i INTEGER, j INTEGER);

statement ok
CREATE INDEX idx ON t(i);

# insert 500K rows: fills ~4 full row groups + 1 partial
statement ok
INSERT INTO t SELECT i, i FROM range(500000) tbl(i);

statement ok
CHECKPOINT

# verify initial row group count (~5: four full + one partial)
query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('t')
----
5

# delete ALL rows in the second row group, creating an empty row group in the middle
# row groups are 122880 rows each, so this empties the second one
statement ok
DELETE FROM t WHERE i >= 122880 AND i < 245760

statement ok
SET experimental_vacuum_rebuild_indexes = true


statement ok
CHECKPOINT

# the remaining full row groups (122880 rows each) have no merge candidates,
# so no vacuum tasks run — but the empty row group IS dropped, shifting row IDs
# of all subsequent row groups. the index must be rebuilt to reflect the new row IDs.

# verify the empty row group was dropped
query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('t')
----
4

# verify index lookups across the gap
query II
SELECT i, j FROM t WHERE i = 0
----
0	0

query II
SELECT i, j FROM t WHERE i = 122879
----
122879	122879

query II
SELECT i, j FROM t WHERE i = 245760
----
245760	245760

query II
SELECT i, j FROM t WHERE i = 300000
----
300000	300000

query II
SELECT i, j FROM t WHERE i = 499999
----
499999	499999

# verify no rows from deleted range
query I
SELECT COUNT(*) FROM t WHERE i >= 122880 AND i < 245760
----
0

# verify total count
query I
SELECT COUNT(*) FROM t
----
377120
