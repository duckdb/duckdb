# name: test/sql/storage/compression/alprd/alprd_corrupted_dict_size.test
# group: [alprd]

require vector_size 2048

unzip data/storage/alprd_corrupted_dict_size.db.gz __TEST_DIR__/alprd_corrupted_dict_size.db

statement ok
ATTACH '__TEST_DIR__/alprd_corrupted_dict_size.db' AS db2

statement ok
USE db2;

query I
SELECT compression FROM pragma_storage_info('t') WHERE segment_type = 'DOUBLE' AND compression != 'ALPRD';
----

statement error
SELECT * FROM t LIMIT 1;
----
IO Error: Corrupted ALPRD segment: exceptions payload too large
