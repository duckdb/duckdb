# name: test/sql/storage/compression/alprd/alprd_corrupted_exception_position.test
# group: [alprd]

require vector_size 2048

unzip data/storage/alprd_corrupt_exception_position.db.gz __TEST_DIR__/alprd_corrupt_exception_position.db

statement ok
ATTACH '__TEST_DIR__/alprd_corrupt_exception_position.db' AS db2

statement ok
USE db2;

query I
SELECT compression FROM pragma_storage_info('two_alp') WHERE compression='ALPRD';
----
ALPRD

statement error
SELECT * FROM two_alp LIMIT 1;
----
IO Error: Corrupted ALPRD segment: exception position (60000) exceeds vector_size (1024)
