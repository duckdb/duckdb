# name: test/sql/storage/compression/alp/alp_corrupted_exception_position.test
# group: [alp]

require vector_size 2048

unzip data/storage/alp_corrupt_exception_position.db.gz __TEST_DIR__/alp_corrupt_exception_position.db

statement ok
ATTACH '__TEST_DIR__/alp_corrupt_exception_position.db' AS db2

statement ok
USE db2;

query I
SELECT compression FROM pragma_storage_info('two_alp') WHERE compression='ALP';
----
ALP

statement error
SELECT * FROM two_alp LIMIT 1;
----
IO Error: Corrupted ALP segment: exception position (60000) exceeds vector_size (1024)
