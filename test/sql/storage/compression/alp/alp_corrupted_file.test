# name: test/sql/storage/compression/alp/alp_corrupted_file.test
# group: [alp]

require vector_size 2048

unzip data/storage/alp_corrupted.db.gz __TEST_DIR__/alp_corrupted.db

statement ok
ATTACH '__TEST_DIR__/alp_corrupted.db' AS db2

statement ok
USE db2;

query I
SELECT compression FROM pragma_storage_info('alp') WHERE compression='ALP';
----
ALP

statement error
SELECT * FROM alp LIMIT 1;
----
IO Error: Corrupted ALP segment: Invalid bit_width encountered: 255
