# name: test/sql/storage/checkpoint/checkpoint_in_transaction.test
# group: [checkpoint]

statement ok
SET wal_autocheckpoint='100GB'

statement ok
ATTACH '{TEST_DIR}/checkpoint_in_transaction.db' AS db

statement ok
CREATE TABLE db.t(a INTEGER)

statement ok
INSERT INTO db.t VALUES (1)

statement ok con1
BEGIN

query I con1
SELECT * FROM db.t
----
1

statement ok
INSERT INTO db.t VALUES (2)

statement ok con1
CHECKPOINT db

# Insert within the transaction after checkpoint.
statement ok con1
INSERT INTO db.t VALUES (3)

statement ok con1
COMMIT

# All values should be visible: 1 (before txn), 2 (concurrent insert), 3 (in-txn post-checkpoint).
query I
SELECT * FROM db.t ORDER BY a
----
1
2
3
