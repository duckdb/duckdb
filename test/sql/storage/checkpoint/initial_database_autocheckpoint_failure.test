# name: test/sql/storage/checkpoint/initial_database_autocheckpoint_failure.test
# description: A failing autocheckpoint on the initial database surfaces at commit time as a fatal error
# group: [checkpoint]

require no_alternative_verify

load {TEST_DIR}/initial_autockpt_failure.db

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET auto_checkpoint_skip_wal_threshold = 9999999999;

statement ok
CREATE TABLE tbl(i INTEGER);

statement ok
SET wal_autocheckpoint_entries = 1;

statement ok
PRAGMA debug_checkpoint_abort = 'before_header';

statement error
INSERT INTO tbl VALUES (1), (2), (3);
----
<REGEX>:FATAL Error:.*Transaction COMMIT succeeded.*autocheckpoint failed.*

restart

query I
SELECT COUNT(*) FROM tbl;
----
3
