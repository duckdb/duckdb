# name: test/sql/storage/test_eviction_queue_dead_nodes_underflow.test
# description: Focused repro for eviction queue dead-node counter underflow
# group: [storage]

require no_alternative_verify

statement ok
PRAGMA memory_limit='100MB'

statement ok
PRAGMA temp_directory=''

statement ok
PRAGMA max_temp_directory_size='0B'

statement ok
SET operator_memory_limit='1MB'

# ORDER BY: requires sort buffers that check the operator memory budget.
statement error
SELECT * FROM range(10000000) ORDER BY random();
----
Out of Memory

# GROUP BY with many groups: builds a hash table.
statement error
SELECT i % 1000000 as g, COUNT(*) FROM range(10000000) t(i) GROUP BY 1;
----
Out of Memory

# DISTINCT with many values: builds a hash table.
statement error
SELECT DISTINCT i FROM range(10000000) t(i);
----
Out of Memory

# Window function with PARTITION BY: builds partition state.
statement error
SELECT i, SUM(i) OVER (PARTITION BY i % 100000 ORDER BY i) FROM range(5000000) t(i);
----
Out of Memory

statement ok
CREATE TABLE t1 AS SELECT * FROM range(1000000)

query I
SELECT COUNT(*) FROM t1
----
1000000

query I
SELECT SUM(i) FROM range(1000000) t(i)
----
499999500000

query II
SELECT i % 10 as g, COUNT(*) FROM range(1000000) t(i) GROUP BY 1 ORDER BY 1
----
0	100000
1	100000
2	100000
3	100000
4	100000
5	100000
6	100000
7	100000
8	100000
9	100000

query I
SELECT COUNT(*) FROM (SELECT * FROM range(1000) ORDER BY random())
----
1000

query I
SELECT LENGTH(string_agg(i::VARCHAR, ',')) > 0 FROM range(100000) t(i)
----
true

query I
SELECT LENGTH(list(i)::VARCHAR) > 0 FROM range(50000) t(i)
----
true

query I
SELECT COUNT(*) FROM range(100) a, range(100) b
----
10000

statement ok
RESET operator_memory_limit

statement ok
PRAGMA memory_limit='1GB'

query I
SELECT COUNT(*) = 0
FROM duckdb_eviction_queues()
WHERE dead_nodes < 0
   OR dead_nodes > total_insertions;
----
1
