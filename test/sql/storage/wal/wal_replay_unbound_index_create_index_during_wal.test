# name: test/sql/storage/wal/wal_replay_unbound_index_create_index_during_wal.test
# description: WAL replay where a CREATE INDEX inside the WAL changes the set of indexed columns
# group: [wal]

require skip_reload

load {TEST_DIR}/wal_replay_unbound_index_create_during_wal.db

statement ok
PRAGMA disable_checkpoint_on_shutdown

statement ok
SET checkpoint_threshold='999999GB'

statement ok
CREATE TABLE t(a BIGINT, b VARCHAR)

statement ok
CREATE INDEX i1 ON t(b)

statement ok
CHECKPOINT

statement ok
INSERT INTO t VALUES (1, 'one')

statement ok
CREATE INDEX i2 ON t(a)

statement ok
INSERT INTO t VALUES (2, 'two')

restart

query I
SELECT count(*) FROM t
----
2

# bind the indexes and apply the buffered replays
statement ok
CHECKPOINT

statement ok
SET index_scan_percentage=1

statement ok
SET index_scan_max_count=999999999

query I
SELECT count(*) FROM t WHERE b='one'
----
1

query I
SELECT count(*) FROM t WHERE b='two'
----
1

query I
SELECT count(*) FROM t WHERE a=1
----
1

query I
SELECT count(*) FROM t WHERE a=2
----
1
