# name: test/sql/storage/wal/wal_replay_unbound_index_multi_index.test
# description: WAL replay of inserts and a delete into multiple unbound indexes on different columns
# group: [wal]

require skip_reload

load __TEST_DIR__/wal_replay_unbound_index_multi.db

statement ok
PRAGMA disable_checkpoint_on_shutdown

statement ok
SET checkpoint_threshold='999999GB'

statement ok
CREATE TABLE t(a INTEGER, b VARCHAR, c INTEGER)

statement ok
CREATE INDEX i1 ON t(b)

statement ok
CREATE INDEX i2 ON t(c)

statement ok
CREATE INDEX i3 ON t(upper(b))

# checkpoint so that the WAL replayed on restart contains only the statements below
statement ok
CHECKPOINT

# 123000 rows: one full row group plus a partial trailing chunk
statement ok
INSERT INTO t SELECT v, 'x' || v, v + 1000000 FROM range(123000) r(v)

statement ok
INSERT INTO t VALUES (999999999, 'y', 999)

statement ok
DELETE FROM t WHERE b='x7'

restart

query I
SELECT count(*) FROM t
----
123000

# bind the indexes and apply the buffered replays
statement ok
CHECKPOINT

# force index scans so the lookups probe the index content
statement ok
SET index_scan_percentage=1

statement ok
SET index_scan_max_count=999999999

query I
SELECT count(*) FROM t WHERE b='y'
----
1

query I
SELECT count(*) FROM t WHERE b='x7'
----
0

query I
SELECT count(*) FROM t WHERE c=999
----
1

query I
SELECT count(*) FROM t WHERE c=1000007
----
0

query I
SELECT count(*) FROM t WHERE upper(b)='Y'
----
1

query I
SELECT count(*) FROM t WHERE upper(b)='X7'
----
0
