# name: test/sql/storage/wal/wal_replay_with_function.test
# group: [wal]

load __TEST_DIR__/wal_replay_2.db

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
PRAGMA wal_autocheckpoint='1TB';

statement ok
CREATE TABLE test (id INTEGER);

statement ok
INSERT INTO test VALUES (1);

statement ok
CHECKPOINT;

# ALTER TABLE with function-based DEFAULT — this goes to WAL
statement ok
ALTER TABLE test ADD COLUMN data BIGINT DEFAULT length('duck');

restart

query II
from test;
----
1	4