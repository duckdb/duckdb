# name: test/sql/storage/wal/wal_replay_unbound_index_generated_column.test
# description: WAL replay into an unbound index where a generated column shifts logical vs physical ids
# group: [wal]

require skip_reload

load __TEST_DIR__/wal_replay_unbound_index_generated.db

statement ok
PRAGMA disable_checkpoint_on_shutdown

statement ok
SET checkpoint_threshold='999999GB'

# b is logical column 2 but physical column 1
statement ok
CREATE TABLE t(a INTEGER, g AS (a + 1), b VARCHAR)

statement ok
CREATE INDEX i ON t(b)

statement ok
CHECKPOINT

statement ok
INSERT INTO t SELECT v, 'x' || v FROM range(122880) r(v)

statement ok
INSERT INTO t VALUES (7, 'y')

restart

query I
SELECT count(*) FROM t
----
122881

# bind the index and apply the buffered replays
statement ok
CHECKPOINT

# force index scans so the lookups probe the index content
statement ok
SET index_scan_percentage=1

statement ok
SET index_scan_max_count=999999999

query I
SELECT count(*) FROM t WHERE b='y'
----
1

query I
SELECT count(*) FROM t WHERE b='x123'
----
1

query II
SELECT g, b FROM t WHERE b='y'
----
8	y
