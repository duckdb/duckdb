# name: test/sql/storage/wal/wal_replay_unbound_index_mixed_inserts.test
# description: WAL replay of row-group data and tuple inserts into an unbound index, in both orders
# group: [wal]

require skip_reload

load {TEST_DIR}/wal_replay_unbound_index_mixed.db

statement ok
PRAGMA disable_checkpoint_on_shutdown

statement ok
SET checkpoint_threshold='999999GB'

statement ok
CREATE TABLE t(b TIMESTAMP, a VARCHAR)

statement ok
CREATE INDEX i ON t(a)

# checkpoint so that the WAL replayed on restart contains only the inserts below
statement ok
CHECKPOINT

# one full row group is logged as row-group data in the WAL, the single row as a tuple
statement ok
INSERT INTO t SELECT TIMESTAMP '2026-01-01' + INTERVAL (v) SECOND, 'x' || v FROM range(122880) r(v)

statement ok
INSERT INTO t VALUES (TIMESTAMP '2026-02-01', 'y')

restart

statement ok
PRAGMA disable_checkpoint_on_shutdown

statement ok
SET checkpoint_threshold='999999GB'

query I
SELECT count(*) FROM t
----
122881

# bind the index and apply the buffered replays
statement ok
CHECKPOINT

statement ok
SET index_scan_percentage=1

statement ok
SET index_scan_max_count=999999999

query I
SELECT count(*) FROM t WHERE a='y'
----
1

query I
SELECT count(*) FROM t WHERE a='x123'
----
1

# again with the insert order reversed
statement ok
INSERT INTO t VALUES (TIMESTAMP '2026-03-01', 'w')

statement ok
INSERT INTO t SELECT TIMESTAMP '2026-04-01' + INTERVAL (v) SECOND, 'z' || v FROM range(122880) r(v)

restart

query I
SELECT count(*) FROM t
----
245762

statement ok
CHECKPOINT

statement ok
SET index_scan_percentage=1

statement ok
SET index_scan_max_count=999999999

query I
SELECT count(*) FROM t WHERE a='w'
----
1

query I
SELECT count(*) FROM t WHERE a='z123'
----
1

query I
SELECT count(*) FROM t WHERE a='y'
----
1
