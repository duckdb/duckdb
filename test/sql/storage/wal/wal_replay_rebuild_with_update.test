# name: test/sql/storage/wal/wal_replay_rebuild_with_update.test
# description: Issue #22124 - WAL replay after UPDATE + rename-chain + DROP inside a single transaction (ORM table-rebuild idiom)
# group: [wal]

load {TEST_DIR}/wal_replay_22124.db

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET checkpoint_threshold='1TB';

statement ok
SET wal_autocheckpoint='1TB';

statement ok
CREATE TABLE t(id INT PRIMARY KEY, v VARCHAR);

statement ok
INSERT INTO t VALUES (1, 'dark'), (2, 'light');

# ORM-style table rebuild: UPDATE the existing table, build the replacement in a new table,
# rename the old one out of the way, rename the new one into place, drop the backup. All in one transaction.
statement ok
BEGIN

statement ok
UPDATE t SET v='system' WHERE id=1;

statement ok
INSERT INTO t VALUES (3, 'auto');

statement ok
DELETE FROM t WHERE id=2;

statement ok
CREATE TABLE t_new(id INT PRIMARY KEY, v VARCHAR, extra VARCHAR);

statement ok
INSERT INTO t_new(id, v) SELECT id, v FROM t;

statement ok
ALTER TABLE t RENAME TO t_backup;

statement ok
ALTER TABLE t_new RENAME TO t;

statement ok
DROP TABLE t_backup;

statement ok
COMMIT

restart

statement ok
PRAGMA disable_checkpoint_on_shutdown;

# before the fix, reopen failed with:
#   Catalog Error: Failure while replaying WAL file "...": Table with name t_backup does not exist!
query III
SELECT id, v, extra FROM t
----
1	system	NULL
3	auto	NULL

# confirm the backup table is gone and the new schema is in effect
statement error
SELECT * FROM t_backup
----
does not exist

query I
SELECT column_name FROM duckdb_columns() WHERE table_name='t' ORDER BY column_index
----
id
v
extra
