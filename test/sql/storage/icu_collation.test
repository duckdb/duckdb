# name: test/sql/storage/icu_collation.test
# description: ATTACH to a database that uses ICU collations in types
# group: [storage]

require icu

# The database is written with a vector size of 2048.
statement skip_test_on_error
SELECT assert_true(current_setting('standard_vector_size')::INT >= 2048, 'requires vector_size>=2048')

unzip data/storage/german_collation.db.gz {TEST_DIR}/icu_collation.db

load {TEST_DIR}/icu_collation.db readonly

query I rowsort
SELECT * FROM strings
----
Gabel
Goethe
Goldmann
Göbel
Göthe
Götz

query I
SELECT * FROM strings ORDER BY 1
----
Gabel
Göbel
Goethe
Goldmann
Göthe
Götz
