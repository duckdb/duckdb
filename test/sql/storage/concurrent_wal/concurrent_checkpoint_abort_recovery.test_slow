# name: test/sql/storage/concurrent_wal/concurrent_checkpoint_abort_recovery.test_slow
# description: Test recovery (read-only reattach, aborting while replaying) after a failing checkpoint on an attached database
# group: [concurrent_wal]

# main_db is an attached database, so a failing checkpoint on it is scoped to main_db (the instance keeps running)

foreach wal_abort_mode before_wal_finish before_header

foreach replay_abort_mode before_moving_recovery before_deleting_checkpoint_wal

statement ok
ATTACH '{TEST_DIR}/concurrent_abort.db' AS main_db

statement ok
SET checkpoint_threshold='1TB'

statement ok
PRAGMA disable_checkpoint_on_shutdown

statement ok
SET debug_checkpoint_abort='{wal_abort_mode}'

statement ok
CREATE OR REPLACE TABLE main_db.integers(i INTEGER)

concurrentloop threadid 0 20

loop x 0 10

onlyif threadid<>10
statement maybe
INSERT INTO main_db.integers SELECT * FROM range({x} * 2000 + {threadid} * 100, {x} * 2000 + ({threadid} + 1) * 100);
----
<REGEX>:.*Database "main_db" has been invalidated because checkpointing failed.*

endloop

onlyif threadid=10
statement error
CHECKPOINT main_db
----
<REGEX>:.*Checkpoint failed for database "main_db".*Checkpoint aborted.*

endloop

restart

statement ok
ATTACH '{TEST_DIR}/concurrent_abort.db' AS main_db (READ_ONLY)

query I
SELECT COUNT(*) % 100 = 0 AND COUNT(*) = COUNT(DISTINCT i) FROM main_db.integers
----
true

# neither checkpoint WAL nor WAL is cleared when attaching in read-only mode
# the checkpoint WAL may or may not exist depending on whether concurrent commits wrote to it
query I
SELECT COUNT(*) BETWEEN 1 AND 2 FROM glob('{TEST_DIR}/concurrent_abort.db.wal*')
----
true

restart

# failure while replaying
statement ok
SET debug_checkpoint_abort='{replay_abort_mode}'

statement maybe
ATTACH '{TEST_DIR}/concurrent_abort.db' AS main_db
----
Checkpoint aborted

restart

statement ok
SET debug_checkpoint_abort='none'

statement ok
ATTACH '{TEST_DIR}/concurrent_abort.db' AS main_db

# after a clean replay the recovered data is still uncorrupted
query I
SELECT COUNT(*) % 100 = 0 AND COUNT(*) = COUNT(DISTINCT i) FROM main_db.integers
----
true

restart

endloop

endloop
