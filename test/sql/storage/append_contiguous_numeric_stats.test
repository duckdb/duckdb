query III
SELECT count(*), count(f), count(*) FILTER (WHERE f IS NULL) FROM append_contiguous_all_null_float
----
4096	0	4096

query I
SELECT count(*) FROM (SELECT min(f) AS m FROM append_contiguous_all_null_float) tbl WHERE m IS NULL
----
