# name: test/sql/storage/external_file_cache/external_file_cache_block_size.test
# description: Test that changing cache block size lazily re-indexes blocks on next read
# group: [external_file_cache]

require parquet

statement ok
set enable_external_file_cache=true;

statement ok
set prefetch_all_parquet_files=true;

# Create a test parquet file
statement ok
copy (select range i, range % 100 j from range(10000)) to '{TEST_DIR}/test_block_size.parquet';

# Read the file to populate cache at default 16KiB block size
statement ok
select * from '{TEST_DIR}/test_block_size.parquet';

# Verify cache is populated
query I
select count(*) > 0 from duckdb_external_file_cache();
----
true

# Save total cached bytes before block size change
statement ok
create temp table cached_bytes_before as select sum(nr_bytes) as total from duckdb_external_file_cache();

# Change local block size from 16KiB to 4KiB
statement ok
set external_file_cache_local_block_size=4096;

# Cache should still have data
query I
select count(*) > 0 from duckdb_external_file_cache();
----
true

# Total cached bytes should be preserved (reindex is deferred to next read)
query I
select (select sum(nr_bytes) from duckdb_external_file_cache()) = (select total from cached_bytes_before);
----
true

# Reading triggers lazy re-index and returns correct data
query II
select count(*), sum(i) from '{TEST_DIR}/test_block_size.parquet';
----
10000	49995000

# Save bytes before merging back
statement ok
drop table cached_bytes_before;

statement ok
create temp table cached_bytes_before as select sum(nr_bytes) as total from duckdb_external_file_cache();

# Change block size back to 16KiB (merge)
statement ok
set external_file_cache_local_block_size=16384;

# Total cached bytes should be preserved (reindex deferred to next read)
query I
select (select sum(nr_bytes) from duckdb_external_file_cache()) = (select total from cached_bytes_before);
----
true

# Verify reads are still correct
query II
select count(*), sum(i) from '{TEST_DIR}/test_block_size.parquet';
----
10000	49995000

# Setting to same value should be a no-op
statement ok
drop table cached_bytes_before;

statement ok
create temp table cached_bytes_before as select sum(nr_bytes) as total from duckdb_external_file_cache();

statement ok
set external_file_cache_local_block_size=16384;

query I
select (select sum(nr_bytes) from duckdb_external_file_cache()) = (select total from cached_bytes_before);
----
true

# Reset local block size to default — same size, so no-op re-index
statement ok
drop table cached_bytes_before;

statement ok
create temp table cached_bytes_before as select sum(nr_bytes) as total from duckdb_external_file_cache();

statement ok
reset external_file_cache_local_block_size;

query I
select (select sum(nr_bytes) from duckdb_external_file_cache()) = (select total from cached_bytes_before);
----
true

# Verify reads are still correct after reset
query II
select count(*), sum(i) from '{TEST_DIR}/test_block_size.parquet';
----
10000	49995000

# Change to a different size, then reset — lazy re-index back to default on next read
statement ok
drop table cached_bytes_before;

statement ok
create temp table cached_bytes_before as select sum(nr_bytes) as total from duckdb_external_file_cache();

statement ok
set external_file_cache_local_block_size=8192;

query I
select (select sum(nr_bytes) from duckdb_external_file_cache()) = (select total from cached_bytes_before);
----
true

statement ok
drop table cached_bytes_before;

statement ok
create temp table cached_bytes_before as select sum(nr_bytes) as total from duckdb_external_file_cache();

statement ok
reset external_file_cache_local_block_size;

query I
select (select sum(nr_bytes) from duckdb_external_file_cache()) = (select total from cached_bytes_before);
----
true

query II
select count(*), sum(i) from '{TEST_DIR}/test_block_size.parquet';
----
10000	49995000

# Verify invalid values are rejected
statement error
set external_file_cache_local_block_size=0;
----
value must be positive

statement error
set external_file_cache_remote_block_size=0;
----
value must be positive
