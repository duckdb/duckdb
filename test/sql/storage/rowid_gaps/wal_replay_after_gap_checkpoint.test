# name: test/sql/storage/rowid_gaps/wal_replay_after_gap_checkpoint.test
# description: WAL replay preserves appends made after checkpointed rowid gaps
# group: [rowid_gaps]

require noforcestorage

load {TEST_DIR}/rowid_gap_wal_replay.db readwrite latest

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
PRAGMA wal_autocheckpoint='1TB';

statement ok
CREATE TABLE t AS SELECT i FROM range(368640) tbl(i);

statement ok
CREATE UNIQUE INDEX idx_i ON t(i);

statement ok
CHECKPOINT;

statement ok
DELETE FROM t WHERE i >= 122880 AND i < 245760;

statement ok
CHECKPOINT;

restart

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
PRAGMA wal_autocheckpoint='1TB';

query III
SELECT min(rowid), max(rowid), count(*) FROM t;
----
0	368639	245760

statement ok
INSERT INTO t VALUES (999999);

query II
SELECT rowid, i FROM t WHERE i = 999999;
----
368640	999999

restart

query II
SELECT rowid, i FROM t WHERE i = 999999;
----
368640	999999

query III
SELECT min(rowid), max(rowid), count(*) FROM t;
----
0	368640	245761
