# name: test/sql/storage/rowid_gaps/indexed_checkpoint_drop_row_group.test
# description: checkpoint vacuum preserves indexed rowid gaps
# group: [rowid_gaps]

# With indexes, checkpoint/vacuum may drop a fully deleted row group, but it
# must not merge live row groups across the gap because that would remap the
# rowids stored in the index.

statement ok
ATTACH '{TEST_DIR}/rowid_gap_vacuum_indexed.db' AS rowid_gap_vacuum_idx (ROW_GROUP_SIZE 2048);

statement ok
CREATE TABLE rowid_gap_vacuum_idx.t AS SELECT i FROM range(6144) tbl(i);

statement ok
CHECKPOINT rowid_gap_vacuum_idx;

statement ok
CREATE INDEX t_i_idx ON rowid_gap_vacuum_idx.t(i);

statement ok
DELETE FROM rowid_gap_vacuum_idx.t WHERE i >= 2048 AND i < 4096;

statement ok
CHECKPOINT rowid_gap_vacuum_idx;

statement ok
DETACH rowid_gap_vacuum_idx;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_vacuum_indexed.db' AS rowid_gap_vacuum_idx;

query III
SELECT min(rowid), max(rowid), count(*) FROM rowid_gap_vacuum_idx.t;
----
0	6143	4096

query III
SELECT min(rowid), max(rowid), count(*) FROM rowid_gap_vacuum_idx.t WHERE i >= 4096;
----
4096	6143	2048

query I
SELECT count(*) FROM rowid_gap_vacuum_idx.t WHERE rowid >= 2048 AND rowid < 4096;
----
0

query II
SELECT rowid, i FROM rowid_gap_vacuum_idx.t WHERE i = 4096;
----
4096	4096
