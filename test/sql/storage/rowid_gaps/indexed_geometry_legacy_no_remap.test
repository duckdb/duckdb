# name: test/sql/storage/rowid_gaps/indexed_geometry_legacy_no_remap.test
# description: a legacy-encoded GEOMETRY index blocks vacuum remap until the index is recreated
# group: [rowid_gaps]

require noforcestorage

# Create a legacy-encoded geometry index.
statement ok
ATTACH '{TEST_DIR}/rowid_gap_geom_legacy.db' AS geom_legacy (STORAGE_VERSION 'v1.4.0', ROW_GROUP_SIZE 2048);

statement ok
SET max_vacuum_tasks = 99;

statement ok
CREATE TABLE geom_legacy.t(i INTEGER, geom GEOMETRY);

statement ok
INSERT INTO geom_legacy.t
SELECT i, ('POINT (' || i || ' ' || i || ')')::GEOMETRY FROM range(2048) tbl(i);

statement ok
CHECKPOINT geom_legacy;

statement ok
INSERT INTO geom_legacy.t
SELECT i, ('POINT (' || i || ' ' || i || ')')::GEOMETRY FROM range(2048, 3048) tbl(i);

statement ok
CHECKPOINT geom_legacy;

statement ok
CREATE UNIQUE INDEX t_i_idx ON geom_legacy.t(i);

statement ok
CREATE INDEX t_geom_idx ON geom_legacy.t(geom);

statement ok
CHECKPOINT geom_legacy;

# The legacy geometry index blocks remap after upgrading the database.
statement ok
DETACH geom_legacy;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_geom_legacy.db' AS geom_legacy (STORAGE_VERSION 'latest', ROW_GROUP_SIZE 2048);

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (1500 1500)'::GEOMETRY;
----
1500	1500

# Keep 2048 live rows so the merge stays above the scheduler's small-append threshold on any vector size.
statement ok
DELETE FROM geom_legacy.t WHERE i >= 1048 AND i < 2048;

statement ok
FORCE CHECKPOINT geom_legacy;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('geom_legacy.t');
----
2

# Rowids are unchanged.
query II
SELECT rowid, i FROM geom_legacy.t WHERE i IN (1023, 2548, 3047) ORDER BY i;
----
1023	1023
2548	2548
3047	3047

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
2548	2548

# Recreate the geometry index with the current encoding.
statement ok
DROP INDEX geom_legacy.t_geom_idx;

statement ok
CREATE INDEX t_geom_idx ON geom_legacy.t(geom);

statement ok
FORCE CHECKPOINT geom_legacy;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('geom_legacy.t');
----
1

query II
SELECT rowid, i FROM geom_legacy.t WHERE i IN (1023, 2548, 3047) ORDER BY i;
----
1023	1023
1548	2548
2047	3047

query II
EXPLAIN ANALYZE SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
1548	2548

query II
SELECT rowid, i FROM geom_legacy.t WHERE i = 2548;
----
1548	2548

# Reopen and check the serialized remap.
statement ok
DETACH geom_legacy;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_geom_legacy.db' AS geom_legacy;

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
1548	2548

query II
SELECT rowid, i FROM geom_legacy.t WHERE i = 2548;
----
1548	2548
