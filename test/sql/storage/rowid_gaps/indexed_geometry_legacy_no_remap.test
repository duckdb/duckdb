# name: test/sql/storage/rowid_gaps/indexed_geometry_legacy_no_remap.test
# description: a legacy-encoded GEOMETRY index blocks vacuum remap until the index is recreated
# group: [rowid_gaps]

require noforcestorage

# GEOMETRY ART keys written before v1.5.0 use a different encoding, so regenerated keys may not
# byte-match the stored keys. Such an index refuses incremental remap even after the database
# itself is upgraded; recreating the index re-keys it with the current encoding.

# Phase 1: mint a legacy geometry index by creating it on pre-v1.5.0 storage.
statement ok
ATTACH '{TEST_DIR}/rowid_gap_geom_legacy.db' AS geom_legacy (STORAGE_VERSION 'v1.4.0', ROW_GROUP_SIZE 2048);

statement ok
SET max_vacuum_tasks = 99;

statement ok
CREATE TABLE geom_legacy.t(i INTEGER, geom GEOMETRY);

statement ok
INSERT INTO geom_legacy.t
SELECT i, ('POINT (' || i || ' ' || i || ')')::GEOMETRY FROM range(2048) tbl(i);

statement ok
CHECKPOINT geom_legacy;

statement ok
INSERT INTO geom_legacy.t
SELECT i, ('POINT (' || i || ' ' || i || ')')::GEOMETRY FROM range(2048, 3048) tbl(i);

statement ok
CHECKPOINT geom_legacy;

statement ok
CREATE UNIQUE INDEX t_i_idx ON geom_legacy.t(i);

statement ok
CREATE INDEX t_geom_idx ON geom_legacy.t(geom);

statement ok
CHECKPOINT geom_legacy;

# Phase 2: upgrade the database. The geometry index still carries the legacy key encoding,
# so vacuum must not remap: the row groups cannot be merged.
statement ok
DETACH geom_legacy;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_geom_legacy.db' AS geom_legacy (STORAGE_VERSION 'latest');

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (1500 1500)'::GEOMETRY;
----
1500	1500

statement ok
DELETE FROM geom_legacy.t WHERE i >= 1024 AND i < 2548;

statement ok
FORCE CHECKPOINT geom_legacy;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('geom_legacy.t');
----
2

# Rowids are unchanged: the merge was refused because of the legacy geometry index.
query II
SELECT rowid, i FROM geom_legacy.t WHERE i IN (1023, 2548, 3047) ORDER BY i;
----
1023	1023
2548	2548
3047	3047

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
2548	2548

# Phase 3: recreate the geometry index on current storage. It is re-keyed with the current
# encoding, so vacuum can now merge and remap. The old i-index is also legacy-versioned but has
# no geometry column, so it never blocked remap and is remapped in place.
statement ok
DROP INDEX geom_legacy.t_geom_idx;

statement ok
CREATE INDEX t_geom_idx ON geom_legacy.t(geom);

statement ok
FORCE CHECKPOINT geom_legacy;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('geom_legacy.t');
----
1

query II
SELECT rowid, i FROM geom_legacy.t WHERE i IN (1023, 2548, 3047) ORDER BY i;
----
1023	1023
1024	2548
1523	3047

query II
EXPLAIN ANALYZE SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
1024	2548

query II
SELECT rowid, i FROM geom_legacy.t WHERE i = 2548;
----
1024	2548

# The remapped indexes are what get serialized: reopen and check again.
statement ok
DETACH geom_legacy;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_geom_legacy.db' AS geom_legacy;

query II
SELECT rowid, i FROM geom_legacy.t WHERE geom = 'POINT (2548 2548)'::GEOMETRY;
----
1024	2548

query II
SELECT rowid, i FROM geom_legacy.t WHERE i = 2548;
----
1024	2548
