# name: test/sql/storage/rowid_gaps/metadata_reuse_next_row_id.test
# description: full table metadata reuse preserves next_row_id for rowid gaps
# group: [rowid_gaps]

statement ok
ATTACH '{TEST_DIR}/rowid_gap_metadata_reuse.db' AS rowid_gap_metadata_reuse (STORAGE_VERSION 'latest', ROW_GROUP_SIZE 2048);

statement ok
SET experimental_metadata_reuse = true;

statement ok
CREATE TABLE rowid_gap_metadata_reuse.t AS SELECT i FROM range(6144) tbl(i);

statement ok
CREATE UNIQUE INDEX idx_i ON rowid_gap_metadata_reuse.t(i);

statement ok
CHECKPOINT rowid_gap_metadata_reuse;

statement ok
DELETE FROM rowid_gap_metadata_reuse.t WHERE i >= 2048 AND i < 4096;

statement ok
CHECKPOINT rowid_gap_metadata_reuse;

# This second checkpoint should be able to reuse the existing table metadata.
# It must carry forward next_row_id even though total_rows is smaller.
statement ok
CHECKPOINT rowid_gap_metadata_reuse;

statement ok
DETACH rowid_gap_metadata_reuse;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_metadata_reuse.db' AS rowid_gap_metadata_reuse;

query III
SELECT min(rowid), max(rowid), count(*) FROM rowid_gap_metadata_reuse.t;
----
0	6143	4096

statement ok
INSERT INTO rowid_gap_metadata_reuse.t VALUES (999999);

query II
SELECT rowid, i FROM rowid_gap_metadata_reuse.t WHERE i = 999999;
----
6144	999999

statement ok
CHECKPOINT rowid_gap_metadata_reuse;

statement ok
DETACH rowid_gap_metadata_reuse;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_metadata_reuse.db' AS rowid_gap_metadata_reuse;

query II
SELECT rowid, i FROM rowid_gap_metadata_reuse.t WHERE i = 999999;
----
6144	999999
