# name: test/sql/storage/rowid_gaps/indexed_remap_merges_across_gap.test
# description: indexed vacuum remaps rowids when merging fully-live row groups across a rowid gap
# group: [rowid_gaps]

# Latest storage can remap indexed rowids across the dropped row group.

statement ok
ATTACH '{TEST_DIR}/rowid_gap_no_merge_across_gap.db' AS rowid_gap_no_merge (STORAGE_VERSION 'latest', ROW_GROUP_SIZE 4096);

statement ok
PRAGMA force_checkpoint;

statement ok
SET max_vacuum_tasks = 0;

statement ok
CREATE TABLE rowid_gap_no_merge.t(i INTEGER);

statement ok
INSERT INTO rowid_gap_no_merge.t SELECT i FROM range(1000) tbl(i);

statement ok
CHECKPOINT rowid_gap_no_merge;

statement ok
INSERT INTO rowid_gap_no_merge.t SELECT i FROM range(1000, 2000) tbl(i);

statement ok
CHECKPOINT rowid_gap_no_merge;

statement ok
INSERT INTO rowid_gap_no_merge.t SELECT i FROM range(2000, 3000) tbl(i);

statement ok
CHECKPOINT rowid_gap_no_merge;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('rowid_gap_no_merge.t');
----
3

statement ok
CREATE INDEX t_i_idx ON rowid_gap_no_merge.t(i);

statement ok
DELETE FROM rowid_gap_no_merge.t WHERE i >= 1000 AND i < 2000;

statement ok
SET max_vacuum_tasks = 99;

statement ok
FORCE CHECKPOINT rowid_gap_no_merge;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('rowid_gap_no_merge.t');
----
1

query III
SELECT min(rowid), max(rowid), count(*) FROM rowid_gap_no_merge.t;
----
0	1999	2000

query I
SELECT count(*) FROM rowid_gap_no_merge.t WHERE rowid >= 1000 AND rowid < 2000;
----
1000

query II
SELECT rowid, i FROM rowid_gap_no_merge.t WHERE i IN (999, 2000) ORDER BY i;
----
999	999
1000	2000

query II
EXPLAIN ANALYZE SELECT rowid, i FROM rowid_gap_no_merge.t WHERE i = 2000;
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*
