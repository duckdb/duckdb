# name: test/sql/storage/rowid_gaps/indexed_remap_merges_across_gap.test
# description: indexed vacuum remaps rowids when merging fully-live row groups across a rowid gap
# group: [rowid_gaps]

# Latest storage can remap indexed rowids across the dropped row group.

statement ok
ATTACH '{TEST_DIR}/rowid_gap_remap_across_gap.db' AS remap_across_gap (STORAGE_VERSION 'latest', ROW_GROUP_SIZE 4096);

statement ok
PRAGMA force_checkpoint;

statement ok
SET max_vacuum_tasks = 0;

statement ok
CREATE TABLE remap_across_gap.t(i INTEGER);

statement ok
INSERT INTO remap_across_gap.t SELECT i FROM range(1000) tbl(i);

statement ok
CHECKPOINT remap_across_gap;

statement ok
INSERT INTO remap_across_gap.t SELECT i FROM range(1000, 2000) tbl(i);

statement ok
CHECKPOINT remap_across_gap;

statement ok
INSERT INTO remap_across_gap.t SELECT i FROM range(2000, 3000) tbl(i);

statement ok
CHECKPOINT remap_across_gap;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('remap_across_gap.t');
----
3

statement ok
CREATE INDEX t_i_idx ON remap_across_gap.t(i);

statement ok
DELETE FROM remap_across_gap.t WHERE i >= 1000 AND i < 2000;

statement ok
SET max_vacuum_tasks = 99;

# Before vacuum
query II
SELECT rowid, i FROM remap_across_gap.t WHERE i IN (999, 2000) ORDER BY i;
----
999	999
2000	2000

statement ok
FORCE CHECKPOINT remap_across_gap;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('remap_across_gap.t');
----
1

query III
SELECT min(rowid), max(rowid), count(*) FROM remap_across_gap.t;
----
0	1999	2000

query I
SELECT count(*) FROM remap_across_gap.t WHERE rowid >= 1000 AND rowid < 2000;
----
1000

query II
SELECT rowid, i FROM remap_across_gap.t WHERE i IN (999, 2000) ORDER BY i;
----
999	999
1000	2000

query II
EXPLAIN ANALYZE SELECT rowid, i FROM remap_across_gap.t WHERE i = 2000;
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*
