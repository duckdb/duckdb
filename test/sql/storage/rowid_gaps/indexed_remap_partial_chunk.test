# name: test/sql/storage/rowid_gaps/indexed_remap_partial_chunk.test
# description: vacuum remap buffers only the moved rows of a scan chunk that mixes moved and unmoved rows
# group: [rowid_gaps]

# Deleting a range from the middle of the first row group produces one scan chunk
# whose leading rows keep their rowids while the remaining rows shift, so the
# changed-pair buffering must select a strict subset of the chunk.

statement ok
ATTACH '{TEST_DIR}/rowid_gap_remap_partial.db' AS remap_partial (STORAGE_VERSION 'latest', ROW_GROUP_SIZE 2048);

statement ok
SET max_vacuum_tasks = 99;

statement ok
CREATE TABLE remap_partial.t(i INTEGER, g INTEGER);

statement ok
INSERT INTO remap_partial.t
SELECT i, CASE WHEN i IN (99, 2100) THEN 7 ELSE i + 10000 END FROM range(2048) tbl(i);

statement ok
CHECKPOINT remap_partial;

statement ok
INSERT INTO remap_partial.t
SELECT i, CASE WHEN i IN (99, 2100) THEN 7 ELSE i + 10000 END FROM range(2048, 2148) tbl(i);

statement ok
CHECKPOINT remap_partial;

statement ok
CREATE UNIQUE INDEX t_i_idx ON remap_partial.t(i);

statement ok
CREATE INDEX t_g_idx ON remap_partial.t(g);

statement ok
DELETE FROM remap_partial.t WHERE i >= 100 AND i < 200;

statement ok
FORCE CHECKPOINT remap_partial;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('remap_partial.t');
----
1

query III
SELECT min(rowid), max(rowid), count(*) FROM remap_partial.t;
----
0	2047	2048

# Rows before the deleted range keep their rowids; everything after shifts by 100.
query II
SELECT rowid, i FROM remap_partial.t WHERE i IN (0, 99, 200, 2047, 2048, 2147) ORDER BY i;
----
0	0
99	99
100	200
1947	2047
1948	2048
2047	2147

query II
EXPLAIN ANALYZE SELECT rowid, i FROM remap_partial.t WHERE i = 200;
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*

# Duplicate key with one unmoved row (99) and one moved row (2100 -> 2000).
query II
SELECT rowid, i FROM remap_partial.t WHERE g = 7 ORDER BY i;
----
99	99
2000	2100

query II
EXPLAIN ANALYZE SELECT rowid, i FROM remap_partial.t WHERE g = 7;
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*
