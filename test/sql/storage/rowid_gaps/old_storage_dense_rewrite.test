# name: test/sql/storage/rowid_gaps/old_storage_dense_rewrite.test
# description: old storage densely rewrites rowids when a deleted row group is dropped
# group: [rowid_gaps]

statement ok
ATTACH '{TEST_DIR}/rowid_gap_old_storage_dense.db' AS rowid_gap_old_storage_dense (STORAGE_VERSION 'v1.5.0', ROW_GROUP_SIZE 2048);

statement ok
SET max_vacuum_tasks = 99;

statement ok
CREATE TABLE rowid_gap_old_storage_dense.t AS SELECT i FROM range(6144) tbl(i);

statement ok
CHECKPOINT rowid_gap_old_storage_dense;

statement ok
DELETE FROM rowid_gap_old_storage_dense.t WHERE i >= 2048 AND i < 4096;

statement ok
CHECKPOINT rowid_gap_old_storage_dense;

statement ok
DETACH rowid_gap_old_storage_dense;

statement ok
ATTACH '{TEST_DIR}/rowid_gap_old_storage_dense.db' AS rowid_gap_old_storage_dense;

query I
SELECT COUNT(DISTINCT row_group_id) FROM pragma_storage_info('rowid_gap_old_storage_dense.t');
----
2

query III
SELECT min(rowid), max(rowid), count(*) FROM rowid_gap_old_storage_dense.t;
----
0	4095	4096

query II
SELECT rowid, i FROM rowid_gap_old_storage_dense.t WHERE i = 4096;
----
2048	4096

query I
SELECT count(*) FROM rowid_gap_old_storage_dense.t WHERE rowid >= 4096;
----
0
