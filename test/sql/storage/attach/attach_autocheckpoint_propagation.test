# name: test/sql/storage/attach/attach_autocheckpoint_propagation.test
# description: A failing autocheckpoint surfaces at commit time and reports the original checkpoint error
# group: [attach]

require no_alternative_verify

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET auto_checkpoint_skip_wal_threshold = 9999999999;

statement ok
ATTACH '{TEST_DIR}/attach_autockpt_prop.db' AS a;

statement ok
CREATE TABLE a.tbl(i INTEGER);

statement ok
SET wal_autocheckpoint_entries = 1;

statement ok
PRAGMA debug_checkpoint_abort = 'before_header_non_fatal';

statement error
INSERT INTO a.tbl VALUES (1), (2), (3);
----
<REGEX>:IO Error:.*Transaction COMMIT succeeded.*autocheckpoint failed.*Original error: Checkpoint aborted before header write.*

statement error
SELECT COUNT(*) FROM a.tbl;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

statement ok
PRAGMA debug_checkpoint_abort = 'none';

statement ok
DETACH a;

statement ok
ATTACH '{TEST_DIR}/attach_autockpt_prop.db' AS a;

query I
SELECT COUNT(*) FROM a.tbl;
----
3
