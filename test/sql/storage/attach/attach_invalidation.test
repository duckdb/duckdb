# name: test/sql/storage/attach/attach_invalidation.test
# description: Test attached database invalidation after checkpoint failures
# group: [attach]

require noforcestorage

require no_alternative_verify

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
SET auto_checkpoint_skip_wal_threshold = 9999999999;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_a.db' AS a;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_b.db' AS b;

statement ok
CREATE TABLE main_tbl(i INTEGER);

statement ok
CREATE TABLE a.tbl(i INTEGER);

statement ok
CREATE TABLE b.tbl(i INTEGER);

statement ok
INSERT INTO main_tbl VALUES (1);

statement ok
INSERT INTO a.tbl SELECT range::INTEGER FROM range(10);

statement ok
INSERT INTO b.tbl VALUES (100);

statement ok
CHECKPOINT a;

statement ok
CHECKPOINT b;

statement ok
INSERT INTO a.tbl VALUES (10);

statement ok
PRAGMA debug_checkpoint_abort = 'before_header';

statement error
CHECKPOINT a;
----
<REGEX>:IO Error: Checkpoint failed for database "a".*Checkpoint aborted before header write.*

statement error
SELECT COUNT(*) FROM a.tbl;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

statement error
INSERT INTO a.tbl VALUES (11);
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

statement error
CHECKPOINT a;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

query I
SELECT COUNT(*) FROM b.tbl;
----
1

statement ok
INSERT INTO b.tbl VALUES (101);

query I
SELECT COUNT(*) FROM b.tbl;
----
2

query I
SELECT COUNT(*) FROM main_tbl;
----
1

query I
SELECT 42;
----
42

statement ok
SET immediate_transaction_mode = true;

statement ok
BEGIN;

query I
SELECT COUNT(*) FROM b.tbl;
----
2

statement error
SELECT COUNT(*) FROM a.tbl;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

statement ok
ROLLBACK;

statement ok
SET immediate_transaction_mode = false;

statement ok
PRAGMA debug_checkpoint_abort = 'none';

statement ok
DETACH a;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_a.db' AS a;

query I
SELECT COUNT(*) FROM a.tbl;
----
11

statement ok
SET wal_autocheckpoint = '1KB';

statement ok
PRAGMA debug_checkpoint_abort = 'before_header';

statement ok
INSERT INTO a.tbl SELECT (range + 1000)::INTEGER FROM range(10000);

statement error
SELECT COUNT(*) FROM a.tbl;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

query I
SELECT COUNT(*) FROM b.tbl;
----
2

query I
SELECT 42;
----
42

statement ok
PRAGMA debug_checkpoint_abort = 'none';

statement ok
DETACH a;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_a.db' AS a;

query I
SELECT COUNT(*) FROM a.tbl;
----
10011
