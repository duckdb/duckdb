# name: test/sql/storage/attach/attach_invalidation.test
# description: A checkpoint failure on an attached database is scoped to that database
# group: [attach]

require no_alternative_verify

foreach abort_mode before_header before_header_non_fatal

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
SET auto_checkpoint_skip_wal_threshold = 9999999999;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_a_{abort_mode}.db' AS a;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_b_{abort_mode}.db' AS b;

statement ok
CREATE TABLE a.tbl(i INTEGER);

statement ok
CREATE TABLE b.tbl(i INTEGER);

statement ok
INSERT INTO a.tbl SELECT range::INTEGER FROM range(10);

statement ok
INSERT INTO b.tbl VALUES (100);

statement ok
CHECKPOINT a;

statement ok
INSERT INTO a.tbl VALUES (10);

statement ok
PRAGMA debug_checkpoint_abort = '{abort_mode}';

# the failing checkpoint is scoped to "a"
statement error
CHECKPOINT a;
----
<REGEX>:IO Error: Checkpoint failed for database "a".*Checkpoint aborted before header write.*

# "a" is invalidated: reads, writes and further checkpoints all fail
statement error
SELECT COUNT(*) FROM a.tbl;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

statement error
INSERT INTO a.tbl VALUES (11);
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

statement error
CHECKPOINT a;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

# the instance and the sibling database "b" are unaffected
query I
SELECT 42;
----
42

statement ok
INSERT INTO b.tbl VALUES (101);

query I
SELECT COUNT(*) FROM b.tbl;
----
2

# immediate transaction mode must skip the invalidated database when starting transactions
statement ok
SET immediate_transaction_mode = true;

statement ok
BEGIN;

query I
SELECT COUNT(*) FROM b.tbl;
----
2

statement error
SELECT COUNT(*) FROM a.tbl;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

statement ok
ROLLBACK;

statement ok
SET immediate_transaction_mode = false;

# detach + reattach clears the invalidation and recovers committed data from the WAL
statement ok
PRAGMA debug_checkpoint_abort = 'none';

statement ok
DETACH a;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_a_{abort_mode}.db' AS a;

query I
SELECT COUNT(*) FROM a.tbl;
----
11

# the same scoping applies to a failing auto-checkpoint (triggered by the WAL size, not an explicit CHECKPOINT)
statement ok
SET wal_autocheckpoint = '1KB';

statement ok
PRAGMA debug_checkpoint_abort = '{abort_mode}';

statement error
INSERT INTO a.tbl SELECT (range + 1000)::INTEGER FROM range(10000);
----
<REGEX>:IO Error:.*Transaction COMMIT succeeded.*autocheckpoint failed.*

statement error
SELECT COUNT(*) FROM a.tbl;
----
<REGEX>:IO Error: Database "a" has been invalidated because checkpointing failed.*

query I
SELECT COUNT(*) FROM b.tbl;
----
2

statement ok
PRAGMA debug_checkpoint_abort = 'none';

statement ok
DETACH a;

statement ok
ATTACH '{TEST_DIR}/attach_invalidation_a_{abort_mode}.db' AS a;

query I
SELECT COUNT(*) FROM a.tbl;
----
10011

# detach both so the next iteration can reattach fresh database files
statement ok
DETACH a;

statement ok
DETACH b;

endloop
