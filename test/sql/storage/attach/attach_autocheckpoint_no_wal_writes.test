# name: test/sql/storage/attach/attach_autocheckpoint_no_wal_writes.test
# description: A failing autocheckpoint on a NO_WAL_WRITES database is a non-durable commit failure
# group: [attach]

require no_alternative_verify

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET auto_checkpoint_skip_wal_threshold = 9999999999;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
ATTACH '{TEST_DIR}/attach_autockpt_no_wal.db' AS nw (RECOVERY_MODE NO_WAL_WRITES);

statement ok
CREATE TABLE nw.tbl(i INTEGER);

statement ok
CHECKPOINT nw;

statement ok
SET wal_autocheckpoint = '1KB';

statement ok
PRAGMA debug_checkpoint_abort = 'before_header_non_fatal';

statement error
INSERT INTO nw.tbl SELECT range::INTEGER FROM range(10000);
----
<REGEX>:.*Failed to commit.*Checkpoint failed for database "nw".*

statement ok
PRAGMA debug_checkpoint_abort = 'none';

statement ok
DETACH nw;

statement ok
ATTACH '{TEST_DIR}/attach_autockpt_no_wal.db' AS nw (RECOVERY_MODE NO_WAL_WRITES);

query I
SELECT COUNT(*) FROM nw.tbl;
----
0
