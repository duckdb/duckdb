# name: test/sql/storage/attach/attach_invalidation_default_db.test
# description: A checkpoint failure on the default database is instance-wide, even with another database attached
# group: [attach]

require skip_reload

require no_alternative_verify

foreach abort_mode before_header before_header_non_fatal

load {TEST_DIR}/attach_inval_default_main_{abort_mode}.db

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
PRAGMA wal_autocheckpoint = '1TB';

statement ok
CREATE TABLE t(i INTEGER);

statement ok
INSERT INTO t VALUES (1);

statement ok
CHECKPOINT;

statement ok
ATTACH '{TEST_DIR}/attach_inval_default_sib_{abort_mode}.db' AS sib;

statement ok
CREATE TABLE sib.t(i INTEGER);

statement ok
INSERT INTO sib.t VALUES (100);

statement ok
PRAGMA debug_checkpoint_abort = '{abort_mode}';

statement ok
INSERT INTO t VALUES (2);

statement error
CHECKPOINT;
----
<REGEX>:FATAL Error.*Checkpoint aborted before header write.*

statement error
SELECT 42;
----
<REGEX>:.*database has been invalidated.*

statement error
SELECT COUNT(*) FROM sib.t;
----
<REGEX>:.*database has been invalidated.*

endloop
