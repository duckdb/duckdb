# name: test/sql/table_function/create_external_resource.test
# description: create_external_resource — blocking create + status poll, baseline enforcement, deleter binding
# group: [table_function]

# Mock recipe callbacks (non-TEMP macros, visible instance-wide to the internal connection).
statement ok
CREATE MACRO mock_create(p) AS TABLE SELECT MAP {'id': 'r1'} AS handle;

statement ok
CREATE MACRO mock_status(h) AS TABLE
  SELECT 'ready' AS state, MAP {'uri': 'quack:localhost:9494', 'attached_db_type': 'quack', 'token': 't1'} AS result;

statement ok
CREATE MACRO mock_destroy(h) AS TABLE SELECT 'ok' AS status;

statement ok
CALL register_external_resource_type('mock@local', kind := 'catalog', create_function := 'mock_create',
    status_function := 'mock_status', destroy_function := 'mock_destroy');

# Blocking create: invokes create, polls status to 'ready', extracts uri/attached_db_type, binds deleter.
query TTTT
SELECT uri, attached_db_type, deleter_function, handle
FROM create_external_resource('mock@local', params := MAP {'region': 'x'});
----
quack:localhost:9494	quack	mock_destroy	{id=r1}

# The connect options ride in `result` (e.g. token flows through generically).
query T
SELECT result FROM create_external_resource('mock@local');
----
{uri='quack:localhost:9494', attached_db_type=quack, token=t1}

# End-to-end: capture the deleter binding and invoke it.
statement ok
SET VARIABLE dfn = (SELECT deleter_function FROM create_external_resource('mock@local'));

statement ok
SET VARIABLE dpl = (SELECT deleter_payload FROM create_external_resource('mock@local'));

statement ok
CALL destroy_external_resource(getvariable('dfn'), getvariable('dpl'));

# Baseline enforcement: an catalog resource whose status omits 'uri' errors.
statement ok
CREATE MACRO bad_status(h) AS TABLE SELECT 'ready' AS state, MAP {'foo': 'bar'} AS result;

statement ok
CALL register_external_resource_type('badattach@local', kind := 'catalog', create_function := 'mock_create', status_function := 'bad_status');

statement error
SELECT * FROM create_external_resource('badattach@local');
----
<REGEX>:.*missing 'uri'.*

# A 'failed' status is surfaced as an error.
statement ok
CREATE MACRO fail_status(h) AS TABLE SELECT 'failed' AS state, MAP {'x': 'y'} AS result;

statement ok
CALL register_external_resource_type('failing@local', kind := 'catalog', create_function := 'mock_create', status_function := 'fail_status');

statement error
SELECT * FROM create_external_resource('failing@local');
----
<REGEX>:.*state 'failed'.*

# A type with no status function can't await readiness => error.
statement ok
CALL register_external_resource_type('nostatus@local', kind := 'catalog', create_function := 'mock_create');

statement error
SELECT * FROM create_external_resource('nostatus@local');
----
<REGEX>:.*no status function.*

# Unknown resource type errors.
statement error
SELECT * FROM create_external_resource('does_not_exist@local');
----
<REGEX>:.*unknown resource type.*

# A status function whose 'result' column is not a MAP is rejected with a clear error (not an internal crash).
statement ok
CREATE MACRO nonmap_result_status(h) AS TABLE SELECT 'ready' AS state, 42 AS result;

statement ok
CALL register_external_resource_type('nonmap_result@local', kind := 'compute', create_function := 'mock_create', status_function := 'nonmap_result_status');

statement error
SELECT * FROM create_external_resource('nonmap_result@local');
----
<REGEX>:.*must return a MAP in its 'result' column.*

# A create function whose 'handle' column is not a MAP is likewise rejected (not an internal crash).
statement ok
CREATE MACRO nonmap_handle_create(p) AS TABLE SELECT 99 AS handle;

statement ok
CALL register_external_resource_type('nonmap_handle@local', kind := 'compute', create_function := 'nonmap_handle_create', status_function := 'mock_status');

statement error
SELECT * FROM create_external_resource('nonmap_handle@local');
----
<REGEX>:.*must return a MAP in its 'handle' column.*

# The blocking poll loop stays interruptible: a never-ready resource must surface max_execution_time
# (and, interactively, Ctrl-C) rather than hang until the internal readiness timeout.
statement ok
CREATE MACRO stuck_status(h) AS TABLE SELECT 'pending' AS state, MAP {'uri':'u','attached_db_type':'quack'} AS result;

statement ok
CALL register_external_resource_type('stuck@local', kind := 'catalog', create_function := 'mock_create', status_function := 'stuck_status');

statement ok
SET max_execution_time = 500;

statement error
SELECT * FROM create_external_resource('stuck@local');
----
<REGEX>:.*maximum execution time.*

statement ok
SET max_execution_time = 0;

# A non-catalog (compute) resource is not subject to the uri baseline; a well-formed map result is fine.
statement ok
CREATE MACRO compute_status(h) AS TABLE SELECT 'ready' AS state, MAP {'ip': '10.0.0.1'} AS result;

statement ok
CALL register_external_resource_type('compute@local', kind := 'compute', create_function := 'mock_create', status_function := 'compute_status');

query T
SELECT result FROM create_external_resource('compute@local');
----
{ip=10.0.0.1}

# On a post-create failure the provisioned resource must be torn down (no leak): destroy_function is
# invoked. destroy advances a sequence, which lets us observe the call across the internal connection.
statement ok
CREATE SEQUENCE teardown_calls;

statement ok
CREATE MACRO ok_handle(p) AS TABLE SELECT MAP {'id':'z'} AS handle;

statement ok
CREATE MACRO fails(h) AS TABLE SELECT 'failed' AS state, MAP {'x':'y'} AS result;

statement ok
CREATE MACRO record_teardown(h) AS TABLE SELECT nextval('teardown_calls') AS n;

statement ok
CALL register_external_resource_type('leaky@local', kind := 'compute', create_function := 'ok_handle', status_function := 'fails', destroy_function := 'record_teardown');

statement error
SELECT * FROM create_external_resource('leaky@local');
----
<REGEX>:.*state 'failed'.*

# destroy ran once (consumed value 1), so the next value here is 2.
query I
SELECT nextval('teardown_calls');
----
2

# teardown_on_failure := false leaves the resource for inspection: destroy is NOT invoked.
statement ok
CREATE SEQUENCE teardown_calls_kept;

statement ok
CREATE MACRO record_teardown_kept(h) AS TABLE SELECT nextval('teardown_calls_kept') AS n;

statement ok
CALL register_external_resource_type('kept@local', kind := 'compute', create_function := 'ok_handle', status_function := 'fails', destroy_function := 'record_teardown_kept');

statement error
SELECT * FROM create_external_resource('kept@local', teardown_on_failure := false);
----
<REGEX>:.*state 'failed'.*

# destroy never ran, so the first value here is 1.
query I
SELECT nextval('teardown_calls_kept');
----
1
