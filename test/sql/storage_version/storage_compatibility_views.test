# name: test/sql/storage_version/storage_compatibility_views.test
# description: v0.10.2 storage compatibility must not serialize view dependencies
# group: [storage_version]

# load the DB from disk
load {TEST_DIR}/storage_compatibility_v0102_view_dependencies.db

statement ok
SET storage_compatibility_version='v0.10.2'

statement ok
SET enable_view_dependencies=true

statement ok
CREATE TABLE tbl(a INTEGER, b INTEGER);

statement ok
CREATE VIEW vw AS SELECT * FROM tbl;

statement ok
CHECKPOINT

restart

statement ok
SET enable_view_dependencies=true

# v0.10.2 maps to deprecated serialization version 1, so view dependencies
# should not have been persisted after the checkpoint.
statement ok
ALTER TABLE tbl RENAME COLUMN b TO c;