# DELETE trigger body with correlated WHERE
statement ok
CREATE TABLE t_del1 (id INTEGER);

statement ok
CREATE TABLE other_del1 (id INTEGER);

statement ok
INSERT INTO other_del1 VALUES (1), (2), (3);

statement ok
CREATE TRIGGER trg_del1 AFTER INSERT ON t_del1 FOR EACH ROW
    DELETE FROM other_del1 WHERE id = NEW.id;

statement ok
INSERT INTO t_del1 VALUES (1), (3);

query I
SELECT COUNT(*) FROM other_del1;
