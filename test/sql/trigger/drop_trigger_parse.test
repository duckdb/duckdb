# name: test/sql/trigger/drop_trigger_parse.test
# description: Test parsing of DROP TRIGGER statements
# group: [trigger]

require autocomplete

require noforcestorage

statement ok
call enable_peg_parser();

# Basic DROP TRIGGER - table does not exist, expect catalog error (not parse/bind error)
statement error
DROP TRIGGER my_trigger ON my_table;
----
<REGEX>:.*my_table.*

# DROP TRIGGER IF EXISTS - table does not exist, still errors (IF EXISTS only guards the trigger)
statement error
DROP TRIGGER IF EXISTS my_trigger ON my_table;
----
<REGEX>:.*my_table.*

# Schema-qualified trigger name is not allowed (triggers inherit schema from the table)
statement error
DROP TRIGGER my_schema.my_trigger ON my_table;
----
<REGEX>:.*yntax error.*

# Schema-qualified table name - catalog error (table doesn't exist)
statement error
DROP TRIGGER my_trigger ON my_schema.my_table;
----
<REGEX>:.*my_table.*

# Schema-qualified trigger name with schema-qualified table
statement error
DROP TRIGGER my_schema.my_trigger ON my_schema.my_table;
----
<REGEX>:.*yntax error.*

# DROP TRIGGER IF EXISTS with schema-qualified trigger name
statement error
DROP TRIGGER IF EXISTS my_schema.my_trigger ON my_schema.my_table;
----
<REGEX>:.*yntax error.*

# CASCADE - table does not exist, expect catalog error
statement error
DROP TRIGGER my_trigger ON my_table CASCADE;
----
<REGEX>:.*my_table.*

# RESTRICT - table does not exist, expect catalog error
statement error
DROP TRIGGER my_trigger ON my_table RESTRICT;
----
<REGEX>:.*my_table.*

# IF EXISTS with CASCADE - table does not exist, still errors (IF EXISTS only guards the trigger)
statement error
DROP TRIGGER IF EXISTS my_trigger ON my_table CASCADE;
----
<REGEX>:.*my_table.*

# IF EXISTS with RESTRICT - table does not exist, still errors (IF EXISTS only guards the trigger)
statement error
DROP TRIGGER IF EXISTS my_trigger ON my_table RESTRICT;
----
<REGEX>:.*my_table.*

# Syntax errors - missing ON keyword
statement error
DROP TRIGGER my_trigger my_table;
----
yntax error

# Syntax errors - missing table name
statement error
DROP TRIGGER my_trigger ON;
----
yntax error

# Syntax errors - missing trigger name
statement error
DROP TRIGGER ON my_table;
----
yntax error
