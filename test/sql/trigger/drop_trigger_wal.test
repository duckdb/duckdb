# name: test/sql/trigger/drop_trigger_wal.test
# description: Test that DROP TRIGGER is replayed correctly from WAL (database restart without checkpoint)
# group: [trigger]

require autocomplete

statement ok
call enable_peg_parser();

statement ok
SET checkpoint_threshold = '10.0 GB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/drop_trigger_wal.db' AS triggerdb (STORAGE_VERSION 'v2.0.0');

statement ok
USE triggerdb;

statement ok
CREATE TABLE t1 (id INTEGER);

statement ok
CREATE TABLE log_table (id INTEGER);

statement ok
CREATE TRIGGER keep_trigger AFTER INSERT ON t1 INSERT INTO log_table VALUES (1);

statement ok
CREATE TRIGGER drop_trigger BEFORE DELETE ON t1 DELETE FROM log_table WHERE log_table.id = 1;

query I
SELECT COUNT(*) FROM duckdb_triggers() WHERE table_name = 't1';
----
2

# Drop one trigger without checkpoint
statement ok
DROP TRIGGER drop_trigger ON t1;

query TT
SELECT trigger_name, table_name FROM duckdb_triggers() WHERE table_name = 't1';
----
keep_trigger	t1

# Detach without checkpoint - WAL must replay both CREATE and DROP
statement ok
USE memory;

statement ok
DETACH triggerdb;

# Re-attach simulates a database restart replaying the WAL
statement ok
ATTACH '__TEST_DIR__/drop_trigger_wal.db' AS triggerdb;

# Only keep_trigger should survive
query TT
SELECT trigger_name, table_name FROM duckdb_triggers() WHERE database_name = 'triggerdb' ORDER BY trigger_name;
----
keep_trigger	t1

# drop_trigger should be gone
query I
SELECT COUNT(*) FROM duckdb_triggers() WHERE trigger_name = 'drop_trigger';
----
0

statement ok
USE memory;

statement ok
DETACH triggerdb;
