# name: test/sql/trigger/create_trigger_wal.test
# description: Test that triggers survive WAL replay (database restart without checkpoint)
# group: [trigger]

require autocomplete

require noforcestorage

statement ok
call enable_peg_parser();

statement ok
SET checkpoint_threshold = '10.0 GB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '{TEST_DIR}/create_trigger_wal.db' AS triggerdb (STORAGE_VERSION 'v2.0.0');

statement ok
USE triggerdb;

statement ok
CREATE TABLE t1 (id INTEGER, data VARCHAR);

statement ok
CREATE TABLE log_table (id INTEGER);

statement ok
CREATE TRIGGER my_trigger AFTER INSERT ON t1 INSERT INTO log_table VALUES (1);

statement ok
CREATE TRIGGER del_trigger BEFORE DELETE ON t1 DELETE FROM log_table WHERE log_table.id = 1;

statement ok
CREATE TRIGGER upd_trigger AFTER UPDATE OF id ON t1 UPDATE log_table SET id = 99 WHERE log_table.id = 1;

query I
SELECT COUNT(*) FROM duckdb_triggers() WHERE table_name = 't1';
----
3

# Detach without checkpoint - triggers must survive WAL replay
statement ok
USE memory;

statement ok
DETACH triggerdb;

# Re-attach simulates a database restart replaying the WAL
statement ok
ATTACH '{TEST_DIR}/create_trigger_wal.db' AS triggerdb;

query TTTT
SELECT trigger_name, table_name, action_timing, event_manipulation FROM duckdb_triggers() WHERE database_name = 'triggerdb' ORDER BY trigger_name;
----
del_trigger	t1	BEFORE	DELETE
my_trigger	t1	AFTER	INSERT
upd_trigger	t1	AFTER	UPDATE

query TTT
SELECT trigger_name, for_each, columns FROM duckdb_triggers() WHERE trigger_name = 'upd_trigger';
----
upd_trigger	STATEMENT	[id]

statement ok
USE memory;

statement ok
DETACH triggerdb;
