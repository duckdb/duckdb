# name: test/sql/trigger/trigger_after_insert.test
# description: Test AFTER INSERT trigger firing
# group: [trigger]

require autocomplete

statement ok
call enable_peg_parser();

statement ok
CREATE TABLE target (id INTEGER);

statement ok
CREATE TABLE audit (msg VARCHAR);

# Basic: trigger fires once after INSERT, audit row created
statement ok
CREATE TRIGGER trg_basic AFTER INSERT ON target INSERT INTO audit VALUES ('inserted');

statement ok
INSERT INTO target VALUES (1);

query I
SELECT COUNT(*) FROM audit WHERE msg = 'inserted';
----
1

# Trigger fires again on a second INSERT
statement ok
INSERT INTO target VALUES (2);

query I
SELECT COUNT(*) FROM audit WHERE msg = 'inserted';
----
2

# Default (no FOR EACH clause) fires once per statement, not per row
statement ok
INSERT INTO target VALUES (10), (11), (12);

query I
SELECT COUNT(*) FROM audit WHERE msg = 'inserted';
----
3

# Multiple triggers on same table: all fire
statement ok
CREATE TABLE audit2 (msg VARCHAR);

statement ok
CREATE TRIGGER trg_second AFTER INSERT ON target INSERT INTO audit2 VALUES ('second_trigger');

statement ok
INSERT INTO target VALUES (3);

query I
SELECT COUNT(*) FROM audit WHERE msg = 'inserted';
----
4

query I
SELECT COUNT(*) FROM audit2 WHERE msg = 'second_trigger';
----
1

# Trigger body failure rolls back original INSERT
statement ok
CREATE TABLE strict_target (id INTEGER PRIMARY KEY);

statement ok
CREATE TABLE strict_audit (msg VARCHAR);

statement ok
CREATE TRIGGER trg_fail AFTER INSERT ON strict_target INSERT INTO strict_target VALUES (999);

# Inserting 999, then trigger tries to insert 999 again => PK violation
statement error
INSERT INTO strict_target VALUES (999);
----
Constraint Error: PRIMARY KEY or UNIQUE constraint violation: duplicate key "999"

# Neither the insert into strict_target nor the trigger's insert should persist
query I
SELECT COUNT(*) FROM strict_target;
----
0

# Multi-row INSERT fires trigger once per row
statement ok
CREATE TABLE multi_target (id INTEGER);

statement ok
CREATE TABLE multi_audit (msg VARCHAR);

statement ok
CREATE TRIGGER trg_multi AFTER INSERT ON multi_target FOR EACH ROW INSERT INTO multi_audit VALUES ('row');

statement ok
INSERT INTO multi_target VALUES (1), (2), (3);

query I
SELECT COUNT(*) FROM multi_audit;
----
3

# FOR EACH STATEMENT fires once regardless of row count
statement ok
CREATE TABLE stmt_target (id INTEGER);

statement ok
CREATE TABLE stmt_audit (msg VARCHAR);

statement ok
CREATE TRIGGER trg_stmt AFTER INSERT ON stmt_target FOR EACH STATEMENT INSERT INTO stmt_audit VALUES ('statement');

statement ok
INSERT INTO stmt_target VALUES (1), (2), (3);

query I
SELECT COUNT(*) FROM stmt_audit;
----
1

# A second INSERT also fires exactly once
statement ok
INSERT INTO stmt_target VALUES (4);

query I
SELECT COUNT(*) FROM stmt_audit;
----
2

# Mix: one FOR EACH ROW and one FOR EACH STATEMENT trigger on the same table
statement ok
CREATE TABLE mix_target (id INTEGER);

statement ok
CREATE TABLE mix_row_audit (msg VARCHAR);

statement ok
CREATE TABLE mix_stmt_audit (msg VARCHAR);

statement ok
CREATE TRIGGER trg_mix_row AFTER INSERT ON mix_target FOR EACH ROW INSERT INTO mix_row_audit VALUES ('row');

statement ok
CREATE TRIGGER trg_mix_stmt AFTER INSERT ON mix_target FOR EACH STATEMENT INSERT INTO mix_stmt_audit VALUES ('statement');

statement ok
INSERT INTO mix_target VALUES (1), (2), (3), (4), (5);

query I
SELECT COUNT(*) FROM mix_row_audit;
----
5

query I
SELECT COUNT(*) FROM mix_stmt_audit;
----
1

# INSERT failure does not fire the trigger
statement ok
CREATE TABLE insert_fail_target (id INTEGER PRIMARY KEY);

statement ok
CREATE TABLE insert_fail_audit (msg VARCHAR);

statement ok
CREATE TRIGGER trg_insert_fail AFTER INSERT ON insert_fail_target INSERT INTO insert_fail_audit VALUES ('fired');

statement ok
INSERT INTO insert_fail_target VALUES (1);

# Duplicate PK — INSERT fails before trigger can fire
statement error
INSERT INTO insert_fail_target VALUES (1);
----
Constraint Error: Duplicate key "id: 1" violates primary key constraint.

# Trigger must not have fired for the failed INSERT
query I
SELECT COUNT(*) FROM insert_fail_audit;
----
1

# FOR EACH STATEMENT trigger fires even when INSERT produces 0 rows
statement ok
CREATE TABLE empty_target (id INTEGER);

statement ok
CREATE TABLE empty_audit (msg VARCHAR);

statement ok
CREATE TRIGGER trg_empty AFTER INSERT ON empty_target FOR EACH STATEMENT INSERT INTO empty_audit VALUES ('fired');

statement ok
INSERT INTO empty_target SELECT 1 WHERE false;

query I
SELECT COUNT(*) FROM empty_audit;
----
1

# Trigger fires when inserting from another table
statement ok
CREATE TABLE batch_source (id INTEGER);

statement ok
CREATE TABLE batch_dest (id INTEGER);

statement ok
CREATE TABLE batch_audit (msg VARCHAR);

statement ok
INSERT INTO batch_source VALUES (1), (2), (3);

statement ok
CREATE TRIGGER trg_batch AFTER INSERT ON batch_dest INSERT INTO batch_audit VALUES ('fired');

statement ok
INSERT INTO batch_dest SELECT * FROM batch_source;

query I
SELECT COUNT(*) FROM batch_audit;
----
1

# Trigger body inserts into a table in another schema
statement ok
CREATE SCHEMA audit_schema;

statement ok
CREATE TABLE audit_schema.cross_log (msg VARCHAR);

statement ok
CREATE TABLE cross_src (id INTEGER);

statement ok
CREATE TRIGGER trg_cross_schema AFTER INSERT ON cross_src INSERT INTO audit_schema.cross_log VALUES ('fired');

statement ok
INSERT INTO cross_src VALUES (1);

query I
SELECT COUNT(*) FROM audit_schema.cross_log;
----
1

# RETURNING with triggers is not yet supported (temporary — will be lifted when NEW/OLD references land)
statement ok
CREATE TABLE returning_tbl (id INTEGER);

statement ok
CREATE TABLE returning_audit (msg VARCHAR);

statement ok
CREATE TRIGGER trg_returning AFTER INSERT ON returning_tbl INSERT INTO returning_audit VALUES ('fired');

statement error
INSERT INTO returning_tbl VALUES (1) RETURNING id;
----
Not implemented Error: RETURNING is not yet supported on tables with AFTER INSERT triggers
