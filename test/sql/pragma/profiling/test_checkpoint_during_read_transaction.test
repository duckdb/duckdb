# name: test/sql/pragma/profiling/test_checkpoint_during_read_transaction.test
# group: [profiling]

require notwindows

require json

require noforcestorage

require skip_reload

# Setup.

statement ok
SET threads = 1;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/checkpoint_read_txn.db';

statement ok
CREATE TABLE checkpoint_read_txn.tbl AS SELECT range AS id FROM range(1000);

# con1 starts a read transaction, holding a snapshot.

statement ok con1
BEGIN;

query I con1
SELECT COUNT(*) FROM checkpoint_read_txn.tbl;
----
1000

# Default connection inserts more data.

statement ok
INSERT INTO checkpoint_read_txn.tbl SELECT range + 1000 AS id FROM range(1000);

# Enable profiling and run CHECKPOINT on the default connection.
# This exercises the checkpoint-during-read-transaction code path
# (ActiveCheckpointWrapper creates a new connection for the checkpoint).

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/checkpoint_read_txn.json';

statement ok
PRAGMA custom_profiling_settings='{"CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
CHECKPOINT checkpoint_read_txn;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '__TEST_DIR__/checkpoint_read_txn.json';

# Verify CHECKPOINT_LATENCY is attributed to the original connection.

query I
SELECT
	CASE WHEN checkpoint_latency >= 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
true

# Verify con1 data consistency: still sees the old snapshot.

query I con1
SELECT COUNT(*) FROM checkpoint_read_txn.tbl;
----
1000

statement ok con1
COMMIT;

# After committing, con1 sees the new data.

query I con1
SELECT COUNT(*) FROM checkpoint_read_txn.tbl;
----
2000
