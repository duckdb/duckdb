# name: test/sql/pragma/profiling/test_cumulative_vacuum_time.test_slow
# description: Test cumulative vacuum time for checkpoint row-group vacuum tasks and index rebuilds
# group: [profiling]

require json

require vacuum_rebuild_indexes

require skip_reload

statement ok
SET threads = 1;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
PRAGMA disable_profiling;

statement ok
ATTACH '__TEST_DIR__/cumulative_vacuum_time_vacuum.db' AS vacuum_db;

statement ok
CREATE TABLE vacuum_db.tbl AS SELECT range AS id FROM range(480_000);

statement ok
CHECKPOINT vacuum_db;

statement ok
DELETE FROM vacuum_db.tbl WHERE id % 2 = 0;

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cumulative_vacuum_time_vacuum.json';

statement ok
PRAGMA custom_profiling_settings='{"CUMULATIVE_VACUUM_TIME": "true", "CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
CHECKPOINT vacuum_db;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE vacuum_metrics AS SELECT * FROM '__TEST_DIR__/cumulative_vacuum_time_vacuum.json';

query I
SELECT CASE
	WHEN cumulative_vacuum_time > 0 THEN 'true'
	ELSE 'false'
	END
FROM vacuum_metrics;
----
true

# Dropping fully-deleted row groups during vacuum initialization is not timed.

statement ok
ATTACH '__TEST_DIR__/cumulative_vacuum_time_drop.db' AS drop_vacuum;

statement ok
CREATE TABLE drop_vacuum.tbl AS SELECT range AS id FROM range(300_000);

statement ok
CHECKPOINT drop_vacuum;

statement ok
DELETE FROM drop_vacuum.tbl WHERE id < 122_880;

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cumulative_vacuum_time_drop.json';

statement ok
PRAGMA custom_profiling_settings='{"CUMULATIVE_VACUUM_TIME": "true", "CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
CHECKPOINT drop_vacuum;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE drop_metrics AS SELECT * FROM '__TEST_DIR__/cumulative_vacuum_time_drop.json';

query I
SELECT CASE
	WHEN cumulative_vacuum_time = 0 THEN 'true'
	ELSE 'false'
	END
FROM drop_metrics;
----
true

# With an index and vacuum_rebuild_indexes enabled, the same drop-only vacuum rebuilds indexes and is timed.

statement ok
ATTACH '__TEST_DIR__/cumulative_vacuum_time_index.db' AS index_vacuum;

statement ok
CREATE TABLE index_vacuum.tbl AS SELECT range AS id FROM range(300_000);

statement ok
CREATE INDEX idx ON index_vacuum.tbl(id);

statement ok
CHECKPOINT index_vacuum;

statement ok
DELETE FROM index_vacuum.tbl WHERE id < 122_880;

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cumulative_vacuum_time_index.json';

statement ok
PRAGMA custom_profiling_settings='{"CUMULATIVE_VACUUM_TIME": "true", "CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
CHECKPOINT index_vacuum;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE index_metrics AS SELECT * FROM '__TEST_DIR__/cumulative_vacuum_time_index.json';

query I
SELECT CASE
	WHEN cumulative_vacuum_time > 0 THEN 'true'
	ELSE 'false'
	END
FROM index_metrics;
----
true
