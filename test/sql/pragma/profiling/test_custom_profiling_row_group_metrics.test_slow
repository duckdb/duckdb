# --- Multi-scan query (join): each scan reports its own table's row groups ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM t JOIN small_t USING (i);

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN' ORDER BY total;
----
TABLE_SCAN	1	1
TABLE_SCAN	1	4

query II
SELECT sum(scanned)::BIGINT, sum(total)::BIGINT
FROM operator_metrics
WHERE operator_type = 'TABLE_SCAN';
----
2	5

query II
SELECT * FROM cumulative_metrics;
----
2	5

# --- Repeated scan query: same table's row groups are counted once per scan operator ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM t a, t b WHERE a.i < 100 AND b.i < 100;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN' ORDER BY scanned, total;
----
TABLE_SCAN	1	4
TABLE_SCAN	1	4

query II
SELECT sum(scanned)::BIGINT, sum(total)::BIGINT
FROM operator_metrics
WHERE operator_type = 'TABLE_SCAN';
----
2	8

query II
SELECT * FROM cumulative_metrics;
----
2	8

# --- LIMITation: rows scanned is not flushed when the scan is stopped early ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROWS_SCANNED": "true", "OPERATOR_TYPE": "true"}';

statement ok
SELECT * FROM t LIMIT 1;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE VIEW rows_scanned_operator_metrics AS
WITH RECURSIVE ops AS (
    SELECT unnest(children) AS op FROM '__TEST_DIR__/profiling_output.json'
    UNION ALL
    SELECT unnest(op.children) FROM ops WHERE len(op.children) > 0
)
SELECT op.operator_type,
       op.operator_rows_scanned AS rows_scanned
FROM ops;

# The table scan starts, but the downstream LIMIT prevents FinishSource from
# flushing OPERATOR_ROWS_SCANNED. Once fixed, this should report the started row group.
query II
SELECT * FROM rows_scanned_operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	0

# --- Transaction-local append: pruning covers distinct persistent and local ranges ---

statement ok
PRAGMA threads=1;

statement ok
BEGIN TRANSACTION;

# Two local row groups in a separate middle range. The filter below scans persistent row group 0
# and local row group 0, while pruning persistent row groups 1-3 and local row group 1.
statement ok
INSERT INTO mixed_t SELECT range + 5000000 FROM range(200000);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM mixed_t WHERE i < 5000100;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	2	6

query II
SELECT * FROM cumulative_metrics;
----
2	6

statement ok
ROLLBACK;

# --- Transaction-local append: one persistent and one local row group ---

statement ok
BEGIN TRANSACTION;

statement ok
INSERT INTO persistent_local_rg SELECT range + 10 FROM range(10);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM persistent_local_rg;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	2	2

query II
SELECT * FROM cumulative_metrics;
----
2	2

statement ok
ROLLBACK;

# --- Transaction-local append: total includes uncommitted local row groups ---

statement ok
BEGIN TRANSACTION;

statement ok
INSERT INTO local_t SELECT range FROM range(400000);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM local_t;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	4	4

query II
SELECT * FROM cumulative_metrics;
----
4	4

statement ok
ROLLBACK;
