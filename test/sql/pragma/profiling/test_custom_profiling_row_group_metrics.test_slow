# name: test/sql/pragma/profiling/test_custom_profiling_row_group_metrics.test_slow
# description: Test OPERATOR_ROW_GROUPS_SCANNED and OPERATOR_ROW_GROUPS_TOTAL metrics
# group: [profiling]

require json

# 400000 rows with default row_group_size (122880) => 4 row groups
statement ok
CREATE TABLE t AS SELECT range i FROM range(400000);

statement ok
CREATE TABLE empty_t(i INTEGER);

# Single row group (10 rows < row_group_size)
statement ok
CREATE TABLE small_t AS SELECT range i FROM range(10);

statement ok
CREATE TABLE local_t(i BIGINT);

statement ok
CREATE TABLE persistent_local_rg AS SELECT range i FROM range(10);

# Four persistent row groups: row group 0 is low-valued, row groups 1-3 are high-valued.
statement ok
CREATE TABLE mixed_t AS
SELECT CASE WHEN range < 122880 THEN range ELSE range + 10000000 END AS i FROM range(400000);

# --- Full seq_scan: all 4 row groups scanned ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM t;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE VIEW operator_metrics AS
WITH RECURSIVE ops AS (
    SELECT unnest(children) AS op FROM '__TEST_DIR__/profiling_output.json'
    UNION ALL
    SELECT unnest(op.children) FROM ops WHERE len(op.children) > 0
)
SELECT op.operator_type,
       op.operator_row_groups_scanned AS scanned,
       op.operator_row_groups_total AS total
FROM ops;

statement ok
CREATE VIEW cumulative_metrics AS
SELECT cumulative_row_groups_scanned::BIGINT AS scanned,
       cumulative_total_row_groups_to_scan::BIGINT AS total
FROM '__TEST_DIR__/profiling_output.json';

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	4	4

query II
SELECT * FROM cumulative_metrics;
----
4	4

# --- Filtered scan: skips 3 of 4 row groups ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM t WHERE i < 100;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	1	4

query II
SELECT * FROM cumulative_metrics;
----
1	4

# --- Index scan: scanned stays 0; total still reflects table size ---

statement ok
CREATE INDEX idx ON t(i);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM t WHERE i = 5;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	0	4

query II
SELECT * FROM cumulative_metrics;
----
0	4

statement ok
DROP INDEX idx;

# --- Empty table: 0 / 0 ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

statement ok
SELECT count(*) FROM empty_t;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'TABLE_SCAN';
----
TABLE_SCAN	0	0

query II
SELECT * FROM cumulative_metrics;
----
0	0

# --- Single-row-group table: 1 / 1 ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true", "CUMULATIVE_ROW_GROUPS_SCANNED": "true", "CUMULATIVE_TOTAL_ROW_GROUPS_TO_SCAN": "true"}';

