# name: test/sql/pragma/profiling/test_autocheckpoint_latency.test
# group: [profiling]

require notwindows

require json

require noforcestorage

require skip_reload

# Setup.

statement ok
SET threads = 1;

statement ok
PRAGMA disable_checkpoint_on_shutdown;

# Set a low auto-checkpoint threshold so COMMIT triggers auto-checkpoint.

statement ok
SET wal_autocheckpoint = '100KB';

statement ok
ATTACH '__TEST_DIR__/autocheckpoint_profile.db';

# Insert enough data to exceed the WAL threshold on commit.

statement ok
CREATE TABLE autocheckpoint_profile.tbl AS SELECT range AS id, range::VARCHAR AS data FROM range(100_000);

# Enable profiling with CHECKPOINT_LATENCY on the original connection.

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/autocheckpoint_profile.json';

statement ok
PRAGMA custom_profiling_settings='{"CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

# This INSERT + implicit COMMIT should trigger auto-checkpoint
# because the WAL exceeds the 100KB threshold.

statement ok
INSERT INTO autocheckpoint_profile.tbl SELECT range + 100000 AS id, range::VARCHAR AS data FROM range(100_000);

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '__TEST_DIR__/autocheckpoint_profile.json';

# Verify CHECKPOINT_LATENCY is attributed to the original connection.

query I
SELECT
	CASE WHEN checkpoint_latency >= 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
true
