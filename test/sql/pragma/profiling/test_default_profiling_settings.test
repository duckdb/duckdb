statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

statement ok
SELECT operator.extra_info, operator.intermediate_size_bytes, query.cpu_time, query.rows_returned, query.time FROM metrics_output;

