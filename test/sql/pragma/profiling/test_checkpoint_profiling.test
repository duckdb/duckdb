statement ok
SET wal_autocheckpoint = '100KB';

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cp_auto.json';

statement ok
INSERT INTO checkpoint_prof.tbl SELECT range + 30000, range % 100 FROM range(100_000);

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics AS SELECT * FROM '__TEST_DIR__/cp_auto.json';

query I
SELECT CASE WHEN checkpoint_latency > 0 THEN 'true' ELSE 'false' END FROM metrics;
----
true

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
INSERT INTO checkpoint_prof.tbl SELECT range + 200000, range % 100 FROM range(10000);

statement ok
SET debug_checkpoint_abort = 'before_header';

statement error
CHECKPOINT checkpoint_prof;
----
Checkpoint aborted before header write

restart

statement ok
SET threads = 1;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET debug_checkpoint_abort = 'none';

statement ok
PRAGMA custom_profiling_settings='{"CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
ATTACH '__TEST_DIR__/checkpoint_prof.db';

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cp_post_abort.json';

statement ok
CHECKPOINT checkpoint_prof;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics AS SELECT * FROM '__TEST_DIR__/cp_post_abort.json';

query I
SELECT CASE WHEN checkpoint_latency > 0 THEN 'true' ELSE 'false' END FROM metrics;
