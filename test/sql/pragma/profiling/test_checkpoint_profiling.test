statement ok
INSERT INTO checkpoint_prof.tbl SELECT range + 1000000, range % 100 FROM range(10000);

concurrentloop threadid 0 10

loop x 0 10

onlyif threadid<>0
statement maybe
INSERT INTO checkpoint_prof.tbl SELECT range + (2000000 + ${threadid} * 10000 + ${x} * 1000), range % 100 FROM range(1000);
----

onlyif threadid=0
statement ok
PRAGMA enable_profiling = 'json';

onlyif threadid=0
statement ok
PRAGMA profiling_output = '__TEST_DIR__/cp_concurrent_${x}.json';

onlyif threadid=0
statement maybe
CHECKPOINT checkpoint_prof;
----

onlyif threadid=0
statement ok
PRAGMA disable_profiling;

onlyif threadid=0
query I
SELECT CASE WHEN checkpoint_latency >= 0 THEN 'true' ELSE 'false' END FROM '__TEST_DIR__/cp_concurrent_${x}.json';
----
true

endloop

endloop

statement ok
CREATE OR REPLACE TABLE metrics AS SELECT * FROM '__TEST_DIR__/cp_concurrent_0.json';

query I
SELECT CASE WHEN checkpoint_latency > 0 THEN 'true' ELSE 'false' END FROM metrics;
----
true
