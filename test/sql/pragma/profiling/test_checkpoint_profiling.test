# name: test/sql/pragma/profiling/test_checkpoint_profiling.test
# group: [profiling]

require notwindows

require json

require noforcestorage

require skip_reload

statement ok
SET threads = 1;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/checkpoint_prof.db';

statement ok
CREATE TABLE checkpoint_prof.tbl(id INTEGER, category INTEGER);

statement ok
INSERT INTO checkpoint_prof.tbl SELECT range, range % 100 FROM range(10000);

statement ok
CREATE INDEX idx_category ON checkpoint_prof.tbl(category);

statement ok
CHECKPOINT checkpoint_prof;

statement ok
PRAGMA custom_profiling_settings='{"CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cp_noop.json';

statement ok
CHECKPOINT checkpoint_prof;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics AS SELECT * FROM '__TEST_DIR__/cp_noop.json';

query I
SELECT CASE WHEN checkpoint_latency = 0 THEN 'true' ELSE 'false' END FROM metrics;
----
true

statement ok con1
BEGIN;

query I con1
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE category = 42;
----
100

statement ok
INSERT INTO checkpoint_prof.tbl SELECT range + 10000, range % 100 FROM range(10000);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cp_concurrent.json';

statement ok
CHECKPOINT checkpoint_prof;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics AS SELECT * FROM '__TEST_DIR__/cp_concurrent.json';

query I
SELECT CASE WHEN checkpoint_latency > 0 THEN 'true' ELSE 'false' END FROM metrics;
----
true

query I con1
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE category = 42;
----
100

statement ok con1
COMMIT;

query I con1
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE category = 42;
----
200

statement ok
CREATE INDEX idx_id ON checkpoint_prof.tbl(id);

statement ok con1
BEGIN;

query I con1
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE category = 42;
----
200

statement ok con2
BEGIN;

query I con2
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE id < 5000;
----
5000

statement ok
INSERT INTO checkpoint_prof.tbl SELECT range + 20000, range % 100 FROM range(10000);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cp_multi_reader.json';

statement ok
CHECKPOINT checkpoint_prof;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics AS SELECT * FROM '__TEST_DIR__/cp_multi_reader.json';

query I
SELECT CASE WHEN checkpoint_latency > 0 THEN 'true' ELSE 'false' END FROM metrics;
----
true

query I con1
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE category = 42;
----
200

query I con2
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE id < 5000;
----
5000

statement ok con1
COMMIT;

statement ok con2
COMMIT;

query I con1
SELECT COUNT(*) FROM checkpoint_prof.tbl WHERE category = 42;
----
300

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/cp_noop2.json';

statement ok
CHECKPOINT checkpoint_prof;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics AS SELECT * FROM '__TEST_DIR__/cp_noop2.json';

query I
SELECT CASE WHEN checkpoint_latency = 0 THEN 'true' ELSE 'false' END FROM metrics;
----
