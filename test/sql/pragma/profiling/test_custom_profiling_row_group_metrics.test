# --- Enabled metric appears on non-scan operators with default value 0 ---

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SEQ_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true"}';

statement ok
SELECT count(*) FROM t;

statement ok
PRAGMA disable_profiling;

query III
SELECT * FROM operator_metrics WHERE operator_type = 'UNGROUPED_AGGREGATE';
----
UNGROUPED_AGGREGATE	0	0

# --- Multi-threaded scan: cross-thread sum still equals 4 ---

statement ok
PRAGMA threads=4;

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"OPERATOR_ROW_GROUPS_SEQ_SCANNED": "true", "OPERATOR_ROW_GROUPS_TOTAL": "true", "OPERATOR_TYPE": "true"}';

statement ok
SELECT count(*) FROM t;

statement ok
PRAGMA disable_profiling;

query III
