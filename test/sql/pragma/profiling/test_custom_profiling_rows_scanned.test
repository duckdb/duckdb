# name: test/sql/pragma/profiling/test_custom_profiling_rows_scanned.test
# description: Test ROWS_SCANNED metric.
# group: [profiling]

require json

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"operator.intermediate_rows": "true", "operator.rows_scanned": "true", "query.total_intermediate_rows": "true", "query.total_rows_scanned": "true"}';

statement ok
CREATE TABLE integers(i INTEGER);

statement ok
INSERT INTO integers VALUES (1), (2), (3), (NULL);

statement ok
SELECT * FROM integers i1, integers i2 WHERE i1.i = i2.i ORDER BY 1;

statement ok
pragma disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

statement ok
SELECT query.total_intermediate_rows, query.total_rows_scanned FROM metrics_output;

query I
SELECT
	CASE WHEN query.total_rows_scanned = 8 THEN NULL
	ELSE metrics_output END
FROM metrics_output;
----
NULL

# Only output the cumulative metric.

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"query.total_intermediate_rows": "true", "query.total_rows_scanned": "true", "system.blocked_thread_time": "true"}';

statement ok
SELECT * FROM integers i1, integers i2 WHERE i1.i = i2.i ORDER BY 1;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

query I
SELECT
	CASE WHEN query.total_rows_scanned > 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
true