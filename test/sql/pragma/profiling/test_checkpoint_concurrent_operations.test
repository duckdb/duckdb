# name: test/sql/pragma/profiling/test_checkpoint_concurrent_operations.test
# group: [profiling]

require notwindows

require json

require noforcestorage

require skip_reload

statement ok
SET threads = 1;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/concurrent_ops.db';

statement ok
CREATE TABLE concurrent_ops.tbl(id INTEGER, category INTEGER);

statement ok
INSERT INTO concurrent_ops.tbl SELECT range, range % 100 FROM range(10000);

statement ok
CREATE INDEX idx_category ON concurrent_ops.tbl(category);

statement ok con1
BEGIN;

query I con1
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE category = 42;
----
100

statement ok
INSERT INTO concurrent_ops.tbl SELECT range + 10000, range % 100 FROM range(10000);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/concurrent_ops_p1.json';

statement ok
PRAGMA custom_profiling_settings='{"CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
CHECKPOINT concurrent_ops;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '__TEST_DIR__/concurrent_ops_p1.json';

query I
SELECT
	CASE WHEN checkpoint_latency >= 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
true

query I con1
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE category = 42;
----
100

statement ok con1
COMMIT;

query I con1
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE category = 42;
----
200

statement ok
CREATE INDEX idx_id ON concurrent_ops.tbl(id);

statement ok con1
BEGIN;

query I con1
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE category = 42;
----
200

statement ok con2
BEGIN;

query I con2
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE id < 5000;
----
5000

statement ok
INSERT INTO concurrent_ops.tbl SELECT range + 20000, range % 100 FROM range(10000);

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/concurrent_ops_p2.json';

statement ok
PRAGMA custom_profiling_settings='{"CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
CHECKPOINT concurrent_ops;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '__TEST_DIR__/concurrent_ops_p2.json';

query I
SELECT
	CASE WHEN checkpoint_latency >= 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
true

query I con1
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE category = 42;
----
200

query I con2
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE id < 5000;
----
5000

statement ok con1
COMMIT;

statement ok con2
COMMIT;

query I con1
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE category = 42;
----
300

query I con2
SELECT COUNT(*) FROM concurrent_ops.tbl WHERE id < 5000;
----
5000

statement ok
INSERT INTO concurrent_ops.tbl SELECT range + 30000, range % 100 FROM range(10000);

statement ok
SET debug_checkpoint_abort = 'before_header';

statement error
CHECKPOINT concurrent_ops;
----
Checkpoint aborted before header write

restart

statement ok
SET threads = 1;

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
SET debug_checkpoint_abort = 'none';

statement ok
ATTACH '__TEST_DIR__/concurrent_ops.db';

query I
SELECT COUNT(*) FROM concurrent_ops.tbl;
----
40000

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/concurrent_ops_p3.json';

statement ok
PRAGMA custom_profiling_settings='{"CHECKPOINT_LATENCY": "true"}';

statement ok
SET profiling_coverage='ALL';

statement ok
CHECKPOINT concurrent_ops;

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '__TEST_DIR__/concurrent_ops_p3.json';

query I
SELECT
	CASE WHEN checkpoint_latency >= 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
true
