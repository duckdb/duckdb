# name: test/sql/pragma/profiling/test_custom_profiling_disable_metrics.test
# description: Change CPU_TIME and other metrics.
# group: [profiling]

require json

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
PRAGMA configure_profiling='{"query.cpu_time": "false", "operator.extra_info": "true", "operator.intermediate_rows": "true", "operator.timing": "true", "query.time": "true"}';

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

# Evaluate results.

query I rowsort
SELECT unnest(current_setting('configure_profiling')) ORDER BY ALL;
----
operator.extra_info
operator.intermediate_rows
operator.timing
query.time

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

statement error
SELECT query.cpu_time FROM metrics_output;
----
<REGEX>:Binder Error.*

statement ok
SELECT operator_info[1].extra_info, query.time FROM metrics_output;

# Re-enable the CPU TIME.

statement ok
PRAGMA configure_profiling='{"query.sql": "true", "query.cpu_time": "true", "operator.extra_info": "true", "query.total_intermediate_rows": "true", "query.total_rows_scanned": "true"}'

query I
SELECT unnest(current_setting('configure_profiling')) ORDER BY ALL
----
operator.extra_info
query.cpu_time
query.sql
query.total_intermediate_rows
query.total_rows_scanned

# Re-enabled profiling.

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

query I
SELECT
	CASE WHEN query.cpu_time > 0 THEN 'true'
    ELSE 'false' END
FROM metrics_output;
----
true

query I
SELECT
	CASE WHEN query.total_intermediate_rows > 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
true

# Only collect ROWS_SCANNED for table queries.
query I
SELECT
	CASE WHEN query.total_rows_scanned > 0 THEN 'true'
	ELSE 'false' END
FROM metrics_output;
----
false

# Check if the query struct column is present when query metrics are requested.
query I
SELECT
	CASE WHEN EXISTS(
		SELECT
			1
		FROM information_schema.columns
		WHERE table_name = 'metrics_output' AND column_name = 'query'
	) THEN 'true'
	ELSE 'false' END;
----
true

# Check if query.sql contains the query.
query I
SELECT
	query.sql
FROM metrics_output;
----
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

# Disable all query.* metrics to verify the query struct disappears from output.

statement ok
PRAGMA configure_profiling='{"query.sql": "false", "query.cpu_time": "false", "query.total_intermediate_rows": "false", "query.total_rows_scanned": "false"}'

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output_no_query.json';

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output_no_query.json';

# Check that query struct is not present when all query.* metrics are disabled.
query I
SELECT
	CASE WHEN EXISTS(
		SELECT
			1
		FROM information_schema.columns
		WHERE table_name = 'metrics_output' AND column_name = 'query'
	) THEN 'true'
	ELSE 'false' END;
----
false
