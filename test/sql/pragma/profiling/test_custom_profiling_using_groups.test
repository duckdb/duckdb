# name: test/sql/pragma/profiling/test_custom_profiling_using_groups.test
# description: Test tracked_metrics using glob patterns.
# group: [profiling]

# This file is automatically generated by scripts/generate_metric_enums.py
# Do not edit this file manually, your changes will be overwritten

require json

# Test wildcard: all metrics
statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SET tracked_metrics = ['*'];

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('tracked_metrics')) ORDER BY ALL;
----
*

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

statement ok
SELECT operator_info[1].extra_info,
	optimizer,
	optimizer.total_time,
	parser.total_time,
	physical_planner.column_binding,
	physical_planner.create_plan,
	physical_planner.resolve_types,
	physical_planner.total_time,
	planner.binding_time,
	planner.total_time,
	operator_info[1].intermediate_size_bytes,
	query.cpu_time,
	query.total_intermediate_rows,
	query.total_rows_scanned,
	query.time,
	query.sql,
	system.blocked_thread_time,
	system.peak_buffer_memory,
	system.peak_temp_dir_size,
	system.total_memory_allocated
FROM metrics_output;

