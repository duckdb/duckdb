	optimizer.top_n,
	optimizer.top_n_window_elimination,
	optimizer.unnest_rewriter,
	optimizer.unused_columns,
	optimizer.window_self_join,
	PARSER,
	physical_planner.column_binding,
	physical_planner.create_plan,
	physical_planner.resolve_types,
	physical_planner.total_time,
	PLANNER,
	PLANNER_BINDING,
	RESULT_SET_SIZE,
	query.cpu_time,
	query.cumulative_cardinality,
	query.cumulative_rows_scanned,
	query.latency,
	query.query_name,
	query.rows_returned,
	storage.attach_load_storage_latency,
	storage.attach_replay_wal_latency,
	storage.checkpoint_latency,
	storage.commit_local_storage_latency,
	storage.total_bytes_read,
