require json

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
PRAGMA custom_profiling_settings='{"ALL": "true"}';

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('custom_profiling_settings')) ORDER BY ALL;
