statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

statement ok
SELECT operator_info[1].extra_info,
	optimizer,
	optimizers.total_time,
	parsers.total_time,
	physical_planner.column_binding,
	physical_planner.create_plan,
	physical_planner.resolve_types,
	physical_planner.total_time,
	planner.binding_time,
	planner.total_time,
	operator_info[1].intermediate_size_bytes,
	query.cpu_time,
	query.total_intermediate_rows,
	query.total_rows_scanned,
	query.time,
	query.sql,
	system.blocked_thread_time,
	system.peak_buffer_memory,
	system.peak_temp_dir_size,
	system.total_memory_allocated
FROM metrics_output;

