# name: test/sql/pragma/profiling/test_all_profiling_settings.test
# description: Test all settings profiling settings.
# group: [profiling]

require json

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SET profiling_mode='all';

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('tracked_metrics')) ORDER BY ALL;
----
*

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

statement ok
SELECT operator_info[1].extra_info, operator_info[1].intermediate_size_bytes, query.cpu_time,  query.time FROM metrics_output;
