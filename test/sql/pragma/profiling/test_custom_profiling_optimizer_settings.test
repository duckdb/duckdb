# name: test/sql/pragma/profiling/test_custom_profiling_optimizer_settings.test
# description: Test optimizer profiling settings using tracked_metrics.
# group: [profiling]

require json

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SET profiling_mode='standard';

statement ok
SET tracked_metrics = ['optimizer.total_time'];

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('tracked_metrics'));
----
optimizer.total_time

statement ok
SET tracked_metrics = [];

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('tracked_metrics')) ORDER BY ALL;
----

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SET tracked_metrics = ['optimizer.join_order'];

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('tracked_metrics')) ORDER BY ALL;
----
optimizer.join_order

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

query I
SELECT
    CASE WHEN optimizer.join_order > 0 THEN 'true'
     ELSE 'false' END
FROM metrics_output;
----
true

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SET tracked_metrics = ['optimizer.total_time'];

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

query I
SELECT
    CASE WHEN optimizer.total_time > 0 THEN 'true'
    ELSE 'false' END
FROM metrics_output;
----
true

# All phase timings must be collected when all metrics are tracked.
# 'detailed' is a deprecated alias of 'standard'.

statement ok
RESET tracked_metrics;

statement ok
SET profiling_mode = 'detailed';

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('tracked_metrics'));
----
*

statement ok
RESET tracked_metrics;

statement ok
SET profiling_mode = 'standard';

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '{TEST_DIR}/profiling_output.json';

statement ok
SELECT unnest(['Maia', 'Thijs', 'Mark', 'Hannes', 'Tom', 'Max', 'Carlo', 'Sam', 'Tania']) AS names ORDER BY random();

statement ok
PRAGMA disable_profiling;

query I
SELECT unnest(current_setting('tracked_metrics')) ORDER BY ALL;
----
*

statement ok
CREATE OR REPLACE TABLE metrics_output AS SELECT * FROM '{TEST_DIR}/profiling_output.json';

statement ok
SELECT operator[1].extra_info, operator[1].intermediate_size_bytes, query.cpu_time,  query.total_time FROM metrics_output;
