# name: test/sql/tpch/q01_propagate.test_slow
# description: Test statistics propagation in Q01
# group: [tpch]

require tpch

statement ok
CALL dbgen(sf=0.01);

query II
select s.min, s.max from (SELECT stats(1 - l_discount) s FROM lineitem LIMIT 1);
----
0.90	1.00

query II
select s.min, s.max from (SELECT stats(1 + l_tax) s FROM lineitem LIMIT 1);
----
1.00	1.08

query II
select s.min, s.max from (SELECT stats(l_extendedprice * (1 - l_discount)) s FROM lineitem LIMIT 1);
----
813.6000	94949.5000

query II
select s.min, s.max from (SELECT stats(l_extendedprice * (1 - l_discount) * (1 + l_tax)) s FROM lineitem LIMIT 1);
----
813.600000	102545.460000
