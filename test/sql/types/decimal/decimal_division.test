# name: test/sql/types/decimal/decimal_division.test
# description: test decimal division via the / operator
# group: [decimal]

query I
SELECT (10.00 / 4.00)::DECIMAL(10,6);
----
2.500000

# Result scale is max(6, s1 + p2 + 1): with s1=2, p2=3 → max(6, 2+3+1)=6
query I
SELECT (1.00::DECIMAL(3,2) / 3.00::DECIMAL(3,2))::DECIMAL(10,6);
----
0.333333

# Negative dividend
query I
SELECT (-7.00 / 2.00)::DECIMAL(10,6);
----
-3.500000

# Division by a value less than 1
query I
SELECT (1.00 / 0.25)::DECIMAL(10,6);
----
4.000000

# Division by zero raises an error
statement error
SELECT 1.00 / 0.00;
----
decimal_div: division by zero

# Banker's rounded states:
# If last digit is exactly 5 round to the nearest even number
# https://www.personalinvesting.jpmorgan.com/bankers-rounding/
# Banker's rounding, unrounded 0.00006103515625
query I
SELECT 1::decimal(10,2) / 16384::decimal(10,2);
----
0.0000610351562

# Not Banker's rounding, unrounded 0.00018310546875
query I
SELECT 3::decimal(10,2) / 16384::decimal(10,2);
----
0.0001831054687

query I
SELECT 3::decimal(38,2) / 16384::decimal(37,2);
----
0.000183

# INT16 inputs (p≤4) → DECIMAL(10, 7), INT64 result physical type
# p1=4 s1=2 p2=4 s2=1: result_scale=max(6,2+4+1)=7, result_width=4-2+1+7=10
query I
SELECT typeof(12.34::DECIMAL(4,2) / 3.5::DECIMAL(4,1));
----
DECIMAL(10,7)

query I
SELECT 12.34::DECIMAL(4,2) / 3.5::DECIMAL(4,1);
----
3.5257142

# INT32 inputs (p≤9) → DECIMAL(18, 10), INT64 result physical type
# p1=9 s1=3 p2=6 s2=2: result_scale=max(6,3+6+1)=10, result_width=9-3+2+10=18
query I
SELECT typeof(1000.000::DECIMAL(9,3) / 4.00::DECIMAL(6,2));
----
DECIMAL(18,10)

query I
SELECT 1000.000::DECIMAL(9,3) / 4.00::DECIMAL(6,2);
----
250.0000000000

# INT64 inputs (p≤18) → DECIMAL(31, 18), INT128 result physical type
# p1=15 s1=5 p2=12 s2=3: result_scale=max(6,5+12+1)=18, result_width=15-5+3+18=31
query I
SELECT typeof(100000.00000::DECIMAL(15,5) / 8.000::DECIMAL(12,3));
----
DECIMAL(31,18)

query I
SELECT 100000.00000::DECIMAL(15,5) / 8.000::DECIMAL(12,3);
----
12500.000000000000000000

# INT128 inputs (p≤38), width overflows → capped to DECIMAL(38, 13)
# p1=28 s1=8 p2=20 s2=5: raw result_width=54 → capped to 38, result_scale=29-(54-38)=13
query I
SELECT typeof(10000000000.00000000::DECIMAL(28,8) / 4.00000::DECIMAL(20,5));
----
DECIMAL(38,13)

query I
SELECT 10000000000.00000000::DECIMAL(28,8) / 4.00000::DECIMAL(20,5);
----
2500000000.0000000000000