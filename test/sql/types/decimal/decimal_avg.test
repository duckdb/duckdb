# name: test/sql/types/decimal/decimal_avg.test
# description: Test that avg() on decimal inputs returns decimal
# group: [decimal]

# Return type matches input: DECIMAL(p, s)
query I
SELECT typeof(avg(x)) FROM (VALUES (1.5::DECIMAL(18,8))) t(x)
----
DECIMAL(18,8)

query I
SELECT typeof(avg(x)) FROM (VALUES (1.5::DECIMAL(18,2))) t(x)
----
DECIMAL(18,2)

query I
SELECT typeof(avg(x)) FROM (VALUES (1.5::DECIMAL(9,2))) t(x)
----
DECIMAL(9,2)

query I
SELECT typeof(avg(x)) FROM (VALUES (1.5::DECIMAL(4,2))) t(x)
----
DECIMAL(4,2)

query I
SELECT typeof(avg(x)) FROM (VALUES (1.5::DECIMAL(38,2))) t(x)
----
DECIMAL(38,2)

# Correct values
query I
SELECT avg(x) FROM (VALUES (1.00::DECIMAL(18,2)), (2.00::DECIMAL(18,2)), (3.00::DECIMAL(18,2))) t(x)
----
2.00

query I
SELECT avg(x) FROM (VALUES (1.5::DECIMAL(18,2)), (2.5::DECIMAL(18,2))) t(x)
----
2.00

query I
SELECT avg(x) FROM (VALUES (0.1::DECIMAL(9,8)), (0.3::DECIMAL(9,8))) t(x)
----
0.20000000

# NULL input
query I
SELECT avg(x) FROM (VALUES (NULL::DECIMAL(18,2))) t(x)
----
NULL

# Mixed NULLs
query I
SELECT avg(x) FROM (VALUES (2.00::DECIMAL(18,2)), (NULL::DECIMAL(18,2)), (4.00::DECIMAL(18,2))) t(x)
----
3.00

# Negative values
query I
SELECT avg(x) FROM (VALUES (-1.00::DECIMAL(18,2)), (3.00::DECIMAL(18,2))) t(x)
----
1.00

# Group-by preserves decimal return type
query II
SELECT grp, typeof(avg(x)) FROM (VALUES (1, 1.0::DECIMAL(9,2)), (1, 3.0::DECIMAL(9,2)), (2, 5.0::DECIMAL(9,2))) t(grp, x) GROUP BY grp ORDER BY grp
----
1	DECIMAL(9,2)
2	DECIMAL(9,2)

# Group-by correct values
query II
SELECT grp, avg(x) FROM (VALUES (1, 1.0::DECIMAL(9,2)), (1, 3.0::DECIMAL(9,2)), (2, 5.0::DECIMAL(9,2))) t(grp, x) GROUP BY grp ORDER BY grp
----
1	2.00
2	5.00
