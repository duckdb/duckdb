# name: test/sql/types/time/time_parsing.test
# description: Test time parsing
# group: [time]

query I
SELECT '14:42:04'::TIME::VARCHAR
----
14:42:04

# microseconds
query I
SELECT '14:42:04.35'::TIME::VARCHAR
----
14:42:04.35

# we support up until microsecond precision (max 0-999999)
query I
SELECT '14:42:04.999999'::TIME::VARCHAR
----
14:42:04.999999

# nanosecond precision gets truncated
query I
SELECT '14:42:04.999999999'::TIME::VARCHAR
----
14:42:04.999999

# trailing zeros get truncated
query I
SELECT '14:42:04.000000'::TIME::VARCHAR
----
14:42:04

query I
SELECT '14:42:04.500'::TIME::VARCHAR
----
14:42:04.5

# out of range
statement error
SELECT '50:42:04.500'::TIME::VARCHAR
----
<REGEX>:.*Conversion Error.*time field value out of range.*

statement error
SELECT '100:42:04.500'::TIME::VARCHAR
----
<REGEX>:.*Conversion Error.*time field value out of range.*

statement error
SELECT '14:70:04.500'::TIME::VARCHAR
----
<REGEX>:.*Conversion Error.*time field value out of range.*

statement error
SELECT '14:100:04.500'::TIME::VARCHAR
----
<REGEX>:.*Conversion Error.*time field value out of range.*

statement error
SELECT '14:42:70.500'::TIME::VARCHAR
----
<REGEX>:.*Conversion Error.*time field value out of range.*

# invalid separator
statement error
SELECT '14-42-04'::TIME::VARCHAR
----
<REGEX>:.*Conversion Error.*time field value out of range.*

# strict parsing rejects a single-digit minute at the end of the string, instead of looking
# past the end of the buffer for a seconds separator. strict parsing is reached via the VARIANT cast.
statement error
SELECT '1:2'::VARIANT::TIME
----
<REGEX>:.*Conversion Error.*Can't convert VARIANT.*'1:2'.*

statement error
SELECT '123:4'::VARIANT::TIME
----
<REGEX>:.*Conversion Error.*Can't convert VARIANT.*'123:4'.*

statement error
SELECT '12:3'::VARIANT::TIME
----
<REGEX>:.*Conversion Error.*Can't convert VARIANT.*'12:3'.*

# well-formed strict times still parse
query I
SELECT '11:22'::VARIANT::TIME
----
11:22:00

query I
SELECT '11:22:33'::VARIANT::TIME
----
11:22:33