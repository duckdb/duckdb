# name: test/sql/types/bit/bit_issue_22527.test
# description: Issue #22527 - BIT comparisons should use logical bit order
# group: [bit]

query IIIIIIII
SELECT
	'0'::BIT < '10101010'::BIT,
	'0'::BIT > '10101010'::BIT,
	'0'::BIT <= '10101010'::BIT,
	'0'::BIT >= '10101010'::BIT,
	'0'::BIT < '00'::BIT,
	'00'::BIT > '0'::BIT,
	'01'::BIT < '1'::BIT,
	'1'::BIT > '01'::BIT;
----
true	false	true	false	true	true	true	true

statement ok
CREATE TABLE bit_comparison_values(v BIT);

statement ok
INSERT INTO bit_comparison_values VALUES ('0'), ('10101010'), ('00'), ('01'), ('1');

query I
SELECT v::VARCHAR FROM bit_comparison_values ORDER BY v;
----
0
00
01
1
10101010

query I
SELECT v::VARCHAR FROM bit_comparison_values WHERE v < '10101010'::BIT ORDER BY v;
----
0
00
01
1

query II
SELECT min(v)::VARCHAR, max(v)::VARCHAR FROM bit_comparison_values;
----
0	10101010

statement ok
CREATE TABLE bit_zonemap_values(v BIT);

statement ok
INSERT INTO bit_zonemap_values VALUES ('11111111'), ('0');

query I
SELECT v::VARCHAR FROM bit_zonemap_values WHERE v < '10101010'::BIT ORDER BY v;
----
0

query I
SELECT v::VARCHAR FROM bit_zonemap_values WHERE v > '10101010'::BIT ORDER BY v;
----
11111111
