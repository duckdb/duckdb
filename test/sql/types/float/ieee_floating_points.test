# name: test/sql/types/float/ieee_floating_points.test
# description: Test usage of the INF value
# group: [float]

statement ok
PRAGMA enable_verification

foreach type FLOAT DOUBLE

statement ok
CREATE OR REPLACE TABLE tbl(val {type})

statement ok
INSERT INTO tbl VALUES (1), (-1), (0), ('nan'), ('inf')

# division by zero
query II
SELECT val, val / 0::{type} FROM tbl
----
1.0	inf
-1.0	-inf
0.0	nan
nan	nan
inf	inf

# modulo by zero
query II
SELECT val, val % 0::{type} FROM tbl
----
1.0	nan
-1.0	nan
0.0	nan
nan	nan
inf	nan

statement ok
SET ieee_floating_point_ops = false;

# division by zero
query II
SELECT val, val / 0::{type} FROM tbl
----
1.0	NULL
-1.0	NULL
0.0	NULL
nan	NULL
inf	NULL

# modulo by zero
query II
SELECT val, val % 0::{type} FROM tbl
----
1.0	NULL
-1.0	NULL
0.0	NULL
nan	NULL
inf	NULL

# math domain cases still error when IEEE behavior is disabled
statement ok
SET ieee_floating_point_ops = false;

statement error
SELECT sqrt(-1::{type});
----

statement error
SELECT ln(-1::{type});
----

statement error
SELECT asin(2::{type});
----

statement error
SELECT acos(2::{type});
----

statement error
SELECT atanh(2::{type});
----

statement ok
SET ieee_floating_point_ops = true;

query IIII
SELECT sqrt(-1::{type}), ln(-1::{type}), log10(-1::{type}), log2(-1::{type});
----
nan	nan	nan	nan

query IIII
SELECT ln(0::{type}), log10(0::{type}), log2(0::{type}), log(1::{type}, 64::{type});
----
-inf	-inf	-inf	inf

query IIIII
SELECT asin(2::{type}), acos(2::{type}), atanh(2::{type}), atanh(1::{type}), atanh(-1::{type});
----
nan	nan	nan	inf	-inf

endloop
