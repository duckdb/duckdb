# name: test/sql/types/variant/variant_casts.test
# group: [variant]

# test casts to / from variant

statement ok
CREATE TABLE struct AS SELECT {'a': 42, 'b': 84} s

query I
select s::VARIANT FROM struct
----
{'a': 42, 'b': 84}

query I
select (s::VARIANT).a FROM struct
----
42

query I
select (s::VARIANT).a::BIGINT FROM struct
----
42

query I
select [1, 2, 3, 4]::VARIANT
----
[1, 2, 3, 4]
