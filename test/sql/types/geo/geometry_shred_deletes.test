# name: test/sql/types/geo/geometry_shred_deletes.test
# group: [geo]

statement ok
SET geometry_minimum_shredding_size = 0;

statement ok
ATTACH '__TEST_DIR__/geo.db' AS g (STORAGE_VERSION 'v1.5.0');

statement ok
USE g;

statement ok
CREATE TABLE t1(geom GEOMETRY);

statement ok
INSERT INTO t1 SELECT 'POINT(1 2)'::GEOMETRY FROM range(3);

statement ok
CHECKPOINT g;

statement ok
USE memory;

statement ok
DETACH g;

statement ok
ATTACH '__TEST_DIR__/geo.db' AS g;

statement ok
USE g;

statement ok
DELETE FROM t1 WHERE rowid = 0;

statement ok
CHECKPOINT g;
