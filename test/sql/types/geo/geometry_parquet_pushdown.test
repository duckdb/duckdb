# name: test/sql/types/geo/geometry_parquet_pushdown.test
# group: [geo]

require parquet

require json

statement ok
COPY (
	select
		(x + y) as id,
		printf('POINT(%d %d)', x, y)::GEOMETRY('OGC:CRS84') as g
	from range(100) xx(x), range(100) yy(y)
) TO '__TEST_DIR__/points.parquet' (FORMAT 'parquet', GEOPARQUET_VERSION 'V2', ROW_GROUP_SIZE 1000);

statement ok
CALL enable_profiling(
	format := 'json',
	save_location := '__TEST_DIR__/output.json',
	metrics := [ 'OPERATOR_ROW_GROUPS_SCANNED', 'OPERATOR_TOTAL_ROW_GROUPS_TO_SCAN']
);

statement ok
select * from '__TEST_DIR__/points.parquet' where g && 'POLYGON((10 10, 20 10, 20 20, 10 20, 10 10))'::GEOMETRY;

statement ok
PRAGMA disable_profiling;


statement ok
CREATE VIEW operator_metrics AS WITH RECURSIVE ops AS (
    SELECT unnest(children) AS op FROM '__TEST_DIR__/output.json'
    UNION ALL
    SELECT unnest(op.children) FROM ops WHERE len(op.children) > 0
)
SELECT
	op.operator_name as name,
 	op.operator_row_groups_scanned AS scanned,
 	op.operator_total_row_groups_to_scan AS total
FROM ops;

query III
SELECT * FROM operator_metrics WHERE name = 'PARQUET_SCAN' ORDER BY total;
----
PARQUET_SCAN	2	10
