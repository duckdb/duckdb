# name: test/sql/peg_parser/set_variable.test
# description: Test expression statement
# group: [peg_parser]

require autocomplete

statement ok 
call enable_peg_parser(); 

statement ok
x := 5; 

query I 
select getvariable('x'); 
----
5

statement error
x := 5,5,5
----
Parser Error: Syntax error at or near ","

# You can override variables
statement ok
x := 6

query I 
select getvariable('x'); 
----
6
