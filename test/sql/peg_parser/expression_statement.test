# name: test/sql/peg_parser/expression_statement.test
# description: Test expression statement
# group: [peg_parser]

require autocomplete

statement ok 
call enable_peg_parser();

query I
1 + 1; 
----
2

query I
[1,2,3][1];
----
1

statement ok 
CREATE TABLE foo (i integer); 

statement ok 
INSERT INTO foo values (1), (2), (3);

query I
foo; 
----
1
2
3

query I
('hello world').replace(' ', '_');
----
hello_world

# Aliases also work
statement ok 
bar: 1 + 1

# Multiple epressions
query III
foo: 1 + 1, bar: ('hello world').replace(' ', '_'), [1,2,3][1] as list_element;
----
2	hello_world	1

# Don't allow implicit aliases to avoid confusion, see next test case 
statement error
1 + 1 foo
----
Parser Error: Syntax error at or near "foo"

statement error
selec 42
----
Parser Error: Syntax error at or near "42"

statement error
SEL 
----
Catalog Error: Table with name SEL does not exist!
