# name: test/sql/peg_parser/fuzzer/internal_0227.test
# description: ADD COLUMN with no type (PEG) should give clean error; nested ADD FIELD on missing parent should give clean binder error
# group: [fuzzer]

statement ok
create table mytbl(i bigint);

statement error
ALTER TABLE mytbl ADD IF NOT EXISTS result . v bigint;
----
Binder Error: Table "mytbl" does not have a column with name "result"

