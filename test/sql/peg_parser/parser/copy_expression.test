# name: test/sql/peg_parser/parser/copy_expression.test
# description: Test copy expression syntax in peg parser
# group: [parser]

require autocomplete

statement ok
CALL check_peg_parser($TEST_PEG_PARSER$COPY (SELECT * FROM foo) TO ('foo') WITH (HEADER)$TEST_PEG_PARSER$);

statement ok
CALL check_peg_parser($TEST_PEG_PARSER$COPY (SELECT * FROM range(5) t(i)) TO (getvariable('copy_target')) WITH (HEADER)$TEST_PEG_PARSER$);

# order by specifications in copy options
statement ok
CALL check_peg_parser($TEST_PEG_PARSER$COPY t TO 'x.parquet' (FORMAT parquet, PARTITION_BY (p1, p2), ORDER_BY (a ASC NULLS FIRST, b DESC NULLS LAST, c ASCENDING NULLS LAST, d DESCENDING NULLS FIRST, e NULLS FIRST))$TEST_PEG_PARSER$);

statement ok
CALL check_peg_parser($TEST_PEG_PARSER$COPY t TO 'x.parquet' (FORMAT parquet, ORDER_BY (a DESC, b ASC))$TEST_PEG_PARSER$);

statement ok
CALL check_peg_parser($TEST_PEG_PARSER$COPY t TO 'x.parquet' (FORMAT parquet, ORDER_BY (a, b))$TEST_PEG_PARSER$);
