# name: test/sql/timezone/test_icu_casts.test
# description: Test the ICU cast functions
# group: [timezone]

require icu

statement ok
SET Calendar = 'gregorian';

statement ok
SET TimeZone = 'America/Los_Angeles';

# Test casting to naïve values
statement ok
CREATE TABLE tstzs AS 
	FROM VALUES ('2026-04-09 11:48:07.123456-07'::TIMESTAMPTZ) tbl(t);

query I
select t::TIMESTAMP_NS from tstzs;
----
2026-04-09 11:48:07.123456

query I
select t::TIMESTAMP from tstzs;
----
2026-04-09 11:48:07.123456

query I
select t::TIMESTAMP_MS from tstzs;
----
2026-04-09 11:48:07.123

query I
select t::TIMESTAMP_S from tstzs;
----
2026-04-09 11:48:07

query I
select t::DATE from tstzs;
----
2026-04-09
