# name: test/sql/aggregate/distinct/issue21002.test_slow
# description: Issue #21002: Out Of Memory Error for "select distinct .. limit"
# group: [distinct]

require noforcestorage

statement ok
PRAGMA memory_limit='1GB'

statement ok
CREATE TABLE abc AS SELECT md5(random()::VARCHAR) AS n FROM range(100000000)

query I
SELECT COUNT(*) FROM (SELECT DISTINCT n FROM abc LIMIT 10)
----
10
