# name: test/sql/aggregate/aggregate_state_export/min_max_string_state_no_destructor.test
# description: Importing/finalizing/combining string min/max states must be rejected (self-owning state with custom destructor)
# group: [aggregate_state_export]

# min over VARCHAR uses a state with a custom destructor (delete[] on a heap string).
# Importing such a state via to_aggregate_state would let combine free arena-owned memory -> heap corruption.
# The binder must reject it, mirroring the EXPORT_STATE restriction.

statement error
SELECT to_aggregate_state({'value':'abc','isset':true}, 'min', ['VARCHAR']);
----
custom destructor

statement error
SELECT to_aggregate_state({'value':'abc','isset':true}, 'max', ['VARCHAR']);
----
custom destructor

# the original crashing roundtrip must also error rather than abort
statement error
SELECT finalize(combine(
  to_aggregate_state({'value':'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa','isset':true}, 'min', ['VARCHAR']),
  to_aggregate_state({'value':'zzzzzzzzzzzzz','isset':true}, 'min', ['VARCHAR'])
));
----
custom destructor

# numeric min/max states have no custom destructor and must still roundtrip
statement ok
CREATE TABLE integers AS SELECT * FROM (VALUES (1), (5), (3)) t(i);

query I
SELECT finalize(min(i) EXPORT_STATE) FROM integers;
----
1

query I
SELECT finalize(max(i) EXPORT_STATE) FROM integers;
----
5

# combining two numeric min states still works
query I
SELECT finalize(combine(min(i) EXPORT_STATE, min(i + 10) EXPORT_STATE)) FROM integers;
----
1
