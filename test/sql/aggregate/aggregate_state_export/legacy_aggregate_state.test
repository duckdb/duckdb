# name: test/sql/aggregate/aggregate_state_export/legacy_aggregate_state.test
# description: Test legacy aggregate state
# group: [aggregate_state_export]

# The database is written with a vector size of 2048.
statement skip_test_on_error
SELECT assert_true(current_setting('standard_vector_size')::INT >= 2048, 'requires vector_size>=2048')

unzip data/storage/legacy_aggregate_state.db.gz {TEST_DIR}/legacy_aggregate_state.db

statement ok
ATTACH '{TEST_DIR}/legacy_aggregate_state.db' AS legacy

query I
FROM legacy.t
