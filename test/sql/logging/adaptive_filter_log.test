# name: test/sql/logging/adaptive_filter_log.test
# description: AdaptiveFilter log type emits INIT + REORDER events from parquet scans
# group: [logging]

require parquet

statement ok
COPY (SELECT i AS a, i%10 AS b, i%100 AS c FROM range(100000) t(i)) TO '{TEST_DIR}/af.parquet'

statement ok
CALL enable_logging('AdaptiveFilter')

statement ok
SELECT count(*) FROM read_parquet('{TEST_DIR}/af.parquet') WHERE a > 100 AND b > 3 AND c < 50

query II
SELECT type, log_level FROM duckdb_logs WHERE type = 'AdaptiveFilter' LIMIT 1
----
AdaptiveFilter	DEBUG

query I
SELECT count(*) > 0 FROM duckdb_logs_parsed('AdaptiveFilter') WHERE event = 'INIT'
----
true

query I
SELECT file_path LIKE '%af.parquet' FROM duckdb_logs_parsed('AdaptiveFilter') WHERE event = 'INIT' LIMIT 1
----
true

query I
SELECT regexp_matches(permutation, '^\[\d+, \d+, \d+\]$') FROM duckdb_logs_parsed('AdaptiveFilter') WHERE event = 'INIT' LIMIT 1
----
true

query I
SELECT count(*) > 0 FROM duckdb_logs_parsed('AdaptiveFilter') WHERE event = 'REORDER'
----
true

query I
SELECT info['action'] IN ('kept', 'reverted') FROM duckdb_logs_parsed('AdaptiveFilter') WHERE event = 'REORDER' LIMIT 1
----
true

# Every REORDER event exposes both timing fields
query I
SELECT count(*) FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'REORDER' AND (info['prev_mean_us'] IS NULL OR info['trial_mean_us'] IS NULL)
----
0

# Both timing fields parse as positive doubles
query I
SELECT count(*) FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'REORDER'
  AND NOT (info['prev_mean_us']::DOUBLE > 0 AND info['trial_mean_us']::DOUBLE > 0)
----
0

# 'kept' means the trial order was strictly faster
query I
SELECT count(*) FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'REORDER' AND info['action'] = 'kept'
  AND info['trial_mean_us']::DOUBLE >= info['prev_mean_us']::DOUBLE
----
0

# 'reverted' means the trial order was not strictly faster
query I
SELECT count(*) FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'REORDER' AND info['action'] = 'reverted'
  AND info['trial_mean_us']::DOUBLE < info['prev_mean_us']::DOUBLE
----
0

# Native DuckDB table scans also emit AdaptiveFilter logs (file_path is empty)
statement ok
CALL truncate_duckdb_logs()

statement ok
CREATE TABLE native_t AS SELECT i AS a, i%10 AS b, i%100 AS c FROM range(100000) t(i)

statement ok
SELECT count(*) FROM native_t WHERE a > 100 AND b > 3 AND c < 50

query I
SELECT count(*) > 0 FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND (file_path IS NULL OR file_path = '')
----
true

# Conjunction-expression path (column-vs-column predicate that can't push as a TableFilter)
statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*) FROM native_t WHERE a > b AND c > b AND c < b + 90

query I
SELECT count(*) > 0 FROM duckdb_logs_parsed('AdaptiveFilter') WHERE event = 'INIT'
----
true

