# name: test/sql/secrets/create_secret_oss.test
# description: Test secret creation using the default oss secret provider
# group: [secrets]

statement ok
PRAGMA enable_verification;

require httpfs

# Ensure any currently stored secrets don't interfere with the test
statement ok
set allow_persistent_secrets=false;

statement ok
reset s3_use_ssl;

# OSS Secrets will construct the endpoint with S3 virtual hosted style
statement ok
CREATE SECRET (
    TYPE OSS,
    KEY_ID 'my_key',
    SECRET 'my_secret',
    ENDPOINT 's3.oss-some-bogus-region.aliyuncs.com'
)

# The secret will be created for the default scope
query IIII
SELECT name, type, provider, scope FROM duckdb_secrets();
----
__default_oss	oss	config	[oss://]

statement error
FROM 'oss://test-bucket/test.csv'
----
https://test-bucket.s3.oss-some-bogus-region.aliyuncs.com/test.csv
