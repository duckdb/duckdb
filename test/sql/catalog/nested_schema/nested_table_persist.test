# name: test/sql/catalog/nested_schema/nested_table_persist.test
# description: Persisting tables in nested schemas (checkpoint + WAL) on storage v2.0.0
# group: [nested_schema]

load {TEST_DIR}/nested_table_persist.db readwrite v2.0.0

statement ok
CREATE SCHEMA parent;

statement ok
CREATE SCHEMA parent.child;

statement ok
CREATE TABLE parent.child.t1(i INTEGER);

statement ok
CREATE TABLE parent.child.t2(j INTEGER);

# checkpoint so the tables go through storage serialization (not just the WAL)
statement ok
CHECKPOINT;

restart

query III
SELECT database_name, schema_name, table_name FROM duckdb_tables()
WHERE table_name IN ('t1','t2') ORDER BY table_name;
----
nested_table_persist	child	t1
nested_table_persist	child	t2

# create another nested table and DO NOT checkpoint - exercise the WAL replay path
statement ok
CREATE TABLE parent.child.wal_table(k INTEGER);

# drop one of the checkpointed tables (also WAL-only)
statement ok
DROP TABLE parent.child.t1;

restart

query I
SELECT table_name FROM duckdb_tables()
WHERE table_name IN ('t1','t2','wal_table') ORDER BY table_name;
----
t2
wal_table

# cascade-dropping the parent schema removes the nested schema + all its tables; replay via the WAL
statement ok
DROP SCHEMA parent CASCADE;

restart

query I
SELECT count(*) FROM duckdb_tables() WHERE table_name IN ('t2','wal_table');
----
0

query I
SELECT count(*) FROM duckdb_schemas() WHERE schema_name IN ('parent','child');
----
0

# and once more, but with a checkpoint after the cascade drop
statement ok
CREATE SCHEMA p2

statement ok
CREATE SCHEMA p2.c2

statement ok
CREATE TABLE p2.c2.tbl(i INTEGER)

statement ok
DROP SCHEMA p2 CASCADE

statement ok
CHECKPOINT

restart

query I
SELECT count(*) FROM duckdb_tables() WHERE table_name = 'tbl';
----
0
