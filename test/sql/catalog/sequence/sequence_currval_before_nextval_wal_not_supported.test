# name: test/sql/catalog/sequence/sequence_currval_before_nextval_wal_not_supported.test
# group: [sequence]

statement ok
SET storage_compatibility_version = 'v1.4.4';

load {TEST_DIR}/wal_replay.db

statement ok
PRAGMA disable_checkpoint_on_shutdown

statement ok
PRAGMA wal_autocheckpoint='1TB';

statement ok
CREATE SEQUENCE IF NOT EXISTS scenario_id START 1 INCREMENT BY 1;

statement error
SELECT currval('scenario_id');
----
Sequence Error: currval: sequence is not yet defined in this session

query I
SELECT nextval('scenario_id');
----
1

query I
SELECT nextval('scenario_id');
----
2

restart

statement error
SELECT currval('scenario_id');
----
Sequence Error: currval: sequence is not yet defined in this session

# but the sequence counter should have been restored
query I
SELECT nextval('scenario_id');
----
3

query I
SELECT currval('scenario_id');
----
3