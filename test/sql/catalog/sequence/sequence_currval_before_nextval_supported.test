# name: test/sql/catalog/sequence/sequence_currval_before_nextval_supported.test
# group: [sequence]

statement ok
SET storage_compatibility_version = 'v1.5.0';

load {TEST_DIR}/mydb.db

statement ok
CREATE SEQUENCE IF NOT EXISTS scenario_id START 1 INCREMENT BY 1;

statement error
SELECT currval('scenario_id');
----
Sequence Error: currval: sequence is not yet defined in this session

query I
SELECT nextval('scenario_id');
----
1

query I
SELECT nextval('scenario_id');
----
2

statement ok
checkpoint;

restart

# currval survives restart
query I
SELECT currval('scenario_id');
----
2

query I
SELECT nextval('scenario_id');
----
3

query I
SELECT currval('scenario_id');
----
3
