# name: test/sql/copy/csv/test_11403.test
# description: Test CSV Sniffing detects correct quote for issue 11403
# group: [csv]

# requires notwindows for windows-style path backslash reasons
statement skip_test_on_error
SELECT assert_true(platform NOT LIKE 'windows_%', 'requires a non-windows platform') FROM pragma_platform()

query I
SELECT COUNT(*) FROM '{DATA_DIR}/csv/quoted_newline.csv'
----
1

query I
SELECT quote FROM sniff_csv('{DATA_DIR}/csv/quoted_newline.csv')
----
"