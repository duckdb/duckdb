# name: test/sql/copy/csv/read_ahead/csv_readahead_single_file.test
# description: A single CSV file split into many boundary claims through the read-ahead queue
# group: [read_ahead]

statement ok
SET threads=8

statement ok
COPY (SELECT range AS i FROM range(0, 500000)) TO '{TEST_DIR}/csv_ra_single.csv' (FORMAT csv)

# a small buffer size yields many claims whose buffer loads overlap through the straddle buffer
foreach depth -1 1

statement ok
SET read_ahead_depth={depth}

loop x 0 3

query II
SELECT count(*), sum(i) FROM read_csv('{TEST_DIR}/csv_ra_single.csv', buffer_size=65536)
----
500000	124999750000

query I
SELECT count(*) FROM (
    SELECT i, row_number() OVER () AS rn
    FROM read_csv('{TEST_DIR}/csv_ra_single.csv', buffer_size=65536)
) WHERE i + 1 <> rn
----
0

endloop

endloop
