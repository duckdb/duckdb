# name: test/sql/copy/csv/overwrite/test_overwrite_pipe_windows.test
# description: Test overwrite to pipe on windows systems
# group: [overwrite]

statement skip_test_on_error
SELECT assert_true(platform LIKE 'windows_%', 'requires a windows platform') FROM pragma_platform()

statement skip_test_on_error
SELECT assert_true(platform NOT LIKE '%_mingw', 'requires a non-mingw platform') FROM pragma_platform()

# Write to pipe - should pass since .tmp is not added when writing to a pipe
statement ok
copy (select 42) to 'con:'
