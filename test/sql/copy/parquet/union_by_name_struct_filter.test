# name: test/sql/copy/parquet/union_by_name_struct_filter.test
# description: Test union by name with filter pushdown of struct filter with missing structs
# group: [parquet]

require parquet

statement ok
COPY (SELECT {'a': 1, 'b': 2}::STRUCT(a INT, b INT) AS s, 1 AS id) TO '{TEST_DIR}/f1.parquet'

statement ok
COPY (SELECT 2 AS id) TO '{TEST_DIR}/f2.parquet'

query II
SELECT * FROM read_parquet(['{TEST_DIR}/f1.parquet', '{TEST_DIR}/f2.parquet'], union_by_name=true) WHERE s.a = 1
----
{'a': 1, 'b': 2}	1

