# name: test/sql/copy/parquet/parquet_bloom_filter_corruption.test
# description: Test reading a Parquet file with a corrupted bloom filter payload length
# group: [parquet]

require parquet

query I
SELECT count(*) FROM read_parquet('{DATA_DIR}/parquet-testing/bloom_filter_bad_numbytes.parquet')
----
100000

query I
SELECT count(*) FROM read_parquet('{DATA_DIR}/parquet-testing/bloom_filter_bad_numbytes.parquet') WHERE r = 0
----
1000
