# name: test/sql/copy/parquet/parquet_row_group_outcome.test
# description: ParquetPrefetch logs whether each row group was fully filtered out
# group: [parquet]

require parquet

statement ok
SET threads=1

statement ok
SET prefetch_all_parquet_files=true

statement ok
COPY (
    SELECT i AS a,
        i + 10 AS b,
        CASE
            WHEN i % 100 = 50 THEN 51
            ELSE i % 100
        END AS c,
        CASE
            WHEN i < 6144 AND i % 1000 = 500 THEN 501
            ELSE i % 1000
        END AS g
    FROM RANGE(12288) t(i)
) TO '{TEST_DIR}/rgo.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER FALSE)

statement ok
CALL enable_logging('ParquetPrefetch')

statement ok
SELECT sum(a + b + c + g)
FROM read_parquet('{TEST_DIR}/rgo.parquet')
WHERE a > 5 AND b > 15

query ITTT
SELECT row_group_id, fully_filtered, strategy, prefetch_groups
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo.parquet'
ORDER BY row_group_id
----
0	false	prefetch_filters	[[a, b], [c, g]]
1	false	whole_group	[[a, b, c, g]]
2	false	whole_group	[[a, b, c, g]]
3	false	whole_group	[[a, b, c, g]]
4	false	whole_group	[[a, b, c, g]]
5	false	whole_group	[[a, b, c, g]]

statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT sum(a + b + c + g)
FROM read_parquet('{TEST_DIR}/rgo.parquet')
WHERE c = 50

query ITTT
SELECT row_group_id, fully_filtered, strategy, prefetch_groups
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo.parquet'
ORDER BY row_group_id
----
0	true	prefetch_filters	[[c], [a, b, g]]
1	true	prefetch_filters	[[c], [a, b, g]]
2	true	prefetch_filters	[[c], [a, b, g]]
3	true	prefetch_filters	[[c], [a, b, g]]
4	true	prefetch_filters	[[c], [a, b, g]]
5	true	prefetch_filters	[[c], [a, b, g]]

statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT sum(a + b + c + g)
FROM read_parquet('{TEST_DIR}/rgo.parquet')
WHERE g = 500

query ITTT
SELECT row_group_id, fully_filtered, strategy, prefetch_groups
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo.parquet'
ORDER BY row_group_id
----
0	true	prefetch_filters	[[g], [a, b, c]]
1	true	prefetch_filters	[[g], [a, b, c]]
2	true	prefetch_filters	[[g], [a, b, c]]
3	false	prefetch_filters	[[g], [a, b, c]]
4	false	prefetch_filters	[[g], [a, b, c]]
5	false	prefetch_filters	[[g], [a, b, c]]

statement ok
CALL truncate_duckdb_logs()

# Three filter columns where (a, c) together fully eliminate every row group
statement ok
SELECT sum(a + b + c + g)
FROM read_parquet('{TEST_DIR}/rgo.parquet')
WHERE a > 100 AND b > 5 AND c = 50

query ITTT
SELECT row_group_id, fully_filtered, strategy, prefetch_groups
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo.parquet'
ORDER BY row_group_id
----
0	true	prefetch_filters	[[a, c], [b, g]]
1	true	prefetch_filters	[[a, c], [b, g]]
2	true	prefetch_filters	[[a, c], [b, g]]
3	true	prefetch_filters	[[a, c], [b, g]]
4	true	prefetch_filters	[[a, c], [b, g]]
5	true	prefetch_filters	[[a, c], [b, g]]

statement ok
CALL truncate_duckdb_logs()

# groups 0-2 have matches, groups 3-5 are fully filtered
statement ok
COPY (
    SELECT i AS a,
        i + 10 AS b,
        CASE
            WHEN i % 100 = 50 THEN 51
            ELSE i % 100
        END AS c,
        CASE
            WHEN i >= 6144 AND i % 1000 = 500 THEN 501
            ELSE i % 1000
        END AS g
    FROM RANGE(12288) t(i)
) TO '{TEST_DIR}/rgo2.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER FALSE)

statement ok
SELECT sum(a + b + c + g)
FROM read_parquet('{TEST_DIR}/rgo2.parquet')
WHERE g = 500

query ITTT
SELECT row_group_id, fully_filtered, strategy, prefetch_groups
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo2.parquet'
ORDER BY row_group_id
----
0	false	prefetch_filters	[[g], [a, b, c]]
1	false	whole_group	[[a, b, c, g]]
2	false	whole_group	[[a, b, c, g]]
3	true	whole_group	[[a, b, c, g]]
4	true	prefetch_filters	[[g], [a, b, c]]
5	true	prefetch_filters	[[g], [a, b, c]]

statement ok
CALL truncate_duckdb_logs()

# Test the 90% threshold to go back at whole_group
statement ok
COPY (
    SELECT i AS a,
        i + 10 AS b,
        CASE
            WHEN i % 100 = 50 THEN 51
            ELSE i % 100
        END AS c,
        CASE
            WHEN i < 2048 AND i % 1000 = 500 THEN 501
            ELSE i % 1000
        END AS g
    FROM RANGE(24576) t(i)
) TO '{TEST_DIR}/rgo3.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER FALSE)

statement ok
SELECT sum(a + b + c + g)
FROM read_parquet('{TEST_DIR}/rgo3.parquet')
WHERE g = 500

query ITTT
SELECT row_group_id, fully_filtered, strategy, prefetch_groups
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo3.parquet'
ORDER BY row_group_id
----
0	true	prefetch_filters	[[g], [a, b, c]]
1	false	prefetch_filters	[[g], [a, b, c]]
2	false	prefetch_filters	[[g], [a, b, c]]
3	false	prefetch_filters	[[g], [a, b, c]]
4	false	prefetch_filters	[[g], [a, b, c]]
5	false	prefetch_filters	[[g], [a, b, c]]
6	false	prefetch_filters	[[g], [a, b, c]]
7	false	prefetch_filters	[[g], [a, b, c]]
8	false	prefetch_filters	[[g], [a, b, c]]
9	false	prefetch_filters	[[g], [a, b, c]]
10	false	prefetch_filters	[[g], [a, b, c]]
11	false	whole_group	[[a, b, c, g]]
