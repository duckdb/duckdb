# name: test/sql/copy/parquet/parquet_row_group_outcome.test
# description: ParquetPrefetch logs whether each row group was fully filtered out
# group: [parquet]

require parquet

statement ok
SET threads=1

statement ok
SET prefetch_all_parquet_files=true

statement ok
COPY (
    SELECT i AS a,
        i + 10 AS b,
        CASE
            WHEN i % 100 = 50 THEN 51
            ELSE i % 100
        END AS c
    FROM RANGE(6144) t(i)
) TO '{TEST_DIR}/rgo.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER FALSE)

statement ok
CALL enable_logging('ParquetPrefetch')

statement ok
SELECT count(*)
FROM read_parquet('{TEST_DIR}/rgo.parquet')
WHERE a > 5
    AND b > 15

query IT
SELECT row_group_id, fully_filtered
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo.parquet'
ORDER BY row_group_id
----
0	false
1	false
2	false

statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*)
FROM read_parquet('{TEST_DIR}/rgo.parquet')
WHERE c = 50

query IT
SELECT row_group_id, fully_filtered
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%rgo.parquet'
ORDER BY row_group_id
----
0	true
1	true
2	true
