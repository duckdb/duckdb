# name: test/sql/copy/parquet/read_ahead/readahead_limit_slot_leak_hang.test
# description: Early LIMIT exit must release the read-ahead job, else the remaining threads spin forever
# group: [read_ahead]

require parquet

statement ok
SET threads=4

statement ok
SET read_ahead_depth=1

statement ok
COPY (SELECT range AS i FROM range(120000)) TO '{TEST_DIR}/limit_slot_leak.parquet' (FORMAT parquet, ROW_GROUP_SIZE 2048)

loop x 0 5

query I
SELECT count(*) FROM (SELECT i FROM '{TEST_DIR}/limit_slot_leak.parquet' WHERE i >= 10 LIMIT 5)
----
5

endloop
