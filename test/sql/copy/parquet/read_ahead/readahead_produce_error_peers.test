# name: test/sql/copy/parquet/read_ahead/readahead_produce_error_peers.test
# description: A producer-side error (OOM during ScheduleIO) must reach peer threads spinning on the queue
# group: [read_ahead]

require parquet

statement ok
SET threads=4

statement ok
SET read_ahead_depth=8

loop i 0 8

statement ok
COPY (SELECT range AS i, md5(range::VARCHAR) AS s FROM range(50000)) TO '{TEST_DIR}/pe_{i}.parquet' (FORMAT parquet, ROW_GROUP_SIZE 100000)

endloop

statement ok
SET memory_limit='4MB'

loop x 0 15

statement maybe
SELECT max(s) FROM '{TEST_DIR}/pe_*.parquet'
----
Out of Memory Error

endloop
