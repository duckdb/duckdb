# name: test/sql/copy/parquet/read_ahead/readahead_error_inflight_io.test
# description: An error in one prefetch task must not tear down jobs whose I/O is still in flight
# group: [read_ahead]

require parquet

statement ok
SET threads=2

statement ok
SET read_ahead_depth=8

loop i 0 8

statement ok
COPY (SELECT range AS i, md5(range::VARCHAR) AS s FROM range(50000)) TO '{TEST_DIR}/err_io_{i}.parquet' (FORMAT parquet, ROW_GROUP_SIZE 100000)

endloop

# pinning 8 prefetched row groups exceeds the memory limit, so a detached I/O task raises an
# out-of-memory error
statement ok
SET memory_limit='4MB'

loop x 0 15

statement maybe
SELECT max(s) FROM '{TEST_DIR}/err_io_*.parquet'
----
Out of Memory Error

endloop
