require parquet

statement ok
COPY (SELECT 42 i) to '{TEST_DIR}/parquet_debug_use_openssl.parquet' (DEBUG_USE_OPENSSL true)

query I
SELECT * FROM read_parquet('{TEST_DIR}/parquet_debug_use_openssl.parquet', debug_use_openssl=false)
----
42
