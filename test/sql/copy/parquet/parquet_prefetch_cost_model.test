# name: test/sql/copy/parquet/parquet_prefetch_cost_model.test
# description: Check the Parquet prefetch gap for local files: default until measured, adjusted from disk reads, and the pin setting
# group: [parquet]

require parquet

statement ok
SET threads=1

statement ok
COPY (
    SELECT CASE WHEN i % 7 = 0 THEN NULL ELSE i END AS a,
        i + 1 AS b,
        CASE WHEN i % 11 = 0 THEN NULL ELSE i + 2 END AS c,
        hash(i)::VARCHAR AS d,
        hash(i + 1)::VARCHAR AS e,
        hash(i + 2)::VARCHAR AS f,
        hash(i + 3)::VARCHAR AS g,
        hash(i + 4)::VARCHAR AS h,
        hash(i + 5)::VARCHAR AS ii,
        i + 9 AS j
    FROM RANGE(8192) t(i)
) TO '{TEST_DIR}/cost_model_gap.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER FALSE)

statement ok
CALL enable_logging('ParquetPrefetch')

query I
SELECT sum(b + j) FROM read_parquet('{TEST_DIR}/cost_model_gap.parquet') WHERE a >= 0 AND c >= 0
----
52350266

# Every read of this file is below the bandwidth sample floor, so the gap stays at the default
query I
SELECT DISTINCT accepted_column_gap
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%cost_model_gap.parquet'
----
16384

statement ok
CALL truncate_duckdb_logs()

statement ok
COPY (SELECT hash(range) AS c0, hash(range + 1) AS c1 FROM range(2000000))
TO '{TEST_DIR}/cost_model_big.parquet' (ROW_GROUP_SIZE 500000)

query I
SELECT count(*) FROM read_parquet('{TEST_DIR}/cost_model_big.parquet') WHERE c0 > 42
----
1999999

# The first row group still uses the default, no reads of this handle have been measured yet
query I
SELECT accepted_column_gap
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%cost_model_big.parquet' AND row_group_id = 0
----
16384

# Row group sized reads measure disk latency and bandwidth, later groups adjust the gap upward
query I
SELECT count(*)
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%cost_model_big.parquet' AND row_group_id > 0 AND accepted_column_gap <= 16384
----
0

# The adjusted values stay within the [GAP_MIN, GAP_MAX] clamp
query I
SELECT count(*)
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%cost_model_big.parquet' AND (accepted_column_gap < 4096 OR accepted_column_gap > 33554432)
----
0

statement ok
CALL truncate_duckdb_logs()

# Pinning the gap takes precedence over the cost model for every row group
statement ok
SET parquet_prefetch_column_gap=4096

query I
SELECT count(*) FROM read_parquet('{TEST_DIR}/cost_model_big.parquet') WHERE c0 > 42
----
1999999

query I
SELECT DISTINCT accepted_column_gap
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%cost_model_big.parquet'
----
4096

statement ok
SET parquet_prefetch_column_gap=0
