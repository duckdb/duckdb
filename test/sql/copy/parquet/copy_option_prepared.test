# name: test/sql/copy/parquet/copy_option_prepared.test
# group: [parquet]

require parquet

statement ok
PREPARE statement as COPY (
	SELECT
		42 AS number,
		true AS is_even
) TO '{TEST_DIR}/prepared_parquet_copy.parquet' (
	FORMAT parquet,
	KV_METADATA {
		number: $1,
	}
);

statement ok
execute statement(42)

query II
select * from '{TEST_DIR}/prepared_parquet_copy.parquet';
----
42	true
