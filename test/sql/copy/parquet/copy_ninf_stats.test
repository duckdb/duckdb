# name: test/sql/copy/parquet/copy_ninf_stats.test
# description: Negative infinity stats
# group: [parquet]

require parquet

statement ok
copy (select '-infinity'::double ninf) to '{TEST_DIR}/ninf.parquet';

query II
SELECT stats_min, stats_max FROM parquet_metadata('{TEST_DIR}/ninf.parquet')
