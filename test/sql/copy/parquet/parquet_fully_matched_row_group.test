# name: test/sql/copy/parquet/parquet_fully_matched_row_group.test
# description: Correctness for fully-matched row group filter skip optimization
# group: [parquet]

require parquet

# id/d range [10000, 209999]; filter constants are below the data min so
# always-true is driven by stats, not a type boundary.
statement ok
COPY (
  SELECT (10000 + i)::INTEGER AS id,
         ('payload_' || (10000 + i))::VARCHAR AS s,
         (10000 + i)::DOUBLE AS d
  FROM range(200000) t(i)
) TO '{TEST_DIR}/fully_matched.parquet' (ROW_GROUP_SIZE 50000);

# Integer always-true, filter-only: id not projected, decode should be skipped.
query I
SELECT count(*) FROM '{TEST_DIR}/fully_matched.parquet' WHERE id >= 50;
----
200000

# Integer always-true, projected: predicate skipped but column still decoded.
query II
SELECT count(id), sum(id) FROM '{TEST_DIR}/fully_matched.parquet' WHERE id >= 50;
----
200000	21999900000

# VARCHAR != triggers FILTER_ALWAYS_TRUE ('zzzz' > lex max 'payload_99999').
query II
SELECT count(*), sum(id) FROM '{TEST_DIR}/fully_matched.parquet' WHERE s != 'zzzzzzzzzzzz';
----
200000	21999900000

# VARCHAR >= with constant below lex min ('a' < 'payload_10000').
query I
SELECT count(*) FROM '{TEST_DIR}/fully_matched.parquet' WHERE s >= 'a';
----
200000

# VARCHAR <= with constant above lex max ('z' > 'payload_99999').
query I
SELECT count(*) FROM '{TEST_DIR}/fully_matched.parquet' WHERE s <= 'z';
----
200000

# DOUBLE: falls through to NumericStats::CheckZonemap (can_have_nan is false
# for DuckDB-written files).
query I
SELECT count(*) FROM '{TEST_DIR}/fully_matched.parquet' WHERE d >= 50.0;
----
200000

# Per-column: id >= 50 always-true (filter-only), s LIKE 'payload_2%' selective.
# Matching ids: 20000-29999 and 200000-209999 = 20000 rows.
query I
SELECT count(*) FROM '{TEST_DIR}/fully_matched.parquet' WHERE id >= 50 AND s LIKE 'payload_2%';
----
20000

# Negative: id >= 110000 is not always-true; must still filter correctly.
query I
SELECT count(*) FROM '{TEST_DIR}/fully_matched.parquet' WHERE id >= 110000;
----
100000

# Struct field filter-only across multiple row groups: the parquet reader treats the whole struct
# column as filter-only. The skip path resets the struct vector to NULL but field reads must still
# come through correctly so a different field of the same struct is projected.
statement ok
COPY (
  SELECT i AS id, {a: i, b: 'v_' || i} AS s FROM range(200000) t(i)
) TO '{TEST_DIR}/struct_fully_matched.parquet' (ROW_GROUP_SIZE 50000);

# filter on s.a always-true (constant below min); s.b projected — every row's b must be present.
query II
SELECT count(s.b), count(*) FROM '{TEST_DIR}/struct_fully_matched.parquet' WHERE s.a >= 0;
----
200000	200000

# filter on s.a always-true; sum the projected scalar id alongside the struct field b.
query II
SELECT sum(id), count(s.b) FROM '{TEST_DIR}/struct_fully_matched.parquet' WHERE s.a >= 0;
----
19999900000	200000
