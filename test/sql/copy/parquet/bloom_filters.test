# test some repeated large strings (with default parquet_version v1)
# this should give PLAIN_DICTIONARY dictionary
statement ok
copy (select repeat('abc', 500_000) || (range % 10) s from range(100)) to '{TEST_DIR}/my.parquet';

query I
select encodings from parquet_metadata('{TEST_DIR}/my.parquet');
----
PLAIN_DICTIONARY

# test some repeated large strings with parquet_version v2
# this should give RLE_DICTIONARY dictionary
statement ok
copy (select repeat('abc', 500_000) || (range % 10) s from range(100)) to '{TEST_DIR}/my.parquet' (parquet_version v2);

query I
select encodings from parquet_metadata('{TEST_DIR}/my.parquet');
----
RLE_DICTIONARY

# this cannot do any dictionaries because the strings exceed the limit
statement ok
copy (select repeat('abc', 500_000) || (range % 10) s from range(100)) to '{TEST_DIR}/my.parquet' (STRING_DICTIONARY_PAGE_SIZE_LIMIT 4_000_000);

query I
select encodings in ('PLAIN_DICTIONARY', 'RLE_DICTIONARY') from parquet_metadata('{TEST_DIR}/my.parquet');
----
false

statement ok
COPY (
	SELECT CASE
		WHEN i < 2048 THEN (-1.0::DOUBLE / 'Infinity'::DOUBLE)
		WHEN i % 2 = 0 THEN -1.0::DOUBLE
		ELSE 1.0::DOUBLE
	END AS x
	FROM range(4096) t(i)
	ORDER BY i
) TO '{TEST_DIR}/bloom_ndf_signed_zero.parquet' (
	FORMAT PARQUET,
	ROW_GROUP_SIZE 2048,
	WRITE_BLOOM_FILTER TRUE,
	DICTIONARY_SIZE_LIMIT 1000
);

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM read_parquet('{TEST_DIR}/bloom_ndf_signed_zero.parquet')
WHERE x IS NOT DISTINCT FROM 0.0;
----
analyzed_plan	<REGEX>:(?s).*Row Groups Scanned: 1 / 2.*

query I
SELECT count(*)
FROM read_parquet('{TEST_DIR}/bloom_ndf_signed_zero.parquet')
WHERE x IS NOT DISTINCT FROM 0.0;
----
2048

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM read_parquet('{TEST_DIR}/bloom_ndf_signed_zero.parquet')
WHERE x IS NOT DISTINCT FROM -0.0;
----
analyzed_plan	<REGEX>:(?s).*Row Groups Scanned: 1 / 2.*

query I
SELECT count(*)
FROM read_parquet('{TEST_DIR}/bloom_ndf_signed_zero.parquet')
WHERE x IS NOT DISTINCT FROM -0.0;
----
