copy (select (r1.range*10)::BIGINT r,
from range(100) r1, range(100) order by r) to '{TEST_DIR}/bloom7.parquet' (format parquet, ROW_GROUP_SIZE 10000, dictionary_size_limit 1000, bloom_filter_false_positive_ratio 0.5);


