# name: test/sql/copy/parquet/bloom_filters.test
# group: [parquet]

require parquet

statement ok
copy (select
    (r1.range*10)::BIGINT r,
    r::smallint r_int16,
    r::integer r_int32,
    r::double r_double,
    r::float r_float,
    'string_' || r::VARCHAR r_string,
    ('blob_' || r::VARCHAR)::BLOB r_blob
from range(100) r1, range(1000) order by r) to '{TEST_DIR}/bloom1.parquet' (format parquet, ROW_GROUP_SIZE 10000, dictionary_size_limit 1000);

# we don't check the actual offsets since they might change due to filters being moved around
query III
select column_id, BOOL_AND(bloom_filter_offset > 4), BOOL_AND(bloom_filter_length > 1)  from parquet_metadata('{TEST_DIR}/bloom1.parquet') group by column_id order by column_id;
----
0	true	true
1	true	true
2	true	true
3	true	true
4	true	true
5	true	true
6	true	true

# this value is not in the domain but within min/max
query I
SELECT BOOL_AND(bloom_filter_excludes) FROM parquet_bloom_probe('{TEST_DIR}/bloom1.parquet', 'r', '201');
----
true

# IS NOT DISTINCT FROM a non-NULL constant can use the same Bloom filter probe as equality
query II
EXPLAIN ANALYZE SELECT count(*) FROM '{TEST_DIR}/bloom1.parquet' WHERE r = 201;
----
analyzed_plan	<REGEX>:(?s).*Row Groups Scanned: 0 / 10.*

# Equal inclusive bounds are reduced to equality, enabling Bloom filter pruning
query II
EXPLAIN ANALYZE SELECT count(*) FROM '{TEST_DIR}/bloom1.parquet' WHERE r BETWEEN 201 AND 201;
----
analyzed_plan	<REGEX>:(?s).*Row Groups Scanned: 0 / 10.*

query II
EXPLAIN ANALYZE SELECT count(*) FROM '{TEST_DIR}/bloom1.parquet' WHERE r IS NOT DISTINCT FROM 201;
----
analyzed_plan	<REGEX>:(?s).*Row Groups Scanned: 0 / 10.*

query II
EXPLAIN ANALYZE SELECT count(*) FROM '{TEST_DIR}/bloom1.parquet' WHERE r >= 201 AND r <= 201;
----
analyzed_plan	<REGEX>:(?s).*Row Groups Scanned: 0 / 10.*

# this value is outside min/max
query I
SELECT BOOL_AND(bloom_filter_excludes) FROM parquet_bloom_probe('{TEST_DIR}/bloom1.parquet', 'r', '112121212');
----
true

statement ok
COPY (
    SELECT
        printf('00000000-0000-0000-0000-%012d', (i % 100) * 2)::UUID AS u,
        i::BIGINT AS payload
    FROM range(20480) t(i)
) TO '{TEST_DIR}/bloom_uuid.parquet' (
    FORMAT PARQUET,
    ROW_GROUP_SIZE 2048,
    DICTIONARY_SIZE_LIMIT 1000,
    WRITE_BLOOM_FILTER TRUE
);

# The UUID is absent from every row group but falls within every min/max range
query I
SELECT BOOL_AND(bloom_filter_excludes)
FROM parquet_bloom_probe(
    '{TEST_DIR}/bloom_uuid.parquet',
    'u',
    '00000000-0000-0000-0000-000000000101'
);
----
true

query II
EXPLAIN ANALYZE
SELECT sum(payload)
FROM read_parquet('{TEST_DIR}/bloom_uuid.parquet')
WHERE u = '00000000-0000-0000-0000-000000000101'::UUID;
----
analyzed_plan	<REGEX>:(?s).*Row Groups Scanned: 0 / 10.*

query I
SELECT count(*)
FROM read_parquet('{TEST_DIR}/bloom_uuid.parquet')
WHERE u = '00000000-0000-0000-0000-000000000101'::UUID;
----
0

statement ok
CREATE MACRO assert_bloom_filter_hit(file, col, val) AS TABLE
    SELECT COUNT(*) > 0 AND COUNT(*) < MAX(row_group_id+1) FROM parquet_bloom_probe(file, col, val) WHERE NOT bloom_filter_excludes;

# this in-domain should only be in a subset of row groups since its ordered
query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r', '200');
----
true

# same dance but with probe not being a string
query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r', 200);
----
true

# non-existent file
statement error
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom10000.parquet', 'r', '200');
----
No files found

# non-existent column
statement error
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r2', '200');
----
Column r2 not found

# NULL colname
statement error
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', NULL, '200');
----
Can't have NULL parameters

# NULL probe
statement error
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r', NULL);
----
Can't have NULL parameters

statement error
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r', 'a');
----
Failed to cast value

# more types

query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r_int16', 200);
----
true

query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r_int32', 200);
----
true

query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r_float', 200);
----
true

query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r_double', 200);
----
true

query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r_string', 'string_200');
----
true

query I
FROM assert_bloom_filter_hit('{TEST_DIR}/bloom1.parquet', 'r_blob', 'blob_200'::BLOB);
----
true

# BLOB bloom filters must hash the raw bytes rather than the escaped display string
statement ok
COPY (SELECT from_hex('FF')::BLOB AS b FROM range(10))
TO '{TEST_DIR}/bloom_blob.parquet' (FORMAT PARQUET, WRITE_BLOOM_FILTER TRUE, DICTIONARY_SIZE_LIMIT 1000);

query I
SELECT bool_and(b = from_hex('FF')::BLOB) FROM '{TEST_DIR}/bloom_blob.parquet';
----
true

query I
SELECT count(*) FROM '{TEST_DIR}/bloom_blob.parquet' WHERE b = from_hex('FF')::BLOB;
----
10

query I
SELECT bloom_filter_excludes
FROM parquet_bloom_probe('{TEST_DIR}/bloom_blob.parquet', 'b', from_hex('FF')::BLOB);
----
false

query I
SELECT bloom_filter_excludes
FROM parquet_bloom_probe('{TEST_DIR}/bloom_blob.parquet', 'b', from_hex('FE')::BLOB);
----
true

# Temporal bloom filters use the encoded Parquet value, including the timestamp unit
statement ok
COPY (
    SELECT
        (DATE '2000-01-01' + (2 * (i % 2048))::INTEGER)::DATE AS dt,
        (TIMESTAMP '2000-01-01' + (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIMESTAMP_S AS ts_sec,
        (TIMESTAMP '2000-01-01' + (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIMESTAMP AS ts,
        (TIMESTAMP '2000-01-01' + (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIMESTAMP_MS AS ts_ms,
        (TIMESTAMP '2000-01-01' + (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIMESTAMP_NS AS ts_ns,
        (TIMESTAMP '2000-01-01' + (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIMESTAMPTZ AS ts_tz,
        (TIMESTAMP '2000-01-01' +
         (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIMESTAMPTZ_NS AS ts_tz_ns,
        (TIME '00:00:00' + (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIME AS tm,
        (TIMETZ '12:00:00+02' + (2 * (i % 2048)) * INTERVAL 1 SECOND)::TIMETZ AS tm_tz
    FROM range(8192) t(i)
) TO '{TEST_DIR}/bloom_temporal.parquet' (
    FORMAT PARQUET,
    ROW_GROUP_SIZE 2048,
    DICTIONARY_SIZE_LIMIT 4096,
    BLOOM_FILTER_FALSE_POSITIVE_RATIO 0.0001
);

query III
SELECT column_id, bool_and(bloom_filter_offset IS NOT NULL), bool_and(bloom_filter_length IS NOT NULL)
FROM parquet_metadata('{TEST_DIR}/bloom_temporal.parquet')
GROUP BY column_id
ORDER BY column_id;
----
0	true	true
1	true	true
2	true	true
3	true	true
4	true	true
5	true	true
6	true	true
7	true	true
8	true	true

# Verify the DuckDB logical types and physical Parquet timestamp units under test
query TTIIIT
SELECT name, type,
       coalesce(contains(logical_type, 'MILLIS=MilliSeconds()'), false),
       coalesce(contains(logical_type, 'MICROS=MicroSeconds()'), false),
       coalesce(contains(logical_type, 'NANOS=NanoSeconds()'), false),
       duckdb_type
FROM parquet_schema('{TEST_DIR}/bloom_temporal.parquet')
WHERE type IS NOT NULL
ORDER BY name;
----
dt	INT32	false	false	false	DATE
tm	INT64	false	true	false	TIME
tm_tz	INT64	false	true	false	TIME WITH TIME ZONE
ts	INT64	false	true	false	TIMESTAMP
ts_ms	INT64	true	false	false	TIMESTAMP
ts_ns	INT64	false	false	true	TIMESTAMP_NS
ts_sec	INT64	false	true	false	TIMESTAMP
ts_tz	INT64	false	true	false	TIMESTAMP WITH TIME ZONE
ts_tz_ns	INT64	false	false	true	TIMESTAMPTZ_NS

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'dt', DATE '2000-01-01' + 1001);
----
true

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'ts_sec',
                         TIMESTAMP '2000-01-01' + INTERVAL 1001 SECOND);
----
true

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'ts',
                         TIMESTAMP '2000-01-01' + INTERVAL 1001 SECOND);
----
true

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'ts_ms',
                         TIMESTAMP '2000-01-01' + INTERVAL 1001 SECOND);
----
true

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'ts_ns',
                         TIMESTAMP_NS '2000-01-01' + INTERVAL 1001 SECOND);
----
true

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'ts_tz',
                         (TIMESTAMP '2000-01-01' + INTERVAL 1001 SECOND)::TIMESTAMPTZ);
----
true

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'ts_tz_ns',
                         TIMESTAMPTZ_NS '2000-01-01 00:16:41+00');
----
true

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'tm', TIME '00:16:41');
----
true

# Parquet normalizes TIME WITH TIME ZONE to UTC before hashing
query I
SELECT bool_or(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'tm_tz', TIMETZ '12:00:00+02');
----
false

query I
SELECT bool_and(bloom_filter_excludes)
FROM parquet_bloom_probe('{TEST_DIR}/bloom_temporal.parquet', 'tm_tz', TIMETZ '12:16:41+02');
----
true

