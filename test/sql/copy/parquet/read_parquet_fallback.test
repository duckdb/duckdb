# name: test/sql/copy/parquet/read_parquet_fallback.test
# description: Test read_parquet_fallback
# group: [parquet]

require parquet

statement ok
CREATE TABLE parquet_fallback_source(source VARCHAR, message VARCHAR);

statement ok
INSERT INTO parquet_fallback_source VALUES ('parquet', 'first row'), ('parquet', 'second row');

statement ok
COPY parquet_fallback_source TO '{TEST_DIR}/read_parquet_fallback.parquet' (FORMAT PARQUET);

query TT
SELECT * FROM read_parquet_fallback(['{TEST_DIR}/read_parquet_fallback.parquet'], fallback_query = 'SELECT ''fallback''::VARCHAR, ''unused''::VARCHAR') ORDER BY message;
----
parquet	first row
parquet	second row

query TT
SELECT * FROM read_parquet_fallback(['{TEST_DIR}/read_parquet_fallback_missing.parquet'], fallback_query = 'SELECT ''fallback''::VARCHAR, ''missing file''::VARCHAR');
----
fallback	missing file

query TT
SELECT * FROM read_parquet_fallback([]::VARCHAR[], fallback_query = 'SELECT ''fallback''::VARCHAR, ''empty input''::VARCHAR');
----
fallback	empty input

statement ok
COPY (SELECT 'this is not parquet' AS s) TO '{TEST_DIR}/read_parquet_fallback_invalid.parquet' (FORMAT CSV);

statement error
SELECT * FROM read_parquet_fallback(['{TEST_DIR}/read_parquet_fallback_invalid.parquet'], fallback_query = 'SELECT ''fallback''::VARCHAR, ''invalid file''::VARCHAR');
----
Invalid Input Error: No magic bytes found at end of file '{TEST_DIR}/read_parquet_fallback_invalid.parquet'
