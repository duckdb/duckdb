# name: test/sql/copy/parquet/multi_file/adaptive_filter_carryover.test
# description: Learned AdaptiveFilter order carries across parquet files with matching filter shape
# group: [multi_file]

require parquet

# Deterministic file-open order
statement ok
SET threads=1

statement ok
COPY (SELECT i AS a, i%10 AS b, i%100 AS c FROM range(100000) t(i)) TO '{TEST_DIR}/af_cross_1.parquet'

statement ok
COPY (SELECT i AS a, i%10 AS b, i%100 AS c FROM range(100000) t(i)) TO '{TEST_DIR}/af_cross_2.parquet'

statement ok
COPY (SELECT i AS a, i%10 AS b, i%100 AS c FROM range(100000) t(i)) TO '{TEST_DIR}/af_cross_3.parquet'

statement ok
CALL enable_logging('AdaptiveFilter')

statement ok
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_cross_1.parquet', '{TEST_DIR}/af_cross_2.parquet', '{TEST_DIR}/af_cross_3.parquet']) WHERE a > 100 AND b > 3 AND c < 50

query I
SELECT info['source'] FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND file_path LIKE '%af_cross_1.parquet' ORDER BY timestamp LIMIT 1
----
initial

query I
SELECT info['source'] FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND file_path LIKE '%af_cross_2.parquet' ORDER BY timestamp LIMIT 1
----
seeded

query I
SELECT info['source'] FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND file_path LIKE '%af_cross_3.parquet' ORDER BY timestamp LIMIT 1
----
seeded

# union_by_name
statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_cross_1.parquet', '{TEST_DIR}/af_cross_2.parquet', '{TEST_DIR}/af_cross_3.parquet'], union_by_name=true) WHERE a > 100 AND b > 3 AND c < 50

query I
SELECT count(*) > 0 FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND info['source'] = 'seeded'
----
true

# No pushed-down filters
statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_cross_1.parquet', '{TEST_DIR}/af_cross_2.parquet'])

query I
SELECT count(*) FROM duckdb_logs_parsed('AdaptiveFilter')
----
0

# Check filter-count mismatch
statement ok
CALL truncate_duckdb_logs()

statement ok
COPY (SELECT i AS a, i%10 AS b, i%100 AS c, i%7 AS d FROM range(100000) t(i)) TO '{TEST_DIR}/af_mismatch_1.parquet'

statement ok
COPY (SELECT i AS a, i%10 AS b, i%100 AS c FROM range(100000) t(i)) TO '{TEST_DIR}/af_mismatch_2.parquet'

statement ok
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_mismatch_1.parquet', '{TEST_DIR}/af_mismatch_2.parquet'], union_by_name=true) WHERE a > 100 AND b > 3 AND d IS NULL

query I
SELECT info['source'] FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND file_path LIKE '%af_mismatch_2.parquet' ORDER BY timestamp LIMIT 1
----
initial

# Confirm it's the size check (3 vs 2), not an identity/type miss
query II
SELECT
    (SELECT info['columns'] FROM duckdb_logs_parsed('AdaptiveFilter')
     WHERE event = 'INIT' AND file_path LIKE '%af_mismatch_1.parquet' LIMIT 1),
    (SELECT info['columns'] FROM duckdb_logs_parsed('AdaptiveFilter')
     WHERE event = 'INIT' AND file_path LIKE '%af_mismatch_2.parquet' LIMIT 1)
----
[0, 1, 2]	[0, 1]

# Check columns on different order
statement ok
CALL truncate_duckdb_logs()

statement ok
COPY (SELECT i AS a, i%10 AS b, i%100 AS c FROM range(100000) t(i)) TO '{TEST_DIR}/ord_abc.parquet' (ROW_GROUP_SIZE 10000)

statement ok
COPY (SELECT i%100 AS c, i AS a, i%10 AS b FROM range(100000) t(i)) TO '{TEST_DIR}/ord_cab.parquet' (ROW_GROUP_SIZE 10000)

query I
SELECT count(*) FROM read_parquet(['{TEST_DIR}/ord_abc.parquet', '{TEST_DIR}/ord_cab.parquet']) WHERE a > 100 AND b > 3 AND c < 50
----
59940

query I
SELECT info['source'] FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND file_path LIKE '%ord_abc.parquet' ORDER BY timestamp LIMIT 1
----
initial

query I
SELECT info['source'] FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND file_path LIKE '%ord_cab.parquet' ORDER BY timestamp LIMIT 1
----
seeded

# File 2's seeded ordering matches file 1's latest ordering by column identity
query I
SELECT first.columns = second.columns FROM
    (SELECT info['columns'] AS columns, timestamp FROM duckdb_logs_parsed('AdaptiveFilter')
     WHERE event = 'INIT' AND file_path LIKE '%ord_abc.parquet'
     ORDER BY timestamp DESC LIMIT 1) AS first,
    (SELECT info['columns'] AS columns, timestamp FROM duckdb_logs_parsed('AdaptiveFilter')
     WHERE event = 'INIT' AND file_path LIKE '%ord_cab.parquet' AND info['source'] = 'seeded'
     ORDER BY timestamp LIMIT 1) AS second
----
true

statement ok
CALL truncate_duckdb_logs()

statement ok
SET threads=1

query I
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_cross_1.parquet', '{TEST_DIR}/af_cross_2.parquet', '{TEST_DIR}/af_cross_3.parquet']) WHERE a > 100 AND b > 3 AND c < 50
----
89910

statement ok
CALL truncate_duckdb_logs()

statement ok
SET threads=2

query I
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_cross_1.parquet', '{TEST_DIR}/af_cross_2.parquet', '{TEST_DIR}/af_cross_3.parquet']) WHERE a > 100 AND b > 3 AND c < 50
----
89910

query I
SELECT count(*) FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND info['source'] = 'initial'
----
2

query I
SELECT count(*) FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND info['source'] = 'seeded'
----
1

query I
SELECT file_path LIKE '%af_cross_3.parquet' FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE event = 'INIT' AND info['source'] = 'seeded'
----
true

# Seeded permutation must match one produced by a prior file
query I
SELECT seeded.permutation IN (
    SELECT permutation FROM duckdb_logs_parsed('AdaptiveFilter')
    WHERE file_path LIKE '%af_cross_1.parquet' OR file_path LIKE '%af_cross_2.parquet'
)
FROM duckdb_logs_parsed('AdaptiveFilter') AS seeded
WHERE event = 'INIT' AND info['source'] = 'seeded'
----
true
