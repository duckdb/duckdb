# name: test/sql/copy/parquet/multi_file/adaptive_filter_selectivity.test
# description: ParquetPrefetch logs per-row-group filter survivorship
# group: [multi_file]

require parquet

statement ok
SET threads=1

statement ok
SET prefetch_all_parquet_files=true

statement ok
COPY (
    SELECT i AS a,
        i + 10 AS b,
        CASE
        WHEN i % 100 = 50 THEN 51
        ELSE i % 100
    END AS c,
        CASE
        WHEN i = 100 THEN 42
        WHEN i % 100 = 42 THEN 43
        ELSE i % 100
    END AS d
    FROM RANGE(6144) t(i)
) TO '{TEST_DIR}/af_1.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER FALSE)

statement ok
COPY (
    SELECT i AS a,
        i + 10 AS b,
        CASE
        WHEN i % 100 = 50 THEN 51
        ELSE i % 100
    END AS c,
        CASE
        WHEN i = 100 THEN 42
        WHEN i % 100 = 42 THEN 43
        ELSE i % 100
    END AS d
    FROM RANGE(6144) t(i)
) TO '{TEST_DIR}/af_2.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER FALSE)

statement ok
CALL enable_logging('ParquetPrefetch')

statement ok
SELECT count(*)
FROM read_parquet([ '{TEST_DIR}/af_1.parquet', '{TEST_DIR}/af_2.parquet' ])
WHERE a > 5
    AND b > 15

# All row groups have survivors; tally carries across files on the same thread.
query II
SELECT info [ 'row_groups_executed' ]::BIGINT,
    info [ 'row_groups_with_matches' ]::BIGINT
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%af_1.parquet'
ORDER BY row_group_id
----
0	0
1	1
2	2

query II
SELECT info [ 'row_groups_executed' ]::BIGINT,
    info [ 'row_groups_with_matches' ]::BIGINT
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%af_2.parquet'
ORDER BY row_group_id
----
3	3
4	4
5	5

statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*)
FROM read_parquet([ '{TEST_DIR}/af_1.parquet', '{TEST_DIR}/af_2.parquet' ])
WHERE c = 50
    AND a > 0

# No row groups produce survivors.
query II
SELECT info [ 'row_groups_executed' ]::BIGINT,
    info [ 'row_groups_with_matches' ]::BIGINT
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%af_1.parquet'
ORDER BY row_group_id
----
0	0
1	0
2	0

query II
SELECT info [ 'row_groups_executed' ]::BIGINT,
    info [ 'row_groups_with_matches' ]::BIGINT
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%af_2.parquet'
ORDER BY row_group_id
----
3	0
4	0
5	0

statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*)
FROM read_parquet([ '{TEST_DIR}/af_1.parquet', '{TEST_DIR}/af_2.parquet' ])
WHERE d = 42
    AND a > 0

# Only the first row group of each file has survivors (i=100).
query II
SELECT info [ 'row_groups_executed' ]::BIGINT,
    info [ 'row_groups_with_matches' ]::BIGINT
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%af_1.parquet'
ORDER BY row_group_id
----
0	0
1	1
2	1

query II
SELECT info [ 'row_groups_executed' ]::BIGINT,
    info [ 'row_groups_with_matches' ]::BIGINT
FROM duckdb_logs_parsed('ParquetPrefetch')
WHERE file_path LIKE '%af_2.parquet'
ORDER BY row_group_id
----
3	1
4	2
5	2
