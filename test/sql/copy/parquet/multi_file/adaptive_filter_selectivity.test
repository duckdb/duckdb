# name: test/sql/copy/parquet/multi_file/adaptive_filter_selectivity.test
# description: AdaptiveFilter selectivity counters carry across parquet files
# group: [multi_file]

require parquet

statement ok
SET threads=1

statement ok
COPY (SELECT i AS a, i + 10 AS b, CASE WHEN i % 100 = 50 THEN 51 ELSE i % 100 END AS c, CASE WHEN i = 100 THEN 42 WHEN i % 100 = 42 THEN 43 ELSE i % 100 END AS d FROM range(6144) t(i)) TO '{TEST_DIR}/af_1.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER false)

statement ok
COPY (SELECT i AS a, i + 10 AS b, CASE WHEN i % 100 = 50 THEN 51 ELSE i % 100 END AS c, CASE WHEN i = 100 THEN 42 WHEN i % 100 = 42 THEN 43 ELSE i % 100 END AS d FROM range(6144) t(i)) TO '{TEST_DIR}/af_2.parquet' (ROW_GROUP_SIZE 2048, WRITE_BLOOM_FILTER false)

statement ok
CALL enable_logging('AdaptiveFilter')

statement ok
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_1.parquet', '{TEST_DIR}/af_2.parquet']) WHERE a > 5 AND b > 15

query II
SELECT info['total_filter_calls']::BIGINT, info['filter_calls_with_matches']::BIGINT FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE file_path LIKE '%af_1.parquet' ORDER BY timestamp
----
0	0
1	1
2	2

query II
SELECT info['total_filter_calls']::BIGINT, info['filter_calls_with_matches']::BIGINT FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE file_path LIKE '%af_2.parquet' ORDER BY timestamp
----
3	3
4	4
5	5

statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_1.parquet', '{TEST_DIR}/af_2.parquet']) WHERE c = 50 AND a > 0

query II
SELECT info['total_filter_calls']::BIGINT, info['filter_calls_with_matches']::BIGINT FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE file_path LIKE '%af_1.parquet' ORDER BY timestamp
----
0	0
1	0
2	0

query II
SELECT info['total_filter_calls']::BIGINT, info['filter_calls_with_matches']::BIGINT FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE file_path LIKE '%af_2.parquet' ORDER BY timestamp
----
3	0
4	0
5	0

statement ok
CALL truncate_duckdb_logs()

statement ok
SELECT count(*) FROM read_parquet(['{TEST_DIR}/af_1.parquet', '{TEST_DIR}/af_2.parquet']) WHERE d = 42 AND a > 0

query II
SELECT info['total_filter_calls']::BIGINT, info['filter_calls_with_matches']::BIGINT FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE file_path LIKE '%af_1.parquet' ORDER BY timestamp
----
0	0
1	1
2	1

query II
SELECT info['total_filter_calls']::BIGINT, info['filter_calls_with_matches']::BIGINT FROM duckdb_logs_parsed('AdaptiveFilter')
WHERE file_path LIKE '%af_2.parquet' ORDER BY timestamp
----
3	1
4	2
5	2