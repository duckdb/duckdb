# name: test/sql/copy/parquet/parquet_async_io.test
# description: Async IO for parquet reads - results are identical across async/sync, thread counts, and strategies
# group: [parquet]

require parquet

statement ok
SET enable_external_file_cache=true;

# prefetch_all_parquet_files makes ShouldAndCanPrefetch return true for local on-disk files, so prefetch_mode
# (and therefore the async IO path) actually engages here. Without it, local files never prefetch and the
# parquet_async_io toggle would be a no-op for this test.
statement ok
SET prefetch_all_parquet_files=true;

# multi-row-group file (100 row groups) with numeric, string, list and struct columns
statement ok
COPY (
    SELECT
        range AS i,
        range % 100 AS g,
        'str_' || (range % 1000)::VARCHAR AS s,
        [range, range + 1, range + 2] AS lst,
        {'a': range, 'b': range % 7} AS strc
    FROM range(10000)
) TO '{TEST_DIR}/async_io.parquet' (FORMAT parquet, ROW_GROUP_SIZE 100);

# One self-checking query: compares parquet aggregates against the generating range() expression, so
# there are no hand-computed constants. It covers a full scan, a filter that keeps half the row groups,
# a filter that statistics-prunes every row group, projection of a subset, and nested (list/struct) reads.
# We run it under every (parquet_async_io x async_threads) combination - all must return true. With
# parquet_async_io=true and async_threads>0 this drives the real async BLOCKED path; the other combinations
# exercise the synchronous fallback - results must match.

foreach async_io true false

statement ok
SET parquet_async_io={async_io};

foreach threads 0 1 4

statement ok
SET async_threads={threads};

query I
SELECT
    (SELECT count(*) FROM '{TEST_DIR}/async_io.parquet') = 10000 AND
    (SELECT sum(i) FROM '{TEST_DIR}/async_io.parquet') = (SELECT sum(range) FROM range(10000)) AND
    (SELECT sum(g) FROM '{TEST_DIR}/async_io.parquet') = (SELECT sum(range % 100) FROM range(10000)) AND
    (SELECT count(*) FROM '{TEST_DIR}/async_io.parquet' WHERE i >= 5000) = 5000 AND
    (SELECT sum(i) FROM '{TEST_DIR}/async_io.parquet' WHERE i >= 5000) = (SELECT sum(range) FROM range(5000, 10000)) AND
    (SELECT count(*) FROM '{TEST_DIR}/async_io.parquet' WHERE i < 0) = 0 AND
    (SELECT max(s) FROM '{TEST_DIR}/async_io.parquet') = (SELECT max('str_' || (range % 1000)::VARCHAR) FROM range(10000)) AND
    (SELECT sum(strc.a) FROM '{TEST_DIR}/async_io.parquet') = (SELECT sum(range) FROM range(10000)) AND
    (SELECT sum(strc.b) FROM '{TEST_DIR}/async_io.parquet') = (SELECT sum(range % 7) FROM range(10000)) AND
    (SELECT sum(lst[2]) FROM '{TEST_DIR}/async_io.parquet') = (SELECT sum(range + 1) FROM range(10000));
----
true

endloop

endloop

# Force the eager whole-group strategy with async IO on
statement ok
SET parquet_async_io=true;

statement ok
SET async_threads=4;

query I
SELECT sum(i) = (SELECT sum(range) FROM range(10000))
FROM read_parquet('{TEST_DIR}/async_io.parquet', prefetch_strategy='whole_group');
----
true

# High intra-query parallelism: many scan threads switch row groups concurrently and issue async prefetch
# against the shared CachingFileHandle. Results must still match the generating expression.
statement ok
PRAGMA threads=8;

query I
SELECT sum(i) = (SELECT sum(range) FROM range(10000)) AND
       sum(lst[3]) = (SELECT sum(range + 2) FROM range(10000)) AND
       count(*) FILTER (WHERE i >= 2500) = 7500
FROM '{TEST_DIR}/async_io.parquet';
----
true

statement ok
PRAGMA threads=4;

# SYNCHRONOUS execution strategy: MultiFileScan must run the async tasks inline (ExecuteTasksSynchronously)
# instead of returning BLOCKED. This is the strategy that `make test_configs` forces globally.
statement ok
SET debug_physical_table_scan_execution_strategy='synchronous';

query I
SELECT count(*) = 5000 AND sum(i) = (SELECT sum(range) FROM range(5000, 10000))
FROM '{TEST_DIR}/async_io.parquet' WHERE i >= 5000;
----
true

statement ok
RESET debug_physical_table_scan_execution_strategy;
