# name: test/sql/copy/parquet/parquet_glob_cache.test
# description: Test usage of metadata cache in COUNT(*)
# group: [parquet]

# On Windows, freshly checked-out files can fail the metadata cache validity
# check because local-file reuse falls back to last_modified and requires files
# without a version tag to be older than 10 seconds, so the bind rewrite keeps
# PARQUET_SCAN even when the cache entry exists.
require notwindows

require parquet

statement ok
SET parquet_metadata_cache=true;

# first read reads the parquet files
query II
EXPLAIN select count(*) from parquet_scan('{DATA_DIR}/parquet-testing/glob/*')
----
physical_plan	<REGEX>:.*PARQUET_SCAN.*

query I
select count(*) from parquet_scan('{DATA_DIR}/parquet-testing/glob/*')
----
2

# second read uses the metadata cache
query II
EXPLAIN select count(*) from parquet_scan('{DATA_DIR}/parquet-testing/glob/*')
----
physical_plan	<!REGEX>:.*PARQUET_SCAN.*

query I
select count(*) from parquet_scan('{DATA_DIR}/parquet-testing/glob/*')
----
2
