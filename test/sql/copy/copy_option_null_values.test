# name: test/sql/copy/copy_option_null_values.test
# description: Test that explicit NULL values for COPY options produce clean errors
# group: [copy]

statement error
COPY (SELECT 1 AS a) TO '{TEST_DIR}/test_null_use_tmp_file.csv' (FORMAT CSV, use_tmp_file NULL);
----
<REGEX>:Binder Error.*NULL is not supported as a valid option for COPY option "use_tmp_file".*

statement error
COPY (SELECT 1 AS a) TO '{TEST_DIR}/test_null_overwrite.csv' (FORMAT CSV, overwrite NULL);
----
<REGEX>:Binder Error.*NULL is not supported as a valid option for COPY option "overwrite".*
