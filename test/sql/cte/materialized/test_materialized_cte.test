query I
WITH d AS MATERIALIZED (
  SELECT
    CASE WHEN i > 80000 THEN error('cte limit should stop producer') ELSE i END AS c00,
    i AS c01, i AS c02, i AS c03, i AS c04, i AS c05, i AS c06, i AS c07,
    i AS c08, i AS c09, i AS c10, i AS c11, i AS c12, i AS c13, i AS c14, i AS c15,
    i AS c16, i AS c17, i AS c18, i AS c19, i AS c20, i AS c21, i AS c22, i AS c23,
    i AS c24, i AS c25, i AS c26, i AS c27, i AS c28, i AS c29, i AS c30, i AS c31,
    i AS c32, i AS c33, i AS c34, i AS c35, i AS c36, i AS c37, i AS c38, i AS c39,
    i AS c40, i AS c41, i AS c42, i AS c43, i AS c44, i AS c45, i AS c46, i AS c47,
    i AS c48, i AS c49, i AS c50, i AS c51, i AS c52, i AS c53, i AS c54, i AS c55,
    i AS c56, i AS c57, i AS c58, i AS c59, i AS c60, i AS c61, i AS c62, i AS c63
  FROM range(1000000) tbl(i)
)
SELECT sum(c00 + c01 + c02 + c03 + c04 + c05 + c06 + c07 +
           c08 + c09 + c10 + c11 + c12 + c13 + c14 + c15 +
           c16 + c17 + c18 + c19 + c20 + c21 + c22 + c23 +
           c24 + c25 + c26 + c27 + c28 + c29 + c30 + c31 +
           c32 + c33 + c34 + c35 + c36 + c37 + c38 + c39 +
           c40 + c41 + c42 + c43 + c44 + c45 + c46 + c47 +
           c48 + c49 + c50 + c51 + c52 + c53 + c54 + c55 +
           c56 + c57 + c58 + c59 + c60 + c61 + c62 + c63)
FROM (SELECT * FROM d LIMIT 10);
----
2880

query II
WITH d AS MATERIALIZED (
  SELECT
    i AS c00,
    i AS c01, i AS c02, i AS c03, i AS c04, i AS c05, i AS c06, i AS c07,
    i AS c08, i AS c09, i AS c10, i AS c11, i AS c12, i AS c13, i AS c14, i AS c15
  FROM range(300000) tbl(i)
)
SELECT (SELECT sum(c00 + c01 + c02 + c03 + c04 + c05 + c06 + c07 +
                   c08 + c09 + c10 + c11 + c12 + c13 + c14 + c15)
        FROM (SELECT * FROM d LIMIT 10)),
       (SELECT sum(c00 + c01 + c02 + c03 + c04 + c05 + c06 + c07 +
                   c08 + c09 + c10 + c11 + c12 + c13 + c14 + c15)
        FROM (SELECT * FROM d LIMIT 10));
----
720	720

