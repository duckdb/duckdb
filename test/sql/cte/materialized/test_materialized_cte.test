query II
WITH d AS (
  SELECT
    i AS c00, i + 1 AS c01, i + 2 AS c02, i + 3 AS c03, i + 4 AS c04,
    i + 5 AS c05, i + 6 AS c06, i + 7 AS c07, i + 8 AS c08, i + 9 AS c09,
    i + 10 AS c10, i + 11 AS c11, i + 12 AS c12, i + 13 AS c13, i + 14 AS c14,
    i + 15 AS c15, i + 16 AS c16, i + 17 AS c17, i + 18 AS c18, i + 19 AS c19
  FROM range(220000) tbl(i)
  GROUP BY ALL
)
SELECT (SELECT count(c00) FROM d), (SELECT count(c01) FROM d);
----
220000	220000

query I
WITH d AS MATERIALIZED (
  SELECT i, i AS q
  FROM range(256) tbl(i)
)
SELECT count(*)
FROM d lhs
WHERE q < (SELECT avg(q) + 1 FROM d rhs WHERE rhs.i = lhs.i);
----
256

query II
EXPLAIN ANALYZE WITH d AS MATERIALIZED (
  SELECT i % 8 AS k, i AS v
  FROM range(64) tbl(i)
)
SELECT count(*)
FROM d lhs
WHERE v < (SELECT avg(v) + 1 FROM d rhs WHERE rhs.k = lhs.k);
----
analyzed_plan	<REGEX>:.*Execution Mode: HYBRID_FANOUT.*Fanout Mode: DIRECT.*Direct Consumers: (1|2).*Buffered Consumers: 0.*Materialized Consumers: 1.*

query IIII
WITH d AS (
  SELECT i::INTEGER AS c0, CASE WHEN i % 4 = 0 THEN NULL ELSE i::INTEGER END AS c1
  FROM range(16) tbl(i)
)
SELECT (SELECT sum(c0) FROM d), (SELECT sum(c1) FROM d), (SELECT count(c0) FROM d), (SELECT count(c1) FROM d);
----
120	96	16	12

