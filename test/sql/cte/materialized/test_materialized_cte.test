query I
WITH t AS MATERIALIZED (SELECT i FROM range(3) tbl(i))
SELECT sum(a.i + b.i) FROM t a, t b;
----
18

query I
WITH t AS MATERIALIZED (
  SELECT CASE WHEN i > 5000000 THEN error('cte should not fully materialize') ELSE i END AS i
  FROM range(10000000) tbl(i)
)
SELECT * FROM t LIMIT 5;
----
0
1
2
3
4

statement ok
PRAGMA threads=1

query I
WITH d AS MATERIALIZED (
  SELECT
    CASE WHEN i > 80000 THEN error('cte limit should stop producer') ELSE i END AS c00,
    i AS c01, i AS c02, i AS c03, i AS c04, i AS c05, i AS c06, i AS c07,
    i AS c08, i AS c09, i AS c10, i AS c11, i AS c12, i AS c13, i AS c14, i AS c15,
    i AS c16, i AS c17, i AS c18, i AS c19, i AS c20, i AS c21, i AS c22, i AS c23,
    i AS c24, i AS c25, i AS c26, i AS c27, i AS c28, i AS c29, i AS c30, i AS c31,
    i AS c32, i AS c33, i AS c34, i AS c35, i AS c36, i AS c37, i AS c38, i AS c39,
    i AS c40, i AS c41, i AS c42, i AS c43, i AS c44, i AS c45, i AS c46, i AS c47,
    i AS c48, i AS c49, i AS c50, i AS c51, i AS c52, i AS c53, i AS c54, i AS c55,
    i AS c56, i AS c57, i AS c58, i AS c59, i AS c60, i AS c61, i AS c62, i AS c63
  FROM range(1000000) tbl(i)
)
SELECT sum(c00 + c01 + c02 + c03 + c04 + c05 + c06 + c07 +
           c08 + c09 + c10 + c11 + c12 + c13 + c14 + c15 +
           c16 + c17 + c18 + c19 + c20 + c21 + c22 + c23 +
           c24 + c25 + c26 + c27 + c28 + c29 + c30 + c31 +
           c32 + c33 + c34 + c35 + c36 + c37 + c38 + c39 +
           c40 + c41 + c42 + c43 + c44 + c45 + c46 + c47 +
           c48 + c49 + c50 + c51 + c52 + c53 + c54 + c55 +
           c56 + c57 + c58 + c59 + c60 + c61 + c62 + c63)
FROM (SELECT * FROM d LIMIT 10);
----
2880

statement ok
PRAGMA threads=4

query II
WITH d AS (
  SELECT
    i AS c00, i + 1 AS c01, i + 2 AS c02, i + 3 AS c03, i + 4 AS c04,
    i + 5 AS c05, i + 6 AS c06, i + 7 AS c07, i + 8 AS c08, i + 9 AS c09,
    i + 10 AS c10, i + 11 AS c11, i + 12 AS c12, i + 13 AS c13, i + 14 AS c14,
    i + 15 AS c15, i + 16 AS c16, i + 17 AS c17, i + 18 AS c18, i + 19 AS c19
  FROM range(220000) tbl(i)
  GROUP BY ALL
)
SELECT (SELECT count(c00) FROM d), (SELECT count(c01) FROM d);
----
220000	220000

query IIII
WITH d AS (
  SELECT i::INTEGER AS c0, CASE WHEN i % 4 = 0 THEN NULL ELSE i::INTEGER END AS c1
  FROM range(16) tbl(i)
)
SELECT (SELECT sum(c0) FROM d), (SELECT sum(c1) FROM d), (SELECT count(c0) FROM d), (SELECT count(c1) FROM d);
----
120	96	16	12

query II
WITH t(x) AS MATERIALIZED (SELECT 1),
     u(x) AS MATERIALIZED (SELECT 2)
  SELECT *
  FROM u FULL OUTER JOIN t ON TRUE;
----
2	1

query I
WITH t(x) AS MATERIALIZED (SELECT x FROM generate_series(1,10) AS _(x) limit 4)   SELECT DISTINCT x   FROM t order by x desc;
