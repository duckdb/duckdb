# name: test/sql/cte/materialized/test_materialized_cte.test
# description: Test Materialized Common Table Expressions (CTE)
# group: [materialized]

query I
WITH t(x) AS MATERIALIZED (SELECT 1) SELECT * FROM t;
----
1

query II
EXPLAIN WITH t AS MATERIALIZED (SELECT i FROM range(3) tbl(i))
SELECT * FROM t LIMIT 1;
----
physical_plan	<REGEX>:.*PIPELINE_DEPENDENT.*CTE( Scan|_SCAN).*

query II
EXPLAIN ANALYZE WITH d AS (SELECT i AS a, i AS b FROM range(10) tbl(i))
SELECT (SELECT sum(a) FROM d), (SELECT sum(b) FROM d);
----
analyzed_plan	<REGEX>:.*Fanout Mode: DIRECT.*Direct Consumers: 2.*Buffered Consumers: 0.*

query II
EXPLAIN ANALYZE WITH d AS MATERIALIZED (SELECT i FROM range(10000) tbl(i))
SELECT sum(i) FROM d;
----
analyzed_plan	<REGEX>:.*CTE Mode: DIRECT.*10,000 rows.*

query II
EXPLAIN ANALYZE WITH d AS MATERIALIZED (SELECT i FROM range(10) tbl(i))
SELECT * FROM d ORDER BY i LIMIT 3;
----
analyzed_plan	<REGEX>:.*Fanout Mode: BUFFERED.*Direct Consumers: 0.*Buffered Consumers: 1.*

query II
EXPLAIN ANALYZE WITH d AS (SELECT i AS a FROM range(10) tbl(i))
SELECT * FROM (SELECT sum(a) FROM d), (SELECT a FROM d ORDER BY a LIMIT 1);
----
analyzed_plan	<REGEX>:.*Execution Mode: HYBRID_FANOUT.*Fanout Mode: DIRECT.*Direct Consumers: 1.*Buffered Consumers: 0.*Materialized Consumers: 1.*

query II
EXPLAIN ANALYZE WITH d AS (SELECT i AS a FROM range(10) tbl(i))
SELECT * FROM (SELECT sum(a) FROM d), (SELECT a FROM d LIMIT 1);
----
analyzed_plan	<REGEX>:.*Execution Mode: STREAMING_FANOUT.*Fanout Mode: MIXED.*Direct Consumers: 1.*Buffered Consumers: 1.*

