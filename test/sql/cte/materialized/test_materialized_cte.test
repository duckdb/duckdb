3

query I
WITH t(x) AS MATERIALIZED (
  WITH u(x) AS MATERIALIZED (
    SELECT 42
  ) SELECT * FROM u
) SELECT * FROM t;
----
42

query I
WITH t(x) AS MATERIALIZED (SELECT 1),
     u(x) AS MATERIALIZED (SELECT x+1 FROM t)
  TABLE u UNION ALL TABLE t;
----
2
1

