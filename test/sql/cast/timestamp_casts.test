# name: test/sql/cast/timestamp_casts.test
# description: Test the TIMESTAMP cast functions
# group: [cast]

statement ok
CREATE TABLE tss AS 
	FROM VALUES ('2026-04-09 11:48:07.123456'::TIMESTAMP) tbl(t);

query I
select t::TIMESTAMP_NS from tss;
----
2026-04-09 11:48:07.123456

query I
select t::TIMESTAMP from tss;
----
2026-04-09 11:48:07.123456

query I
select t::TIMESTAMP_MS from tss;
----
2026-04-09 11:48:07.123

query I
select t::TIMESTAMP_S from tss;
----
2026-04-09 11:48:07

query I
select t::DATE from tss;
----
2026-04-09

query I
SELECT TRY_CAST(TIMESTAMP '2262-04-11 23:47:16.854776' AS TIMESTAMP_NS);
----
NULL

statement error
SELECT CAST(TIMESTAMP '2262-04-11 23:47:16.854776' AS TIMESTAMP_NS);
----
Could not convert Timestamp to higher precision.

statement error
SELECT CAST(TIMESTAMP '2262-04-11 23:47:16.854776' AS TIMESTAMPTZ_NS);
----
Could not convert Timestamp to higher precision.

statement error
SELECT CAST(TIMESTAMPTZ '2262-04-11 23:47:16.854776+00' AS TIMESTAMP_NS);
----
Could not convert Timestamp to higher precision.

statement error
SELECT CAST(TIMESTAMP_MS '2262-04-11 23:47:16.855' AS TIMESTAMP_NS);
----
Could not convert Timestamp to higher precision.

statement error
SELECT CAST(TIMESTAMP_MS '2262-04-11 23:47:16.855' AS TIMESTAMPTZ_NS);
----
Could not convert Timestamp to higher precision.

statement error
SELECT CAST(TIMESTAMP_S '2262-04-12 00:00:00' AS TIMESTAMP_NS);
----
Could not convert Timestamp to higher precision.

statement error
SELECT CAST(TIMESTAMP_S '2262-04-12 00:00:00' AS TIMESTAMPTZ_NS);
----
Could not convert Timestamp to higher precision.

statement error
SELECT CAST(TIMESTAMP 'infinity' AS TIME);
----
Can't get TIME of infinite TIMESTAMP

statement error
SELECT CAST(TIMESTAMP 'infinity' AS TIMETZ);
----
Can't get TIME of infinite TIMESTAMP

statement error
SELECT CAST(TIMESTAMPTZ 'infinity' AS TIMETZ);
----
Can't get TIME of infinite TIMESTAMP

statement error
SELECT CAST('infinity'::TIMESTAMPTZ_NS AS TIMETZ);
----
Can't get TIME of infinite TIMESTAMP

statement error
SELECT CAST(TIMESTAMP_MS 'infinity' AS TIME);
----
Can't get TIME of infinite TIMESTAMP

statement error
SELECT CAST('infinity'::TIMESTAMP_NS AS TIME);
----
Can't get TIME of infinite TIMESTAMP

statement error
SELECT CAST(TIMESTAMP_S 'infinity' AS TIME);
----
Can't get TIME of infinite TIMESTAMP

statement error
SELECT CAST('infinity'::TIMESTAMP_NS AS TIME_NS);
----
Can't get TIME_NS of infinite TIMESTAMP

query II
SELECT
	CAST('1970-01-01 23:59:59.999999999'::TIMESTAMP_NS AS DATE),
	TRY_CAST('1970-01-01 23:59:59.999999999'::TIMESTAMP_NS AS DATE)
----
1970-01-02	1970-01-02

query IIIIIIIII
SELECT
	TRY_CAST(TIMESTAMP 'infinity' AS TIME) IS NULL,
	TRY_CAST(TIMESTAMP 'infinity' AS TIMETZ) IS NULL,
	TRY_CAST(TIMESTAMPTZ 'infinity' AS TIMETZ) IS NULL,
	TRY_CAST('infinity'::TIMESTAMP_NS AS TIME) IS NULL,
	TRY_CAST('infinity'::TIMESTAMP_NS AS TIME_NS) IS NULL,
	TRY_CAST('infinity'::TIMESTAMPTZ_NS AS TIMETZ) IS NULL,
	TRY_CAST(TIMESTAMPTZ '2262-04-11 23:47:16.854776+00' AS TIMESTAMP_NS) IS NULL,
	TRY_CAST(TIMESTAMP_MS '2262-04-11 23:47:16.855' AS TIMESTAMP_NS) IS NULL,
	TRY_CAST(TIMESTAMP_S '2262-04-12 00:00:00' AS TIMESTAMP_NS) IS NULL
----
true	true	true	true	true	true	true	true	true

query II
SELECT
	CAST('1970-01-01 23:59:59.999999999+00'::TIMESTAMPTZ_NS AS TIMETZ),
	TRY_CAST('1970-01-01 23:59:59.999999999+00'::TIMESTAMPTZ_NS AS TIMETZ)
----
00:00:00+00	00:00:00+00
