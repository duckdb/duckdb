# name: test/sql/cast/signed_cast_repro.test
# description: String to Integer casts with Decimals
# group: [cast]

statement ok
CREATE TABLE tab2(col0 INTEGER, col1 INTEGER, col2 INTEGER)

statement ok
INSERT INTO tab2 VALUES(64,77,40)

statement ok
INSERT INTO tab2 VALUES(75,67,58)

statement ok
INSERT INTO tab2 VALUES(46,51,23)

# SIGNED maps to INTEGER (default_types.cpp). The WHERE clause contains a chain of INT32
# multiplications that overflow (e.g. 1168724480 * -64). In v1.5 this throws an error.
# In main, PR #22384 (ArgProperties/TryPropagateMonotoneBounds) lets the statistics propagator
# derive that the multiplication result is non-nullable (all input columns are non-null), so
# the IS NOT NULL folds to true and the multiplication is never executed. The remaining
# BETWEEN ... AND NULL condition folds to NOT NULL (always false), so no rows pass the filter,
# MAX() returns NULL, and the query succeeds returning NULL.
statement error
SELECT 43 - MAX( ALL - 87 + col1 ) FROM tab2 WHERE col1 * col1 * - CAST( - col2 AS SIGNED ) * + - col0 * + - 77 * - col0 IS NOT NULL AND NOT + col0 BETWEEN 35 * - col2 AND NULL