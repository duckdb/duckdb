# name: test/sql/feature/test_feature_materialize.test
# description: Test PIT-correct materialization and direct querying of backing table
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# Setup: source table with known data for deterministic results
# ============================================================
statement ok
CREATE TABLE transactions (user_id INTEGER, amount DOUBLE, ts TIMESTAMP);

statement ok
INSERT INTO transactions VALUES
    (1, 100.0, '2024-01-01 10:00:00'),
    (1, 200.0, '2024-01-02 14:00:00'),
    (1,  50.0, '2024-01-04 09:00:00'),
    (2,  50.0, '2024-01-01 09:00:00'),
    (2,  75.0, '2024-01-03 11:00:00'),
    (2, 120.0, '2024-01-05 17:00:00'),
    (3, 300.0, '2024-01-02 16:00:00'),
    (3, 150.0, '2024-01-03 08:00:00'),
    (4,  10.0, '2024-01-01 06:00:00'),
    (4,  20.0, '2024-01-01 22:00:00'),
    (4,  30.0, '2024-01-02 07:00:00');

# ============================================================
# SUM feature: PIT-correct windowed aggregation
# ============================================================
statement ok
CREATE FEATURE total_spend ON transactions ENTITY user_id TIMESTAMP ts GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT user_id, SUM(amount) AS total FROM transactions GROUP BY user_id);

# PIT-correct results — no future data leakage. Each source timestamp anchors one feature timestamp.
query ITR rowsort
SELECT * FROM total_spend;
----
1	2024-01-01 10:00:00	100.0
1	2024-01-02 14:00:00	300.0
1	2024-01-04 09:00:00	350.0
2	2024-01-01 09:00:00	50.0
2	2024-01-03 11:00:00	125.0
2	2024-01-05 17:00:00	245.0
3	2024-01-02 16:00:00	300.0
3	2024-01-03 08:00:00	450.0
4	2024-01-01 06:00:00	10.0
4	2024-01-01 22:00:00	30.0
4	2024-01-02 07:00:00	60.0

# Row count
query I
SELECT COUNT(*) FROM total_spend;
----
11

# Verify individual entity full timelines
query TR rowsort
SELECT feature_timestamp, total FROM total_spend WHERE user_id = 3;
----
2024-01-02 16:00:00	300.0
2024-01-03 08:00:00	450.0

query TR rowsort
SELECT feature_timestamp, total FROM total_spend WHERE user_id = 4;
----
2024-01-01 06:00:00	10.0
2024-01-01 22:00:00	30.0
2024-01-02 07:00:00	60.0

# ============================================================
# AVG feature: different aggregate on same source
# ============================================================
statement ok
CREATE FEATURE avg_spend ON transactions ENTITY user_id TIMESTAMP ts GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT user_id, AVG(amount) AS avg_amt FROM transactions GROUP BY user_id);

query ITR rowsort
SELECT * FROM avg_spend;
----
1	2024-01-01 10:00:00	100.0
1	2024-01-02 14:00:00	150.0
1	2024-01-04 09:00:00	116.66666666666667
2	2024-01-01 09:00:00	50.0
2	2024-01-03 11:00:00	62.5
2	2024-01-05 17:00:00	81.66666666666667
3	2024-01-02 16:00:00	300.0
3	2024-01-03 08:00:00	225.0
4	2024-01-01 06:00:00	10.0
4	2024-01-01 22:00:00	15.0
4	2024-01-02 07:00:00	20.0

query I
SELECT COUNT(*) FROM avg_spend;
----
11

# ============================================================
# Multiple aggregates in one feature
# ============================================================
statement ok
CREATE FEATURE multi_agg ON transactions ENTITY user_id TIMESTAMP ts GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT user_id, SUM(amount) AS total, COUNT(*) AS cnt, AVG(amount) AS avg_amt FROM transactions GROUP BY user_id);

# user 1 @ 01-02 14:00: total=300, cnt=2, avg=150 (aggregates Jan 1 + Jan 2 events)
query ITRIR
SELECT * FROM multi_agg WHERE user_id = 1 AND feature_timestamp = '2024-01-02 14:00:00'::TIMESTAMP;
----
1	2024-01-02 14:00:00	300.0	2	150.0

# user 1 @ 01-04 09:00: total=350, cnt=3, avg≈116.67 (Jan 1 + Jan 2 + Jan 4 events)
query ITRIR
SELECT * FROM multi_agg WHERE user_id = 1 AND feature_timestamp = '2024-01-04 09:00:00'::TIMESTAMP;
----
1	2024-01-04 09:00:00	350.0	3	116.66666666666667

# user 4 @ 01-01 22:00: total=30, cnt=2, avg=15 (two Jan 1 events)
query ITRIR
SELECT * FROM multi_agg WHERE user_id = 4 AND feature_timestamp = '2024-01-01 22:00:00'::TIMESTAMP;
----
4	2024-01-01 22:00:00	30.0	2	15.0

# user 4 @ 01-02 07:00: total=60, cnt=3, avg=20 (two Jan 1 + one Jan 2)
query ITRIR
SELECT * FROM multi_agg WHERE user_id = 4 AND feature_timestamp = '2024-01-02 07:00:00'::TIMESTAMP;
----
4	2024-01-02 07:00:00	60.0	3	20.0

# ============================================================
# COUNT feature: verify row counts per event timestamp
# ============================================================
statement ok
CREATE FEATURE event_count ON transactions ENTITY user_id TIMESTAMP ts GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT user_id, COUNT(*) AS cnt FROM transactions GROUP BY user_id);

query ITI rowsort
SELECT user_id, feature_timestamp, cnt FROM event_count;
----
1	2024-01-01 10:00:00	1
1	2024-01-02 14:00:00	2
1	2024-01-04 09:00:00	3
2	2024-01-01 09:00:00	1
2	2024-01-03 11:00:00	2
2	2024-01-05 17:00:00	3
3	2024-01-02 16:00:00	1
3	2024-01-03 08:00:00	2
4	2024-01-01 06:00:00	1
4	2024-01-01 22:00:00	2
4	2024-01-02 07:00:00	3

# ============================================================
# Window boundary: data outside window excluded
# ============================================================
statement ok
CREATE TABLE narrow_window_src (eid VARCHAR, val INTEGER, ts TIMESTAMP);

statement ok
INSERT INTO narrow_window_src VALUES
    ('a', 10, '2024-01-01 08:00:00'),
    ('a', 20, '2024-01-02 08:00:00'),
    ('a', 30, '2024-01-03 08:00:00'),
    ('a', 40, '2024-01-04 08:00:00'),
    ('a', 50, '2024-01-05 08:00:00'),
    ('b', 100, '2024-01-01 08:00:00'),
    ('b', 200, '2024-01-03 08:00:00'),
    ('b', 300, '2024-01-05 08:00:00');

# Window of 2 days: each timestamp includes rows in the preceding two-day lookback window.
statement ok
CREATE FEATURE narrow_feat ON narrow_window_src ENTITY eid TIMESTAMP ts GRANULARITY DAY WINDOW 2 REFRESH FULL RETAIN 1 AS (SELECT eid, SUM(val) AS total FROM narrow_window_src GROUP BY eid);

query TIR rowsort
SELECT eid, feature_timestamp, total FROM narrow_feat;
----
a	2024-01-01 08:00:00	10
a	2024-01-02 08:00:00	30
a	2024-01-03 08:00:00	60
a	2024-01-04 08:00:00	90
a	2024-01-05 08:00:00	120
b	2024-01-01 08:00:00	100
b	2024-01-03 08:00:00	300
b	2024-01-05 08:00:00	500

# ============================================================
# Explicit interval window: units are independent from GRANULARITY
# ============================================================
statement ok
CREATE TABLE hour_window_src (eid VARCHAR, val INTEGER, ts TIMESTAMP);

statement ok
INSERT INTO hour_window_src VALUES
    ('a', 10, '2024-01-01 00:00:00'),
    ('a', 20, '2024-01-01 12:00:00'),
    ('a', 30, '2024-01-02 06:00:00');

statement ok
CREATE FEATURE half_day_feat ON hour_window_src ENTITY eid TIMESTAMP ts GRANULARITY DAY WINDOW 12 HOURS REFRESH FULL RETAIN 1 AS (SELECT eid, SUM(val) AS total FROM hour_window_src GROUP BY eid);

query TIR rowsort
SELECT eid, feature_timestamp, total FROM half_day_feat;
----
a	2024-01-01 00:00:00	10
a	2024-01-01 12:00:00	30
a	2024-01-02 06:00:00	30

# ============================================================
# MIN/MAX features: non-sum aggregates
# ============================================================
statement ok
CREATE FEATURE max_spend ON transactions ENTITY user_id TIMESTAMP ts GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT user_id, MAX(amount) AS peak FROM transactions GROUP BY user_id);

# user 1: peak at each event timestamp
query TR rowsort
SELECT feature_timestamp, peak FROM max_spend WHERE user_id = 1;
----
2024-01-01 10:00:00	100.0
2024-01-02 14:00:00	200.0
2024-01-04 09:00:00	200.0

# user 4: peak at each event timestamp (two events on Jan 1 = 20.0; adding Jan 2 = 30.0)
query TR rowsort
SELECT feature_timestamp, peak FROM max_spend WHERE user_id = 4;
----
2024-01-01 06:00:00	10.0
2024-01-01 22:00:00	20.0
2024-01-02 07:00:00	30.0

# ============================================================
# Cleanup
# ============================================================
statement ok
DROP FEATURE total_spend;

# Backing table gone after DROP FEATURE
statement error
SELECT * FROM total_spend;
----
<REGEX>:.*does not exist.*

# Other features unaffected
query I
SELECT COUNT(*) FROM avg_spend;
----
11

statement ok
DROP TABLE transactions CASCADE;

statement ok
DROP TABLE narrow_window_src CASCADE;

statement ok
DROP TABLE hour_window_src CASCADE;

query I
SELECT COUNT(*) FROM duckdb_features();
----
0
