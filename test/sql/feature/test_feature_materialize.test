# name: test/sql/feature/test_feature_materialize.test
# description: Test snapshot-correct materialization: one row per entity, windowed aggregation, defaults
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# Setup: entity table (incl. user 5 with no events) + event table
# ============================================================
statement ok
CREATE TABLE users (user_id INTEGER PRIMARY KEY);

statement ok
INSERT INTO users VALUES (1), (2), (3), (4), (5);

statement ok
CREATE TABLE transactions (user_id INTEGER, amount DOUBLE, ts TIMESTAMP, FOREIGN KEY (user_id) REFERENCES users(user_id));

statement ok
INSERT INTO transactions VALUES
    (1, 100.0, '2024-01-01 10:00:00'),
    (1, 200.0, '2024-01-02 14:00:00'),
    (1,  50.0, '2024-01-04 09:00:00'),
    (2,  50.0, '2024-01-01 09:00:00'),
    (2,  75.0, '2024-01-03 11:00:00'),
    (2, 120.0, '2024-01-05 17:00:00'),
    (3, 300.0, '2024-01-02 16:00:00'),
    (3, 150.0, '2024-01-03 08:00:00'),
    (4,  10.0, '2024-01-01 06:00:00'),
    (4,  20.0, '2024-01-01 22:00:00'),
    (4,  30.0, '2024-01-02 07:00:00');

# ============================================================
# SUM: one snapshot row per entity; user 5 (no events) defaults to 0
# ============================================================
statement ok
CREATE FEATURE total_spend ENTITY users TIMESTAMP ts WINDOW 7 DAYS RETAIN 1 AS (SELECT user_id, SUM(amount) AS total FROM transactions GROUP BY user_id);

statement ok
REFRESH FEATURE total_spend AT '2024-01-08 00:00:00';

query IR rowsort
SELECT user_id, total FROM total_spend;
----
1	350.0
2	245.0
3	450.0
4	60.0
5	0.0

query I
SELECT COUNT(*) FROM total_spend;
----
5

# ============================================================
# AVG: non-additive aggregate; user 5 stays NULL (no natural zero)
# ============================================================
statement ok
CREATE FEATURE avg_spend ENTITY users TIMESTAMP ts WINDOW 7 DAYS RETAIN 1 AS (SELECT user_id, AVG(amount) AS avg_amt FROM transactions GROUP BY user_id);

statement ok
REFRESH FEATURE avg_spend AT '2024-01-08 00:00:00';

query IR rowsort
SELECT user_id, avg_amt FROM avg_spend;
----
1	116.66666666666667
2	81.66666666666667
3	225.0
4	20.0
5	NULL

# ============================================================
# Multiple aggregates in one feature
# ============================================================
statement ok
CREATE FEATURE multi_agg ENTITY users TIMESTAMP ts WINDOW 7 DAYS RETAIN 1 AS (SELECT user_id, SUM(amount) AS total, COUNT(*) AS cnt, AVG(amount) AS avg_amt FROM transactions GROUP BY user_id);

statement ok
REFRESH FEATURE multi_agg AT '2024-01-08 00:00:00';

query IRIR
SELECT user_id, total, cnt, avg_amt FROM multi_agg WHERE user_id = 1;
----
1	350.0	3	116.66666666666667

# COUNT defaults to 0 for the entity with no events
query I
SELECT cnt FROM multi_agg WHERE user_id = 5;
----
0

# ============================================================
# MAX: NULL default for the no-event entity
# ============================================================
statement ok
CREATE FEATURE max_spend ENTITY users TIMESTAMP ts WINDOW 7 DAYS RETAIN 1 AS (SELECT user_id, MAX(amount) AS peak FROM transactions GROUP BY user_id);

statement ok
REFRESH FEATURE max_spend AT '2024-01-08 00:00:00';

query IR rowsort
SELECT user_id, peak FROM max_spend;
----
1	200.0
2	120.0
3	300.0
4	30.0
5	NULL

# ============================================================
# Window boundary: a 2-day window AT Jan 5 keeps only events in [Jan 3, Jan 5)
# ============================================================
statement ok
CREATE FEATURE narrow ENTITY users TIMESTAMP ts WINDOW 2 DAYS RETAIN 1 AS (SELECT user_id, SUM(amount) AS total FROM transactions GROUP BY user_id);

statement ok
REFRESH FEATURE narrow AT '2024-01-05 00:00:00';

# user1: Jan4 (50); user2: Jan3 11:00 (75); user3: Jan3 08:00 (150);
# user4: none in window (0); user5: none (0)
query IR rowsort
SELECT user_id, total FROM narrow;
----
1	50.0
2	75.0
3	150.0
4	0.0
5	0.0

# ============================================================
# Cleanup
# ============================================================
statement ok
DROP FEATURE total_spend;

statement error
SELECT * FROM total_spend;
----
<REGEX>:.*does not exist.*

query I
SELECT COUNT(*) FROM avg_spend;
----
5

statement ok
DROP TABLE transactions CASCADE;

query I
SELECT COUNT(*) FROM duckdb_features();
----
0
