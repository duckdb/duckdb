# name: test/sql/feature/test_feature_schedule_persistence.test
# description: Test that a feature's refresh schedule survives a database restart
# group: [feature]

load {TEST_DIR}/feature_schedule_persistence.db

statement ok
CREATE TABLE customers (customer VARCHAR PRIMARY KEY);

statement ok
INSERT INTO customers VALUES ('x'), ('y');

statement ok
CREATE TABLE events (customer VARCHAR, value INTEGER, event_time TIMESTAMP, FOREIGN KEY (customer) REFERENCES customers(customer));

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00');

statement ok
CREATE FEATURE sched
    ENTITY customers
    TIMESTAMP event_time
    WINDOW 24 HOURS
    EVERY INTERVAL 90 MINUTES
    RETAIN 3
    AS (SELECT customer, SUM(value) AS total_value FROM events GROUP BY customer);

query II
SELECT schedule_interval, schedule_enabled FROM duckdb_features() WHERE feature_name = 'sched';
----
01:30:00	true

# ============================================================
# Restart 1 — replay the WAL (no checkpoint yet)
# ============================================================
restart

query II
SELECT schedule_interval, schedule_enabled FROM duckdb_features() WHERE feature_name = 'sched';
----
01:30:00	true

# ============================================================
# Force a checkpoint, then restart again
# ============================================================
# The enabled schedule may fire a background refresh, so its write transaction can
# be active here; FORCE CHECKPOINT waits for it instead of erroring out.
statement ok
FORCE CHECKPOINT;

restart

query II
SELECT schedule_interval, schedule_enabled FROM duckdb_features() WHERE feature_name = 'sched';
----
01:30:00	true
