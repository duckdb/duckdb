# name: test/sql/feature/test_feature_persistence.test
# description: Test that features survive a database restart (WAL replay + checkpoint)
# group: [feature]

# Persist to disk so we can reload it
load {TEST_DIR}/feature_persistence.db

# ============================================================
# Setup
# ============================================================
statement ok
CREATE TABLE customers (customer VARCHAR PRIMARY KEY);

statement ok
INSERT INTO customers VALUES ('x'), ('y'), ('z');

statement ok
CREATE TABLE events (
    customer VARCHAR,
    value INTEGER,
    event_time TIMESTAMP,
    FOREIGN KEY (customer) REFERENCES customers(customer)
);

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('x', 20, '2024-01-02 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00'),
    ('y', 15, '2024-01-02 16:00:00'),
    ('z',  5, '2024-01-01 06:00:00');

statement ok
CREATE FEATURE persisted ENTITY customers TIMESTAMP event_time
    WINDOW 7 DAYS
    RETAIN 3
    AS (SELECT customer, SUM(value) AS total_value FROM events GROUP BY customer);

# Three refreshes advance current_version to 3 (each snapshots the same window).
statement ok
REFRESH FEATURE persisted AT '2024-01-03 00:00:00';

statement ok
REFRESH FEATURE persisted AT '2024-01-03 00:00:00';

statement ok
REFRESH FEATURE persisted AT '2024-01-03 00:00:00';

# Sanity check before restart
query II
SELECT feature_name, current_version FROM duckdb_features() WHERE feature_name = 'persisted';
----
persisted	3

query II rowsort
SELECT customer, total_value FROM persisted;
----
x	30
y	45
z	5

# ============================================================
# Restart 1 — replay the WAL (no checkpoint yet)
# ============================================================
restart

# Feature catalog entry survives, including current_version
query II
SELECT feature_name, current_version FROM duckdb_features() WHERE feature_name = 'persisted';
----
persisted	3

# Other metadata survives
query IIIII
SELECT entity_table, source_table, entity_columns, window_interval, retain_versions
FROM duckdb_features() WHERE feature_name = 'persisted';
----
customers	events	customer	7 days	3

# The view still resolves to the current snapshot
query II rowsort
SELECT customer, total_value FROM persisted;
----
x	30
y	45
z	5

# The store table (with three retained versions) survives
query I
SELECT COUNT(*) FROM persisted__store;
----
9

# ============================================================
# Force a checkpoint, then restart again to exercise the checkpoint read path
# ============================================================
statement ok
CHECKPOINT;

restart

query II
SELECT feature_name, current_version FROM duckdb_features() WHERE feature_name = 'persisted';
----
persisted	3

# Refresh still works after reload — version advances from the persisted value
statement ok
REFRESH FEATURE persisted AT '2024-01-03 00:00:00';

query II
SELECT feature_name, current_version FROM duckdb_features() WHERE feature_name = 'persisted';
----
persisted	4

query I
SELECT COUNT(*) FROM persisted__store;
----
9

# ============================================================
# DROP FEATURE cascade still works after reload
# ============================================================
statement ok
DROP FEATURE persisted;

query I
SELECT COUNT(*) FROM duckdb_features() WHERE feature_name = 'persisted';
----
0

statement error
SELECT * FROM persisted;
----
<REGEX>:.*does not exist.*
