# name: test/sql/feature/test_feature_ddl.test
# description: Test CREATE/DROP FEATURE DDL, metadata, validation, and dependencies
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# Setup
# ============================================================
# The snapshot is built over the entity table; the event table must carry a foreign key into it.
statement ok
CREATE TABLE cards (card_no VARCHAR PRIMARY KEY);

statement ok
CREATE TABLE transactions (card_no VARCHAR, amount DECIMAL(10,2), event_time TIMESTAMP, FOREIGN KEY (card_no) REFERENCES cards(card_no));

statement ok
CREATE TABLE events (id INTEGER, name VARCHAR);

statement ok
CREATE TABLE no_fk (uid VARCHAR, amount INTEGER, ts TIMESTAMP);

# ============================================================
# Parser validation
# ============================================================

# Missing ENTITY keyword
statement error
CREATE FEATURE bad TIMESTAMP event_time WINDOW 7 DAYS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);
----
syntax error

# Missing TIMESTAMP keyword
statement error
CREATE FEATURE bad ENTITY cards WINDOW 7 DAYS RETAIN 1 AS (SELECT 1 FROM transactions);
----
syntax error

# ============================================================
# Binder validation
# ============================================================

# Non-existent source table
statement error
CREATE FEATURE bad ENTITY cards TIMESTAMP col2 WINDOW 7 DAYS RETAIN 1 AS (SELECT 1 FROM nonexistent);
----
Table with name nonexistent does not exist

# Non-existent entity column
statement error
CREATE FEATURE bad ENTITY cards TIMESTAMP event_time WINDOW 7 DAYS RETAIN 1 AS (SELECT bad_col, SUM(amount) FROM transactions GROUP BY bad_col);
----
Entity column "bad_col" does not exist

# Non-existent timestamp column
statement error
CREATE FEATURE bad ENTITY cards TIMESTAMP bad_col WINDOW 7 DAYS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);
----
Timestamp column "bad_col" does not exist

# Timestamp column with wrong type (VARCHAR)
statement error
CREATE FEATURE bad ENTITY events TIMESTAMP name WINDOW 7 DAYS RETAIN 1 AS (SELECT id, COUNT(*) FROM events GROUP BY id);
----
must be a temporal type

# Non-existent entity table
statement error
CREATE FEATURE bad ENTITY nonexistent TIMESTAMP event_time WINDOW 7 DAYS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);
----
<REGEX>:.*nonexistent does not exist.*

# Entity columns without a FOREIGN KEY into the entity table
statement error
CREATE FEATURE bad ENTITY cards TIMESTAMP ts WINDOW 7 DAYS RETAIN 1 AS (SELECT uid, SUM(amount) FROM no_fk GROUP BY uid);
----
<REGEX>:.*FOREIGN KEY.*

# ============================================================
# CREATE FEATURE basic
# ============================================================
statement ok
CREATE FEATURE daily_txn ENTITY cards TIMESTAMP event_time  WINDOW 7 DAYS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

# Feature appears in duckdb_features()
query IIIII
SELECT feature_name, entity_table, source_table, entity_columns, window_interval FROM duckdb_features();
----
daily_txn	cards	transactions	card_no	7 days

# DESCRIBE FEATURE shows metadata. current_version is 0 until the first REFRESH materializes v1.
query IIIIIIIIII
DESCRIBE FEATURE daily_txn;
----
daily_txn	cards	transactions	card_no	event_time	1	0	7 days	00:00:00	CREATE FEATURE daily_txn ENTITY cards TIMESTAMP event_time WINDOW INTERVAL '7 days' RETAIN 1 AS (SELECT card_no, sum(amount) FROM transactions GROUP BY card_no)

# DESCRIBE non-existent feature returns empty
query I
SELECT COUNT(*) FROM (DESCRIBE FEATURE nonexistent);
----
0

# Duplicate fails
statement error
CREATE FEATURE daily_txn ENTITY cards TIMESTAMP event_time  WINDOW 7 DAYS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);
----
already exists

# IF NOT EXISTS succeeds silently
statement ok
CREATE FEATURE IF NOT EXISTS daily_txn ENTITY cards TIMESTAMP event_time  WINDOW 7 DAYS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

# HOUR windows work
statement ok
CREATE FEATURE hourly_stats ENTITY cards TIMESTAMP event_time  WINDOW 24 HOURS RETAIN 5 AS (SELECT card_no, AVG(amount) FROM transactions GROUP BY card_no);

# WINDOW accepts explicit interval shorthand
statement ok
CREATE FEATURE explicit_hours ENTITY cards TIMESTAMP event_time  WINDOW 24 HOURS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

query I
SELECT window_interval FROM duckdb_features() WHERE feature_name = 'explicit_hours';
----
24:00:00

query I
SELECT sql FROM duckdb_features() WHERE feature_name = 'explicit_hours';
----
<REGEX>:.*WINDOW INTERVAL '24:00:00'.*

query II
SELECT window_interval, watermark_interval FROM duckdb_features() WHERE feature_name = 'daily_txn';
----
7 days	00:00:00

# WATERMARK accepts explicit interval shorthand independent of WINDOW
statement ok
CREATE FEATURE watermark_minutes ENTITY cards TIMESTAMP event_time  WINDOW 24 HOURS WATERMARK 30 MINUTES RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

query II
SELECT watermark_interval, sql FROM duckdb_features() WHERE feature_name = 'watermark_minutes';
----
00:30:00	CREATE FEATURE watermark_minutes ENTITY cards TIMESTAMP event_time WINDOW INTERVAL '24:00:00' WATERMARK INTERVAL '00:30:00' RETAIN 1 AS (SELECT card_no, sum(amount) FROM transactions GROUP BY card_no)

# WINDOW also accepts INTERVAL string syntax
statement ok
CREATE FEATURE interval_minutes ENTITY cards TIMESTAMP event_time  WINDOW INTERVAL '90 minutes' RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

query I
SELECT window_interval FROM duckdb_features() WHERE feature_name = 'interval_minutes';
----
01:30:00

# WATERMARK also accepts INTERVAL string syntax
statement ok
CREATE FEATURE watermark_interval_string ENTITY cards TIMESTAMP event_time  WINDOW 7 DAYS WATERMARK INTERVAL '2 hours' RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

query II
SELECT watermark_interval, sql FROM duckdb_features() WHERE feature_name = 'watermark_interval_string';
----
02:00:00	CREATE FEATURE watermark_interval_string ENTITY cards TIMESTAMP event_time WINDOW INTERVAL '7 days' WATERMARK INTERVAL '02:00:00' RETAIN 1 AS (SELECT card_no, sum(amount) FROM transactions GROUP BY card_no)

query I
SELECT COUNT(*) FROM duckdb_features();
----
6

statement ok
DROP FEATURE explicit_hours;

statement ok
DROP FEATURE interval_minutes;

statement ok
DROP FEATURE watermark_minutes;

statement ok
DROP FEATURE watermark_interval_string;

# ============================================================
# Default parameter values
# ============================================================

# WINDOW requires an explicit unit
statement error
CREATE FEATURE bare_window ENTITY cards TIMESTAMP event_time WINDOW 3 RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);
----
syntax error

# Explicit day shorthand works
statement ok
CREATE FEATURE explicit_days ENTITY cards TIMESTAMP event_time WINDOW 3 DAYS RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

query II
SELECT feature_name, window_interval FROM duckdb_features() WHERE feature_name = 'explicit_days';
----
explicit_days	3 days

statement ok
DROP FEATURE explicit_days;

# Omit WINDOW -> defaults to 1
statement ok
CREATE FEATURE default_window ENTITY cards TIMESTAMP event_time  RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

query II
SELECT feature_name, window_interval FROM duckdb_features() WHERE feature_name = 'default_window';
----
default_window	1 day

statement ok
DROP FEATURE default_window;

# Omit RETAIN -> defaults to 1
statement ok
CREATE FEATURE default_retain ENTITY cards TIMESTAMP event_time  WINDOW 3 DAYS AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

query II
SELECT feature_name, retain_versions FROM duckdb_features() WHERE feature_name = 'default_retain';
----
default_retain	1

statement ok
DROP FEATURE default_retain;

# Omit all optional params -> all defaults applied
statement ok
CREATE FEATURE all_defaults ENTITY cards TIMESTAMP event_time AS (SELECT card_no, COUNT(*) AS cnt FROM transactions GROUP BY card_no);

query IIII
SELECT feature_name, window_interval, watermark_interval, retain_versions FROM duckdb_features() WHERE feature_name = 'all_defaults';
----
all_defaults	1 day	00:00:00	1

statement ok
DROP FEATURE all_defaults;

# ============================================================
# DROP FEATURE
# ============================================================
statement ok
DROP FEATURE hourly_stats;

query I
SELECT COUNT(*) FROM duckdb_features();
----
1

# DROP IF EXISTS on non-existent: no error
statement ok
DROP FEATURE IF EXISTS nonexistent_feature;

# DROP non-existent: error
statement error
DROP FEATURE nonexistent_feature;
----
does not exist

# ============================================================
# Dependencies: DROP TABLE blocked, CASCADE removes feature
# ============================================================

# DROP TABLE blocked by feature dependency
statement error
DROP TABLE transactions;
----
there are entries that depend on it

# CASCADE removes feature AND its backing table
statement ok
DROP TABLE transactions CASCADE;

query I
SELECT COUNT(*) FROM duckdb_features();
----
0

# Backing table gone too
statement error
SELECT * FROM daily_txn;
----
<REGEX>:.*does not exist.*

# ============================================================
# Cascade chains: multiple features on different tables
# ============================================================
statement ok
CREATE TABLE entities (entity_id VARCHAR PRIMARY KEY);

statement ok
CREATE TABLE t1 (entity_id VARCHAR, val DECIMAL, ts TIMESTAMP, FOREIGN KEY (entity_id) REFERENCES entities(entity_id));

statement ok
CREATE TABLE t2 (entity_id VARCHAR, score INTEGER, ts TIMESTAMP, FOREIGN KEY (entity_id) REFERENCES entities(entity_id));

statement ok
CREATE FEATURE feat_t1 ENTITY entities TIMESTAMP ts  WINDOW 7 DAYS RETAIN 1 AS (SELECT entity_id, SUM(val) FROM t1 GROUP BY entity_id);

statement ok
CREATE FEATURE feat_t2 ENTITY entities TIMESTAMP ts  WINDOW 24 HOURS RETAIN 3 AS (SELECT entity_id, AVG(score) FROM t2 GROUP BY entity_id);

query I
SELECT COUNT(*) FROM duckdb_features();
----
2

# Drop t1 CASCADE only removes feat_t1
statement ok
DROP TABLE t1 CASCADE;

query II
SELECT feature_name, source_table FROM duckdb_features();
----
feat_t2	t2

# Drop t2 CASCADE removes feat_t2
statement ok
DROP TABLE t2 CASCADE;

query I
SELECT COUNT(*) FROM duckdb_features();
----
0

statement ok
DROP TABLE events;
