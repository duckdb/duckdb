# name: test/sql/feature/test_feature_cascade_chain.test
# description: Test cascading drops through dependency chains (table2 -> view/table1 -> feature)
# group: [feature]

# Setup: table2 is the base, table1 is a view depending on table2, feature depends on table1
statement ok
CREATE TABLE base_table (card_no VARCHAR, amount DECIMAL, event_time TIMESTAMP);

statement ok
CREATE VIEW derived_view AS SELECT card_no, amount, event_time FROM base_table;

# Feature depends on a view that depends on base_table
# Views are tables for the purpose of column lookups
statement ok
CREATE TABLE derived_table (card_no VARCHAR, total DECIMAL, event_time TIMESTAMP);

statement ok
CREATE FEATURE feat_on_derived ON derived_table ENTITY card_no TIMESTAMP event_time GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT card_no, SUM(total) FROM derived_table GROUP BY card_no);

# Add a foreign key style dependency: derived_table has no FK but let's test chain with another feature on base
statement ok
CREATE FEATURE feat_on_base ON base_table ENTITY card_no TIMESTAMP event_time GRANULARITY HOUR WINDOW 24 REFRESH FULL RETAIN 3 AS (SELECT card_no, SUM(amount) FROM base_table GROUP BY card_no);

# Both features exist
query I
SELECT COUNT(*) FROM duckdb_features();
----
2

# Drop base_table without CASCADE should be blocked by feat_on_base
statement error
DROP TABLE base_table;
----
there are entries that depend on it

# Drop derived_table without CASCADE should be blocked by feat_on_derived
statement error
DROP TABLE derived_table;
----
there are entries that depend on it

# CASCADE drop of derived_table removes feat_on_derived but not feat_on_base
statement ok
DROP TABLE derived_table CASCADE;

query II
SELECT feature_name, source_table FROM duckdb_features();
----
feat_on_base	base_table

# CASCADE drop of base_table removes feat_on_base
statement ok
DROP TABLE base_table CASCADE;

query I
SELECT COUNT(*) FROM duckdb_features();
----
0
