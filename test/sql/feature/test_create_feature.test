# name: test/sql/feature/test_create_feature.test
# description: Test CREATE FEATURE syntax
# group: [feature]

statement ok
CREATE TABLE transactions (card_no VARCHAR, amount DECIMAL, event_time TIMESTAMP);

# Basic CREATE FEATURE succeeds
statement ok
CREATE FEATURE daily_txn_stats ON transactions ENTITY card_no TIMESTAMP event_time GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

# Feature appears in duckdb_features()
query IIIII
SELECT feature_name, source_table, entity_column, granularity, window_size FROM duckdb_features();
----
daily_txn_stats	transactions	card_no	DAY	7

# Duplicate feature fails
statement error
CREATE FEATURE daily_txn_stats ON transactions ENTITY card_no TIMESTAMP event_time GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);
----
already exists

# IF NOT EXISTS does not error
statement ok
CREATE FEATURE IF NOT EXISTS daily_txn_stats ON transactions ENTITY card_no TIMESTAMP event_time GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT card_no, SUM(amount) FROM transactions GROUP BY card_no);

# Different granularities
statement ok
CREATE FEATURE hourly_stats ON transactions ENTITY card_no TIMESTAMP event_time GRANULARITY HOUR WINDOW 24 REFRESH INCREMENTAL RETAIN 5 AS (SELECT card_no, AVG(amount) FROM transactions GROUP BY card_no);

query I
SELECT COUNT(*) FROM duckdb_features();
----
2

# DROP FEATURE
statement ok
DROP FEATURE hourly_stats;

query I
SELECT COUNT(*) FROM duckdb_features();
----
1

# DROP FEATURE IF EXISTS (non-existent)
statement ok
DROP FEATURE IF EXISTS nonexistent_feature;

# DROP FEATURE (non-existent, should error)
statement error
DROP FEATURE nonexistent_feature;
----
does not exist

# DROP TABLE blocked by dependency
statement error
DROP TABLE transactions;
----
there are entries that depend on it

# DROP TABLE CASCADE removes feature too
statement ok
DROP TABLE transactions CASCADE;

query I
SELECT COUNT(*) FROM duckdb_features();
----
0
