# name: test/sql/feature/test_feature_drop_gc_check.test
# description: Verify only the latest store table survives, retention lives in the rows, DROP removes all
# group: [feature]

require noforcestorage

require skip_reload

statement ok
CREATE TABLE customers (customer VARCHAR PRIMARY KEY);

statement ok
INSERT INTO customers VALUES ('x'), ('y');

statement ok
CREATE TABLE events (
    customer VARCHAR,
    value INTEGER,
    event_time TIMESTAMP,
    FOREIGN KEY (customer) REFERENCES customers(customer)
);

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('x', 20, '2024-01-02 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00');

# ============================================================
# RETAIN 2: the store carries at most two versions; only the latest store table exists
# ============================================================
statement ok
CREATE FEATURE f ENTITY customers TIMESTAMP event_time
    WINDOW 7 DAYS
    RETAIN 2
    AS (SELECT customer, SUM(value) AS total_value FROM events GROUP BY customer);

statement ok
REFRESH FEATURE f AT '2024-01-03 00:00:00';

# After the first refresh: exactly one store table (v1), holding version 1 only (2 entity rows)
query I
SELECT COUNT(*) FROM duckdb_tables WHERE table_name LIKE 'f\_\_v%' ESCAPE '\';
----
1

query I
SELECT COUNT(*) FROM f__v1;
----
2

# Second refresh: still exactly one store table (v2), now holding versions 1 and 2
statement ok
REFRESH FEATURE f AT '2024-01-03 00:00:00';

query I
SELECT table_name FROM duckdb_tables WHERE table_name LIKE 'f\_\_v%' ESCAPE '\';
----
f__v2

query I
SELECT COUNT(DISTINCT __feature_version) FROM f__v2;
----
2

# Third refresh: RETAIN 2 evicts version 1; the store holds versions 2 and 3
statement ok
REFRESH FEATURE f AT '2024-01-03 00:00:00';

query I
SELECT table_name FROM duckdb_tables WHERE table_name LIKE 'f\_\_v%' ESCAPE '\';
----
f__v3

query II rowsort
SELECT __feature_version, COUNT(*) FROM f__v3 GROUP BY __feature_version;
----
2	2
3	2

# ============================================================
# DROP FEATURE: the store table and the view are both removed
# ============================================================
statement ok
DROP FEATURE f;

query I
SELECT COUNT(*) FROM duckdb_tables WHERE table_name LIKE 'f\_\_v%' ESCAPE '\';
----
0

query I
SELECT COUNT(*) FROM duckdb_features() WHERE feature_name = 'f';
----
0

query I
SELECT COUNT(*) FROM duckdb_views WHERE view_name = 'f';
----
0

statement ok
DROP TABLE events;
