# name: test/sql/feature/test_feature_drop_gc_check.test
# description: Verify the single persistent store, in-place version eviction, and DROP cleanup
# group: [feature]

require noforcestorage

require skip_reload

statement ok
CREATE TABLE customers (customer VARCHAR);

statement ok
INSERT INTO customers VALUES ('x'), ('y');

statement ok
CREATE TABLE events (
    customer VARCHAR,
    value INTEGER,
    event_time TIMESTAMP
);

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('x', 20, '2024-01-02 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00');

# ============================================================
# RETAIN 2: one persistent store table; old versions are deleted in place
# ============================================================
statement ok
CREATE FEATURE f ENTITY customers TIMESTAMP event_time
    WINDOW 7 DAYS
    RETAIN 2
    AS (SELECT customer, SUM(value) AS total_value FROM events GROUP BY customer);

statement ok
REFRESH FEATURE f AT '2024-01-03 00:00:00';

# After the first refresh: exactly one store table (f__store), holding version 1 (2 entity rows)
query I
SELECT table_name FROM duckdb_tables WHERE table_name LIKE 'f\_\_%' ESCAPE '\';
----
f__store

query I
SELECT COUNT(*) FROM f__store;
----
2

# Second refresh: still one store table, now holding versions 1 and 2
statement ok
REFRESH FEATURE f AT '2024-01-03 00:00:00';

query I
SELECT COUNT(*) FROM duckdb_tables WHERE table_name LIKE 'f\_\_%' ESCAPE '\';
----
1

query I
SELECT COUNT(DISTINCT __feature_version) FROM f__store;
----
2

# Third refresh: RETAIN 2 evicts version 1 in place; the store holds versions 2 and 3, still 4 rows
statement ok
REFRESH FEATURE f AT '2024-01-03 00:00:00';

query II rowsort
SELECT __feature_version, COUNT(*) FROM f__store GROUP BY __feature_version;
----
2	2
3	2

query I
SELECT COUNT(*) FROM f__store;
----
4

# ============================================================
# DROP FEATURE: the store table and the view are both removed
# ============================================================
statement ok
DROP FEATURE f;

query I
SELECT COUNT(*) FROM duckdb_tables WHERE table_name LIKE 'f\_\_%' ESCAPE '\';
----
0

query I
SELECT COUNT(*) FROM duckdb_features() WHERE feature_name = 'f';
----
0

query I
SELECT COUNT(*) FROM duckdb_views WHERE view_name = 'f';
----
0

statement ok
DROP TABLE events;
