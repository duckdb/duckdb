# name: test/sql/feature/test_feature_scheduler.test_slow
# description: Test that FeatureRefreshScheduler automatically refreshes scheduled features in the background
# group: [feature]

# Use a persistent database so the scheduler can scan the catalog after a restart.
load {TEST_DIR}/feature_scheduler.db

statement ok
CREATE TABLE users (UserID VARCHAR);

statement ok
INSERT INTO users VALUES ('alice'), ('bob');

statement ok
CREATE TABLE hits (UserID VARCHAR, EventTime TIMESTAMP);

statement ok
INSERT INTO hits VALUES
    ('alice', '2024-01-01 08:00:00'),
    ('alice', '2024-01-01 14:00:00'),
    ('bob',   '2024-01-01 12:00:00');

# ============================================================
# Feature WITH a 1-second schedule
# ============================================================
statement ok
CREATE FEATURE auto_sched
    ENTITY users
    TIMESTAMP EventTime
    WINDOW 24 HOURS
    EVERY INTERVAL 1 SECOND
    RETAIN 20
    AS (SELECT UserID, COUNT(*) AS event_count FROM hits GROUP BY UserID);

# ============================================================
# Feature WITHOUT a schedule (should never be auto-refreshed)
# ============================================================
statement ok
CREATE FEATURE no_sched
    ENTITY users
    TIMESTAMP EventTime
    WINDOW 24 HOURS
    RETAIN 20
    AS (SELECT UserID, COUNT(*) AS event_count FROM hits GROUP BY UserID);

# Both start at version 0: CREATE FEATURE only registers metadata, nothing is materialized yet.
query I
SELECT current_version FROM duckdb_features() WHERE feature_name = 'auto_sched';
----
0

query I
SELECT current_version FROM duckdb_features() WHERE feature_name = 'no_sched';
----
0

# ============================================================
# Restart so the scheduler scans the catalog and picks up
# both features from the committed WAL.
# ============================================================
restart

# ============================================================
# Give the background thread time to fire the 1-second
# schedule at least twice (3 s >> 1 s interval + startup time).
# ============================================================
sleep 3 seconds

# The scheduled feature must have been refreshed automatically (bootstrapped to v1 or beyond).
query I
SELECT current_version > 0 FROM duckdb_features() WHERE feature_name = 'auto_sched';
----
true

# The unscheduled feature must remain untouched at version 0 (never refreshed).
query I
SELECT current_version FROM duckdb_features() WHERE feature_name = 'no_sched';
----
0

# ============================================================
# The scheduler continues running: wait another 2 seconds and
# verify the version advanced again beyond the first check.
# ============================================================
sleep 2 seconds

# After 5 s total with a 1-second interval the version must have advanced again (well above v1).
query I
SELECT current_version > 1 FROM duckdb_features() WHERE feature_name = 'auto_sched';
----
true
