# name: test/sql/feature/test_feature_validation.test
# description: Test CREATE FEATURE binder validation
# group: [feature]

statement ok
CREATE TABLE transactions (card_no VARCHAR, amount DECIMAL, event_time TIMESTAMP);

statement ok
CREATE TABLE t2 (id INTEGER, name VARCHAR);

# Non-existent table
statement error
CREATE FEATURE bad ON nonexistent ENTITY col1 TIMESTAMP col2 GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT 1);
----
Table with name nonexistent does not exist

# Non-existent entity column
statement error
CREATE FEATURE bad ON transactions ENTITY bad_col TIMESTAMP event_time GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT 1);
----
Entity column "bad_col" does not exist

# Non-existent timestamp column
statement error
CREATE FEATURE bad ON transactions ENTITY card_no TIMESTAMP bad_col GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT 1);
----
Timestamp column "bad_col" does not exist

# Timestamp column with wrong type
statement error
CREATE FEATURE bad ON t2 ENTITY id TIMESTAMP name GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT 1);
----
must be a temporal type

# Missing TIMESTAMP keyword (parser error)
statement error
CREATE FEATURE bad ON transactions ENTITY card_no GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT 1);
----
syntax error

# Missing GRANULARITY keyword (parser error)
statement error
CREATE FEATURE bad ON transactions ENTITY card_no TIMESTAMP event_time WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT 1);
----
syntax error
