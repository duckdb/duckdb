# name: test/sql/feature/test_serve_feature.test
# description: Test SERVE FEATURE statement for point-in-time feature retrieval
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# Setup: create source data and feature
# ============================================================
statement ok
CREATE TABLE transactions (card_no VARCHAR, amount DECIMAL(10,2), event_time TIMESTAMP);

statement ok
INSERT INTO transactions VALUES
    ('C001', 100.00, '2024-03-01 10:00:00'),
    ('C001', 200.00, '2024-03-01 14:00:00'),
    ('C001', 50.00, '2024-03-02 09:00:00'),
    ('C002', 75.00, '2024-03-01 11:00:00'),
    ('C002', 300.00, '2024-03-02 16:00:00'),
    ('C002', 25.00, '2024-03-03 08:00:00');

statement ok
CREATE FEATURE daily_txn ON transactions ENTITY card_no TIMESTAMP event_time GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT card_no, SUM(amount) AS total_amount, COUNT(amount) AS txn_count FROM transactions GROUP BY card_no);

# ============================================================
# SERVE FEATURE: basic retrieval (same column names, no explicit ENTITY/ASOF)
# ============================================================

# Create a spine (incoming request data) with SAME column names as feature
statement ok
CREATE TABLE requests (card_no VARCHAR, event_time TIMESTAMP);

statement ok
INSERT INTO requests VALUES
    ('C001', '2024-03-02 12:00:00'),
    ('C002', '2024-03-03 10:00:00');

# Serve the feature for the spine — no ENTITY/ASOF needed since column names match
query IIIII sort
SERVE FEATURE daily_txn FOR requests;
----
C001	2024-03-02 12:00:00	2024-03-02 00:00:00	300.00	2
C002	2024-03-03 10:00:00	2024-03-03 00:00:00	375.00	2

# ============================================================
# SERVE FEATURE: explicit ENTITY and ASOF (different column names)
# ============================================================

statement ok
CREATE TABLE incoming (customer_id VARCHAR, request_time TIMESTAMP, payload VARCHAR);

statement ok
INSERT INTO incoming VALUES
    ('C001', '2024-03-02 12:00:00', 'data1'),
    ('C002', '2024-03-03 10:00:00', 'data2');

# Spine has different column names — specify mapping
query IIIIII sort
SERVE FEATURE daily_txn FOR incoming ENTITY customer_id ASOF request_time;
----
C001	2024-03-02 12:00:00	data1	2024-03-02 00:00:00	300.00	2
C002	2024-03-03 10:00:00	data2	2024-03-03 00:00:00	375.00	2

# ============================================================
# SERVE FEATURE: only ENTITY override (ASOF defaults to feature's timestamp col name)
# ============================================================

statement ok
CREATE TABLE requests2 (customer_id VARCHAR, event_time TIMESTAMP);

statement ok
INSERT INTO requests2 VALUES
    ('C001', '2024-03-02 12:00:00'),
    ('C002', '2024-03-03 10:00:00');

# event_time matches feature's timestamp column, but entity doesn't
query IIIII sort
SERVE FEATURE daily_txn FOR requests2 ENTITY customer_id;
----
C001	2024-03-02 12:00:00	2024-03-02 00:00:00	300.00	2
C002	2024-03-03 10:00:00	2024-03-03 00:00:00	375.00	2

# ============================================================
# SERVE FEATURE: only ASOF override (ENTITY defaults to same col name)
# ============================================================

statement ok
CREATE TABLE requests3 (card_no VARCHAR, ts TIMESTAMP);

statement ok
INSERT INTO requests3 VALUES
    ('C001', '2024-03-02 12:00:00'),
    ('C002', '2024-03-03 10:00:00');

# card_no matches feature's entity column, but timestamp doesn't
query IIIII sort
SERVE FEATURE daily_txn FOR requests3 ASOF ts;
----
C001	2024-03-02 12:00:00	2024-03-02 00:00:00	300.00	2
C002	2024-03-03 10:00:00	2024-03-03 00:00:00	375.00	2

# ============================================================
# SERVE FEATURE: uses only current version
# ============================================================

# Refresh the feature (creates version 2)
statement ok
INSERT INTO transactions VALUES ('C001', 999.00, '2024-03-03 10:00:00');

statement ok
REFRESH FEATURE daily_txn;

# Serve again - should use version 2 data (new version only)
query IIIII sort
SERVE FEATURE daily_txn FOR requests;
----
C001	2024-03-02 12:00:00	2024-03-02 00:00:00	300.00	2
C002	2024-03-03 10:00:00	2024-03-03 00:00:00	375.00	2

# ============================================================
# SERVE FEATURE: parser validation
# ============================================================

# Missing FOR
statement error
SERVE FEATURE daily_txn ASOF request_time;
----
syntax error

# Non-existent feature
statement error
SERVE FEATURE nonexistent FOR requests;
----
does not exist

# Non-existent spine table
statement error
SERVE FEATURE daily_txn FOR nonexistent_table;
----
does not exist

# ============================================================
# SERVE FEATURES (plural) with multiple features
# ============================================================

statement ok
CREATE FEATURE daily_txn_avg ON transactions ENTITY card_no TIMESTAMP event_time GRANULARITY DAY WINDOW 7 REFRESH FULL RETAIN 1 AS (SELECT card_no, AVG(amount) AS avg_amount FROM transactions GROUP BY card_no);

query IIIIIII sort
SERVE FEATURES daily_txn, daily_txn_avg FOR requests;
----
C001	2024-03-02 12:00:00	2024-03-02 00:00:00	300.00	2	2024-03-02 00:00:00	150.0
C002	2024-03-03 10:00:00	2024-03-03 00:00:00	375.00	2	2024-03-03 00:00:00	187.5

# Multiple features with explicit entity/as_of
query IIIIIIII sort
SERVE FEATURES daily_txn, daily_txn_avg FOR incoming ENTITY customer_id ASOF request_time;
----
C001	2024-03-02 12:00:00	data1	2024-03-02 00:00:00	300.00	2	2024-03-02 00:00:00	150.0
C002	2024-03-03 10:00:00	data2	2024-03-03 00:00:00	375.00	2	2024-03-03 00:00:00	187.5

# ============================================================
# SERVE FEATURE: LEFT ASOF semantics — unmatched spine rows are retained
# with NULL feature columns instead of being dropped.
# ============================================================

statement ok
CREATE TABLE mixed (card_no VARCHAR, event_time TIMESTAMP);

statement ok
INSERT INTO mixed VALUES
    ('C001', '2024-03-02 12:00:00'),
    ('C001', '2024-03-01 12:00:00'),
    ('C999', '2024-03-02 12:00:00');

# C001 @ 03-02 matches the 03-02 feature row (300/2).
# C001 @ 03-01 is earlier than any feature_timestamp for C001 -> NULL features.
# C999 has no feature rows at all -> NULL features.
query IIIII sort
SERVE FEATURE daily_txn FOR mixed;
----
C001	2024-03-01 12:00:00	NULL	NULL	NULL
C001	2024-03-02 12:00:00	2024-03-02 00:00:00	300.00	2
C999	2024-03-02 12:00:00	NULL	NULL	NULL

# LEFT ASOF also applies to multi-feature serving: both features are NULL
# for unmatched spine rows.
query IIIIIII sort
SERVE FEATURES daily_txn, daily_txn_avg FOR mixed;
----
C001	2024-03-01 12:00:00	NULL	NULL	NULL	NULL	NULL
C001	2024-03-02 12:00:00	2024-03-02 00:00:00	300.00	2	2024-03-02 00:00:00	150.0
C999	2024-03-02 12:00:00	NULL	NULL	NULL	NULL	NULL

# ============================================================
# Cleanup
# ============================================================
statement ok
DROP TABLE transactions CASCADE;

statement ok
DROP TABLE requests;

statement ok
DROP TABLE incoming;

statement ok
DROP TABLE requests2;

statement ok
DROP TABLE requests3;

statement ok
DROP TABLE mixed;
