# name: test/sql/feature/test_feature_refresh.test
# description: Test REFRESH FEATURE statement — FULL and INCREMENTAL (watermark + window)
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# FULL refresh: delete everything, recompute from scratch
# ============================================================
statement ok
CREATE TABLE transactions (
    user_id VARCHAR,
    amount DECIMAL(10,2),
    ts TIMESTAMP
);

statement ok
INSERT INTO transactions VALUES
    ('alice', 100.00, '2024-01-01 10:00:00'),
    ('alice', 200.00, '2024-01-01 14:00:00'),
    ('bob',   50.00,  '2024-01-01 09:00:00'),
    ('bob',   75.00,  '2024-01-02 11:00:00'),
    ('carol', 400.00, '2024-01-02 08:00:00'),
    ('carol', 150.00, '2024-01-03 10:00:00');

statement ok
CREATE FEATURE total_spend ON transactions
    ENTITY user_id
    TIMESTAMP ts 
    WINDOW 7 DAYS
    REFRESH FULL
    RETAIN 1
    AS (SELECT user_id, SUM(amount) AS total_amount, COUNT(*) AS tx_count);

# Initial state: one feature row per source event timestamp
query I
SELECT COUNT(*) FROM total_spend;
----
6

# Verify initial values for each entity
query RT rowsort
SELECT total_amount, feature_timestamp FROM total_spend WHERE user_id = 'alice';
----
100.00	2024-01-01 10:00:00
300.00	2024-01-01 14:00:00

query RT rowsort
SELECT total_amount, feature_timestamp FROM total_spend WHERE user_id = 'bob';
----
125.00	2024-01-02 11:00:00
50.00	2024-01-01 09:00:00

query RT rowsort
SELECT total_amount, feature_timestamp FROM total_spend WHERE user_id = 'carol';
----
400.00	2024-01-02 08:00:00
550.00	2024-01-03 10:00:00

# Add new data to source
statement ok
INSERT INTO transactions VALUES
    ('alice',   300.00, '2024-01-03 08:00:00'),
    ('alice',    50.00, '2024-01-04 12:00:00'),
    ('charlie',  25.00, '2024-01-01 12:00:00'),
    ('charlie',  75.00, '2024-01-03 15:00:00');

# FULL refresh picks up everything
# alice: 4 timestamps; bob: 2; carol: 2; charlie: 2
query I
REFRESH FEATURE total_spend;
----
10

query I
SELECT COUNT(*) FROM total_spend;
----
10

# New entity charlie exists with 2 event-time feature rows
query I
SELECT COUNT(*) FROM total_spend WHERE user_id = 'charlie';
----
2

# Alice's Jan 3 event timestamp: 100+200+300 = 600 (all within 7-day window)
query R
SELECT total_amount FROM total_spend WHERE user_id = 'alice' AND feature_timestamp = '2024-01-03 08:00:00'::TIMESTAMP;
----
600.00

# Alice's Jan 4 event timestamp: all 4 events = 650.00
query R
SELECT total_amount FROM total_spend WHERE user_id = 'alice' AND feature_timestamp = '2024-01-04 12:00:00'::TIMESTAMP;
----
650.00

# Charlie: 25.00 at first event timestamp, then 25+75=100.00 at second event timestamp
query RT rowsort
SELECT total_amount, feature_timestamp FROM total_spend WHERE user_id = 'charlie';
----
100.00	2024-01-03 15:00:00
25.00	2024-01-01 12:00:00

# tx_count is correct: alice @ 01-01 14:00 has 2 events (both on Jan 1)
query I
SELECT tx_count FROM total_spend WHERE user_id = 'alice' AND feature_timestamp = '2024-01-01 14:00:00'::TIMESTAMP;
----
2

# Idempotent: running FULL refresh again gives same results
query I
REFRESH FEATURE total_spend;
----
10

statement ok
DROP FEATURE total_spend;

statement ok
DROP TABLE transactions;

# ============================================================
# INCREMENTAL refresh: watermark + window approach
# ============================================================
statement ok
CREATE TABLE events (
    customer VARCHAR,
    value INTEGER,
    event_time TIMESTAMP
);

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('x', 20, '2024-01-02 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00'),
    ('y', 15, '2024-01-02 15:00:00'),
    ('z',  5, '2024-01-01 06:00:00');

statement ok
CREATE FEATURE event_sum ON events
    ENTITY customer
    TIMESTAMP event_time 
    WINDOW 7 DAYS
    REFRESH INCREMENTAL
    RETAIN 1
    AS (SELECT customer, SUM(value) AS total_value);

# Initial: 5 rows
# x has two event-time rows, y has two, z has one.
query I
SELECT COUNT(*) FROM event_sum;
----
5

query II rowsort
SELECT customer, total_value FROM event_sum WHERE feature_timestamp IN ('2024-01-01 08:00:00'::TIMESTAMP, '2024-01-01 12:00:00'::TIMESTAMP, '2024-01-01 06:00:00'::TIMESTAMP);
----
x	10
y	30
z	5

query II rowsort
SELECT customer, total_value FROM event_sum WHERE feature_timestamp IN ('2024-01-02 08:00:00'::TIMESTAMP, '2024-01-02 15:00:00'::TIMESTAMP);
----
x	30
y	45

# ---- Scenario 1: Append new data beyond watermark ----
statement ok
INSERT INTO events VALUES
    ('x', 40, '2024-01-03 09:00:00'),
    ('y', 50, '2024-01-03 10:00:00'),
    ('z', 60, '2024-01-03 14:00:00');

# Default watermark is zero, so recompute runs from max(feature_timestamp) onward.
query I
REFRESH FEATURE event_sum;
----
4

query II rowsort
SELECT customer, total_value FROM event_sum WHERE feature_timestamp IN ('2024-01-01 08:00:00'::TIMESTAMP, '2024-01-01 12:00:00'::TIMESTAMP, '2024-01-01 06:00:00'::TIMESTAMP) ORDER BY customer;
----
x	10
y	30
z	5

# Jan 2 timestamps are unchanged by Jan 3 data.
query II rowsort
SELECT customer, total_value FROM event_sum WHERE feature_timestamp IN ('2024-01-02 08:00:00'::TIMESTAMP, '2024-01-02 15:00:00'::TIMESTAMP) ORDER BY customer;
----
x	30
y	45

# Jan 3 event timestamps: x=10+20+40=70, y=30+15+50=95, z=5+60=65 (7-day window lookback)
query II rowsort
SELECT customer, total_value FROM event_sum WHERE feature_timestamp IN ('2024-01-03 09:00:00'::TIMESTAMP, '2024-01-03 10:00:00'::TIMESTAMP, '2024-01-03 14:00:00'::TIMESTAMP) ORDER BY customer;
----
x	70
y	95
z	65

# ---- Scenario 2: No new data — refresh still recomputes the tail ----
# A refresh always recomputes the event-time tail and bumps the version, even
# when no source rows changed. The recomputed values are identical.
query I
REFRESH FEATURE event_sum;
----
1

# ---- Scenario 3: Add more data, verify watermark advances ----
statement ok
INSERT INTO events VALUES
    ('x', 100, '2024-01-05 12:00:00'),
    ('y',  80, '2024-01-06 09:00:00');

# New data plus the current max timestamp are processed forward.
query I
REFRESH FEATURE event_sum;
----
3

# Jan 5 timestamp: x sees 10+20+40+100=170
query II rowsort
SELECT customer, total_value FROM event_sum WHERE feature_timestamp = '2024-01-05 12:00:00'::TIMESTAMP ORDER BY customer;
----
x	170

# Jan 6 timestamp: y sees 30+15+50+80=175
query II rowsort
SELECT customer, total_value FROM event_sum WHERE feature_timestamp = '2024-01-06 09:00:00'::TIMESTAMP ORDER BY customer;
----
y	175

# Earliest timestamps are still untouched from original
query II
SELECT customer, total_value FROM event_sum WHERE feature_timestamp = '2024-01-01 08:00:00'::TIMESTAMP AND customer = 'x';
----
x	10

query II
SELECT customer, total_value FROM event_sum WHERE feature_timestamp = '2024-01-02 15:00:00'::TIMESTAMP AND customer = 'y';
----
y	45

# ---- Scenario 4: Add a new entity after initial materialization ----
statement ok
INSERT INTO events VALUES
    ('w', 200, '2024-01-07 10:00:00');

# New entity w arrives on Jan 7; the current max timestamp is recomputed too.
query I
REFRESH FEATURE event_sum;
----
2

query II
SELECT customer, total_value FROM event_sum WHERE feature_timestamp = '2024-01-07 10:00:00'::TIMESTAMP;
----
w	200

# ============================================================
# INCREMENTAL refresh: late-arriving data inside the watermark interval
# ============================================================
# After initial materialization, a new row arrives before the current max timestamp.
# The explicit watermark interval makes refresh recompute far enough back to pick it up.

statement ok
CREATE TABLE late_events (
    entity VARCHAR,
    val INTEGER,
    ts TIMESTAMP
);

statement ok
INSERT INTO late_events VALUES
    ('a', 10, '2024-01-01 08:00:00'),
    ('a', 20, '2024-01-02 08:00:00');

statement ok
CREATE FEATURE late_test ON late_events
    ENTITY entity
    TIMESTAMP ts 
    WINDOW 7 DAYS
    WATERMARK 1 DAY
    REFRESH INCREMENTAL
    RETAIN 1
    AS (SELECT entity, SUM(val) AS total);

# Initial materialization: one row per source timestamp.
query I
SELECT COUNT(*) FROM late_test;
----
2

query RT rowsort
SELECT total, feature_timestamp FROM late_test WHERE entity = 'a';
----
10	2024-01-01 08:00:00
30	2024-01-02 08:00:00

# Insert a late row before the current max timestamp, but inside the watermark interval.
statement ok
INSERT INTO late_events VALUES ('a', 5, '2024-01-02 06:00:00');

# Refresh recomputes from max(feature_timestamp) - watermark_interval, picking up the late arrival.
query I
REFRESH FEATURE late_test;
----
3

# First timestamp unchanged: only the Jan 1 event (10) is in its lookback window.
query R
SELECT total FROM late_test WHERE entity = 'a' AND feature_timestamp = '2024-01-01 08:00:00'::TIMESTAMP;
----
10

# Late timestamp has Jan 1 (10) + Jan 2 late (5) = 15.
query R
SELECT total FROM late_test WHERE entity = 'a' AND feature_timestamp = '2024-01-02 06:00:00'::TIMESTAMP;
----
15

# The original Jan 2 timestamp sees the late row too.
query R
SELECT total FROM late_test WHERE entity = 'a' AND feature_timestamp = '2024-01-02 08:00:00'::TIMESTAMP;
----
35

# Another refresh with no new data still recomputes the watermark tail and bumps the version.
query I
REFRESH FEATURE late_test;
----
3

statement ok
DROP FEATURE late_test;

statement ok
DROP TABLE late_events;

# ============================================================
# INCREMENTAL refresh: different watermark intervals on the same source
# ============================================================
# A zero watermark only recomputes the current max timestamp anchor. A wider
# watermark also creates late-arriving anchors that fall inside the interval.

statement ok
CREATE TABLE watermark_events (
    entity VARCHAR,
    val INTEGER,
    ts TIMESTAMP
);

statement ok
INSERT INTO watermark_events VALUES
    ('a', 10, '2024-01-01 08:00:00'),
    ('a', 20, '2024-01-03 08:00:00');

statement ok
CREATE FEATURE wm_zero ON watermark_events
    ENTITY entity
    TIMESTAMP ts
    WINDOW 7 DAYS
    REFRESH INCREMENTAL
    RETAIN 1
    AS (SELECT entity, SUM(val) AS total);

statement ok
CREATE FEATURE wm_two_days ON watermark_events
    ENTITY entity
    TIMESTAMP ts
    WINDOW 7 DAYS
    WATERMARK 2 DAYS
    REFRESH INCREMENTAL
    RETAIN 1
    AS (SELECT entity, SUM(val) AS total);

statement ok
INSERT INTO watermark_events VALUES ('a', 5, '2024-01-02 08:00:00');

query I
REFRESH FEATURE wm_zero;
----
1

query I
REFRESH FEATURE wm_two_days;
----
3

# The zero-watermark feature recomputes the max timestamp, so the late value is
# included in the Jan 3 aggregate, but no Jan 2 anchor is materialized.
query I
SELECT COUNT(*) FROM wm_zero;
----
2

query I
SELECT COUNT(*) FROM wm_zero WHERE feature_timestamp = '2024-01-02 08:00:00'::TIMESTAMP;
----
0

query R
SELECT total FROM wm_zero WHERE feature_timestamp = '2024-01-03 08:00:00'::TIMESTAMP;
----
35

# The two-day watermark recomputes far enough back to materialize the late Jan 2 anchor.
query I
SELECT COUNT(*) FROM wm_two_days;
----
3

query R
SELECT total FROM wm_two_days WHERE feature_timestamp = '2024-01-02 08:00:00'::TIMESTAMP;
----
15

query R
SELECT total FROM wm_two_days WHERE feature_timestamp = '2024-01-03 08:00:00'::TIMESTAMP;
----
35

statement ok
DROP FEATURE wm_zero;

statement ok
DROP FEATURE wm_two_days;

statement ok
DROP TABLE watermark_events;

# ============================================================
# Error cases
# ============================================================

# Non-existent feature
statement error
REFRESH FEATURE nonexistent;
----
Feature "nonexistent" does not exist

# ============================================================
# Cleanup
# ============================================================
statement ok
DROP FEATURE event_sum;

statement ok
DROP TABLE events;
