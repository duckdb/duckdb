# name: test/sql/feature/test_feature_refresh.test
# description: Test REFRESH FEATURE — entity snapshots, REFRESH AT, carry-forward store, retention
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# Setup: entity table + event table with a foreign key into it
# ============================================================
statement ok
CREATE TABLE users (user_id VARCHAR PRIMARY KEY);

statement ok
INSERT INTO users VALUES ('alice'), ('bob'), ('carol');

statement ok
CREATE TABLE transactions (
    user_id VARCHAR,
    amount DECIMAL(10,2),
    ts TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(user_id)
);

# carol has no events: she must still appear in every snapshot with default values.
statement ok
INSERT INTO transactions VALUES
    ('alice', 100.00, '2024-01-01 10:00:00'),
    ('alice', 200.00, '2024-01-01 14:00:00'),
    ('alice', 300.00, '2024-01-03 08:00:00'),
    ('bob',   50.00,  '2024-01-01 09:00:00'),
    ('bob',   75.00,  '2024-01-02 11:00:00');

statement ok
CREATE FEATURE total_spend
    ENTITY users
    TIMESTAMP ts
    WINDOW 7 DAYS
    RETAIN 2
    AS (SELECT user_id, SUM(amount) AS total, COUNT(*) AS tx_count FROM transactions GROUP BY user_id);

# ============================================================
# First snapshot AT Jan 2: window [Dec 26, Jan 2)
# alice = 100+200 (tx 2), bob = 50 (tx 1), carol = 0 (tx 0)
# ============================================================
query I
REFRESH FEATURE total_spend AT '2024-01-02 00:00:00';
----
3

# One snapshot row per entity in the store
query I
SELECT COUNT(*) FROM total_spend;
----
3

query IRI rowsort
SELECT user_id, total, tx_count FROM total_spend;
----
alice	300.00	2
bob	50.00	1
carol	0.00	0

# ============================================================
# Second snapshot AT Jan 4: window [Dec 28, Jan 4)
# alice = 100+200+300 (tx 3), bob = 50+75 (tx 2), carol = 0
# REFRESH appends one snapshot row per entity (3); the store now holds 6 rows (2 versions x 3 entities).
# ============================================================
query I
REFRESH FEATURE total_spend AT '2024-01-04 00:00:00';
----
3

query I
SELECT current_version FROM duckdb_features() WHERE feature_name = 'total_spend';
----
2

# View resolves to the current snapshot (version 2)
query IRI rowsort
SELECT user_id, total, tx_count FROM total_spend;
----
alice	600.00	3
bob	125.00	2
carol	0.00	0

# The store table holds both versions, tagged with the refresh version
query I
SELECT COUNT(*) FROM total_spend__store;
----
6

query II rowsort
SELECT __feature_version, COUNT(*) FROM total_spend__store GROUP BY __feature_version;
----
1	3
2	3

# feature_at_version reads a specific retained version out of the store
query IR rowsort
SELECT user_id, total FROM feature_at_version('total_spend', 1);
----
alice	300.00
bob	50.00
carol	0.00

query IR rowsort
SELECT user_id, total FROM feature_at_version('total_spend', 2);
----
alice	600.00
bob	125.00
carol	0.00

# ============================================================
# Third snapshot AT Jan 6 -> version 3; RETAIN 2 evicts version 1 in place
# ============================================================
query I
REFRESH FEATURE total_spend AT '2024-01-06 00:00:00';
----
3

# There is exactly one persistent store table; retention lives in the rows, not in separate tables
query I
SELECT table_name FROM duckdb_tables WHERE table_name LIKE 'total\_spend\_\_%' ESCAPE '\' ORDER BY table_name;
----
total_spend__store

# The store now retains versions 2 and 3 only (version 1's rows were deleted in place)
query II rowsort
SELECT __feature_version, COUNT(*) FROM total_spend__store GROUP BY __feature_version;
----
2	3
3	3

# Version 1 has been evicted from the retain window
query I
SELECT COUNT(*) FROM feature_at_version('total_spend', 1);
----
0

# ============================================================
# SERVE resolves each spine row to the entity's latest snapshot at or before its timestamp
# ============================================================
statement ok
CREATE TABLE spine (user_id VARCHAR, ts TIMESTAMP);

statement ok
INSERT INTO spine VALUES
    ('alice', '2024-01-04 12:00:00'),
    ('alice', '2024-01-07 00:00:00'),
    ('bob',   '2024-01-03 00:00:00'),
    ('dave',  '2024-01-07 00:00:00');

# alice @ Jan 4 -> version 2 (600); alice @ Jan 7 -> version 3 (600);
# bob @ Jan 3 -> no retained version at or before Jan 3 (v2=Jan 4, v3=Jan 6) -> NULL;
# dave is not an entity -> NULL.
query IIRI rowsort
SERVE FEATURE total_spend FOR spine;
----
alice	2024-01-04 12:00:00	600.00	3
alice	2024-01-07 00:00:00	600.00	3
bob	2024-01-03 00:00:00	NULL	NULL
dave	2024-01-07 00:00:00	NULL	NULL

statement ok
DROP TABLE spine;

# ============================================================
# Error cases
# ============================================================
statement error
REFRESH FEATURE nonexistent;
----
Feature "nonexistent" does not exist

# Dropping the source table with CASCADE removes the dependent feature.
statement ok
CREATE TABLE err_users (entity VARCHAR PRIMARY KEY);

statement ok
INSERT INTO err_users VALUES ('a');

statement ok
CREATE TABLE refresh_error_src (
    entity VARCHAR,
    val INTEGER,
    ts TIMESTAMP,
    FOREIGN KEY (entity) REFERENCES err_users(entity)
);

statement ok
INSERT INTO refresh_error_src VALUES ('a', 10, '2024-01-01 08:00:00');

statement ok
CREATE FEATURE refresh_error_feature
    ENTITY err_users
    TIMESTAMP ts
    WINDOW 7 DAYS
    RETAIN 1
    AS (SELECT entity, SUM(val) AS total FROM refresh_error_src GROUP BY entity);

statement ok
REFRESH FEATURE refresh_error_feature AT '2024-01-02 00:00:00';

statement ok
DROP TABLE refresh_error_src CASCADE;

statement error
REFRESH FEATURE refresh_error_feature AT '2024-01-02 00:00:00';
----
Feature "refresh_error_feature" does not exist

# ============================================================
# Cleanup
# ============================================================
statement ok
DROP FEATURE total_spend;

statement ok
DROP TABLE transactions;
