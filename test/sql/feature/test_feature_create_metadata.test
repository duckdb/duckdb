# name: test/sql/feature/test_feature_create_metadata.test
# description: CREATE FEATURE registers metadata only; the feature is unusable until the first REFRESH
# group: [feature]

require noforcestorage

require skip_reload

# The snapshot is built over the entity table; no primary/foreign key is required.
statement ok
CREATE TABLE customers (customer VARCHAR);

statement ok
INSERT INTO customers VALUES ('x'), ('y');

statement ok
CREATE TABLE events (customer VARCHAR, value INTEGER, event_time TIMESTAMP);

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('x', 20, '2024-01-02 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00');

# ============================================================
# CREATE FEATURE returns the created feature's name
# ============================================================
query I
CREATE FEATURE f ENTITY customers TIMESTAMP event_time WINDOW 7 DAYS RETAIN 2 AS (SELECT customer, SUM(value) AS total FROM events GROUP BY customer);
----
f

# The feature exists in the catalog but has not been materialized yet: current_version = 0
query II
SELECT feature_name, current_version FROM duckdb_features() WHERE feature_name = 'f';
----
f	0

# No store table has been created yet
query I
SELECT COUNT(*) FROM duckdb_tables WHERE table_name LIKE 'f\_\_%' ESCAPE '\';
----
0

# The resolver view exists, but querying it before any refresh raises a clear error
statement error
SELECT * FROM f;
----
<REGEX>:.*has not been refreshed yet.*

# FEATURE ... AT VERSION for the (non-existent) v1 also fails clearly
statement error
SELECT * FROM FEATURE f AT VERSION 1;
----
<REGEX>:.*has not been refreshed yet.*

# ============================================================
# SERVE FEATURE on an unrefreshed feature errors the same way
# ============================================================
statement ok
CREATE TABLE spine (customer VARCHAR, event_time TIMESTAMP);

statement ok
INSERT INTO spine VALUES ('x', '2024-01-03 00:00:00');

statement error
SERVE FEATURE f FOR spine;
----
<REGEX>:.*has not been refreshed yet.*

# ============================================================
# After the first REFRESH the feature materializes v1 and becomes queryable
# ============================================================
statement ok
REFRESH FEATURE f AT '2024-01-03 00:00:00';

query II
SELECT feature_name, current_version FROM duckdb_features() WHERE feature_name = 'f';
----
f	1

# The store holds one snapshot row per entity (x, y)
query I
SELECT COUNT(*) FROM f__store;
----
2

# The view resolves to the current snapshot: SUM over [Dec 27, Jan 3)
query II rowsort
SELECT customer, total FROM f;
----
x	30
y	30

# SERVE resolves each spine row to the entity's snapshot at or before the spine time.
query III
SERVE FEATURE f FOR spine;
----
x	2024-01-03 00:00:00	30

# ============================================================
# A second feature on the same tables also bootstraps v1 on its first refresh
# ============================================================
statement ok
CREATE FEATURE g ENTITY customers TIMESTAMP event_time WINDOW 7 DAYS RETAIN 1 AS (SELECT customer, SUM(value) AS total FROM events GROUP BY customer);

statement error
SELECT * FROM g;
----
<REGEX>:.*has not been refreshed yet.*

statement ok
REFRESH FEATURE g AT '2024-01-03 00:00:00';

query I
SELECT COUNT(*) FROM g;
----
2

query I
SELECT current_version FROM duckdb_features() WHERE feature_name = 'g';
----
1

statement ok
DROP TABLE events CASCADE;

statement ok
DROP TABLE spine;
