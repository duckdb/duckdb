# name: test/sql/feature/test_feature_versioning.test
# description: Test feature versioning — each refresh appends a version to the store; RETAIN controls GC
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# Setup
# ============================================================
statement ok
CREATE TABLE customers (customer VARCHAR);

statement ok
INSERT INTO customers VALUES ('x'), ('y'), ('z');

statement ok
CREATE TABLE events (
    customer VARCHAR,
    value INTEGER,
    event_time TIMESTAMP
);

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('x', 20, '2024-01-02 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00'),
    ('y', 15, '2024-01-02 16:00:00'),
    ('z',  5, '2024-01-01 06:00:00');

# ============================================================
# RETAIN 2: each refresh appends a version; the store carries retained versions forward
# ============================================================
statement ok
CREATE FEATURE versioned
    ENTITY customers
    TIMESTAMP event_time
    WINDOW 7 DAYS
    RETAIN 2
    AS (SELECT customer, SUM(value) AS total_value FROM events GROUP BY customer);

# Version 1 AT Jan 3: x=30, y=45, z=5 (one snapshot row per entity)
statement ok
REFRESH FEATURE versioned AT '2024-01-03 00:00:00';

query I
SELECT COUNT(*) FROM versioned__store;
----
3

query II rowsort
SELECT customer, total_value FROM versioned;
----
x	30
y	45
z	5

# Version 2 (same AT) -> the store now holds 6 rows across 2 versions
statement ok
REFRESH FEATURE versioned AT '2024-01-03 00:00:00';

query I
SELECT current_version FROM duckdb_features() WHERE feature_name = 'versioned';
----
2

query II rowsort
SELECT __feature_version, COUNT(*) FROM versioned__store GROUP BY __feature_version;
----
1	3
2	3

# There is a single persistent store table, not one table per version
query I
SELECT COUNT(*) FROM duckdb_tables WHERE table_name LIKE 'versioned\_\_%' ESCAPE '\';
----
1

# ============================================================
# New data + RETAIN 2 GC: version 3 keeps versions 2 and 3, evicts version 1
# ============================================================
statement ok
INSERT INTO events VALUES ('x', 40, '2024-01-03 09:00:00');

# Version 3 AT Jan 4: window [Dec 29, Jan 4). x = 10+20+40 = 70
statement ok
REFRESH FEATURE versioned AT '2024-01-04 00:00:00';

query I
SELECT COUNT(*) FROM versioned__store;
----
6

query II rowsort
SELECT __feature_version, COUNT(*) FROM versioned__store GROUP BY __feature_version;
----
2	3
3	3

# The view resolves to the current snapshot (version 3): x now 70
query II rowsort
SELECT customer, total_value FROM versioned;
----
x	70
y	45
z	5

# Each retained version preserves its own snapshot
query I
SELECT total_value FROM feature_at_version('versioned', 2) WHERE customer = 'x';
----
30

query I
SELECT total_value FROM feature_at_version('versioned', 3) WHERE customer = 'x';
----
70

# Version 1 has been evicted from the retain window
query I
SELECT COUNT(*) FROM feature_at_version('versioned', 1);
----
0

statement ok
DROP FEATURE versioned;

# ============================================================
# RETAIN 1: only the latest version is ever kept
# ============================================================
statement ok
CREATE FEATURE latest_only
    ENTITY customers
    TIMESTAMP event_time
    WINDOW 7 DAYS
    RETAIN 1
    AS (SELECT customer, SUM(value) AS total_value FROM events GROUP BY customer);

statement ok
REFRESH FEATURE latest_only AT '2024-01-03 00:00:00';

statement ok
REFRESH FEATURE latest_only AT '2024-01-04 00:00:00';

# The store holds only the current version's rows
query I
SELECT COUNT(*) FROM latest_only__store;
----
3

query I
SELECT DISTINCT __feature_version FROM latest_only__store;
----
2

# The previous version is no longer retrievable
query I
SELECT COUNT(*) FROM feature_at_version('latest_only', 1);
----
0

statement ok
DROP FEATURE latest_only;

statement ok
DROP TABLE events;
