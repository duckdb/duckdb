# name: test/sql/feature/test_feature_versioning.test
# description: Test feature versioning — each refresh creates a new version table, RETAIN controls GC
# group: [feature]

require noforcestorage

require skip_reload

# ============================================================
# Setup
# ============================================================
statement ok
CREATE TABLE events (
    customer VARCHAR,
    value INTEGER,
    event_time TIMESTAMP
);

statement ok
INSERT INTO events VALUES
    ('x', 10, '2024-01-01 08:00:00'),
    ('x', 20, '2024-01-02 08:00:00'),
    ('y', 30, '2024-01-01 12:00:00');

# ============================================================
# FULL refresh with RETAIN 3: version increments each refresh
# ============================================================
statement ok
CREATE FEATURE versioned_full ON events
    ENTITY customer
    TIMESTAMP event_time
    GRANULARITY DAY
    WINDOW 7
    REFRESH FULL
    RETAIN 3
    AS (SELECT customer, SUM(value) AS total_value);

# Initial materialization creates version table __v1
query I
SELECT COUNT(*) FROM versioned_full__v1;
----
3

# The view resolves to current version (v1)
query II rowsort
SELECT customer, total_value FROM versioned_full WHERE feature_timestamp = '2024-01-01'::TIMESTAMP;
----
x	10
y	30

# First refresh -> version 2
query I
REFRESH FEATURE versioned_full;
----
3

# Both v1 and v2 tables exist
query I
SELECT COUNT(*) FROM versioned_full__v1;
----
3

query I
SELECT COUNT(*) FROM versioned_full__v2;
----
3

# View shows current (v2) data
query II rowsort
SELECT customer, total_value FROM versioned_full WHERE feature_timestamp = '2024-01-01'::TIMESTAMP;
----
x	10
y	30

# Second refresh -> version 3 (now we have 3 versions, at RETAIN limit)
query I
REFRESH FEATURE versioned_full;
----
3

query I
SELECT COUNT(*) FROM versioned_full__v3;
----
3

# Third refresh -> version 4, GC removes version 1 (retain 3 means keep 2,3,4)
query I
REFRESH FEATURE versioned_full;
----
3

query I
SELECT COUNT(*) FROM versioned_full__v4;
----
3

# Version 1 table is gone (GC'd)
statement error
SELECT COUNT(*) FROM versioned_full__v1;
----
<REGEX>:.*does not exist.*

# Version 2 still exists (within retain window)
query I
SELECT COUNT(*) FROM versioned_full__v2;
----
3

# Latest version has correct data
query II rowsort
SELECT customer, total_value FROM versioned_full WHERE feature_timestamp = '2024-01-01'::TIMESTAMP;
----
x	10
y	30

statement ok
DROP FEATURE versioned_full;

# ============================================================
# RETAIN 1: only latest version kept (default behavior)
# ============================================================
statement ok
CREATE FEATURE versioned_retain1 ON events
    ENTITY customer
    TIMESTAMP event_time
    GRANULARITY DAY
    WINDOW 7
    REFRESH FULL
    RETAIN 1
    AS (SELECT customer, SUM(value) AS total_value);

# Version 1 table exists initially
query I
SELECT COUNT(*) FROM versioned_retain1__v1;
----
3

# Refresh -> version 2, GC removes version 1
query I
REFRESH FEATURE versioned_retain1;
----
3

query I
SELECT COUNT(*) FROM versioned_retain1__v2;
----
3

# Version 1 is gone
statement error
SELECT COUNT(*) FROM versioned_retain1__v1;
----
<REGEX>:.*does not exist.*

statement ok
DROP FEATURE versioned_retain1;

# ============================================================
# INCREMENTAL refresh: version increments, old versions GC'd
# ============================================================
statement ok
CREATE FEATURE versioned_incr ON events
    ENTITY customer
    TIMESTAMP event_time
    GRANULARITY DAY
    WINDOW 7
    REFRESH INCREMENTAL
    RETAIN 2
    AS (SELECT customer, SUM(value) AS total_value);

# Initial: version 1 with 3 rows
query I
SELECT COUNT(*) FROM versioned_incr__v1;
----
3

query I
SELECT COUNT(*) FROM versioned_incr;
----
3

# Add new data beyond watermark
statement ok
INSERT INTO events VALUES
    ('x', 40, '2024-01-03 09:00:00'),
    ('y', 50, '2024-01-03 10:00:00');

# Incremental refresh -> version 2
# Unaffected rows are copied forward, new buckets computed
query I
REFRESH FEATURE versioned_incr;
----
2

# Both v1 and v2 exist (RETAIN 2)
query I
SELECT COUNT(*) FROM versioned_incr__v1;
----
3

query I
SELECT COUNT(*) FROM versioned_incr__v2;
----
5

# View shows current version (v2) which has the new bucket
query II rowsort
SELECT customer, total_value FROM versioned_incr WHERE feature_timestamp = '2024-01-03'::TIMESTAMP;
----
x	70
y	80

# Add more data and refresh again -> version 3, GC removes version 1
statement ok
INSERT INTO events VALUES
    ('x', 100, '2024-01-05 12:00:00');

query I
REFRESH FEATURE versioned_incr;
----
1

# Version 1 is gone (GC'd, only retain 2)
statement error
SELECT COUNT(*) FROM versioned_incr__v1;
----
<REGEX>:.*does not exist.*

# Version 2 still exists
query I
SELECT COUNT(*) FROM versioned_incr__v2;
----
5

# Version 3 exists with new data
query I
SELECT COUNT(*) FROM versioned_incr__v3;
----
6

statement ok
DROP FEATURE versioned_incr;

# ============================================================
# No-op refresh: version does NOT increment
# ============================================================
statement ok
CREATE TABLE stable_src (
    eid VARCHAR,
    val INTEGER,
    ts TIMESTAMP
);

statement ok
INSERT INTO stable_src VALUES ('a', 10, '2024-01-01 08:00:00');

statement ok
CREATE FEATURE stable_feat ON stable_src
    ENTITY eid
    TIMESTAMP ts
    GRANULARITY DAY
    WINDOW 7
    REFRESH INCREMENTAL
    RETAIN 3
    AS (SELECT eid, SUM(val) AS total);

# Version 1 after creation
query I
SELECT COUNT(*) FROM stable_feat__v1;
----
1

# No new data -> no-op refresh, version stays at 1
query I
REFRESH FEATURE stable_feat;
----
0

# Still only v1 (no v2 created)
query I
SELECT COUNT(*) FROM stable_feat__v1;
----
1

statement error
SELECT COUNT(*) FROM stable_feat__v2;
----
<REGEX>:.*does not exist.*

# Add data, refresh -> version 2
statement ok
INSERT INTO stable_src VALUES ('a', 20, '2024-01-02 08:00:00');

query I
REFRESH FEATURE stable_feat;
----
1

query I
SELECT COUNT(*) FROM stable_feat__v2;
----
2

# No-op again -> still at version 2, no v3
query I
REFRESH FEATURE stable_feat;
----
0

statement error
SELECT COUNT(*) FROM stable_feat__v3;
----
<REGEX>:.*does not exist.*

statement ok
DROP FEATURE stable_feat;

statement ok
DROP TABLE stable_src;

statement ok
DROP TABLE events;
