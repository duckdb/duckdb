# name: test/sql/settings/global_timeout.test
# description: Test global_timeout setting
# group: [settings]

statement ok
SET global_timeout=100

# test timeout triggers (50ms timeout on slow cross-product query)
statement ok
SET global_timeout=50

statement error
SELECT COUNT(*) FROM range(100000000) t1, range(1000) t2
----
Query exceeded maximum execution time

statement ok
SET global_timeout=100

# recursive cte
statement error
WITH RECURSIVE cte AS (
    SELECT 1 as n
    UNION ALL
    SELECT n+1 FROM cte WHERE n < 10000000
)
SELECT COUNT(*) FROM cte
----
Query exceeded maximum execution time

# Complex aggregation
statement ok
SET global_timeout=5000

statement error
SELECT i % 10000000 as g, COUNT(*) FROM range(100000000) t(i) GROUP BY 1
----
Query exceeded maximum execution time
