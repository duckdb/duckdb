# name: test/sql/setops/test_setops_window.test
# description: Test UNION/EXCEPT/INTERSECT in combination with window function
# group: [setops]

statement ok
PRAGMA enable_verification

statement ok
CREATE TABLE t1 (id INT, ord INT, grp INT);

statement ok
INSERT INTO t1 VALUES (1, 1, 1);


query II
SELECT sub.id, sub.ord
FROM (SELECT id, ord, grp, row_number() OVER (ORDER BY ord) AS rn FROM t1) sub
JOIN (VALUES (1)) t2(grp) ON t2.grp = sub.grp
WHERE sub.rn = 1
UNION
SELECT id, ord FROM (SELECT id, ord, row_number() OVER (ORDER BY ord) AS rn FROM t1) WHERE rn = 1;
----
1	1

query II
SELECT sub.id, sub.ord
FROM (SELECT id, ord, grp, row_number() OVER (ORDER BY ord) AS rn FROM t1) sub
JOIN (VALUES (1)) t2(grp) ON t2.grp = sub.grp
WHERE sub.rn = 1
UNION ALL
SELECT id, ord FROM (SELECT id, ord, row_number() OVER (ORDER BY ord) AS rn FROM t1) WHERE rn = 1;
----
1	1
1	1

query II
SELECT sub.id, sub.ord
FROM (SELECT id, ord, grp, row_number() OVER (ORDER BY ord) AS rn FROM t1) sub
JOIN (VALUES (1)) t2(grp) ON t2.grp = sub.grp
WHERE sub.rn = 1
EXCEPT
SELECT id, ord FROM (SELECT id, ord, row_number() OVER (ORDER BY ord) AS rn FROM t1) WHERE rn = 1;
----

query II
SELECT sub.id, sub.ord
FROM (SELECT id, ord, grp, row_number() OVER (ORDER BY ord) AS rn FROM t1) sub
JOIN (VALUES (1)) t2(grp) ON t2.grp = sub.grp
WHERE sub.rn = 1
INTERSECT
SELECT id, ord FROM (SELECT id, ord, row_number() OVER (ORDER BY ord) AS rn FROM t1) WHERE rn = 1;
----
1	1
