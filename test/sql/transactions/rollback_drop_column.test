# name: test/sql/transactions/rollback_drop_column.test
# description: A reverted ALTER TABLE DROP COLUMN must not leave column blocks marked, so a retried DROP COLUMN does not hit a double-mark assertion.
# group: [transactions]

load {TEST_DIR}/test_drop_column_rollback.db

statement ok
SET immediate_transaction_mode=true

statement ok
CREATE TABLE t1 (id INTEGER, val INTEGER, extra VARCHAR)

statement ok
INSERT INTO t1 SELECT i, i, repeat(md5(i::VARCHAR), 200) FROM range(50000) tbl(i)

statement ok
CREATE TABLE t2 (id INTEGER)

statement ok
INSERT INTO t2 SELECT i FROM range(10) tbl(i)

statement ok
CHECKPOINT

statement ok con1
BEGIN

statement ok con1
ALTER TABLE t1 DROP COLUMN extra

statement ok con1
DELETE FROM t2 WHERE id < 5

statement ok
ALTER TABLE t2 ADD COLUMN x INTEGER

statement error con1
COMMIT
----
another transaction has

statement ok
ALTER TABLE t1 DROP COLUMN extra
