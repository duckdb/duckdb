# name: test/sql/transactions/test_copy_from_database_is_transactional.test
# group: [transactions]

require tpch

statement ok
attach ':memory:' as db1;

statement ok
use db1;

statement ok
call dbgen(sf=1);

statement ok
attach ':memory:' as db2;

statement ok
use db2;

statement ok
set memory_limit='10MB';

statement error
copy from database db1 to db2;
----
<REGEX>:.*Out of Memory Error.*

statement error
SHOW TABLES;
----
TransactionContext Error: Current transaction is aborted (please ROLLBACK)

statement ok
rollback;

query I
SHOW TABLES;
----
