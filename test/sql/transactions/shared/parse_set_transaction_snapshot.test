# name: test/sql/transactions/shared/parse_set_transaction_snapshot.test
# description: Parser/binder coverage for SET TRANSACTION SNAPSHOT 'id'.
# group: [shared]

# malformed id: must error cleanly (does not crash)
statement ok
BEGIN;

statement error
SET TRANSACTION SNAPSHOT '999999/nonexistent';
----
<REGEX>:.*no live connection.*

statement ok
ROLLBACK;

# without BEGIN, must error
statement error
SET TRANSACTION SNAPSHOT '999999/nonexistent';
----
<REGEX>:.*BEGIN.*

# missing required argument is a parse error
statement error
SET TRANSACTION SNAPSHOT;
----
<REGEX>:.*Parser Error.*

# duckdb_export_transaction outside an explicit transaction must error
statement error
SELECT duckdb_export_transaction();
----
<REGEX>:.*explicit transaction.*

# inside a transaction it returns "<connection_id>/<db_name>"
statement ok
BEGIN;

query I
SELECT regexp_matches(duckdb_export_transaction(), '^[0-9]+/[A-Za-z0-9_]+$');
----
true

statement ok
ROLLBACK;
