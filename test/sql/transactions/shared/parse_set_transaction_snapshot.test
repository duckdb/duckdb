# name: test/sql/transactions/shared/parse_set_transaction_snapshot.test
# description: Parser/binder coverage for SET TRANSACTION SNAPSHOT 'id'.
# group: [shared]

# unknown id: must error cleanly (does not crash)
statement ok
BEGIN;

statement error
SET TRANSACTION SNAPSHOT '00000000-0000-0000-0000-000000000000';
----
<REGEX>:.*does not exist.*

statement ok
ROLLBACK;

# without BEGIN, must error
statement error
SET TRANSACTION SNAPSHOT '00000000-0000-0000-0000-000000000000';
----
<REGEX>:.*BEGIN.*

# missing required argument is a parse error
statement error
SET TRANSACTION SNAPSHOT;
----
<REGEX>:.*Parser Error.*

# duckdb_export_transaction outside an explicit transaction must error
statement error
SELECT duckdb_export_transaction();
----
<REGEX>:.*explicit transaction.*

# inside a transaction it returns a non-empty UUID-shaped string
statement ok
BEGIN;

query I
SELECT length(duckdb_export_transaction()) >= 36;
----
true

statement ok
ROLLBACK;
