# name: test/sql/transactions/statement-preprocessor/pivot_is_handled_correctly.test
# description: Test SQL pivot with transaction
# group: [statement-preprocessor]

query III
PIVOT VALUES(1,2),(1,3) x(y,z) ON x USING FIRST(y) ORDER BY 1;
----
2	1	NULL
3	NULL	1

statement ok
BEGIN TRANSACTION

query III
PIVOT VALUES(1,2),(1,3) x(y,z) ON x USING FIRST(y) ORDER BY 1;
----
2	1	NULL
3	NULL	1

statement ok
ROLLBACK