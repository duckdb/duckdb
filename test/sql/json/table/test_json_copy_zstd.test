# name: test/sql/json/table/test_json_copy_zstd.test
# description: Test JSON COPY to zstd
# group: [table]

require json

require parquet

require no_extension_autoloading "FIXME: Autoloading on zstd compression (parquet) not yet there"

statement ok
create table my_range as select range as i from range(10)

statement ok
copy (select range as i from range(10)) to '{TEMP_DIR}/my.json.zst' (COMPRESSION ZSTD)

query I
select * from '{TEMP_DIR}/my.json.zst'
