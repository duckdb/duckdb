# name: test/sql/function/variant/variant_keys.test
# group: [variant]

statement ok
CREATE MACRO struct_cast_data() AS TABLE (
	SELECT {'a': [
		{
			'b': 'hello',
			'c': NULL,
			'a': '1970/03/15'::DATE
		},
		{
			'b': NULL,
			'c': True,
			'a': '2020/11/03'::DATE
		}
	]}::VARIANT AS a
	UNION ALL
	SELECT {'a': [
		{
			'b': 'this is a long string',
			'c': False,
			'a': '1953/9/16'::DATE
		}
	],
	'b': 42,
	'c': {
	    'd': 'world'
	}}::VARIANT
);

query I
select variant_keys('{"a": 1, "b": {"c": 12, "d": 10}}');
----
[a, b]

# No path supplied

# query I
# select variant_keys(a) from struct_cast_data();
# ----
# [a]
# [a, b, c]

# Single path supplied

# query I
# select variant_keys(a, 'c') from struct_cast_data();
# ----
# []
# [d]

# Multiple paths supplied

# query I
# select variant_keys(a, ['', 'c']) from struct_cast_data();
# ----
# [[a], []]
# [[a, b, c], [d]]

# Arrays do not have keys

# query I
# select variant_keys(['duck', 'goose']::VARIANT) from struct_cast_data();
# ----
# []
#
