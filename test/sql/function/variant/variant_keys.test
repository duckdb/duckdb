# name: test/sql/function/variant/variant_keys.test
# group: [variant]

require json

load {TEST_DIR}/variant_keys.db readwrite v1.5.0

statement ok
CREATE MACRO struct_cast_data() AS TABLE (
	SELECT {'a': [
		{
			'b': 'hello',
			'c': NULL,
			'a': '1970/03/15'::DATE
		},
		{
			'b': NULL,
			'c': True,
			'a': '2020/11/03'::DATE
		}
	]}::VARIANT AS a
	UNION ALL
	SELECT {'a': [
		{
			'b': 'this is a long string',
			'c': False,
			'a': '1953/9/16'::DATE
		}
	],
	'b': 42,
	'c': {
	    'd': 'world'
	}}::VARIANT
);

# FIXME: Can have VARCHAR as input for variant parameter (should produce [a, b]).

query I
select variant_keys('{"a": 1, "b": {"c": 12, "d": 10}}');
----
[]

# No path supplied

query I
select variant_keys(a) from struct_cast_data();
----
[a]
[a, b, c]

# Empty path supplied

query I
select variant_keys(a, '') from struct_cast_data();
----
[a]
[a, b, c]

query I
select variant_keys(a, []) from struct_cast_data();
----
[]
[]

query I
select variant_keys(a, ['']) from struct_cast_data();
----
[[a]]
[[a, b, c]]

# Single path supplied

query I
select variant_keys(a, 'c') from struct_cast_data();
----
NULL
[d]

query I
select variant_keys(a, ['c']) from struct_cast_data();
----
[NULL]
[[d]]

# Multiple paths supplied

query I
select variant_keys(a, ['', 'c']) from struct_cast_data();
----
[[a], NULL]
[[a, b, c], [d]]

# Empty objects do not have keys

query I
select variant_keys('{}'::VARIANT);
----
[]

# Arrays do not have keys

query I
select variant_keys(['duck', 'goose']::VARIANT);
----
[]

query I
select variant_keys({'a': 1, 'b': ['duck', 'goose']}::VARIANT, 'b');
----
[]

# FIXME: map type is currently casted into a shape inconsistent with respect to JSON

query I
select variant_keys(MAP {'a': 1, 'b': 2}::VARIANT, 'a');
----
NULL

# Primitive values do not have keys

query I
select variant_keys(''::VARIANT);
----
[]

query I
select variant_keys({'a': 'goose'}::VARIANT, 'a');
----
[]

query I
select variant_keys(42::VARIANT);
----
[]

query I
select variant_keys({'a': 42}::VARIANT, 'a');
----
[]

# NULL returns NULL

query I
select variant_keys(NULL::VARIANT);
----
NULL

query I
select variant_keys(NULL::VARIANT);
----
NULL

query I
select variant_keys(NULL::VARIANT, 'a');
----
NULL

# VARIANT_NULL

query I
select variant_keys({'a': 1, 'b': null}::VARIANT, 'b');
----
[]

# Supplied path does not exist in variant

query I
select variant_keys('{}'::VARIANT, 'a');
----
NULL

query I
select variant_keys({'a': 1, 'b': {'c': 12, 'd': 10}}::VARIANT, 'q');
----
NULL

# NULL path returns NULL

query I
select variant_keys({'a': 1}::VARIANT, NULL);
----
NULL

# FIXME: Support for JSONPath and JSONPointer

query I
select variant_keys({'a': 1, 'b': {'c': {'d': 12}}}::VARIANT, '$.b.c');
----
NULL

# Incorrect parameters

statement error
select variant_keys({'a': 1}::VARIANT, [1]);
----

statement error
select variant_keys({'a': 1}::VARIANT, [NULL]);
----

# FIXME: malformed JSON object should result in an error

statement ok
select variant_keys('{"a"\: 1}'::VARIANT);

# Table of varying objects

statement ok
create table t1 as
select range, case when range % 2 = 0 then {"duck": 42}::VARIANT else {"duck": 42, "goose": 43}::VARIANT end j
from range(4096)

query II
select range % 2 g, sum(length(variant_keys(j))) c
from t1
group by g
order by all
----
0	2048
1	4096

# Table whilst applying list of paths

statement ok
create table t2 as
select range, {'duck': {'key1': 42}, 'goose': {'key1': 42, 'key2': 43}}::VARIANT j
from range(4096)

query T
select sum(list_sum([length(l) for l in variant_keys(j, ['duck', 'goose'])])) s
from t2
----
12288