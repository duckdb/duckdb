# name: test/sql/function/variant/variant_exists_shredded.test
# description: Test variant_exists with shredded VARIANT values
# group: [variant]

load {TEST_DIR}/variant_exists_shredded.db readwrite v1.5.0

statement ok
SET variant_minimum_shredding_size = 0;

statement ok
SET force_variant_shredding = 'STRUCT(b INTEGER, a INTEGER)';

statement ok
CREATE TABLE variants(id INTEGER, v VARIANT);

statement ok
INSERT INTO variants VALUES
    -- partially shredded
	(1, {'z': 9, 'a': 1, 'b': 2}::VARIANT),
	-- VARIANT_NULL
	(2, {'a': 10, 'b': NULL}::VARIANT),
	-- missing value in shredded schema
	(3, {'a': 20}::VARIANT),
	(4, {'z': 40}::VARIANT),
	-- root with different type than shredded schema
	(5, 42::VARIANT),
	-- SQL-NULL
	(6, NULL::VARIANT);

statement ok
CHECKPOINT;

restart

query I
SELECT DISTINCT vector_type(v) FROM variants;
----
SHREDDED_VECTOR

query II
SELECT variant_exists(v, 'b'), variant_exists(v, 'z') FROM variants ORDER BY id;
----
true	true
true	false
false	false
false	true
false	false
NULL	NULL

query I
SELECT variant_exists(v, ['b', 'z', 'missing']) FROM variants ORDER BY id;
----
[true, true, false]
[true, false, false]
[false, false, false]
[false, true, false]
[false, false, false]
NULL

# --- Fully consistent object VARIANT ---

statement ok
SET variant_minimum_shredding_size = 0;

statement ok
SET force_variant_shredding = 'STRUCT(b INTEGER, a INTEGER)';

statement ok
CREATE TABLE fully_shredded_objects(id INTEGER, v VARIANT);

statement ok
INSERT INTO fully_shredded_objects VALUES
	(1, {'a': 1, 'b': 2}::VARIANT),
	(2, {'a': 3, 'b': 4}::VARIANT),
	(3, NULL::VARIANT);

statement ok
CHECKPOINT;

restart

query I
SELECT DISTINCT vector_type(v) FROM fully_shredded_objects;
----
SHREDDED_VECTOR

query II
SELECT variant_exists(v, 'b'), variant_exists(v, 'missing')
FROM fully_shredded_objects
ORDER BY id;
----
true	false
true	false
NULL	NULL
