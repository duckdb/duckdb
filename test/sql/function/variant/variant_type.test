# name: test/sql/function/variant/variant_type.test
# group: [variant]

require json

load {TEST_DIR}/variant_type.db readwrite v1.5.0

statement ok
CREATE MACRO struct_cast_data() AS TABLE (
	SELECT {'a': [
		{
			'b': 'hello',
			'c': NULL,
			'a': '1970/03/15'::DATE
		},
		{
			'b': NULL,
			'c': True,
			'a': '2020/11/03'::DATE
		}
	]}::VARIANT AS a
	UNION ALL
	SELECT {'a': [
		{
			'b': 'this is a long string',
			'c': False,
			'a': '1953/9/16'::DATE
		}
	],
	'b': 42,
	'c': {
	    'd': 'world'
	}}::VARIANT
);

# FIXME: Can have VARCHAR as input for variant parameter (should produce [a, b]).

query I
select variant_type('{"a": 1, "b": {"c": 12, "d": 10}}');
----
VARCHAR

# No path supplied

query I
select variant_type(a) from struct_cast_data();
----
OBJECT
OBJECT

# Empty path supplied

query I
select variant_type(a, '') from struct_cast_data();
----
OBJECT
OBJECT

query I
select variant_type(a, []) from struct_cast_data();
----
[]
[]

query I
select variant_type(a, ['']) from struct_cast_data();
----
[OBJECT]
[OBJECT]

# Single path supplied

query I
select variant_type(a, 'c') from struct_cast_data();
----
NULL
OBJECT

query I
select variant_type(a, ['c']) from struct_cast_data();
----
[NULL]
[OBJECT]

# Multiple paths supplied

query I
select variant_type(a, ['', 'c']) from struct_cast_data();
----
[OBJECT, NULL]
[OBJECT, OBJECT]

# Empty object

query I
select variant_type('{}'::VARIANT);
----
VARCHAR

# Arrays

query I
select variant_type(['duck', 'goose']::VARIANT);
----
ARRAY

query I
select variant_type({'a': 1, 'b': ['duck', 'goose']}::VARIANT, 'b');
----
ARRAY

# FIXME: map type is currently casted into a shape inconsistent with respect to JSON

query I
select variant_type(MAP {'a': 1, 'b': 2}::VARIANT, 'a');
----
NULL

# Primitive values

query I
SELECT [*COLUMNS(*)] FROM (
	SELECT variant_type(
		COLUMNS(lambda c: NOT regexp_matches(c, 'array|struct|map|union|tuple'))::VARIANT
	)
	FROM test_all_types()
	-- strip NULLs from output
	WHERE bool IS NOT NULL
);
----
[BOOL_FALSE, INT8, INT16, INT32, INT64, INT128, UINT128, UINT8, UINT16, UINT32, UINT64, BIGNUM, DATE, TIME_MICROS, TIMESTAMP_MICROS, TIMESTAMP_SEC, TIMESTAMP_MILIS, TIMESTAMP_NANOS, TIME_MICROS_TZ, TIMESTAMP_MICROS_TZ, TIMESTAMP_NANOS_TZ, FLOAT, DOUBLE, DECIMAL, DECIMAL, DECIMAL, DECIMAL, UUID, INTERVAL, VARCHAR, BLOB, BITSTRING, VARCHAR, VARCHAR, VARCHAR, TIME_NANOS, GEOMETRY]
[BOOL_TRUE, INT8, INT16, INT32, INT64, INT128, UINT128, UINT8, UINT16, UINT32, UINT64, BIGNUM, DATE, TIME_MICROS, TIMESTAMP_MICROS, TIMESTAMP_SEC, TIMESTAMP_MILIS, TIMESTAMP_NANOS, TIME_MICROS_TZ, TIMESTAMP_MICROS_TZ, TIMESTAMP_NANOS_TZ, FLOAT, DOUBLE, DECIMAL, DECIMAL, DECIMAL, DECIMAL, UUID, INTERVAL, VARCHAR, BLOB, BITSTRING, VARCHAR, VARCHAR, VARCHAR, TIME_NANOS, GEOMETRY]

# NULL returns NULL

query I
select variant_type(NULL::VARIANT);
----
NULL

query I
select variant_type(NULL::VARIANT);
----
NULL

query I
select variant_type(NULL::VARIANT, 'a');
----
NULL

query I
select variant_type(j, 'a') from (values ({'a': {'x': 1}}::VARIANT), (NULL::VARIANT)) t(j);
----
OBJECT
NULL

query I
select variant_type(j, ['a', 'b']) from (values ({'a': {'x': 1}}::VARIANT), (NULL::VARIANT)) t(j);
----
[OBJECT, NULL]
NULL

# VARIANT_NULL

query I
select variant_type({'a': 1, 'b': null}::VARIANT, 'b');
----
VARIANT_NULL

# Supplied path does not exist in variant

query I
select variant_type('{}'::VARIANT, 'a');
----
NULL

query I
select variant_type({'a': 1, 'b': {'c': 12, 'd': 10}}::VARIANT, 'q');
----
NULL

# NULL path returns NULL

query I
select variant_type({'a': 1}::VARIANT, NULL);
----
NULL

# FIXME: Support for JSONPath and JSONPointer

query I
select variant_type({'a': 1, 'b': {'c': {'d': 12}}}::VARIANT, '$.b.c');
----
NULL

# Incorrect parameters

statement error
select variant_type({'a': 1}::VARIANT, [1]);
----
<REGEX>:.*No function matches the given name and argument types 'variant_type\(VARIANT, INTEGER\[\]\)'.*

statement error
select variant_type({'a': 1}::VARIANT, [NULL]);
----
Binder Error: 'variant_type' does not accept NULL paths

statement error
select variant_type({'a': 1}::VARIANT, [NULL::VARCHAR]);
----
Binder Error: 'variant_type' does not accept NULL paths

statement error
select variant_type({'c': 1}::VARIANT, ['c', NULL]::VARCHAR[]);
----
Binder Error: 'variant_type' does not accept NULL paths

query I
select variant_type({'c': 1}::VARIANT, []::VARCHAR[]);
----
[]

# FIXME: malformed JSON object should result in an error

statement ok
select variant_type('{"a"\: 1}'::VARIANT);
