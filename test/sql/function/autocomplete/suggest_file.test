# name: test/sql/function/autocomplete/suggest_file.test
# description: Test sql_auto_complete
# group: [autocomplete]

statement skip_test_on_error
SELECT assert_true(platform NOT LIKE 'windows_%', 'requires a non-windows platform') FROM pragma_platform()

require autocomplete

# test file auto complete
query I
SELECT suggestion FROM sql_auto_complete('COPY tbl FROM ''{DATA_DIR}/parq') LIMIT 1;
----
parquet-testing/

query I
SELECT suggestion FROM sql_auto_complete('COPY tbl FROM ''{DATA_DIR}/csv/all_quote') LIMIT 1;
