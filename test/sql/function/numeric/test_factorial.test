# name: test/sql/function/numeric/test_factorial.test
# description: Mod test
# group: [numeric]

query I
SELECT factorial(0);
----
1

statement error
SELECT factorial(-1);
----
factorial of a negative number is undefined

query I
SELECT factorial(NULL);
----
NULL

query I
SELECT factorial(2);
----
2

query I
SELECT factorial(10);
----
3628800

# postfix op
query I
SELECT 10!;
----
3628800

query I
SELECT factorial(20);
----
2432902008176640000

query I
SELECT factorial(30);
----
265252859812191058636308480000000

# overflow
statement error
SELECT factorial(40);
----
<REGEX>:.*Out of Range Error.*out of range.*

# last valid input
query I
SELECT factorial(33);
----
8683317618811886495518194401280000000

# first invalid input
statement error
SELECT factorial(34);
----
<REGEX>:.*Out of Range Error.*out of range.*

statement error
SELECT factorial(1.5);
----
<REGEX>:.*No function matches.*

statement error
SELECT factorial(3.0);
----
<REGEX>:.*No function matches.*