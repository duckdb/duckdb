statement ok
CREATE TABLE expected_result AS FROM (VALUES
	('microseconds', 0, 59999999),
	('milliseconds', 0, 59999),
	('second', 0, 59),
	('minute', 0, 59),
	('hour', 0, 24),
	('epoch', 0, 86400)
	) t(component, min, max)

foreach component second minute hour milliseconds microseconds epoch

query I
SELECT
	CASE WHEN stats.min = expected_result.min AND stats.max = expected_result.max THEN NULL ELSE {'stats': stats, 'expected_result': expected_result} END
FROM (
	SELECT STATS(EXTRACT({component} FROM i)) AS stats, (SELECT expected_result FROM expected_result WHERE component = '{component}') expected_result FROM times LIMIT 1
)
