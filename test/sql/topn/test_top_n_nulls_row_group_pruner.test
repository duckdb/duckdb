statement ok
CREATE TABLE integers AS
SELECT NULL::BIGINT AS i FROM range(122881)
UNION ALL
SELECT range::BIGINT AS i FROM range(122880)

query I
SELECT i FROM integers ORDER BY i NULLS LAST LIMIT 1 OFFSET 122880;
