statement ok
CREATE OR REPLACE TABLE prf_build_span (
	k BIGINT,
	g INTEGER,
	payload INTEGER
);

statement ok
INSERT INTO prf_build_span VALUES
	(0, 0, 10),
	(1048576, 3, 11),
	(2097152, 4, 12),
	(3145728, 10, 13);

query IIII
SELECT p.id, p.k, p.g, b.payload
FROM prf_probe_span p
JOIN prf_build_span b
  ON p.k = b.k
 AND p.g >= b.g
ORDER BY ALL;
----
1	0	0	10
3	1048576	5	11

statement ok
SET disabled_optimizers = 'join_filter_pushdown';

query IIII
SELECT p.id, p.k, p.g, b.payload
