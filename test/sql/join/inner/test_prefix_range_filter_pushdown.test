	k VARCHAR,
	g INTEGER,
	payload INTEGER
);

statement ok
INSERT INTO prf_build_string VALUES
	('ab', 0, 100),
	('abc', 2, 101),
	('abcd0', 4, 102),
	('abcd1', 3, 103),
	('abce0', 6, 104),
	('', 6, 105),
	('zzzzzz', 4, 106),
	(NULL, 0, 107),
	('abcd2', 1, 108);

query IIII
SELECT p.id, p.k, p.g, b.payload
FROM prf_probe_string p
JOIN prf_build_string b
  ON p.k = b.k
 AND p.g >= b.g
ORDER BY ALL;
----
