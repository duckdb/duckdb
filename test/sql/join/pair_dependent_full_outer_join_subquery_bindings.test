# name: test/sql/join/pair_dependent_full_outer_join_subquery_bindings.test
# description: Test payload and state binding layouts for pair-dependent FULL OUTER joins
# group: [join]

# A FULL OUTER pair-dependent predicate should also work when one side of the
# join exposes more than one underlying table binding.
statement ok
CREATE TABLE pair_multi_l(a INTEGER);

statement ok
CREATE TABLE pair_multi_l2(c INTEGER);

statement ok
CREATE TABLE pair_multi_r(b INTEGER);

statement ok
CREATE TABLE pair_multi_s(a INTEGER, b INTEGER, c INTEGER);

statement ok
INSERT INTO pair_multi_l VALUES (1), (2);

statement ok
INSERT INTO pair_multi_l2 VALUES (5);

statement ok
INSERT INTO pair_multi_r VALUES (10), (20), (30);

statement ok
INSERT INTO pair_multi_s VALUES (1, 10, 5), (2, 20, 5);

query III
SELECT l.a, l2.c, r.b
FROM pair_multi_l l
JOIN pair_multi_l2 l2 ON true
FULL OUTER JOIN pair_multi_r r ON EXISTS (
	SELECT 1
	FROM pair_multi_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	  AND s.c = l2.c
)
ORDER BY ALL;
----
1	5	10
2	5	20
NULL	NULL	30

