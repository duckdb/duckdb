# A single join input can also expose multiple binding groups through aggregate
# or window outputs.
statement ok
CREATE TABLE pair_multi_agg_s(a INTEGER, b INTEGER, cnt BIGINT);

statement ok
INSERT INTO pair_multi_agg_s VALUES (1, 10, 1), (2, 20, 1);

query III
SELECT l.a, l.cnt, r.b
FROM (SELECT a, count(*) AS cnt FROM pair_multi_l GROUP BY a) l
FULL OUTER JOIN pair_multi_r r ON EXISTS (
	SELECT 1
	FROM pair_multi_agg_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	  AND s.cnt = l.cnt
)
ORDER BY ALL;
----
1	1	10
2	1	20
NULL	NULL	30

statement ok
CREATE TABLE pair_multi_window_s(a INTEGER, b INTEGER, rn BIGINT);

statement ok
INSERT INTO pair_multi_window_s VALUES (1, 10, 1), (2, 20, 2);

query III
SELECT l.a, l.rn, r.b
FROM (SELECT a, row_number() OVER (ORDER BY a) AS rn FROM pair_multi_l) l
FULL OUTER JOIN pair_multi_r r ON EXISTS (
	SELECT 1
	FROM pair_multi_window_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	  AND s.rn = l.rn
)
ORDER BY ALL;
----
1	1	10
2	2	20
NULL	NULL	30

