query II
SELECT l.a, r.b
FROM (
	SELECT a FROM pair_multi_l WHERE a = 1
	UNION ALL
	SELECT a FROM pair_multi_l WHERE a = 2
) l
FULL OUTER JOIN (
	SELECT b FROM pair_multi_r WHERE b <= 20
	UNION ALL
	SELECT b FROM pair_multi_r WHERE b = 30
) r ON EXISTS (
	SELECT 1
	FROM pair_multi_s s
	WHERE s.a = l.a
	  AND s.b = r.b
)
ORDER BY ALL;
----
1	10
2	20
NULL	30

