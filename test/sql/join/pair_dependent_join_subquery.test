query IIII
SELECT o.a, q.a, q.x, q.b
FROM pair_right_corr_outer_l o
LEFT JOIN LATERAL (
	SELECT l.a, l.x, r.b
	FROM (SELECT * FROM pair_right_corr_l WHERE pair_right_corr_l.a = o.a) l
	RIGHT JOIN pair_right_corr_r r ON EXISTS (
		SELECT 1
		FROM pair_right_corr_s s
		WHERE s.a = l.a
		  AND s.b = r.b
	)
) q ON true
ORDER BY ALL;
----
