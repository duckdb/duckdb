# name: test/sql/join/pair_dependent_join_subquery.test
# description: Test pair-dependent subqueries in non-FULL join conditions
# group: [join]

statement ok
CREATE TABLE pair_l(a INTEGER, x INTEGER);

statement ok
CREATE TABLE pair_r(b INTEGER, y INTEGER);

statement ok
CREATE TABLE pair_s(a INTEGER, b INTEGER);

statement ok
INSERT INTO pair_l VALUES (1, 10), (1, 11), (2, 20), (3, 30);

statement ok
INSERT INTO pair_r VALUES (10, 100), (20, 200), (30, 300), (40, 400);

statement ok
INSERT INTO pair_s VALUES (1, 10), (1, 20), (2, 20), (NULL, 30), (3, NULL);

# Pair-dependent EXISTS can be lowered to a left lateral join: the RHS is
# filtered per left-side domain value and decorrelated by the dependent join
# planner.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

# When build/probe-side optimization is disabled, RIGHT JOIN reaches the
# join-condition dependent planner before it is normalized to LEFT JOIN.
statement ok
PRAGMA disable_optimizer;

query IIII
SELECT l.a, l.x, r.b, r.y
FROM pair_l l
RIGHT JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY ALL;
----
1	10	10	100
1	10	20	200
1	11	10	100
1	11	20	200
2	20	20	200
NULL	NULL	30	300
NULL	NULL	40	400

statement ok
PRAGMA enable_optimizer;

# Pair-dependent IN works in both orientations.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON l.a IN (
	SELECT s.a FROM pair_s s WHERE s.b = r.b
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON r.b IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON l.x > 10 AND r.b IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	NULL
1	11	10
1	11	20
2	20	20
3	30	NULL

# Pair-dependent NOT IN must preserve SQL null semantics.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON r.b NOT IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	30
1	10	40
1	11	30
1	11	40
2	20	10
2	20	30
2	20	40
3	30	NULL

# Scalar pair-dependent subqueries use the same left lateral lowering.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON r.b = (
	SELECT max(s.b) FROM pair_s s WHERE s.a = l.a AND s.b <= r.b
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON CASE WHEN l.x > 10 THEN r.b ELSE NULL END = (
	SELECT s.b FROM pair_s s WHERE s.a = l.a AND s.b = r.b LIMIT 1
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	NULL
1	11	10
1	11	20
2	20	20
3	30	NULL

# Pair-dependent subqueries can appear under OR with side-local predicates.
query IIII
SELECT l.a, l.x, r.b, r.y
FROM pair_l l
FULL OUTER JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
) OR l.x * 10 = r.y
ORDER BY ALL;
----
1	10	10	100
1	10	20	200
1	11	10	100
1	11	20	200
2	20	20	200
3	30	30	300
NULL	NULL	40	400

query II
SELECT l.a, l.x
FROM pair_l l
SEMI JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
) OR l.x * 10 = r.y
ORDER BY ALL;
----
1	10
1	11
2	20
3	30

query II
SELECT l.a, l.x
FROM pair_l l
ANTI JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
) OR l.x * 10 = r.y
ORDER BY ALL;
----

# A condition that depends only on the local side is planned independently.
query III
SELECT l.a, l.x, count(r.b)
FROM pair_l l
LEFT JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.b = r.b
)
GROUP BY l.a, l.x
ORDER BY ALL;
----
1	10	3
1	11	3
2	20	3
3	30	3

# Pair-dependent LEFT joins are represented as dependent joins, and still
# support inputs that expose more than one binding group on either side.
statement ok
CREATE TABLE pair_left_multi_l2(c INTEGER);

statement ok
CREATE TABLE pair_left_multi_r2(c INTEGER);

statement ok
CREATE TABLE pair_left_multi_s(a INTEGER, b INTEGER, c INTEGER);

statement ok
INSERT INTO pair_left_multi_l2 VALUES (5);

statement ok
INSERT INTO pair_left_multi_r2 VALUES (5), (6);

statement ok
INSERT INTO pair_left_multi_s VALUES (1, 10, 5), (2, 20, 5);

query III
SELECT l.a, r.b, r2.c
FROM pair_l l
LEFT JOIN (pair_r r JOIN pair_left_multi_r2 r2 ON true) ON EXISTS (
	SELECT 1
	FROM pair_left_multi_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	  AND s.c = r2.c
)
ORDER BY l.a, r.b NULLS LAST, r2.c NULLS LAST;
----
1	10	5
1	10	5
2	20	5
3	NULL	NULL

query III
SELECT l.a, l2.c, r.b
FROM (pair_l l JOIN pair_left_multi_l2 l2 ON true)
LEFT JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_multi_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	  AND s.c = l2.c
)
ORDER BY l.a, l2.c, r.b NULLS LAST;
----
1	5	10
1	5	10
2	5	20
3	5	NULL

# Local correlations inside nested subqueries should remain local to that
# subquery chain, not become lateral join correlations.
statement ok
CREATE TABLE pair_left_nested_t(c INTEGER);

statement ok
INSERT INTO pair_left_nested_t VALUES (5);

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		FROM pair_left_multi_s s
		WHERE s.a = l.a
		  AND s.b = r.b
		  AND s.c = t.c
	)
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	10
1	11	10
2	20	20
3	30	NULL

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		WHERE EXISTS (
			SELECT 1
			FROM pair_left_multi_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
		)
	)
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	10
1	11	10
2	20	20
3	30	NULL

# Pair-dependent SEMI and ANTI joins only expose the left input and must not
# multiply it by matching right-side rows.
query II
SELECT l.a, l.x
FROM pair_l l
SEMI JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		WHERE EXISTS (
			SELECT 1
			FROM pair_left_multi_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
		)
	)
)
ORDER BY ALL;
----
1	10
1	11
2	20

query II
SELECT l.a, l.x
FROM pair_l l
ANTI JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		WHERE EXISTS (
			SELECT 1
			FROM pair_left_multi_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
		)
	)
)
ORDER BY ALL;
----
3	30

# The dependent LEFT rewrite preserves duplicate payload multiplicities and
