FROM pair_right_corr_outer_r o
LEFT JOIN LATERAL (
	SELECT l.a, l.x, r.b
	FROM pair_right_corr_l l
	RIGHT JOIN (SELECT * FROM pair_right_corr_r WHERE pair_right_corr_r.b = o.b) r ON EXISTS (
		SELECT 1
		FROM pair_right_corr_s s
		WHERE s.a = l.a
		  AND s.b = r.b
	)
) q ON true
ORDER BY ALL;
