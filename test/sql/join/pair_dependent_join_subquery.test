# The generated side CTEs must preserve single evaluation of side-effecting
# expressions from the original join inputs in LEFT joins as well.
statement ok
CREATE SEQUENCE pair_left_effect_seq START 1;

statement ok
CREATE TABLE pair_left_effect_l(a INTEGER);

statement ok
CREATE TABLE pair_left_effect_r(b BIGINT);

statement ok
INSERT INTO pair_left_effect_l VALUES (1), (2);

statement ok
INSERT INTO pair_left_effect_r VALUES (1), (2), (3);

query II
WITH q AS (
	SELECT count(*)::INTEGER AS count_value
	FROM (SELECT a, nextval('pair_left_effect_seq') AS v FROM pair_left_effect_l) l
	LEFT JOIN pair_left_effect_r r ON EXISTS (
		SELECT 1 WHERE l.v = r.b
	)
)
SELECT count_value, currval('pair_left_effect_seq') FROM q;
----
2	2

# SEMI/ANTI pair-dependent rewrites route through dependent join decorrelation.
# The exposed left input must still be evaluated only once.
statement ok
CREATE SEQUENCE pair_exists_effect_seq START 1;

query II
WITH q AS (
	SELECT count(*)::INTEGER AS count_value
	FROM (SELECT a, nextval('pair_exists_effect_seq') AS v FROM pair_left_effect_l) l
	SEMI JOIN pair_left_effect_r r ON EXISTS (
		SELECT 1 WHERE l.v = r.b
	)
)
SELECT count_value, currval('pair_exists_effect_seq') FROM q;
----
2	2

statement ok
CREATE SEQUENCE pair_anti_effect_seq START 1;

query II
WITH q AS (
	SELECT count(*)::INTEGER AS count_value
	FROM (SELECT a, nextval('pair_anti_effect_seq') AS v FROM pair_left_effect_l) l
	ANTI JOIN pair_left_effect_r r ON EXISTS (
		SELECT 1 WHERE l.v = r.b
	)
)
SELECT count_value, currval('pair_anti_effect_seq') FROM q;
----
0	2

statement ok
CREATE SEQUENCE pair_exists_right_effect_seq START 1;

query II
WITH q AS (
	SELECT count(*)::INTEGER AS count_value
	FROM pair_left_effect_l l
	SEMI JOIN (SELECT b, nextval('pair_exists_right_effect_seq') AS v FROM pair_left_effect_r) r ON EXISTS (
		SELECT 1 WHERE l.a = r.v
	)
)
SELECT count_value, currval('pair_exists_right_effect_seq') FROM q;
----
2	3

statement ok
CREATE SEQUENCE pair_anti_right_effect_seq START 1;

query II
WITH q AS (
	SELECT count(*)::INTEGER AS count_value
	FROM pair_left_effect_l l
	ANTI JOIN (SELECT b, nextval('pair_anti_right_effect_seq') AS v FROM pair_left_effect_r) r ON EXISTS (
		SELECT 1 WHERE l.a = r.v
	)
)
SELECT count_value, currval('pair_anti_right_effect_seq') FROM q;
----
0	3

# RIGHT joins are normalized to LEFT joins before planning the pair-dependent predicate.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
RIGHT JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY r.b, l.x NULLS LAST;
----
1	10	10
1	11	10
1	10	20
1	11	20
2	20	20
NULL	NULL	30
NULL	NULL	40

query III
SELECT l.a, l.x, r.b
FROM pair_l l
RIGHT JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		FROM pair_left_multi_s s
		WHERE s.a = l.a
		  AND s.b = r.b
		  AND s.c = t.c
	)
)
ORDER BY r.b, l.x NULLS LAST;
----
1	10	10
1	11	10
2	20	20
NULL	NULL	30
NULL	NULL	40

