# name: test/sql/join/mark/mark_join_keyword.test
# description: Test the MARK JOIN keyword
# group: [mark]

statement ok
CREATE TABLE t1(a INTEGER);

statement ok
INSERT INTO t1 VALUES (1), (2), (3);

statement ok
CREATE TABLE t2(b INTEGER);

statement ok
INSERT INTO t2 VALUES (2), (3), (4);

# a MARK join projects the left hand side plus a boolean marker column
query II
SELECT a, m FROM (SELECT * FROM t1 MARK JOIN t2 ON (a = b)) tbl(a, m) ORDER BY a;
----
1	false
2	true
3	true

# the marker column can be used in a WHERE clause (equivalent to a SEMI join)
query I
SELECT a FROM (SELECT * FROM t1 MARK JOIN t2 ON (a = b)) tbl(a, m) WHERE m ORDER BY a;
----
2
3

# negating the marker is equivalent to an ANTI join
query I
SELECT a FROM (SELECT * FROM t1 MARK JOIN t2 ON (a = b)) tbl(a, m) WHERE NOT m ORDER BY a;
----
1

# MARK join with no matching rows on the right marks everything false
query II
SELECT a, m FROM (SELECT * FROM t1 MARK JOIN t2 ON (a = b + 100)) tbl(a, m) ORDER BY a;
----
1	false
2	false
3	false

# three-valued marker logic
# ==========================
statement ok
CREATE TABLE l(a INTEGER);

statement ok
INSERT INTO l VALUES (1), (2), (NULL);

statement ok
CREATE TABLE r(b INTEGER);

# right side WITHOUT NULLs: marker is true on match, false on no-match, NULL when the
# left value is NULL (NULL = b is unknown so it can never be a confirmed match)
statement ok
INSERT INTO r VALUES (2), (3);

query II
SELECT a, m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m) ORDER BY a NULLS LAST;
----
1	false
2	true
NULL	NULL

# right side WITH a NULL: a non-matching left value now yields NULL instead of false,
# because the unmatched NULL on the right makes the absence of a match unknown
statement ok
INSERT INTO r VALUES (NULL);

query II
SELECT a, m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m) ORDER BY a NULLS LAST;
----
1	NULL
2	true
NULL	NULL

# empty right side: marker is false for every left row, including NULL
# (mirrors `x IN (empty set)` being false even for NULL x)
statement ok
DELETE FROM r;

query II
SELECT a, m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m) ORDER BY a NULLS LAST;
----
1	false
2	false
NULL	false

# equivalence with subquery-generated MARK joins
# ==============================================
# `x IN (subquery)` is planned as a MARK join. An explicit single-condition MARK join
# must produce exactly the same three-valued marker as the IN expression.
statement ok
DELETE FROM r;

statement ok
INSERT INTO r VALUES (2), (3), (NULL);

# verify the IN subquery actually compiles to a MARK join
query II
EXPLAIN SELECT a, a IN (SELECT b FROM r) FROM l;
----
physical_plan	<REGEX>:.*MARK.*

# symmetric difference between explicit MARK join and IN must be empty (right has NULL)
query II
(SELECT a, m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m)
 EXCEPT SELECT a, a IN (SELECT b FROM r) FROM l)
UNION ALL
(SELECT a, a IN (SELECT b FROM r) FROM l
 EXCEPT SELECT a, m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m));
----

# same equivalence with the right side containing no NULLs
statement ok
DELETE FROM r WHERE b IS NULL;

query II
(SELECT a, m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m)
 EXCEPT SELECT a, a IN (SELECT b FROM r) FROM l)
UNION ALL
(SELECT a, a IN (SELECT b FROM r) FROM l
 EXCEPT SELECT a, m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m));
----

# the negated marker matches NOT IN (NULL-aware)
query II
(SELECT a, NOT m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m)
 EXCEPT SELECT a, a NOT IN (SELECT b FROM r) FROM l)
UNION ALL
(SELECT a, a NOT IN (SELECT b FROM r) FROM l
 EXCEPT SELECT a, NOT m FROM (SELECT * FROM l MARK JOIN r ON (a = b)) x(a, m));
----

# like SEMI/ANTI, MARK is still usable as a quoted identifier
statement ok
CREATE TABLE "mark"("mark" INTEGER);

statement ok
INSERT INTO "mark" VALUES (1);

query I
SELECT "mark" FROM "mark";
----
1
