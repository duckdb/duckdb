# fallback: SINGLE join via correlated scalar subquery
query II
SELECT b.k, b.name
FROM small_build b
WHERE b.k = (SELECT MAX(p.k) FROM big_probe p WHERE p.k = b.k)
ORDER BY b.k;
----
K1	one
K10	ten
K2	two
K3	three
K4	four
K5	five
K6	six
K7	seven
K8	eight
K9	nine

