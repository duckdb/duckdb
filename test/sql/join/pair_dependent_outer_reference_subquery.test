# A CTE ref can hide an input dependency on the enclosing query until CTE
# decorrelation. The dependent-join pipeline must keep that dependency intact.
query IIII
SELECT outer_r.b, q.a, q.x, q.b
FROM pair_r outer_r
LEFT JOIN LATERAL (
	WITH cr AS (SELECT b FROM pair_r WHERE pair_r.b = outer_r.b)
	SELECT l.a, l.x, cr.b
	FROM pair_l l
	LEFT JOIN cr ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = l.a
		  AND s.b = cr.b
	)
) q ON true
ORDER BY outer_r.b, q.a, q.x, q.b NULLS LAST;
----
10	1	10	10
10	1	11	10
10	2	20	NULL
10	3	30	NULL
20	1	10	20
20	1	11	20
20	2	20	20
20	3	30	NULL
30	1	10	NULL
30	1	11	NULL
30	2	20	NULL
30	3	30	NULL
40	1	10	NULL
40	1	11	NULL
40	2	20	NULL
40	3	30	NULL

query IIII
SELECT outer_l.a, q.a, q.x, q.b
FROM pair_right_corr_outer_l outer_l
LEFT JOIN LATERAL (
	WITH cl AS (SELECT a, x FROM pair_l WHERE pair_l.a = outer_l.a)
	SELECT cl.a, cl.x, r.b
	FROM cl
	LEFT JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = cl.a
		  AND s.b = r.b
	)
) q ON true
ORDER BY outer_l.a, q.a, q.x, q.b NULLS LAST;
