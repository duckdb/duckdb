query III
SELECT outer_l.x, q.a, q.b
FROM pair_l outer_l
LEFT JOIN LATERAL (
	SELECT l.a, r.b
	FROM pair_l l
	FULL OUTER JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = l.a
		  AND s.b = r.b
		  AND s.a = outer_l.a
	)
	WHERE l.x = outer_l.x
) q ON true
ORDER BY outer_l.x, q.a, q.b NULLS LAST;
----
10	1	10
10	1	20
11	1	10
11	1	20
20	2	20
30	3	NULL

query III
SELECT outer_l.x, q.a, q.b
FROM pair_l outer_l
LEFT JOIN LATERAL (
	SELECT l.a, r.b
	FROM pair_l l
	LEFT JOIN pair_r r ON l.a = outer_l.a AND r.b IN (
		SELECT s.b
		FROM pair_s s
		WHERE s.a = l.a
	)
	WHERE l.x = outer_l.x
) q ON true
ORDER BY outer_l.x, q.a, q.b NULLS LAST;
----
10	1	10
10	1	20
11	1	10
11	1	20
20	2	20
30	3	NULL
