query IIII
SELECT outer_l.a, q.a, q.x, q.b
FROM pair_right_corr_outer_l outer_l
LEFT JOIN LATERAL (
	WITH cl AS MATERIALIZED (
		SELECT a, x
		FROM pair_l
		WHERE EXISTS (
			SELECT 1
			WHERE pair_l.a = outer_l.a
		)
	)
	SELECT l.a, l.x, r.b
	FROM cl l
	LEFT JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = l.a
		  AND s.b = r.b
	)
) q ON true
ORDER BY outer_l.a, q.a, q.x, q.b NULLS LAST;
----
