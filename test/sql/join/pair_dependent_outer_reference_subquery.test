# Pair-dependent LEFT joins inside an enclosing lateral join stay in the normal
# dependent-join pipeline.
query III
SELECT outer_l.x, q.lx, q.b
FROM pair_l outer_l
LEFT JOIN LATERAL (
	SELECT l.x AS lx, r.b
	FROM (SELECT * FROM pair_l WHERE pair_l.a = outer_l.a) l
	LEFT JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = l.a
		  AND s.b = r.b
	)
) q ON true
ORDER BY outer_l.x, q.lx, q.b NULLS LAST;
----
10	10	10
10	10	20
10	11	10
10	11	20
11	10	10
11	10	20
11	11	10
11	11	20
20	20	20
30	30	NULL

query IIII
