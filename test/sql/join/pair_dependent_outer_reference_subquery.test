# The independent left input of a right-correlated SEMI join is paired with the
# active delim state before applying the SEMI predicate. Build/probe-side
# optimization must not reorder that delim-state cross product.
query II
SELECT outer_r.b, q.flag
FROM pair_r outer_r
LEFT JOIN LATERAL (
	WITH cr AS (SELECT b FROM pair_r WHERE pair_r.b = outer_r.b)
	SELECT 1 AS flag
	FROM (SELECT 1) ll
	SEMI JOIN cr ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.b = cr.b
	)
) q ON true
ORDER BY outer_r.b, q.flag;
----
10	1
20	1
30	1
40	NULL

statement ok
CREATE TABLE pair_outer_nested_o(x INTEGER);

statement ok
INSERT INTO pair_outer_nested_o VALUES (5), (6);

query IIII
SELECT o.x, q.a, q.lx, q.b
FROM pair_outer_nested_o o
LEFT JOIN LATERAL (
	SELECT l.a, l.x AS lx, r.b
	FROM pair_l l
	LEFT JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_left_nested_t t
		WHERE EXISTS (
			SELECT 1
			FROM pair_left_multi_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
			  AND s.c = o.x
		)
	)
) q ON true
ORDER BY o.x, q.a, q.lx, q.b NULLS LAST;
----
5	1	10	10
5	1	11	10
5	2	20	20
5	3	30	NULL
6	1	10	NULL
6	1	11	NULL
6	2	20	NULL
6	3	30	NULL

query IIII
SELECT o.x, q.a, q.lx, q.b
FROM pair_outer_nested_o o
LEFT JOIN LATERAL (
	SELECT l.a, l.x AS lx, r.b
	FROM pair_l l
	LEFT JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_left_nested_t t
		WHERE EXISTS (
			SELECT 1
			WHERE EXISTS (
				SELECT 1
				FROM pair_left_multi_s s
				WHERE s.a = l.a
				  AND s.b = r.b
				  AND s.c = t.c
				  AND s.c = o.x
			)
		)
	)
) q ON true
ORDER BY o.x, q.a, q.lx, q.b NULLS LAST;
----
