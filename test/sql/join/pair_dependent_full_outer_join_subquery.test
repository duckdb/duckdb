FROM pair_nested_l l
FULL OUTER JOIN pair_nested_r r ON EXISTS (
	SELECT 1
	WHERE EXISTS (
		SELECT 1 FROM pair_split_l sl WHERE sl.a = l.a
	)
	AND EXISTS (
		SELECT 1 FROM pair_split_r sr WHERE sr.b = r.b
	)
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
