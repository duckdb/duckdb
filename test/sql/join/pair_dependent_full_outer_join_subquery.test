query II
SELECT l.a, r.b
FROM pair_nested_l l
FULL OUTER JOIN pair_nested_r r ON EXISTS (
	SELECT 1
	FROM pair_nested_local_t t
	WHERE EXISTS (
		SELECT 1
		WHERE EXISTS (
			SELECT 1
			FROM pair_nested_local_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
		)
	)
)
ORDER BY ALL;
