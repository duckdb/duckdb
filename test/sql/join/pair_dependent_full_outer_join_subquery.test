# The executable pair domain deduplicates each raw side before forming the
# intended cross product. Payload columns are not part of either domain key.
query II
EXPLAIN SELECT l.a, l.x, r.b, r.y
FROM pair_unique_domain_l l
FULL OUTER JOIN pair_unique_domain_r r ON EXISTS (
	SELECT 1
	FROM pair_unique_domain_s s
	WHERE s.a = l.a
	  AND s.b = r.b
);
----
physical_plan	<REGEX>:.*Cross Product.*Hash Group By.*Hash Group By.*

query II
EXPLAIN SELECT l.a, l.x, r.b, r.y
FROM pair_unique_domain_l l
FULL OUTER JOIN pair_unique_domain_r r ON EXISTS (
	SELECT 1
	FROM pair_unique_domain_s s
	WHERE s.a = l.a
	  AND s.b = r.b
);
----
physical_plan	<!REGEX>:.*Cross Product.*Groups: #0, #1.*

query II
EXPLAIN SELECT l.a, l.x, r.b, r.y
FROM pair_unique_domain_l l
FULL OUTER JOIN pair_unique_domain_r r ON EXISTS (
	SELECT 1
	FROM pair_unique_domain_s s
	WHERE s.a = l.a
	  AND s.b = r.b
);
----
physical_plan	<!REGEX>:.*ROW_NUMBER.*

# Inputs already unique on the complete free-variable key are projected into
# the pair domain directly, without a second grouping step after the cross.
query II
EXPLAIN SELECT l.a, l.x, r.b, r.y
FROM (SELECT a, max(x)::INTEGER AS x FROM pair_unique_domain_l GROUP BY a) l
FULL OUTER JOIN (SELECT b, max(y)::INTEGER AS y FROM pair_unique_domain_r GROUP BY b) r ON EXISTS (
	SELECT 1
	FROM pair_unique_domain_s s
	WHERE s.a = l.a
	  AND s.b = r.b
);
----
physical_plan	<!REGEX>:.*Cross Product.*Hash Group By.*
