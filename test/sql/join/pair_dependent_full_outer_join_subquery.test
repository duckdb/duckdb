# name: test/sql/join/pair_dependent_full_outer_join_subquery.test
# description: Test pair-dependent subqueries in FULL OUTER join conditions
# group: [join]

statement ok
CREATE TABLE pair_l(a INTEGER, x INTEGER);

statement ok
CREATE TABLE pair_r(b INTEGER, y INTEGER);

statement ok
CREATE TABLE pair_s(a INTEGER, b INTEGER);

statement ok
INSERT INTO pair_l VALUES (1, 10), (1, 11), (2, 20), (3, 30);

statement ok
INSERT INTO pair_r VALUES (10, 100), (20, 200), (30, 300), (40, 400);

statement ok
INSERT INTO pair_s VALUES (1, 10), (1, 20), (2, 20), (NULL, 30), (3, NULL);

# Pair-dependent FULL OUTER JOIN predicates are evaluated through a match-domain
# CTE so unmatched rows from both sides are preserved.
query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	10
1	20
1	20
2	20
3	NULL
NULL	30
NULL	40

query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON r.b IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	10
1	20
1	20
2	20
3	NULL
NULL	30
NULL	40

query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON r.b = ANY (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	10
1	20
1	20
2	20
3	NULL
NULL	30
NULL	40

query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON r.b <> ALL (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	30
1	30
1	40
1	40
2	10
2	30
2	40
3	NULL
NULL	20

query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON NOT EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	30
1	30
1	40
1	40
2	10
2	30
2	40
3	10
3	20
3	30
3	40

# Nested subqueries inside the match-domain predicate may already contain their own
# dependent joins. Rebinding the predicate to the generated CTE refs must also
# update the dependent join correlation metadata, not just visible expressions.
statement ok
CREATE TABLE pair_nested_l(a INTEGER);

statement ok
CREATE TABLE pair_nested_r(b INTEGER);

statement ok
CREATE TABLE pair_nested_s(a INTEGER, b INTEGER);

statement ok
INSERT INTO pair_nested_l VALUES (1), (2), (3);

statement ok
INSERT INTO pair_nested_r VALUES (10), (20), (30);

statement ok
INSERT INTO pair_nested_s VALUES (1, 10), (2, 20);

query II
SELECT l.a, r.b
FROM pair_nested_l l
FULL OUTER JOIN pair_nested_r r ON EXISTS (
	SELECT 1 WHERE EXISTS (
		SELECT 1 FROM pair_nested_s s WHERE s.a = l.a AND s.b = r.b
	)
)
ORDER BY ALL;
----
1	10
2	20
3	NULL
NULL	30

query II
SELECT l.a, r.b
FROM pair_nested_l l
FULL OUTER JOIN pair_nested_r r ON EXISTS (
	WITH c AS (
		SELECT s.b
		FROM pair_nested_s s
		WHERE s.a = l.a
	)
	SELECT 1
	FROM c
	WHERE c.b = r.b
)
ORDER BY ALL;
----
1	10
2	20
3	NULL
NULL	30

