statement ok
CREATE TABLE pair_split_r(b INTEGER);

statement ok
INSERT INTO pair_split_l VALUES (1), (2);

statement ok
INSERT INTO pair_split_r VALUES (10), (20);

query II
SELECT l.a, r.b
FROM pair_nested_l l
FULL OUTER JOIN pair_nested_r r ON EXISTS (
	SELECT 1
	WHERE EXISTS (
		SELECT 1 FROM pair_split_l sl WHERE sl.a = l.a
	)
	AND EXISTS (
		SELECT 1 FROM pair_split_r sr WHERE sr.b = r.b
	)
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	20
2	10
2	20
3	NULL
NULL	30

query II
SELECT l.a, r.b
FROM pair_nested_l l
FULL OUTER JOIN pair_nested_r r ON EXISTS (
	SELECT 1
	WHERE EXISTS (
		SELECT 1 FROM pair_split_l sl WHERE sl.a = l.a
	)
	OR EXISTS (
		SELECT 1 FROM pair_split_r sr WHERE sr.b = r.b
	)
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	20
1	30
2	10
2	20
2	30
3	10
3	20

