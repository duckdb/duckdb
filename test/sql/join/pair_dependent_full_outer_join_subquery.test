# A FULL OUTER pair-dependent predicate should also work when one side of the
# join exposes more than one underlying table binding.
statement ok
CREATE TABLE pair_multi_l(a INTEGER);

statement ok
CREATE TABLE pair_multi_l2(c INTEGER);

statement ok
CREATE TABLE pair_multi_r(b INTEGER);

statement ok
CREATE TABLE pair_multi_s(a INTEGER, b INTEGER, c INTEGER);

