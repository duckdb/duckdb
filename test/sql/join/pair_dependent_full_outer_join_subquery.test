# Volatile pair-dependent predicates follow the same decorrelation semantics as
# the rest of the dependent join machinery.
query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
) AND random() >= 0
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	10
1	20
1	20
2	20
3	NULL
NULL	30
NULL	40

query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b AND random() >= 0
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	10
1	20
1	20
2	20
3	NULL
NULL	30
NULL	40

query TII
SELECT 'semi' AS j, l.a, l.x
FROM pair_l l
SEMI JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	  AND random() >= 0
)
UNION ALL
SELECT 'anti' AS j, l.a, l.x
FROM pair_l l
ANTI JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	  AND random() >= 0
)
ORDER BY j, l.a, l.x;
----
anti	3	30
semi	1	10
semi	1	11
semi	2	20

