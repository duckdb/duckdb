statement ok
CREATE TABLE pair_nested_outer_o(x INTEGER);

statement ok
INSERT INTO pair_nested_outer_o VALUES (5);

query I
SELECT *
FROM pair_nested_outer_o o
WHERE EXISTS (
	SELECT 1
	FROM pair_nested_l l
	FULL OUTER JOIN pair_nested_r r ON EXISTS (
		SELECT 1
		FROM pair_nested_local_s s
		WHERE s.a = l.a
		  AND s.b = r.b
		  AND s.c = o.x
	)
);
----
5

query I
SELECT *
FROM pair_nested_outer_o o
WHERE EXISTS (
	SELECT 1
	FROM pair_nested_l l
	FULL OUTER JOIN pair_nested_r r ON EXISTS (
		SELECT 1
		FROM pair_nested_local_t t
		WHERE EXISTS (
			SELECT 1
			FROM pair_nested_local_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
			  AND s.c = o.x
		)
	)
);
----
5

# The match-domain filter still goes through normal subquery decorrelation, including
# LIMIT, aggregate, and window paths.
statement ok
CREATE TABLE pair_decor_l(a INTEGER);

statement ok
CREATE TABLE pair_decor_r(b INTEGER);

statement ok
CREATE TABLE pair_decor_s(a INTEGER, b INTEGER);

statement ok
INSERT INTO pair_decor_l VALUES (1), (2), (3);

statement ok
INSERT INTO pair_decor_r VALUES (10), (20), (30);

statement ok
INSERT INTO pair_decor_s VALUES (1, 20), (1, 10), (2, 20);

query II
SELECT l.a, r.b
FROM pair_decor_l l
FULL OUTER JOIN pair_decor_r r ON EXISTS (
	SELECT 1
	FROM (
		SELECT s.b
		FROM pair_decor_s s
		WHERE s.a = l.a
		ORDER BY s.b
		LIMIT 1
	) q
	WHERE q.b = r.b
)
ORDER BY ALL;
----
1	10
2	20
3	NULL
NULL	30

query II
SELECT l.a, r.b
FROM pair_decor_l l
FULL OUTER JOIN pair_decor_r r ON EXISTS (
	SELECT s.a
	FROM pair_decor_s s
	WHERE s.a = l.a
	  AND s.b = r.b
	GROUP BY s.a
	HAVING count(*) > 0
)
ORDER BY ALL;
----
1	10
1	20
2	20
3	NULL
NULL	30

query II
SELECT l.a, r.b
FROM pair_decor_l l
FULL OUTER JOIN pair_decor_r r ON EXISTS (
	SELECT 1
	FROM (
		SELECT s.b, row_number() OVER (PARTITION BY s.a ORDER BY s.b) rn
		FROM pair_decor_s s
		WHERE s.a = l.a
	) q
	WHERE q.b = r.b
	  AND q.rn = 1
)
ORDER BY ALL;
----
1	10
2	20
3	NULL
NULL	30

# Nested FULL OUTER rewrites can replace the payload bindings from an inner
# match-domain rewrite again in the outer rewrite. References above the outer
# join should resolve to the final projection bindings.
statement ok
CREATE TABLE pair_nested_full_l(a INTEGER);

statement ok
CREATE TABLE pair_nested_full_m(b INTEGER);

statement ok
CREATE TABLE pair_nested_full_r(c INTEGER);

statement ok
CREATE TABLE pair_nested_full_s1(a INTEGER, b INTEGER);

statement ok
CREATE TABLE pair_nested_full_s2(a INTEGER, c INTEGER);

statement ok
INSERT INTO pair_nested_full_l VALUES (1), (2);

statement ok
INSERT INTO pair_nested_full_m VALUES (10), (20);

statement ok
INSERT INTO pair_nested_full_r VALUES (100), (200);

statement ok
INSERT INTO pair_nested_full_s1 VALUES (1, 10);

statement ok
INSERT INTO pair_nested_full_s2 VALUES (1, 100), (2, 200);

query III
SELECT l.a, m.b, r.c
FROM pair_nested_full_l l
FULL OUTER JOIN pair_nested_full_m m ON EXISTS (
	SELECT 1
	FROM pair_nested_full_s1 s
	WHERE s.a = l.a
	  AND s.b = m.b
)
FULL OUTER JOIN pair_nested_full_r r ON EXISTS (
	SELECT 1
	FROM pair_nested_full_s2 s
	WHERE s.a = l.a
	  AND s.c = r.c
)
ORDER BY ALL;
----
1	10	100
2	NULL	200
NULL	20	NULL

# The FULL OUTER rewrite must preserve payload columns and unmatched rows from
# both sides across the optimized and unoptimized paths.
query IIIII
SELECT l.a, l.x, r.b, r.y, count(*)::INTEGER
FROM pair_l l
FULL OUTER JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
GROUP BY ALL
ORDER BY ALL;
----
1	10	10	100	1
1	10	20	200	1
1	11	10	100	1
1	11	20	200	1
2	20	20	200	1
3	30	NULL	NULL	1
NULL	NULL	30	300	1
NULL	NULL	40	400	1

query IIIII
SELECT l.a, l.x, r.b, r.y, count(*)::INTEGER
FROM pair_l l
FULL OUTER JOIN pair_r r ON r.b = (
	SELECT max(s.b) FROM pair_s s WHERE s.a = l.a AND s.b <= r.b
)
GROUP BY ALL
ORDER BY ALL;
----
1	10	10	100	1
1	10	20	200	1
1	11	10	100	1
1	11	20	200	1
2	20	20	200	1
3	30	NULL	NULL	1
NULL	NULL	30	300	1
NULL	NULL	40	400	1

query IIIII
SELECT l.a, l.x, r.b, r.y, count(*)::INTEGER
FROM pair_l l
FULL OUTER JOIN pair_r r ON l.x > 10 AND r.b IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
GROUP BY ALL
ORDER BY ALL;
----
1	10	NULL	NULL	1
1	11	10	100	1
1	11	20	200	1
2	20	20	200	1
3	30	NULL	NULL	1
NULL	NULL	30	300	1
NULL	NULL	40	400	1

query IIIII
SELECT l.a, l.x, r.b, r.y, count(*)::INTEGER
FROM pair_l l
FULL OUTER JOIN pair_r r ON r.b NOT IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
GROUP BY ALL
ORDER BY ALL;
----
1	10	30	300	1
1	10	40	400	1
1	11	30	300	1
1	11	40	400	1
2	20	10	100	1
2	20	30	300	1
2	20	40	400	1
3	30	NULL	NULL	1
NULL	NULL	20	200	1

