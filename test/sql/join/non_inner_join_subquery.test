SELECT outer_l.a, q.a, q.x
FROM pair_right_corr_outer_l outer_l
LEFT JOIN LATERAL (
	WITH cl AS (SELECT a, x FROM pair_l WHERE pair_l.a = outer_l.a)
	SELECT cl.a, cl.x
	FROM cl
	SEMI JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = cl.a
		  AND s.b = r.b
	)
) q ON true
ORDER BY outer_l.a, q.a, q.x;
----
1	1	10
1	1	11
2	2	20
4	NULL	NULL

