FROM pair_l outer_l
LEFT JOIN LATERAL (
	SELECT l.a, r.b
	FROM pair_l l
	LEFT JOIN pair_r r ON l.a = outer_l.a AND r.b IN (
		SELECT s.b
		FROM pair_s s
		WHERE s.a = l.a
	)
	WHERE l.x = outer_l.x
) q ON true
ORDER BY outer_l.x, q.a, q.b NULLS LAST;
