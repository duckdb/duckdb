# name: test/sql/join/non_inner_join_subquery.test
# description: Test subqueries in non-inner join conditions
# group: [join]

statement ok
CREATE TABLE non_inner_l(i INTEGER, j INTEGER);

statement ok
CREATE TABLE non_inner_r(i INTEGER, j INTEGER);

statement ok
CREATE TABLE non_inner_s(i INTEGER, j INTEGER);

statement ok
INSERT INTO non_inner_l VALUES (1, 10), (2, 20), (3, 30);

statement ok
INSERT INTO non_inner_r VALUES (1, 100), (2, 200), (4, 400), (NULL, 999);

statement ok
INSERT INTO non_inner_s VALUES (1, 10), (2, 20), (NULL, 99);

# The subquery only depends on the left input. It is decorrelated into the
# left input, but the resulting predicate must remain an outer join predicate.
query II
SELECT l.i, r.i
FROM non_inner_l l
LEFT JOIN non_inner_r r ON l.i IN (SELECT s.i FROM non_inner_s s WHERE s.i = l.i)
ORDER BY l.i, r.i NULLS LAST;
----
1	1
1	2
1	4
1	NULL
2	1
2	2
2	4
2	NULL
3	NULL

# The subquery only depends on the right input. This is safe to push into the
# right side for a left join.
query II
SELECT l.i, r.i
FROM non_inner_l l
LEFT JOIN non_inner_r r ON r.i IN (SELECT s.i FROM non_inner_s s WHERE s.i = r.i)
ORDER BY l.i, r.i NULLS LAST;
----
1	1
1	2
2	1
2	2
3	1
3	2

# The subquery is in a comparison condition and depends on the left input.
query II
SELECT l.i, r.i
FROM non_inner_l l
LEFT JOIN non_inner_r r ON r.i = CASE
	WHEN l.j >= 20 THEN (SELECT s.i FROM non_inner_s s WHERE s.i = l.i LIMIT 1)
	ELSE NULL
END
ORDER BY l.i, r.i NULLS LAST;
----
1	NULL
2	2
3	NULL

# Uncorrelated subqueries inside comparison keys must be planned into the same
# side as their containing expression, otherwise the comparison join key no
# longer belongs to a single input side.
query II
SELECT l.i, r.i
FROM non_inner_l l
LEFT JOIN non_inner_r r ON l.i + (SELECT 1) = r.i + (SELECT 0)
ORDER BY l.i, r.i NULLS LAST;
----
1	2
2	NULL
3	4

# The NOT IN marker is decorrelated before evaluating the arbitrary ON
# predicate.
query III
SELECT l.i, r.i, r.j
FROM non_inner_l l
LEFT JOIN non_inner_r r ON r.i IS NULL OR (r.i = l.i AND l.i NOT IN (SELECT i FROM non_inner_s))
ORDER BY l.i, r.i NULLS LAST, r.j NULLS LAST;
----
1	NULL	999
2	NULL	999
3	NULL	999

# An uncorrelated scalar subquery can be planned into either input. The join
# predicate remains an outer join predicate.
query III
SELECT l.i, r.i, r.j
FROM non_inner_l l
FULL OUTER JOIN non_inner_r r ON l.i = (SELECT MIN(i) FROM non_inner_s)
ORDER BY l.i, r.i NULLS LAST, r.j NULLS LAST;
----
1	1	100
1	2	200
1	4	400
1	NULL	999
2	NULL	NULL
3	NULL	NULL

# FULL OUTER joins with side-local subqueries are not accepted by PostgreSQL
# for this arbitrary predicate shape, but DuckDB can evaluate the predicate
# while preserving both unmatched sides.
query III
SELECT l.i, r.i, r.j
FROM non_inner_l l
FULL OUTER JOIN non_inner_r r ON l.i IN (SELECT s.i FROM non_inner_s s WHERE s.i = l.i)
ORDER BY l.i NULLS LAST, r.i NULLS LAST, r.j NULLS LAST;
----
1	1	100
1	2	200
1	4	400
1	NULL	999
2	1	100
2	2	200
2	4	400
2	NULL	999
3	NULL	NULL

query III
SELECT l.i, r.i, r.j
FROM non_inner_l l
FULL OUTER JOIN non_inner_r r ON r.i IN (SELECT s.i FROM non_inner_s s WHERE s.i = r.i)
ORDER BY l.i NULLS LAST, r.i NULLS LAST, r.j NULLS LAST;
----
1	1	100
1	2	200
2	1	100
2	2	200
3	1	100
3	2	200
NULL	4	400
NULL	NULL	999

# RIGHT joins with side-local subqueries are normalized to LEFT joins by the
# planner and should retain PostgreSQL-compatible results.
query III
SELECT l.i, r.i, r.j
FROM non_inner_l l
RIGHT JOIN non_inner_r r ON l.i IN (SELECT s.i FROM non_inner_s s WHERE s.i = l.i)
ORDER BY l.i NULLS LAST, r.i NULLS LAST, r.j NULLS LAST;
----
1	1	100
1	2	200
1	4	400
1	NULL	999
2	1	100
2	2	200
2	4	400
2	NULL	999

query III
SELECT l.i, r.i, r.j
FROM non_inner_l l
RIGHT JOIN non_inner_r r ON r.i IN (SELECT s.i FROM non_inner_s s WHERE s.i = r.i)
ORDER BY l.i NULLS LAST, r.i NULLS LAST, r.j NULLS LAST;
----
1	1	100
1	2	200
2	1	100
2	2	200
3	1	100
3	2	200
NULL	4	400
NULL	NULL	999

statement ok
CREATE TABLE pair_l(a INTEGER, x INTEGER);

statement ok
CREATE TABLE pair_r(b INTEGER, y INTEGER);

statement ok
CREATE TABLE pair_s(a INTEGER, b INTEGER);

statement ok
INSERT INTO pair_l VALUES (1, 10), (1, 11), (2, 20), (3, 30);

statement ok
INSERT INTO pair_r VALUES (10, 100), (20, 200), (30, 300), (40, 400);

statement ok
INSERT INTO pair_s VALUES (1, 10), (1, 20), (2, 20), (NULL, 30), (3, NULL);

# Pair-dependent EXISTS can be lowered to a left lateral join: the RHS is
# filtered per left-side domain value and decorrelated by the dependent join
# planner.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

# Pair-dependent IN works in both orientations.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON l.a IN (
	SELECT s.a FROM pair_s s WHERE s.b = r.b
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON r.b IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON l.x > 10 AND r.b IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.x, r.b NULLS LAST;
----
1	10	NULL
1	11	10
1	11	20
2	20	20
3	30	NULL

# Pair-dependent NOT IN must preserve SQL null semantics.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON r.b NOT IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	30
1	10	40
1	11	30
1	11	40
2	20	10
2	20	30
2	20	40
3	30	NULL

# Scalar pair-dependent subqueries use the same left lateral lowering.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON r.b = (
	SELECT max(s.b) FROM pair_s s WHERE s.a = l.a AND s.b <= r.b
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	10
1	10	20
1	11	10
1	11	20
2	20	20
3	30	NULL

query III
SELECT l.a, l.x, r.b
FROM pair_l l
LEFT JOIN pair_r r ON CASE WHEN l.x > 10 THEN r.b ELSE NULL END = (
	SELECT s.b FROM pair_s s WHERE s.a = l.a AND s.b = r.b LIMIT 1
)
ORDER BY l.a, l.x, r.b NULLS LAST;
----
1	10	NULL
1	11	10
1	11	20
2	20	20
3	30	NULL

# RIGHT joins are normalized to LEFT joins before planning the pair-dependent predicate.
query III
SELECT l.a, l.x, r.b
FROM pair_l l
RIGHT JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY r.b, l.x NULLS LAST;
----
1	10	10
1	11	10
1	10	20
1	11	20
2	20	20
NULL	NULL	30
NULL	NULL	40

# Pair-dependent FULL OUTER JOIN predicates are evaluated through a match-set
# CTE so unmatched rows from both sides are preserved.
query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON EXISTS (
	SELECT 1 FROM pair_s s WHERE s.a = l.a AND s.b = r.b
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	10
1	20
1	20
2	20
3	NULL
NULL	30
NULL	40

query II
SELECT l.a, r.b
FROM pair_l l
FULL OUTER JOIN pair_r r ON r.b IN (
	SELECT s.b FROM pair_s s WHERE s.a = l.a
)
ORDER BY l.a NULLS LAST, r.b NULLS LAST;
----
1	10
1	10
1	20
1	20
2	20
3	NULL
NULL	30
NULL	40

# Pair-dependent joins can also reference an outer query. The pair-dependent
# predicate is still lowered to a left lateral join, and the outer reference is
# handled by the enclosing dependent join.
query III
SELECT outer_l.x, q.a, q.b
FROM pair_l outer_l
LEFT JOIN LATERAL (
	SELECT l.a, r.b
	FROM pair_l l
	LEFT JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = l.a
		  AND s.b = r.b
		  AND s.a = outer_l.a
	)
	WHERE l.x = outer_l.x
) q ON true
ORDER BY outer_l.x, q.a, q.b NULLS LAST;
----
10	1	10
10	1	20
11	1	10
11	1	20
20	2	20
30	3	NULL

query III
SELECT outer_l.x, q.a, q.b
FROM pair_l outer_l
LEFT JOIN LATERAL (
	SELECT l.a, r.b
	FROM pair_l l
	LEFT JOIN pair_r r ON l.a = outer_l.a AND r.b IN (
		SELECT s.b
		FROM pair_s s
		WHERE s.a = l.a
	)
	WHERE l.x = outer_l.x
) q ON true
ORDER BY outer_l.x, q.a, q.b NULLS LAST;
----
10	1	10
10	1	20
11	1	10
11	1	20
20	2	20
30	3	NULL
