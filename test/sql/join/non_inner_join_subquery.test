FROM pair_l l
RIGHT JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		FROM pair_left_multi_s s
		WHERE s.a = l.a
		  AND s.b = r.b
		  AND s.c = t.c
	)
)
ORDER BY r.b, l.x NULLS LAST;
----
1	10	10
1	11	10
2	20	20
NULL	NULL	30
NULL	NULL	40

