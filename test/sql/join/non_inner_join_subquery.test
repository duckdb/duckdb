FROM pair_right_corr_outer_l outer_l
LEFT JOIN LATERAL (
	WITH cl AS (SELECT a, x FROM pair_l WHERE pair_l.a = outer_l.a)
	SELECT cl.a, cl.x, r.b
	FROM cl
	LEFT JOIN pair_r r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = cl.a
		  AND s.b = r.b
	)
) q ON true
