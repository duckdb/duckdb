# Both inputs can expose multiple binding layouts. The row-id stitching used
# for side reconstruction must preserve duplicates and NULL matches for FULL,
# SEMI, and ANTI pair-dependent rewrites.
statement ok
CREATE TABLE pair_multi_both_l(id INTEGER, a INTEGER);

statement ok
CREATE TABLE pair_multi_both_l2(lid INTEGER, z INTEGER);

statement ok
CREATE TABLE pair_multi_both_r(id INTEGER, b INTEGER);

statement ok
CREATE TABLE pair_multi_both_r2(rid INTEGER, w INTEGER);

statement ok
CREATE TABLE pair_multi_both_s(a INTEGER, b INTEGER, z INTEGER, w INTEGER);

statement ok
INSERT INTO pair_multi_both_l VALUES (1, 1), (2, 1), (3, 2), (4, NULL);

statement ok
INSERT INTO pair_multi_both_l2 VALUES (1, 5), (2, 5), (3, 6), (4, 7);

statement ok
INSERT INTO pair_multi_both_r VALUES (10, 10), (11, 10), (12, 20), (13, NULL);

statement ok
INSERT INTO pair_multi_both_r2 VALUES (10, 50), (11, 50), (12, 60), (13, 70);

statement ok
INSERT INTO pair_multi_both_s VALUES (1, 10, 5, 50), (2, 20, 6, 60), (NULL, NULL, 7, 70), (1, 20, 5, 60);

query TII
WITH left_side AS (
	SELECT l.id AS lid, l.a, l2.z
	FROM pair_multi_both_l l
	JOIN pair_multi_both_l2 l2 ON l.id = l2.lid
), right_side AS (
	SELECT r.id AS rid, r.b, r2.w
	FROM pair_multi_both_r r
	JOIN pair_multi_both_r2 r2 ON r.id = r2.rid
), actual AS (
	SELECT l.id AS lid, l.a, l2.z, r.id AS rid, r.b, r2.w
	FROM pair_multi_both_l l
	JOIN pair_multi_both_l2 l2 ON l.id = l2.lid
	FULL OUTER JOIN (
		pair_multi_both_r r
		JOIN pair_multi_both_r2 r2 ON r.id = r2.rid
	) ON EXISTS (
		SELECT 1
		FROM pair_multi_both_s s
		WHERE s.a IS NOT DISTINCT FROM l.a
		  AND s.b IS NOT DISTINCT FROM r.b
		  AND s.z IS NOT DISTINCT FROM l2.z
		  AND s.w IS NOT DISTINCT FROM r2.w
	)
), manual_matches AS (
	SELECT l.lid, l.a, l.z, r.rid, r.b, r.w
	FROM left_side l, right_side r
	WHERE EXISTS (
		SELECT 1
		FROM pair_multi_both_s s
		WHERE s.a IS NOT DISTINCT FROM l.a
		  AND s.b IS NOT DISTINCT FROM r.b
		  AND s.z IS NOT DISTINCT FROM l.z
		  AND s.w IS NOT DISTINCT FROM r.w
	)
), manual AS (
	SELECT * FROM manual_matches
	UNION ALL
	SELECT l.lid, l.a, l.z, NULL::INTEGER, NULL::INTEGER, NULL::INTEGER
	FROM left_side l
	WHERE NOT EXISTS (
		SELECT 1
		FROM right_side r
		WHERE EXISTS (
			SELECT 1
			FROM pair_multi_both_s s
			WHERE s.a IS NOT DISTINCT FROM l.a
			  AND s.b IS NOT DISTINCT FROM r.b
			  AND s.z IS NOT DISTINCT FROM l.z
			  AND s.w IS NOT DISTINCT FROM r.w
		)
	)
	UNION ALL
	SELECT NULL::INTEGER, NULL::INTEGER, NULL::INTEGER, r.rid, r.b, r.w
	FROM right_side r
	WHERE NOT EXISTS (
		SELECT 1
		FROM left_side l
		WHERE EXISTS (
			SELECT 1
			FROM pair_multi_both_s s
			WHERE s.a IS NOT DISTINCT FROM l.a
			  AND s.b IS NOT DISTINCT FROM r.b
			  AND s.z IS NOT DISTINCT FROM l.z
			  AND s.w IS NOT DISTINCT FROM r.w
		)
	)
), a_minus_m AS (
	SELECT * FROM actual EXCEPT ALL SELECT * FROM manual
), m_minus_a AS (
	SELECT * FROM manual EXCEPT ALL SELECT * FROM actual
)
SELECT 'full_multi_layout', (SELECT count(*) FROM a_minus_m), (SELECT count(*) FROM m_minus_a);
----
full_multi_layout	0	0

query TII
WITH left_side AS (
	SELECT l.id AS lid, l.a, l2.z
	FROM pair_multi_both_l l
	JOIN pair_multi_both_l2 l2 ON l.id = l2.lid
), right_side AS (
	SELECT r.id AS rid, r.b, r2.w
	FROM pair_multi_both_r r
	JOIN pair_multi_both_r2 r2 ON r.id = r2.rid
), actual AS (
	SELECT l.id AS lid, l.a, l2.z
	FROM pair_multi_both_l l
	JOIN pair_multi_both_l2 l2 ON l.id = l2.lid
	SEMI JOIN (
		pair_multi_both_r r
		JOIN pair_multi_both_r2 r2 ON r.id = r2.rid
	) ON EXISTS (
		SELECT 1
		FROM pair_multi_both_s s
		WHERE s.a IS NOT DISTINCT FROM l.a
		  AND s.b IS NOT DISTINCT FROM r.b
		  AND s.z IS NOT DISTINCT FROM l2.z
		  AND s.w IS NOT DISTINCT FROM r2.w
	)
), manual AS (
	SELECT l.lid, l.a, l.z
	FROM left_side l
	WHERE EXISTS (
		SELECT 1
		FROM right_side r
		WHERE EXISTS (
			SELECT 1
			FROM pair_multi_both_s s
			WHERE s.a IS NOT DISTINCT FROM l.a
			  AND s.b IS NOT DISTINCT FROM r.b
			  AND s.z IS NOT DISTINCT FROM l.z
			  AND s.w IS NOT DISTINCT FROM r.w
