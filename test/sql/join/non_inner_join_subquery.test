1	11	10
2	20	20
3	30	NULL

# Pair-dependent SEMI and ANTI joins use the same match-set shape, but only
# expose the left input and must not multiply it by matching right-side rows.
query II
SELECT l.a, l.x
FROM pair_l l
SEMI JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		WHERE EXISTS (
			SELECT 1
			FROM pair_left_multi_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
		)
	)
)
ORDER BY ALL;
----
1	10
1	11
2	20

query II
SELECT l.a, l.x
FROM pair_l l
ANTI JOIN pair_r r ON EXISTS (
	SELECT 1
	FROM pair_left_nested_t t
	WHERE EXISTS (
		SELECT 1
		WHERE EXISTS (
			SELECT 1
			FROM pair_left_multi_s s
			WHERE s.a = l.a
			  AND s.b = r.b
			  AND s.c = t.c
		)
	)
)
ORDER BY ALL;
----
3	30

