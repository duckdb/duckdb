query II
SELECT l.a, r.b
FROM pair_decor_l l
FULL OUTER JOIN pair_decor_r r ON EXISTS (
	SELECT 1
	FROM (
		SELECT s.b
		FROM pair_decor_s s
		WHERE s.a = l.a
		ORDER BY s.b
		LIMIT 1
	) q
	WHERE q.b = r.b
)
ORDER BY ALL;
----
