FROM pair_r outer_r
LEFT JOIN LATERAL (
	SELECT l.a, l.x, r.b
	FROM pair_l l
	LEFT JOIN (SELECT * FROM pair_r WHERE pair_r.b = outer_r.b) r ON EXISTS (
		SELECT 1
		FROM pair_s s
		WHERE s.a = l.a
		  AND s.b = r.b
	)
) q ON true
