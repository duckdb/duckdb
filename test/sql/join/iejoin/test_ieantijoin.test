# Verify all predicates
query IIIII
FROM wide_ranges l
ANTI JOIN narrow_ranges r
	   ON l.start < r.stop
	  AND r.start < l.stop
	  AND r.symbol = l.symbol
	  AND l.price + r.bid < 375
ORDER BY id;
