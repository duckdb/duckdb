# name: test/sql/merge/merge_query_node.test
# description: Tests for MergeQueryNode (MergeIntoStatement as thin wrapper over MergeQueryNode)
# group: [merge]

statement ok
PRAGMA enable_verification

statement ok
CREATE TABLE Stock(item_id INTEGER, balance INTEGER);

statement ok
INSERT INTO Stock VALUES (10, 2200), (20, 1900);

statement ok
CREATE TABLE Buy(item_id INTEGER, volume INTEGER);

statement ok
INSERT INTO Buy VALUES (10, 1000), (30, 300);

# basic MERGE with UPDATE + INSERT
statement ok
MERGE INTO Stock USING Buy ON Stock.item_id = Buy.item_id
WHEN MATCHED THEN UPDATE SET balance = balance + Buy.volume
WHEN NOT MATCHED THEN INSERT VALUES (Buy.item_id, Buy.volume);

query II
SELECT * FROM Stock ORDER BY item_id;
----
10	3200
20	1900
30	300

# MERGE with DELETE
statement ok
MERGE INTO Stock USING Buy ON Stock.item_id = Buy.item_id
WHEN MATCHED THEN DELETE;

query II
SELECT * FROM Stock ORDER BY item_id;
----
20	1900

# MERGE with RETURNING
query II rowsort
MERGE INTO Stock USING Buy ON Stock.item_id = Buy.item_id
WHEN NOT MATCHED THEN INSERT VALUES (Buy.item_id, Buy.volume)
RETURNING item_id, balance;
----
10	1000
30	300

# MERGE with USING column list
statement ok
CREATE TABLE t1(i INTEGER, j INTEGER);

statement ok
INSERT INTO t1 VALUES (1, 1), (2, 2);

statement ok
CREATE TABLE t2(i INTEGER, j INTEGER);

statement ok
INSERT INTO t2 VALUES (1, 10), (3, 30);

statement ok
MERGE INTO t1 USING t2 USING (i)
WHEN MATCHED THEN UPDATE SET j = t2.j
WHEN NOT MATCHED THEN INSERT VALUES (t2.i, t2.j);

query II
SELECT * FROM t1 ORDER BY i;
----
1	10
2	2
3	30

# MERGE driven by a CTE source
statement ok
MERGE INTO t1 USING (WITH src AS (SELECT 2 AS i, 222 AS j) SELECT * FROM src) AS s ON t1.i = s.i
WHEN MATCHED THEN UPDATE SET j = s.j;

query II
SELECT * FROM t1 ORDER BY i;
----
1	10
2	222
3	30

# MERGE with WHEN NOT MATCHED BY SOURCE
statement ok
MERGE INTO t1 USING t2 ON t1.i = t2.i
WHEN NOT MATCHED BY SOURCE THEN DELETE;

query II
SELECT * FROM t1 ORDER BY i;
----
1	10
3	30
