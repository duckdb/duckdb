# name: test/sql/variant/variant_comparator.test
# description: Test the logical ordering of VARIANT values (variant_comparator + collation)
# group: [variant]

require parquet

# integers: negative numbers sort before positive numbers (not by raw bytes)
query I
SELECT v::INT FROM (VALUES (-123), (5), (-1), (100), (0)) t(v)
ORDER BY v::INT::VARIANT
----
-123
-1
0
5
100

# descending
query I
SELECT v::INT FROM (VALUES (-123), (5), (-1), (100), (0)) t(v)
ORDER BY v::INT::VARIANT DESC
----
100
5
0
-1
-123

# doubles, including NaN (NaN sorts after everything) and -inf/+inf
query I
SELECT v FROM (VALUES ('nan'::DOUBLE), (1.5::DOUBLE), (-1.5::DOUBLE), ('-inf'::DOUBLE), ('inf'::DOUBLE), (0.0::DOUBLE)) t(v)
ORDER BY v::VARIANT
----
-inf
-1.5
0.0
1.5
inf
nan

# -0.0 is equivalent to 0.0 in the comparator (IEEE / SQL semantics)
query I
SELECT variant_comparator('-0.0'::DOUBLE::VARIANT) = variant_comparator('0.0'::DOUBLE::VARIANT)
----
true

# strings
query I
SELECT v FROM (VALUES ('banana'), ('apple'), ('cherry')) t(v)
ORDER BY v::VARCHAR::VARIANT
----
apple
banana
cherry

# objects with the same keys in different order must produce identical sort keys
query I
SELECT variant_comparator({'b': 10, 'a': 1}::VARIANT) = variant_comparator({'a': 1, 'b': 10}::VARIANT)
----
true

# objects with different values are not equal
query I
SELECT variant_comparator({'a': 1, 'b': 10}::VARIANT) = variant_comparator({'a': 1, 'b': 11}::VARIANT)
----
false

# arrays sort element-by-element, shorter prefix sorts first
query I
SELECT v::INT[]::VARCHAR FROM (VALUES ([1,2,3]), ([1,2]), ([1,3]), ([1])) t(v)
ORDER BY v::INT[]::VARIANT
----
[1]
[1, 2]
[1, 2, 3]
[1, 3]

# NUMBER fold: integers of all widths/signedness with the same value produce the same sort key
query IIII
SELECT
    variant_comparator(1::TINYINT::VARIANT) = variant_comparator(1::INTEGER::VARIANT),
    variant_comparator(1::BIGINT::VARIANT) = variant_comparator(1::UINTEGER::VARIANT),
    variant_comparator(1::HUGEINT::VARIANT) = variant_comparator(1::UTINYINT::VARIANT),
    variant_comparator(1::INTEGER::VARIANT) = variant_comparator(1::UHUGEINT::VARIANT)
----
true	true	true	true

# NUMBER fold: integers, decimals and bignums of equal value produce the same sort key
query III
SELECT
    variant_comparator(5::INTEGER::VARIANT) = variant_comparator(5.00::DECIMAL(5,2)::VARIANT),
    variant_comparator(5::BIGINT::VARIANT) = variant_comparator(5::BIGNUM::VARIANT),
    variant_comparator(5.00::DECIMAL(5,2)::VARIANT) = variant_comparator(5::BIGNUM::VARIANT)
----
true	true	true

# NUMBER fold: ordered by numeric value across integers, decimals and bignums (negatives included)
query I
SELECT v::VARCHAR FROM (VALUES
    ((-100.5)::DECIMAL(5,1)::VARIANT),
    (3::TINYINT::VARIANT),
    (1000000000000000000000000000::BIGNUM::VARIANT),
    (0::UTINYINT::VARIANT),
    (1.5::DECIMAL(2,1)::VARIANT),
    ((-128)::TINYINT::VARIANT),
    (15::BIGINT::VARIANT)
) t(v)
ORDER BY v
----
-128
-100.5
0
1.5
3
15
1000000000000000000000000000

# NUMBER fold makes -100.5 less than 0 (decimals and integers compare by numeric value)
query I
SELECT (-100.5)::DECIMAL(5,1)::VARIANT > 0
----
false

# real fold: FLOAT and DOUBLE with the same value produce the same sort key
query I
SELECT variant_comparator(1.5::FLOAT::VARIANT) = variant_comparator(1.5::DOUBLE::VARIANT)
----
true

# NUMBER and REAL are still distinct ranks (1::INT is not equal to 1.0::DOUBLE)
query I
SELECT variant_comparator(1::INTEGER::VARIANT) = variant_comparator(1.0::DOUBLE::VARIANT)
----
false

# booleans: false sorts before true
query I
SELECT v FROM (VALUES (true), (false), (true), (false)) t(v)
ORDER BY v::BOOLEAN::VARIANT
----
false
false
true
true

# BITSTRING is ordered by its logical bit sequence (like the bitstring_byte_comparable collation),
# so a shorter bitstring that is a prefix sorts first and bit 0 sorts before bit 1
query I
SELECT v::VARCHAR FROM (VALUES
    ('0'::BIT::VARIANT),
    ('10101010'::BIT::VARIANT),
    ('00'::BIT::VARIANT),
    ('01'::BIT::VARIANT),
    ('1'::BIT::VARIANT)
) t(v)
ORDER BY v
----
0
00
01
1
10101010

# temporal fold: DATE and all (non-tz) TIMESTAMP precisions fold into one rank and compare by instant
# (a DATE compares as midnight of that day, and equal instants of different precision are equal)
query III
SELECT
    variant_comparator('2020-01-01'::DATE::VARIANT) = variant_comparator('2020-01-01 00:00:00'::TIMESTAMP::VARIANT),
    variant_comparator('2020-01-01 00:00:00'::TIMESTAMP_S::VARIANT) = variant_comparator('2020-01-01 00:00:00'::TIMESTAMP_MS::VARIANT),
    variant_comparator('2020-01-01 00:00:00'::TIMESTAMP::VARIANT) = variant_comparator('2020-01-01 00:00:00'::TIMESTAMP_NS::VARIANT)
----
true	true	true

# temporal fold: ordering is by actual instant across DATE and every TIMESTAMP precision
query I
SELECT v::VARCHAR FROM (VALUES
    ('2019-12-31'::DATE::VARIANT),
    ('2020-01-01 00:00:01'::TIMESTAMP_MS::VARIANT),
    ('2020-01-01 00:00:00'::TIMESTAMP_S::VARIANT),
    ('2020-01-02'::DATE::VARIANT),
    ('2020-01-01 00:00:00.5'::TIMESTAMP_NS::VARIANT)
) t(v)
ORDER BY v
----
2019-12-31
2020-01-01 00:00:00
2020-01-01 00:00:00.5
2020-01-01 00:00:01
2020-01-02

# temporal fold: TIME precisions fold into one rank and compare by time-of-day
query I
SELECT variant_comparator('12:00:00'::TIME::VARIANT) = variant_comparator('12:00:00'::TIME_NS::VARIANT)
----
true

query I
SELECT v::VARCHAR FROM (VALUES
    ('12:00:01'::TIME::VARIANT),
    ('00:00:00'::TIME_NS::VARIANT),
    ('12:00:00.5'::TIME_NS::VARIANT)
) t(v)
ORDER BY v
----
00:00:00
12:00:00.5
12:00:01

# the four temporal groups (TIMESTAMP / TIMESTAMP WITH TIME ZONE / TIME / TIME WITH TIME ZONE) keep
# their own ranks, so values from different groups are never equal even at the same wall-clock value
query III
SELECT
    variant_comparator('2020-01-01 00:00:00'::TIMESTAMP::VARIANT) = variant_comparator('2020-01-01 00:00:00+00'::TIMESTAMPTZ::VARIANT),
    variant_comparator('12:00:00'::TIME::VARIANT) = variant_comparator('2020-01-01 12:00:00'::TIMESTAMP::VARIANT),
    variant_comparator('12:00:00'::TIME::VARIANT) = variant_comparator('12:00:00+00'::TIMETZ::VARIANT)
----
false	false	false

# variant_comparator propagates NULL (so NULL = NULL stays NULL and NULLS FIRST/LAST works)
query I
SELECT variant_comparator(NULL::VARIANT) IS NULL
----
true
