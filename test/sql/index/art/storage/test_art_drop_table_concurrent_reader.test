# name: test/sql/index/art/storage/test_art_drop_table_concurrent_reader.test
# description: DROP TABLE while a reader holds a snapshot must defer index memory cleanup.
# group: [storage]

load __TEST_DIR__/test_art_drop_concurrent.db

statement ok
SET immediate_transaction_mode=true

statement ok con1
CREATE TABLE t(i INTEGER PRIMARY KEY)

statement ok con1
INSERT INTO t SELECT range FROM range(10)

statement ok con1
CHECKPOINT

query I con1
SELECT i FROM t WHERE i = 5
----
5

statement ok con2
BEGIN TRANSACTION

query I con2
SELECT COUNT(*) FROM t
----
10

query I con2
SELECT memory_usage_bytes FROM duckdb_memory() WHERE tag = 'ART_INDEX'
----
524288

statement ok con1
DROP TABLE t

query I con2
SELECT memory_usage_bytes FROM duckdb_memory() WHERE tag = 'ART_INDEX'
----
524288

query I con1
SELECT used_blocks FROM pragma_database_size()
----
3

query I con2
SELECT i FROM t WHERE i = 5
----
5

statement ok con2
COMMIT

query I con1
SELECT memory_usage_bytes FROM duckdb_memory() WHERE tag = 'ART_INDEX'
----
0

query I con1
SELECT used_blocks FROM pragma_database_size()
----
3

statement ok con1
CHECKPOINT

query I con1
SELECT memory_usage_bytes FROM duckdb_memory() WHERE tag = 'ART_INDEX'
----
0

query I con1
SELECT used_blocks FROM pragma_database_size()
----
1
