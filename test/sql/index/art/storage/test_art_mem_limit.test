# name: test/sql/index/art/storage/test_art_mem_limit.test
# description: Test retrieving memory information after creating an ART.
# group: [storage]

statement skip_test_on_error
SELECT assert_true(current_setting('standard_vector_size')::INT >= 2048, 'requires vector_size>=2048')

load {TEST_DIR}/index_mem_limit.db

statement ok
SET threads=1;

statement ok
SET memory_limit = '10MB';

statement ok
CREATE TABLE tbl AS SELECT range AS id FROM range(200000);

statement ok
CREATE INDEX idx ON tbl(id);

statement ok
FROM duckdb_memory();