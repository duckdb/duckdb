# name: test/sql/index/art/storage/test_art_import_export.test
# description: Test the export and import of the ART
# group: [storage]

# Issue #4126

load {TEST_DIR}/test_art_export.db

statement ok
CREATE TABLE raw(
    "year" SMALLINT,
    "month" TINYINT,
    "day" TINYINT,
    "customer_ID" BIGINT
);

statement ok
INSERT INTO raw VALUES (1, 1, 1, 1);

statement ok
CREATE UNIQUE INDEX customer_year_month_idx ON raw (customer_ID, year, month);

restart

statement ok
EXPORT DATABASE '{TEST_DIR}/export_index_db' (FORMAT CSV)

load {TEST_DIR}/test_art_import.db

statement ok
IMPORT DATABASE '{TEST_DIR}/export_index_db'

statement error
INSERT INTO raw VALUES (1, 1, 1, 1);
