# name: test/sql/index/art/nodes/test_art_prefix_transform_deprecated_create.test
# description: Test transforming a prefix to v1.0.0 storage with CHECKPOINT after CREATE INDEX
# group: [nodes]

# FIXME: sporadically breaks
mode skip

statement ok
SET checkpoint_threshold = '10.0 GB';

statement ok
ATTACH '{TEST_DIR}/prefix_transform.db' AS db (STORAGE_VERSION 'v1.0.0');

statement ok
CREATE TABLE db.t (id VARCHAR, ts TIMESTAMP, value INTEGER, PRIMARY KEY (id, ts));

statement ok
INSERT OR IGNORE INTO db.t
	SELECT range || 'hello this is a long prefix', current_timestamp, range
	FROM range(1_000_000);

statement ok
CHECKPOINT db;