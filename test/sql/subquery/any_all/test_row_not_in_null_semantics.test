# name: test/sql/subquery/any_all/test_row_not_in_null_semantics.test
# description: Regression tests for row-valued IN/ANY/NOT IN with NULLs in subqueries
# group: [any_all]

statement ok
PRAGMA enable_verification

query I
SELECT (1, 0) =ANY ((VALUES (0, NULL)))
----
false

query I
SELECT (0, 0) =ANY ((VALUES (0, NULL)))
----
NULL

query I
SELECT (1, 7) =ANY ((VALUES (0, NULL), (NULL, 5)))
----
false

query I
SELECT (0, 7) =ANY ((VALUES (0, NULL), (NULL, 5)))
----
NULL

query I
SELECT (0, 1) =ANY ((VALUES (0, 1), (0, NULL), (NULL, 1)))
----
true

query I
SELECT (2, 1) =ANY ((VALUES (0, NULL), (NULL, 5)))
----
false

query I
SELECT (NULL, 1) =ANY ((VALUES (0, 1), (NULL, 5)))
----
NULL

query I
SELECT (1, 2, 3) =ANY ((VALUES (1, NULL, 4)))
----
false

query I
SELECT (1, 2, 3) =ANY ((VALUES (1, NULL, 3)))
----
NULL

query I
SELECT (1, 2, 3) =ANY ((VALUES (NULL, 2, 3)))
----
NULL

query I
SELECT (1, 2, 3) =ANY ((VALUES (0, NULL, 3)))
----
false

query I
SELECT (1, 2) =ANY ((VALUES (NULL, NULL)))
----
NULL

query I
WITH r(k, x, y) AS (
	SELECT * FROM (VALUES
		(1, 1, 5),
		(2, 2, 6),
		(4, 3, 9),
		(8, 9, 8),
		(16, 3, NULL),
		(32, NULL, 8)
	) v(k, x, y)
)
SELECT coalesce(sum(k), 0) FROM r
WHERE (x, y) IN (SELECT * FROM (VALUES (2, 6), (3, 7), (4, 8)) s(a, b))
----
2

query I
