query I
SELECT (3, 4) =ANY (SELECT a, b FROM all_null_rhs)
----
NULL

query I
SELECT count(*) FROM (VALUES (1, 7), (0, 7), (NULL, 7)) t(a, b)
WHERE COALESCE((a, b) =ANY ((VALUES (0, NULL), (NULL, 5))), FALSE)
----
0

query I
WITH cte AS (
	SELECT COALESCE((a, b) =ANY ((VALUES (0, NULL), (NULL, 5))), FALSE) AS marker
	FROM (VALUES (1, 7), (0, 7), (NULL, 7)) t(a, b)
)
SELECT count(*) FROM cte WHERE marker
----
0

query I
WITH rhs AS (
	SELECT * FROM (VALUES (0, NULL), (NULL, 5), (7, 7), (NULL, NULL)) v(a, b)
)
SELECT CASE
	WHEN ((1, 7) =ANY (SELECT a, b FROM rhs)) IS NULL THEN 1
	WHEN ((1, 7) =ANY (SELECT a, b FROM rhs)) THEN 2
	ELSE 3
END
----
1

