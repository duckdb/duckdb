# name: test/sql/subquery/any_all/test_row_ordered_any_null_semantics.test
# description: Regression tests for row-valued ordered ANY predicates with NULLs in non-hash MARK joins
# group: [any_all]

query I
SELECT (5, 100) < ANY (SELECT * FROM (VALUES (1, NULL)) t(x, y))
----
false

query I
SELECT (1, 100) < ANY (SELECT * FROM (VALUES (1, NULL)) t(x, y))
----
true

query I
SELECT (5, 100) >= ANY (SELECT * FROM (VALUES (10, NULL)) t(x, y))
----
false

query I
SELECT (10, 100) >= ANY (SELECT * FROM (VALUES (10, NULL)) t(x, y))
----
false

query I
SELECT (2, 2) < ANY (SELECT * FROM (VALUES (1, NULL), (3, 4)) t(x, y))
----
true

query I
SELECT (2, 2) >= ANY (SELECT * FROM (VALUES (1, NULL), (3, 4)) t(x, y))
----
true

query I
SELECT (NULL, 2) < ANY (SELECT * FROM (VALUES (1, NULL), (3, 4)) t(x, y))
----
false

query I
SELECT (NULL, 2) >= ANY (SELECT * FROM (VALUES (1, NULL), (3, 4)) t(x, y))
----
true
