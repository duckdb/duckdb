# name: test/sql/prepared/test_issue_21077.test
# description: Issue 21077: Out of Range Error when executing prepared statement with unary minus on BIGINT minimum value
# group: [prepared]

statement ok
PREPARE pssmallint AS SELECT - ?

query I
EXECUTE pssmallint(-32768);
----
32768

statement ok
PREPARE psinteger AS SELECT - ?

query I
EXECUTE psinteger(-2147483648);
----
2147483648

statement ok
PREPARE psbigint AS SELECT - ?

query I
EXECUTE psbigint(-9223372036854775808);
----
9223372036854775808