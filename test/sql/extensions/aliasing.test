# name: test/sql/extensions/aliasing.test
# description: Aliasing of extensions, and puts it in a separate extension schema
# group: [extensions]

# Note that this behavior is subject to change
# When we register extensions in a separate extension schema

# Behavior: with aliasing; you load can reload extensions with identical names under a different alias
# for now, this means that their function names need to differ

require skip_reload

require allow_unsigned_extensions

require notmingw

statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS demo

query II
select extension_name, loaded from duckdb_extensions() where extension_name = 'demo';
----
demo	true

statement error
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS demo2
----
Initialization function

# duplicate alias is rejected
statement error
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS demo
----
Alias 'demo' already exists for extension 'loadable_extension_demo'

# unqualified call works
query I
SELECT bounded_max(1::BOUNDED(10))
----
10

# load a new extension
statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo_double.duckdb_extension' AS double

# we load the same extension again
statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo_double.duckdb_extension' AS second

query II
select extension_name, loaded from duckdb_extensions() where extension_name = 'demo' or extension_name = 'double' or extension_name = 'second';
----
demo	true
double	true
second	true

statement error
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension'
----
Extension 'loadable_extension_demo' already exists under alias 'demo'


# ONCE the PEG parser issue is fixed
# we can check functions with
# query I
# SELECT * from duckdb_functions() where extension_name = LIKE ....;
