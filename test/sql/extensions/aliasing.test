# name: test/sql/extensions/aliasing.test
# description: Aliasing of extensions, and puts it in a separate extension schema
# group: [extensions]

# Note that this behavior is subject to change
# When we register extensions in a separate extension schema

# TODO, also test, what if schema == extension name??

# Behavior: with aliasing; you load can reload the extension under a different alias
# the extension will be registered under name of the alias
# the alias will be used further on
# if the extension is already loaded twice,

query I
SELECT * from duckdb_functions();
----
10

require skip_reload

require allow_unsigned_extensions

statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS demo

statement error
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS demo2
----
Initialization function "loadable_extension_demo_duckdb_cpp_init"

# duplicate alias is rejected
statement error
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_optimizer_demo.duckdb_extension' AS demo
----
Alias 'demo' already exists for extension 'loadable_extension_demo'

# query I
# SELECT * from duckdb_functions();
# ----
# 10

# unqualified call works
query I
SELECT bounded_max(1::BOUNDED(10))
----
10

# load an entirely different binary that shares the same extension name but has different functions
statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo_double.duckdb_extension' AS copy

query I
SELECT loadable_extension_demo_double()
----
Hello from the loadable_extension_demo_double binary!

require double_extension_loading

statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo_double.duckdb_extension' AS second_copy

query I
SELECT _second_copy__loadable_extension_demo_double()
----
Hello from the loadable_extension_demo_double binary!

query I
SELECT loadable_extension_demo_double()
----
Hello from the loadable_extension_demo_double binary!
