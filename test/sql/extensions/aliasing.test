# name: test/sql/extensions/aliasing.test
# description: Aliasing of extensions, and puts it in a separate extension schema
# group: [extensions]

require autocomplete

require skip_reload

require allow_unsigned_extensions

statement ok
call enable_peg_parser()

# instead of registering in a separate schema, when loading, we register it in the global extension alias thing
# whenever we add a new alias, we register this function in main but then with the alias and not the extension name
statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS demo

# what if we load again? do we overwrite?

statement error
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_optimizer_demo.duckdb_extension' AS demo
----
Alias 'demo' already exists for extension 'loadable_extension_demo'

# can we ovewrite an extension?
statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS second_demo

query I
SELECT bounded_max(1::BOUNDED(10))
----
10

# if we use same alias for
query I
SELECT demo.bounded_max(1::BOUNDED(10))
----
10

query I
SELECT second_demo.bounded_max(1::BOUNDED(10))
----
10

# test also if we set the schema to demo, nothing will happen right?

# what would not work
# load same extension (name), but under different alias, if same functions, this will error out ?
