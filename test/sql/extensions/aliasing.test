# name: test/sql/extensions/aliasing.test
# description: Aliasing of extensions, and puts it in a separate extension schema
# group: [extensions]

# Note that this behavior is subject to change
# When we register extensions in a separate extension schema

# TODO, also test, what if schema == extension name??

require skip_reload

require allow_unsigned_extensions

statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension' AS demo

# duplicate alias is rejected
statement error
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_optimizer_demo.duckdb_extension' AS demo
----
Alias 'demo' already exists for extension 'loadable_extension_demo'

# unqualified call works
query I
SELECT bounded_max(1::BOUNDED(10))
----
10

# alias-prefixed call routes to the original binary
query I
SELECT demo.bounded_max(1::BOUNDED(10))
----
10

# load an entirely different binary that shares the same extension name but has different functions
statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/copy/loadable_extension_demo.duckdb_extension' AS copy

query I
SELECT copy.loadable_extension_second_demo()
----
Hello from the second loadable_extension_demo binary!

# check if names are not mingled
statement error
SELECT xxx.bounded_max(1::BOUNDED(10))
----
Referenced column "xxx" was not found because the FROM clause is missing

# check if names are not mingled
statement error
SELECT copy.bounded_max(1::BOUNDED(10))
----
Referenced column "copy" was not found because the FROM clause is missing

# the original alias still routes to its own binary's function
query I
SELECT demo.bounded_max(1::BOUNDED(10))
----
10
