# name: test/sql/projection/select_star_replace_colon.test
# description: Test colon-style and other alias forms in SELECT * REPLACE
# group: [projection]

statement ok
CREATE TABLE t (a INTEGER, b INTEGER, c INTEGER)

statement ok
INSERT INTO t VALUES (10, 20, 30), (100, 200, 300)

query III
SELECT * REPLACE (a: a+1) FROM t ORDER BY a
----
11	20	30
101	200	300

query III
SELECT * REPLACE (a: a+1) FROM t ORDER BY a
----
11	20	30
101	200	300

query III
SELECT * REPLACE (a+1 AS a) FROM t ORDER BY a
----
11	20	30
101	200	300

query III
SELECT * REPLACE (a+1 a) FROM t ORDER BY a
----
11	20	30
101	200	300

query III
SELECT * REPLACE (a: b, b: a) FROM t ORDER BY a
----
20	10	30
200	100	300

query III
SELECT * REPLACE (a+100 AS a, b+200 AS b) FROM t ORDER BY a
----
110	220	30
200	400	300

query III
SELECT * REPLACE (a: a*2, b+5 AS b) FROM t ORDER BY a
----
20	25	30
200	205	300

query III
SELECT * REPLACE (a: a+b, b: b+c, c: a+b+c) FROM t ORDER BY a
----
30	50	60
300	500	600

query III
SELECT * REPLACE (a: NULL) FROM t ORDER BY b
----
NULL	20	30
NULL	200	300

query III
SELECT * REPLACE (NULL AS a) FROM t ORDER BY b
----
NULL	20	30
NULL	200	300

query III
SELECT * REPLACE (a: (SELECT 42)) FROM t ORDER BY b
----
42	20	30
42	200	300

query II
SELECT * EXCLUDE(c) REPLACE (a: a*3) FROM t ORDER BY a
----
30	20
300	200

query III
SELECT * REPLACE (a: a+1) RENAME (c AS new_c) FROM t ORDER BY a
----
11	20	30
101	200	300

query III
SELECT t.* REPLACE (a: a-1) FROM t ORDER BY a
----
9	20	30
99	200	300

statement error
SELECT * REPLACE (a) FROM t
----
Parser Error: All REPLACE entries must have an alias

statement error
SELECT * REPLACE (NULL) FROM t
----
Parser Error: All REPLACE entries must have an alias

statement error
SELECT * REPLACE (a) FROM t
----
Parser Error: All REPLACE entries must have an alias

statement error
SELECT * REPLACE (a+1) FROM t
----
Parser Error: All REPLACE entries must have an alias

statement error
SELECT * REPLACE (a: 1, a: 2) FROM t
----
<REGEX>:.*Duplicate entry.*

statement error
SELECT * REPLACE (a: 1, 2 AS a) FROM t
----
<REGEX>:.*Duplicate entry.*

statement error
SELECT * REPLACE (1 AS a, 2 a) FROM t
----
<REGEX>:.*Duplicate entry.*

statement error
SELECT * REPLACE (nonexistent: 5) FROM t
----
<REGEX>:.*Binder Error.*not found.*

statement error
SELECT * EXCLUDE(a) REPLACE (a: 5) FROM t
----
<REGEX>:.*cannot occur in both.*

statement error
SELECT * REPLACE (a:) FROM t
----
<REGEX>:.*syntax error.*