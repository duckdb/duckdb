# name: test/sql/attach/attach_huggingface_index.test
# description: Test attach mixed with sequences and default values
# group: [attach]

# The database is written with a vector size of 2048.
statement skip_test_on_error
SELECT assert_true(current_setting('standard_vector_size')::INT >= 2048, 'requires vector_size>=2048')

unzip data/storage/huggingface_index.db.gz {TEST_DIR}/huggingface_index.db

statement ok
ATTACH '{TEST_DIR}/huggingface_index.db'