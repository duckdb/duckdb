# name: test/sql/attach/attach_checkpoint_on_detach.test
# description: Test the checkpoint_on_detach per-session setting.
# group: [attach]

require noforcestorage

statement ok
SET wal_autocheckpoint = '1TB';

# unset + global enabled → checkpoint
statement ok
ATTACH '__TEST_DIR__/test1.db' AS test1;

statement ok
CREATE TABLE test1.tbl AS SELECT range AS id FROM range(100);

statement ok
DETACH test1;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/test1.db.wal')
----
0

# unset + global disabled → no checkpoint
statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/test2.db' AS test2;

statement ok
CREATE TABLE test2.tbl AS SELECT range AS id FROM range(100);

statement ok
DETACH test2;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/test2.db.wal')
----
1

# true + global enabled → checkpoint
statement ok
PRAGMA enable_checkpoint_on_shutdown;

statement ok
SET checkpoint_on_detach = 'true';

statement ok
ATTACH '__TEST_DIR__/test3.db' AS test3;

statement ok
CREATE TABLE test3.tbl AS SELECT range AS id FROM range(100);

statement ok
DETACH test3;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/test3.db.wal')
----
0

# true + global disabled → checkpoint (override)
statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/test4.db' AS test4;

statement ok
CREATE TABLE test4.tbl AS SELECT range AS id FROM range(100);

statement ok
DETACH test4;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/test4.db.wal')
----
0

# false + global enabled → no checkpoint (override)
statement ok
PRAGMA enable_checkpoint_on_shutdown;

statement ok
SET checkpoint_on_detach = 'false';

statement ok
ATTACH '__TEST_DIR__/test5.db' AS test5;

statement ok
CREATE TABLE test5.tbl AS SELECT range AS id FROM range(100);

statement ok
DETACH test5;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/test5.db.wal')
----
1

# false + global disabled → no checkpoint
statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/test6.db' AS test6;

statement ok
CREATE TABLE test6.tbl AS SELECT range AS id FROM range(100);

statement ok
DETACH test6;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/test6.db.wal')
----
1

# RESET returns to unset → defers to global (still disabled) → no checkpoint
statement ok
RESET checkpoint_on_detach;

statement ok
ATTACH '__TEST_DIR__/test7.db' AS test7;

statement ok
CREATE TABLE test7.tbl AS SELECT range AS id FROM range(100);

statement ok
DETACH test7;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/test7.db.wal')
----
1
