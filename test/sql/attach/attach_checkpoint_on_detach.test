# name: test/sql/attach/attach_checkpoint_on_detach.test
# description: Test the checkpoint_on_detach per-session setting.
# group: [attach]

require noforcestorage

require skip_reload

require json

require notwindows

statement ok
SET wal_autocheckpoint = '1TB';

statement ok
PRAGMA disable_checkpoint_on_shutdown;

statement ok
ATTACH '__TEST_DIR__/no_checkpoint.db' AS no_checkpoint;

statement ok
CREATE TABLE no_checkpoint.tbl AS SELECT range AS id FROM range(100_000);

statement ok
SET checkpoint_on_detach = false;

statement ok
DETACH no_checkpoint;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/no_checkpoint.db.wal')
----
1

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/no_checkpoint_metrics.json';

statement ok
PRAGMA custom_profiling_settings='{"ATTACH_REPLAY_WAL_LATENCY": "true", "WAL_REPLAY_ENTRY_COUNT": "true"}';

statement ok
SET profiling_coverage = 'ALL';

statement ok
ATTACH '__TEST_DIR__/no_checkpoint.db' AS no_checkpoint;

statement ok
PRAGMA disable_profiling;

query I
SELECT CASE WHEN wal_replay_entry_count > 0 THEN 'true' ELSE 'false' END
FROM '__TEST_DIR__/no_checkpoint_metrics.json';
----
true

query I
SELECT CASE WHEN attach_replay_wal_latency > 0 THEN 'true' ELSE 'false' END
FROM '__TEST_DIR__/no_checkpoint_metrics.json';
----
true

query I
SELECT COUNT(*) FROM no_checkpoint.tbl;
----
100000

statement ok
DETACH no_checkpoint;

statement ok
SET checkpoint_on_detach = true;

statement ok
ATTACH '__TEST_DIR__/with_checkpoint.db' AS with_checkpoint;

statement ok
CREATE TABLE with_checkpoint.tbl AS SELECT range AS id FROM range(100_000);

statement ok
DETACH with_checkpoint;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/with_checkpoint.db.wal')
----
0

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/with_checkpoint_metrics.json';

statement ok
PRAGMA custom_profiling_settings='{"ATTACH_REPLAY_WAL_LATENCY": "true", "WAL_REPLAY_ENTRY_COUNT": "true"}';

statement ok
SET profiling_coverage = 'ALL';

statement ok
ATTACH '__TEST_DIR__/with_checkpoint.db' AS with_checkpoint;

statement ok
PRAGMA disable_profiling;

query I
SELECT CASE WHEN wal_replay_entry_count = 0 THEN 'true' ELSE 'false' END
FROM '__TEST_DIR__/with_checkpoint_metrics.json';
----
true

query I
SELECT COUNT(*) FROM with_checkpoint.tbl;
----
100000

statement ok
DETACH with_checkpoint;

statement ok
SET checkpoint_on_detach = false;

statement ok
ATTACH '__TEST_DIR__/toggled.db' AS toggled;

statement ok
CREATE TABLE toggled.tbl AS SELECT range AS id FROM range(100_000);

statement ok
SET checkpoint_on_detach = true;

statement ok
DETACH toggled;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/toggled.db.wal')
----
0

statement ok
PRAGMA enable_profiling = 'json';

statement ok
PRAGMA profiling_output = '__TEST_DIR__/toggled_metrics.json';

statement ok
PRAGMA custom_profiling_settings='{"WAL_REPLAY_ENTRY_COUNT": "true"}';

statement ok
SET profiling_coverage = 'ALL';

statement ok
ATTACH '__TEST_DIR__/toggled.db' AS toggled;

statement ok
PRAGMA disable_profiling;

query I
SELECT CASE WHEN wal_replay_entry_count = 0 THEN 'true' ELSE 'false' END
FROM '__TEST_DIR__/toggled_metrics.json';
----
true

query I
SELECT COUNT(*) FROM toggled.tbl;
----
100000

statement ok
DETACH toggled;

statement ok con1
SET wal_autocheckpoint = '1TB';

statement ok con1
PRAGMA disable_checkpoint_on_shutdown;

statement ok con2
SET wal_autocheckpoint = '1TB';

statement ok con2
PRAGMA disable_checkpoint_on_shutdown;

statement ok con1
SET checkpoint_on_detach = false;

statement ok con1
ATTACH '__TEST_DIR__/con1_db.db' AS con1_db;

statement ok con2
ATTACH '__TEST_DIR__/con2_db.db' AS con2_db;

statement ok con1
CREATE TABLE con1_db.tbl AS SELECT range AS id FROM range(100_000);

statement ok con2
CREATE TABLE con2_db.tbl AS SELECT range AS id FROM range(100_000);

statement ok con1
DETACH con1_db;

statement ok con2
DETACH con2_db;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/con1_db.db.wal')
----
1

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/con2_db.db.wal')
----
0

statement ok
ATTACH '__TEST_DIR__/con1_db.db' AS con1_db;

query I
SELECT COUNT(*) FROM con1_db.tbl;
----
100000

statement ok
DETACH con1_db;

statement ok
ATTACH '__TEST_DIR__/con2_db.db' AS con2_db;

query I
SELECT COUNT(*) FROM con2_db.tbl;
----
100000

statement ok
DETACH con2_db;
