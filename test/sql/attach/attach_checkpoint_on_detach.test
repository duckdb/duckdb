# name: test/sql/attach/attach_checkpoint_on_detach.test
# description: Test the checkpoint_on_detach per-session setting.
# group: [attach]

require noforcestorage

# Globally disabled, locally enabled → no checkpoint (global master switch wins).
statement ok con1
SET wal_autocheckpoint = '1TB';

statement ok con1
PRAGMA disable_checkpoint_on_shutdown;

statement ok con1
ATTACH '__TEST_DIR__/con1_db.db' AS con1_db;

statement ok con1
CREATE TABLE con1_db.tbl AS SELECT range AS id FROM range(100);

statement ok con1
DETACH con1_db;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/con1_db.db.wal')
----
1

# Globally enabled, locally disabled → no checkpoint (local opt-out wins).
statement ok con2
SET wal_autocheckpoint = '1TB';

statement ok con2
SET checkpoint_on_detach = false;

statement ok con2
ATTACH '__TEST_DIR__/con2_db.db' AS con2_db;

statement ok con2
CREATE TABLE con2_db.tbl AS SELECT range AS id FROM range(100);

statement ok con2
DETACH con2_db;

query I
SELECT COUNT(*) FROM glob('__TEST_DIR__/con2_db.db.wal')
----
1

# Verify data integrity after re-attaching both.
statement ok
ATTACH '__TEST_DIR__/con1_db.db' AS con1_db;

query I
SELECT COUNT(*) FROM con1_db.tbl;
----
100

statement ok
ATTACH '__TEST_DIR__/con2_db.db' AS con2_db;

query I
SELECT COUNT(*) FROM con2_db.tbl;
----
100
