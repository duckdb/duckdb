# name: test/sql/attach/attach_fsspec.test
# description: Test attach using fsspec
# group: [attach]

# this doesn't work on Windows because this expands to "file:///Users/..." on Mac/Linux, but "file://C:\.." on Windows
statement skip_test_on_error
SELECT assert_true(platform NOT LIKE 'windows_%', 'requires a non-windows platform') FROM pragma_platform()

statement error
ATTACH 'dummy_extension:/hello.world';
----
not found

statement ok
ATTACH 'file://{TEMP_DIR_ABSOLUTE}/dummy.csv'

statement error
ATTACH 'file://{TEMP_DIR_ABSOLUTE}/dummy.csv'
----
already attached

statement ok
CREATE TABLE dummy.tbl(i INTEGER);

statement ok
DETACH dummy

statement ok
ATTACH 'file://{TEMP_DIR_ABSOLUTE}/dummy.csv'

query I
FROM dummy.tbl
----
