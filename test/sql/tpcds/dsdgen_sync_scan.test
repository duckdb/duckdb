# name: test/sql/tpcds/dsdgen_sync_scan.test
# description: Test TPC-DS dsdgen with synchronous table scan execution
# group: [tpcds]

require tpcds

statement ok
SET debug_physical_table_scan_execution_strategy=SYNCHRONOUS;

statement ok
CALL dsdgen(sf=0.01, suffix='_sync_scan');

statement ok
SET debug_physical_table_scan_execution_strategy=DEFAULT;
