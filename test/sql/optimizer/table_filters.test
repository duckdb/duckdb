# name: test/sql/optimizer/table_filters.test
# description: Temporary reproducers for filter statistics pruning issues
# group: [optimizer]

statement ok
SET profiling_renderer_settings = MAP {'operator_casing': 'upper'};

statement ok
PRAGMA threads=1

statement ok
SET disabled_optimizers='join_order,build_side_probe_side'

statement ok
SET dynamic_or_filter_threshold=0

# `IS DISTINCT FROM` with a non-null constant must keep NULL rows. The unified
# expression/table-filter stats pruning currently treats all-null stats as
# always false for every comparison, which incorrectly removes this table.
statement ok
CREATE TABLE distinct_from_nulls AS
SELECT NULL::INTEGER AS a
FROM range(10000)

query I
SELECT count(*)
FROM distinct_from_nulls
WHERE a IS DISTINCT FROM 5
----
10000

# The same predicate must not prune a segment whose non-null min/max are exactly
# the constant if the segment can also contain NULL values.
statement ok
CREATE TABLE distinct_from_mixed_nulls AS
SELECT CASE WHEN i % 2 = 0 THEN NULL ELSE 5 END::INTEGER AS a
FROM range(10000) t(i)

query I
SELECT count(*)
FROM distinct_from_mixed_nulls
WHERE a IS DISTINCT FROM 5
----
5000

statement ok
CHECKPOINT

query I
SELECT count(*)
FROM distinct_from_mixed_nulls
WHERE a IS DISTINCT FROM 5
----
5000

statement ok
SET force_compression='rle'

statement ok
CREATE TABLE distinct_from_mixed_nulls_rle AS
SELECT CASE WHEN i % 2 = 0 THEN NULL ELSE 5 END::INTEGER AS a
FROM range(10000) t(i)

statement ok
CHECKPOINT

query I
SELECT count(*)
FROM distinct_from_mixed_nulls_rle
WHERE a IS DISTINCT FROM 5
----
5000

statement ok
SET force_compression='auto'

# Numeric prefix-range filters still use row-group statistics. With two sparse
# build keys, the probe scan should only produce the two matching keys.
statement ok
CREATE TABLE probe_num AS
SELECT i::BIGINT AS k, (i % 7)::INTEGER AS g
FROM range(0, 1000000) t(i)

statement ok
CREATE TABLE build_num AS
SELECT i::BIGINT AS k, (i % 7)::INTEGER AS g
FROM (VALUES (100000), (900000)) v(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM probe_num p
JOIN build_num b
  ON p.k = b.k
 AND p.g >= b.g
----
analyzed_plan	<REGEX>:(?s).*IN.*PRF.*\(k\).*

query I
SELECT count(*)
FROM probe_num p
JOIN build_num b
  ON p.k = b.k
 AND p.g >= b.g
----
2

# The varchar equivalent should also use string row-group statistics in the PRF
# pruning callback. The current PR regresses this: the plan still contains the
# PRF dynamic filter, but the probe scan produces hundreds of thousands of rows.
statement ok
CREATE TABLE probe_str AS
SELECT lpad(i::VARCHAR, 8, '0') AS k, (i % 7)::INTEGER AS g
FROM range(0, 1000000) t(i)

statement ok
CREATE TABLE build_str AS
SELECT lpad(i::VARCHAR, 8, '0') AS k, (i % 7)::INTEGER AS g
FROM (VALUES (100000), (900000)) v(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM probe_str p
JOIN build_str b
  ON p.k = b.k
 AND p.g >= b.g
----
analyzed_plan	<!REGEX>:.*[1-9][0-9]{2},[0-9]{3} rows.*

query I
SELECT count(*)
FROM probe_str p
JOIN build_str b
  ON p.k = b.k
 AND p.g >= b.g
----
2

require parquet

# Optional runtime filters should still evaluate their child filter when pruning
# constant columns such as hive partition values. The expression-backed optional
# scalar returns TRUE for every value, so all partition files are opened here.
statement ok
CREATE TABLE partition_src AS
SELECT i::INTEGER AS id, (i % 100)::INTEGER AS part
FROM range(0, 100000) t(i)

statement ok
COPY partition_src
TO '{TEMP_DIR}/optional_partition_prune_22617'
(FORMAT parquet, PARTITION_BY part, OVERWRITE true)

statement ok
CREATE TABLE build_part AS
SELECT v::INTEGER AS part
FROM (VALUES (42), (43)) t(v)

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM read_parquet('{TEMP_DIR}/optional_partition_prune_22617/*/*.parquet',
                  hive_partitioning=1,
                  hive_types={'part': INTEGER}) p
JOIN build_part b
  ON p.part = b.part
----
analyzed_plan	<!REGEX>:.*Total Files Read: 100.*

query I
SELECT count(*)
FROM read_parquet('{TEMP_DIR}/optional_partition_prune_22617/*/*.parquet',
                  hive_partitioning=1,
                  hive_types={'part': INTEGER}) p
JOIN build_part b
  ON p.part = b.part
----
2000

# PR #21791 made non-min/max runtime join filters work when the probe-side
# storage type needs to be cast to the hash-table key type. PR #22645 currently
# keeps the min/max filters but drops the PRF in this shape.
statement ok
CREATE TABLE probe_cast_up AS
SELECT i::INTEGER AS k, (i % 7)::INTEGER AS g
FROM range(0, 1000000) t(i)

statement ok
CREATE TABLE build_cast_up AS
SELECT i::BIGINT AS k, (i % 7)::INTEGER AS g
FROM (VALUES (100000), (900000)) v(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM probe_cast_up p
JOIN build_cast_up b
  ON p.k = b.k
 AND p.g >= b.g
----
analyzed_plan	<REGEX>:(?s).*IN.*PRF.*\(k\).*

query I
SELECT count(*)
FROM probe_cast_up p
JOIN build_cast_up b
  ON p.k = b.k
 AND p.g >= b.g
----
2

# The reverse cast direction still has the PRF. This keeps the test from being
# only a generic "PRF disabled" check.
statement ok
CREATE TABLE probe_cast_down AS
SELECT i::BIGINT AS k, (i % 7)::INTEGER AS g
FROM range(0, 1000000) t(i)

statement ok
CREATE TABLE build_cast_down AS
SELECT i::INTEGER AS k, (i % 7)::INTEGER AS g
FROM (VALUES (100000), (900000)) v(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM probe_cast_down p
JOIN build_cast_down b
  ON p.k = b.k
 AND p.g >= b.g
----
analyzed_plan	<REGEX>:(?s).*IN.*PRF.*\(CAST\(k.*AS BIGINT\)\).*

query I
SELECT count(*)
FROM probe_cast_down p
JOIN build_cast_down b
  ON p.k = b.k
 AND p.g >= b.g
----
2

# The exact PRF can handle this small build range. The cast-up case keeps the
# filter on the probe storage type when the runtime filter type is compatible.
statement ok
CREATE TABLE phj_probe_cast_up AS
SELECT i::INTEGER AS k
FROM range(0, 1000000) t(i)

statement ok
CREATE TABLE phj_build_cast_up AS
SELECT i::BIGINT AS k
FROM range(100000, 100010) t(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM phj_probe_cast_up p
JOIN phj_build_cast_up b
  ON p.k = b.k
----
analyzed_plan	<REGEX>:(?s).*IN.*PRF.*\(k\).*

query I
SELECT count(*)
FROM phj_probe_cast_up p
JOIN phj_build_cast_up b
  ON p.k = b.k
----
10

statement ok
CREATE TABLE phj_probe_cast_down AS
SELECT i::BIGINT AS k
FROM range(0, 1000000) t(i)

statement ok
CREATE TABLE phj_build_cast_down AS
SELECT i::INTEGER AS k
FROM range(100000, 100010) t(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM phj_probe_cast_down p
JOIN phj_build_cast_down b
  ON p.k = b.k
----
analyzed_plan	<REGEX>:(?s).*IN.*PRF.*\(CAST\(k.*AS BIGINT\)\).*

query I
SELECT count(*)
FROM phj_probe_cast_down p
JOIN phj_build_cast_down b
  ON p.k = b.k
----
10

# A narrowing probe cast must still produce an exact runtime filter instead of
# falling back to storage-only filtering.
statement ok
CREATE TABLE phj_probe_narrow_cast AS
SELECT i::BIGINT AS k
FROM range(0, 1000000) t(i)
UNION ALL
SELECT 1000000000::BIGINT
UNION ALL
SELECT 3000000000::BIGINT

statement ok
CREATE TABLE phj_build_narrow_cast AS
SELECT i::INTEGER AS k
FROM range(100000, 100010) t(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM (
  SELECT *
  FROM phj_probe_narrow_cast
  WHERE k < 1000000
) p
JOIN phj_build_narrow_cast b
  ON p.k::INTEGER = b.k
----
analyzed_plan	<REGEX>:(?s).*IN.*PRF.*\(k\).*

query I
SELECT count(*)
FROM (
  SELECT *
  FROM phj_probe_narrow_cast
  WHERE k < 1000000
) p
JOIN phj_build_narrow_cast b
  ON p.k::INTEGER = b.k
----
10

# Sparse values use an IN filter. It must reconstruct the narrowing cast and
# retain the original conversion error for out-of-range probe values.
statement ok
SET dynamic_or_filter_threshold=10

statement ok
CREATE TABLE phj_build_narrow_cast_sparse AS
SELECT *
FROM (VALUES (1::INTEGER), (1000000000::INTEGER)) t(k)

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM (
  SELECT *
  FROM phj_probe_narrow_cast
  WHERE k < 2000000000
) p
JOIN phj_build_narrow_cast_sparse b
  ON p.k::INTEGER = b.k
----
analyzed_plan	<REGEX>:(?s).*TRY_CAST.*IN \(1, 1000000000\).*

query I
SELECT count(*)
FROM (
  SELECT *
  FROM phj_probe_narrow_cast
  WHERE k < 2000000000
) p
JOIN phj_build_narrow_cast_sparse b
  ON p.k::INTEGER = b.k
----
2

# The exact IN filter must not suppress the cast error raised by the join.
statement error
SELECT count(*)
FROM phj_probe_narrow_cast p
JOIN phj_build_narrow_cast_sparse b
  ON p.k::INTEGER = b.k
----
<REGEX>:Conversion Error:.*out of range.*

statement ok
SET dynamic_or_filter_threshold=0

# Runtime-filter reconstruction of a normal narrowing cast must retain the
# conversion error that the join expression itself would raise.
statement error
SELECT count(*)
FROM phj_probe_narrow_cast p
JOIN phj_build_narrow_cast b
  ON p.k::INTEGER = b.k
----
<REGEX>:Conversion Error:.*out of range.*

# Reconstruction retains every cast in a nested exact PRF input.
query II
EXPLAIN ANALYZE
SELECT count(*)
FROM (
  SELECT *
  FROM phj_probe_narrow_cast
  WHERE k < 1000000
) p
JOIN phj_build_narrow_cast b
  ON CAST(CAST(p.k AS INTEGER) AS BIGINT) = CAST(b.k AS BIGINT)
----
analyzed_plan	<REGEX>:(?s).*PRF.*

statement error
SELECT count(*)
FROM phj_probe_narrow_cast p
JOIN phj_build_narrow_cast b
  ON CAST(CAST(p.k AS INTEGER) AS BIGINT) = CAST(b.k AS BIGINT)
----
<REGEX>:Conversion Error:.*out of range.*

# Explicit TRY_CAST has different semantics: failed casts become NULL and may be removed by the runtime filter.
query I
SELECT count(*)
FROM phj_probe_narrow_cast p
JOIN phj_build_narrow_cast b
  ON TRY_CAST(p.k AS INTEGER) = b.k
----
10

# Force the Bloom-filter path with a range that is too wide for an exact PRF.
statement ok
CREATE TABLE bf_build_narrow_cast_errors AS
SELECT (i * 1000)::INTEGER AS k
FROM range(0, 100000) t(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM (
  SELECT *
  FROM phj_probe_narrow_cast
  WHERE k < 2000000000
) p
JOIN bf_build_narrow_cast_errors b
  ON p.k::INTEGER = b.k
----
analyzed_plan	<REGEX>:(?s).*TRY_CAST.*IN.*BF.*

statement error
SELECT count(*)
FROM phj_probe_narrow_cast p
JOIN bf_build_narrow_cast_errors b
  ON p.k::INTEGER = b.k
----
<REGEX>:Conversion Error:.*out of range.*

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM (
  SELECT *
  FROM phj_probe_narrow_cast
  WHERE k < 2000000000
) p
JOIN bf_build_narrow_cast_errors b
  ON CAST(CAST(p.k AS INTEGER) AS BIGINT) = CAST(b.k AS BIGINT)
----
analyzed_plan	<REGEX>:(?s).*BF.*

statement error
SELECT count(*)
FROM phj_probe_narrow_cast p
JOIN bf_build_narrow_cast_errors b
  ON CAST(CAST(p.k AS INTEGER) AS BIGINT) = CAST(b.k AS BIGINT)
----
<REGEX>:Conversion Error:.*out of range.*

query I
SELECT count(*)
FROM phj_probe_narrow_cast p
JOIN bf_build_narrow_cast_errors b
  ON TRY_CAST(p.k AS INTEGER) = b.k
----
1000

# These sparse build sides still fall under the exact PRF budget, so PRF is
# selected before Bloom even with the residual inequality.
statement ok
CREATE TABLE bf_probe_cast_up AS
SELECT i::INTEGER AS k, (i % 7)::INTEGER AS g
FROM range(0, 2000000) t(i)

statement ok
CREATE TABLE bf_build_cast_up AS
SELECT (100000 + i * 3)::BIGINT AS k, ((100000 + i * 3) % 7)::INTEGER AS g
FROM range(0, 600000) t(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM bf_probe_cast_up p
JOIN bf_build_cast_up b
  ON p.k = b.k
 AND p.g >= b.g
----
analyzed_plan	<REGEX>:(?s).*HASH_JOIN.*CAST\(k AS BIGINT\) = k.*g >= g.*

query I
SELECT count(*)
FROM bf_probe_cast_up p
JOIN bf_build_cast_up b
  ON p.k = b.k
 AND p.g >= b.g
----
600000

statement ok
CREATE TABLE bf_probe_cast_down AS
SELECT i::BIGINT AS k, (i % 7)::INTEGER AS g
FROM range(0, 2000000) t(i)

statement ok
CREATE TABLE bf_build_cast_down AS
SELECT (100000 + i * 3)::INTEGER AS k, ((100000 + i * 3) % 7)::INTEGER AS g
FROM range(0, 600000) t(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM bf_probe_cast_down p
JOIN bf_build_cast_down b
  ON p.k = b.k
 AND p.g >= b.g
----
analyzed_plan	<REGEX>:(?s).*HASH_JOIN.*k = CAST\(k AS BIGINT\).*g >= g.*

query I
SELECT count(*)
FROM bf_probe_cast_down p
JOIN bf_build_cast_down b
  ON p.k = b.k
 AND p.g >= b.g
----
600000

# A wide exact PRF is built alongside parallel hash finalization.
statement ok
CREATE TABLE prf_parallel_wide_build AS
SELECT (i * 200)::INTEGER AS k
FROM range(0, 300000) t(i)

statement ok
CHECKPOINT

query II
EXPLAIN ANALYZE
SELECT count(*)
FROM bf_probe_cast_up p
JOIN prf_parallel_wide_build b
  ON p.k = b.k
----
analyzed_plan	<REGEX>:(?s).*IN.*PRF.*

query I
SELECT count(*)
FROM bf_probe_cast_up p
JOIN prf_parallel_wide_build b
  ON p.k = b.k
----
10000

# Chained comparison filters must evaluate later filters at the selected row
# indices from earlier filters, not at dense positions in the vector.
statement ok
CREATE TABLE chained_comparison_filters AS
SELECT i::INTEGER AS a, i::INTEGER AS b
FROM range(0, 4096) t(i)

query I
SELECT count(*)
FROM chained_comparison_filters
WHERE a >= 1000 AND b < 10
----
0
