# name: test/sql/optimizer/string_stats_merge.test
# description: Merging exact and truncated string statistics preserves correct bounds
# group: [optimizer]

statement ok
ATTACH '{TEST_DIR}/string_stats_merge.duckdb' AS db (ROW_GROUP_SIZE 2048);

statement ok
USE db;

statement ok
CREATE TABLE long_strings (v VARCHAR, payload INTEGER);

statement ok
INSERT INTO long_strings SELECT repeat('b', 12), 1 FROM range(2048);

statement ok
INSERT INTO long_strings SELECT repeat('b', 13), 1 FROM range(2048);

# Compare against the exact 12-byte value.
query II
EXPLAIN ANALYZE SELECT sum(payload) FROM long_strings WHERE v > repeat('b', 12);
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 2.*

query I
SELECT sum(payload) FROM long_strings WHERE v > repeat('b', 12);
----
2048

query II
EXPLAIN ANALYZE SELECT sum(payload) FROM long_strings WHERE v < repeat('b', 12);
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 0 / 2.*

query I
SELECT sum(payload) FROM long_strings WHERE v < repeat('b', 12);
----
NULL

query II
EXPLAIN ANALYZE SELECT sum(payload) FROM long_strings WHERE v >= repeat('b', 12);
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 2 / 2.*

query I
SELECT sum(payload) FROM long_strings WHERE v >= repeat('b', 12);
----
4096

query II
EXPLAIN ANALYZE SELECT sum(payload) FROM long_strings WHERE v <= repeat('b', 12);
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 2.*

query I
SELECT sum(payload) FROM long_strings WHERE v <= repeat('b', 12);
----
2048

query II
EXPLAIN ANALYZE SELECT sum(payload) FROM long_strings WHERE v = repeat('b', 12);
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 2.*

query I
SELECT sum(payload) FROM long_strings WHERE v = repeat('b', 12);
----
2048

query II
EXPLAIN ANALYZE SELECT sum(payload) FROM long_strings WHERE v <> repeat('b', 12);
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 2.*

query I
SELECT sum(payload) FROM long_strings WHERE v <> repeat('b', 12);
----
2048

