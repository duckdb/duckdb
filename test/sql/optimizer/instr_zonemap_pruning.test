# name: test/sql/optimizer/instr_zonemap_pruning.test
# description: INSTR prefix comparisons use string statistics for row-group pruning
# group: [optimizer]

statement ok
CREATE TABLE instr_pruning AS
SELECT CASE WHEN i < 122880 THEN 'aaa' || i::VARCHAR
            WHEN i < 245760 THEN 'mmm' || i::VARCHAR
            ELSE 'zzz' || i::VARCHAR
       END AS s
FROM range(368640) tbl(i);

query II
EXPLAIN ANALYZE SELECT count(*) FROM instr_pruning WHERE instr(s, 'mmm') = 1;
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 3.*

query I
SELECT count(*) FROM instr_pruning WHERE instr(s, 'mmm') = 1;
----
122880

query II
EXPLAIN ANALYZE SELECT count(*) FROM instr_pruning WHERE instr(s, 'aaa') = 1;
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 3.*

query I
SELECT count(*) FROM instr_pruning WHERE instr(s, 'aaa') = 1;
----
122880

query II
EXPLAIN ANALYZE SELECT count(*) FROM instr_pruning WHERE instr(s, 'zzz') = 1;
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 3.*

query I
SELECT count(*) FROM instr_pruning WHERE instr(s, 'zzz') = 1;
----
122880

# Equality matching is unordered
query II
EXPLAIN ANALYZE SELECT count(*) FROM instr_pruning WHERE 1 = instr(s, 'mmm');
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 3.*

# A prefix outside all row-group ranges does not scan any row groups
query II
EXPLAIN ANALYZE SELECT count(*) FROM instr_pruning WHERE instr(s, 'qqq') = 1;
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 0 / 3.*
