# name: test/sql/optimizer/plan/test_table_filter_pushdown.test
# description: Test Table Filter Push Down Scan
# group: [plan]

statement ok
PRAGMA enable_verification

statement ok
PRAGMA explain_output='physical_only';

statement ok
CREATE TABLE integers AS SELECT i AS i, i AS j FROM range(0, 100) tbl(i)

query I
SELECT j FROM integers where j = 99
----
99

query I
SELECT j FROM integers where j = 99 AND i=99
----
99

query I
SELECT j FROM integers where j = 99 AND i=90
----

query I
SELECT count(i) FROM integers where j > 90 and i < 95
----
4

query I
SELECT count(i) FROM integers where j > 90 and j < 95
----
4

# multi-column expressions can be pushed into the scan
query I
SELECT j FROM integers WHERE i + j = 198
----
99

query II
EXPLAIN SELECT j FROM integers WHERE i + j = 198
----
physical_plan	<REGEX>:.*SEQ_SCAN.*Filters:.*\(.*i \+ j.*= 198.*\).*

# hidden filter columns stay available until after the generic filter executes
query I
SELECT i FROM integers WHERE i + j = 198
----
99

query II
EXPLAIN SELECT i FROM integers WHERE i + j = 198
----
physical_plan	<REGEX>:.*SEQ_SCAN.*Filters:.*\(.*i \+ j.*= 198.*\).*

# generic filters can coexist with per-column table filters
query I
SELECT count(*) FROM integers WHERE i = 99 AND i + j = 198
----
1

query II
EXPLAIN SELECT count(*) FROM integers WHERE i = 99 AND i + j = 198
----
physical_plan	<REGEX>:.*SEQ_SCAN.*Filters:.*\(i = 99\).*\(.*i \+ j.*= 198.*\).*

require parquet

statement ok
COPY integers TO '__TEST_DIR__/multicol_tablefilter.parquet' (FORMAT parquet);

# shared PhysicalTableScan path also handles multi-column pushed expressions for table functions
query I
SELECT j FROM read_parquet('__TEST_DIR__/multicol_tablefilter.parquet') WHERE i + j = 198
----
99

query II
EXPLAIN SELECT j FROM read_parquet('__TEST_DIR__/multicol_tablefilter.parquet') WHERE i + j = 198
----
physical_plan	<REGEX>:.*READ_PARQUET.*Filters:.*\(.*i \+ j.*= 198.*\).*
