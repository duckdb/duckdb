# Native table scans are left as separate scalar aggregates. Repeated native
# scans can be faster than one filtered aggregate after the data is hot.
statement ok
CREATE TABLE q09_sales(q INTEGER, discount INTEGER, paid INTEGER)

statement ok
CREATE TABLE q09_reason(r_reason_sk INTEGER)

statement ok
INSERT INTO q09_reason VALUES (1), (2)

statement ok
INSERT INTO q09_sales VALUES
	(1, 10, 100), (10, 20, 200), (15, 30, 300),
	(21, 40, 400), (25, 50, 500)

query II
EXPLAIN SELECT
	CASE WHEN (SELECT count(*) FROM q09_sales WHERE q BETWEEN 1 AND 20) > 2
	     THEN (SELECT avg(discount) FROM q09_sales WHERE q BETWEEN 1 AND 20)
	     ELSE (SELECT avg(paid) FROM q09_sales WHERE q BETWEEN 1 AND 20)
	END b1,
	CASE WHEN (SELECT count(*) FROM q09_sales WHERE q BETWEEN 21 AND 40) > 9
	     THEN (SELECT avg(discount) FROM q09_sales WHERE q BETWEEN 21 AND 40)
	     ELSE (SELECT avg(paid) FROM q09_sales WHERE q BETWEEN 21 AND 40)
	END b2
FROM q09_reason
WHERE r_reason_sk = 1;
----
logical_opt	<!REGEX>:.*AGGREGATE.*FILTER \(WHERE.*

query RR
SELECT
	CASE WHEN (SELECT count(*) FROM q09_sales WHERE q BETWEEN 1 AND 20) > 2
	     THEN (SELECT avg(discount) FROM q09_sales WHERE q BETWEEN 1 AND 20)
	     ELSE (SELECT avg(paid) FROM q09_sales WHERE q BETWEEN 1 AND 20)
	END b1,
	CASE WHEN (SELECT count(*) FROM q09_sales WHERE q BETWEEN 21 AND 40) > 9
	     THEN (SELECT avg(discount) FROM q09_sales WHERE q BETWEEN 21 AND 40)
	     ELSE (SELECT avg(paid) FROM q09_sales WHERE q BETWEEN 21 AND 40)
	END b2
FROM q09_reason
WHERE r_reason_sk = 1;
----
20.000000	450.000000

statement ok
CREATE VIEW q09_sales_view AS SELECT * FROM q09_sales

query II
EXPLAIN SELECT
	CASE WHEN (SELECT count(*) FROM q09_sales_view WHERE q BETWEEN 1 AND 20) > 2
	     THEN (SELECT avg(discount) FROM q09_sales_view WHERE q BETWEEN 1 AND 20)
	     ELSE (SELECT avg(paid) FROM q09_sales_view WHERE q BETWEEN 1 AND 20)
	END b1,
	CASE WHEN (SELECT count(*) FROM q09_sales_view WHERE q BETWEEN 21 AND 40) > 9
	     THEN (SELECT avg(discount) FROM q09_sales_view WHERE q BETWEEN 21 AND 40)
	     ELSE (SELECT avg(paid) FROM q09_sales_view WHERE q BETWEEN 21 AND 40)
	END b2
FROM q09_reason
WHERE r_reason_sk = 1;
----
logical_opt	<!REGEX>:.*AGGREGATE.*FILTER \(WHERE.*

query RR
SELECT
	CASE WHEN (SELECT count(*) FROM q09_sales_view WHERE q BETWEEN 1 AND 20) > 2
	     THEN (SELECT avg(discount) FROM q09_sales_view WHERE q BETWEEN 1 AND 20)
	     ELSE (SELECT avg(paid) FROM q09_sales_view WHERE q BETWEEN 1 AND 20)
	END b1,
	CASE WHEN (SELECT count(*) FROM q09_sales_view WHERE q BETWEEN 21 AND 40) > 9
	     THEN (SELECT avg(discount) FROM q09_sales_view WHERE q BETWEEN 21 AND 40)
	     ELSE (SELECT avg(paid) FROM q09_sales_view WHERE q BETWEEN 21 AND 40)
	END b2
FROM q09_reason
WHERE r_reason_sk = 1;
----
20.000000	450.000000

# Q28-style native table scans are also left as separate aggregates.
statement ok
CREATE TABLE q28_sales(q INTEGER, list_price INTEGER, coupon INTEGER, wholesale INTEGER)

statement ok
INSERT INTO q28_sales VALUES
	(1, 10, 100, 10), (2, 20, 200, 20), (7, 50, 300, 30), (8, 50, 350, 35), (20, 90, 900, 90)

query II
EXPLAIN SELECT *
FROM
	(SELECT avg(list_price) lp, count(list_price) cnt, count(DISTINCT list_price) cntd
	 FROM q28_sales
	 WHERE q BETWEEN 0 AND 5 AND (list_price BETWEEN 10 AND 20 OR coupon BETWEEN 100 AND 200)) b1,
	(SELECT avg(list_price) lp, count(list_price) cnt, count(DISTINCT list_price) cntd
	 FROM q28_sales
	 WHERE q BETWEEN 6 AND 10 AND (list_price BETWEEN 50 AND 60 OR wholesale BETWEEN 30 AND 40)) b2;
----
logical_opt	<!REGEX>:[\s\S]*FILTER \(WHERE.*

query RIRRIR
SELECT *
FROM
	(SELECT avg(list_price) lp, count(list_price) cnt, count(DISTINCT list_price) cntd
	 FROM q28_sales
	 WHERE q BETWEEN 0 AND 5 AND (list_price BETWEEN 10 AND 20 OR coupon BETWEEN 100 AND 200)) b1,
	(SELECT avg(list_price) lp, count(list_price) cnt, count(DISTINCT list_price) cntd
	 FROM q28_sales
	 WHERE q BETWEEN 6 AND 10 AND (list_price BETWEEN 50 AND 60 OR wholesale BETWEEN 30 AND 40)) b2;
----
15.000000	2	2	50.000000	2	1

# Do not fuse branches when moving a filtered aggregate child could evaluate a
# throwing expression on rows that the original branch filter excluded.
statement ok
CREATE TABLE throw_t(v VARCHAR, k INTEGER)

statement ok
INSERT INTO throw_t VALUES ('1', 1), ('bad', 2)

query II
SELECT *
FROM
	(SELECT sum(CAST(v AS INTEGER)) s FROM throw_t WHERE k = 1) a,
	(SELECT count(*) c FROM throw_t WHERE k = 2) b;
----
1	1
