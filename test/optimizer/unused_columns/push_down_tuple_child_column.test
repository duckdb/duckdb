statement ok
CREATE TABLE ts AS SELECT (i, i)::TUPLE(INTEGER, INTEGER) AS c FROM range(100) t(i);

statement ok
PRAGMA explain_output = PHYSICAL_ONLY;;

query II
EXPLAIN SELECT sum(struct_extract_at(c, 1)) FROM ts;
