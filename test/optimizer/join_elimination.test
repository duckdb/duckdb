  LEFT JOIN (
      SELECT DISTINCT b.* 
      FROM b 
      LEFT JOIN a ON a.ida = b.idb
  ) AS ab ON c.idc = ab.idb and c.valuec = ab.valueb;
----
physical_plan	<!REGEX>:.*JOIN.*

query II
explain select b.*, tan(a.ida) from b left join a on a.ida=b.idb;
