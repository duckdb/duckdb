# name: test/optimizer/compressed_materialization_decimal.test
# description: Compressed materialization of DECIMAL columns via raw int-to-int down/upcast
# group: [optimizer]

statement ok
PRAGMA explain_output = OPTIMIZED_ONLY

# DECIMAL(15,2) is physically int64; payloads 0..9900 fit int16 -> compress to SMALLINT
statement ok
CREATE TABLE small AS
SELECT ((range % 100))::DECIMAL(15,2) AS d, range AS id FROM range(2000);

# ORDER BY materializes 'd' as a sort payload; CM compresses/decompresses it
query II
EXPLAIN (FORMAT yaml) SELECT d FROM small ORDER BY id
----
logical_opt	<REGEX>:.*__internal_compress_decimal_smallint.*

query II
EXPLAIN (FORMAT yaml) SELECT d FROM small ORDER BY id
----
logical_opt	<REGEX>:.*__internal_decompress_decimal.*

# Round-trip correctness: values survive the compress/decompress unchanged
query I
SELECT d FROM small ORDER BY id LIMIT 5
----
0.00
1.00
2.00
3.00
4.00

query I
SELECT sum(d) FROM (SELECT d FROM small ORDER BY id) t
----
99000.00

# Negative payloads must round-trip too (signed int-to-int cast)
statement ok
CREATE TABLE neg AS
SELECT ((range % 100) - 50)::DECIMAL(15,2) AS d, range AS id FROM range(2000);

query II
EXPLAIN (FORMAT yaml) SELECT d FROM neg ORDER BY id
----
logical_opt	<REGEX>:.*__internal_compress_decimal_smallint.*

query III
SELECT min(d), max(d), sum(d) FROM (SELECT d FROM neg ORDER BY id) t
----
-50.00	49.00	-1000.00

# A DECIMAL whose payload range needs the full physical width must NOT be compressed
statement ok
CREATE TABLE wide AS
SELECT (range * 1000000)::DECIMAL(18,2) AS d, range AS id FROM range(2000);

query II
EXPLAIN (FORMAT yaml) SELECT d FROM wide ORDER BY id
----
logical_opt	<!REGEX>:.*__internal_compress_decimal.*

# Different physical widths: DECIMAL(9,2) is int32; payload 0..9900 fits int16 -> SMALLINT
statement ok
CREATE TABLE small32 AS
SELECT ((range % 100))::DECIMAL(9,2) AS d, range AS id FROM range(2000);

query II
EXPLAIN (FORMAT yaml) SELECT d FROM small32 ORDER BY id
----
logical_opt	<REGEX>:.*__internal_compress_decimal_smallint.*

query I
SELECT d FROM small32 ORDER BY id LIMIT 3
----
0.00
1.00
2.00
