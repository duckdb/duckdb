# name: test/optimizer/aggregate_precompute_function_filter.test
# description: Count with a function filter is precomputed from row-group statistics
# group: [optimizer]

# 4 row groups of 2048 rows, one row every 4 hours: row group 0 lies entirely within 2022
statement ok
ATTACH '{TEST_DIR}/func_filter_agg.duckdb' AS db (ROW_GROUP_SIZE 2048)

statement ok
CREATE TABLE db.t AS SELECT (TIMESTAMP '2022-01-01' + INTERVAL (i*4) HOUR) AS ts, i FROM range(8192) _(i);

restart

statement ok
ATTACH '{TEST_DIR}/func_filter_agg.duckdb' AS db (ROW_GROUP_SIZE 2048)

query II
EXPLAIN ANALYZE SELECT count(*) FROM db.t WHERE year(ts) = 2022
----
analyzed_plan	<REGEX>:.*"\+"\(2048, #0\).*Row Groups Scanned: 1 / 4.*

query I
SELECT count(*) FROM db.t WHERE year(ts) = 2022
----
2190
