----
logical_opt	<REGEX>:.*LEFT.*

query II
EXPLAIN SELECT l.s
FROM (VALUES ('x'), ('2'), ('3')) l(s)
LEFT JOIN (VALUES ('x'), ('2')) r(s) ON l.s = r.s
WHERE CAST(r.s AS INTEGER) IS NULL
