# name: test/optimizer/outer_join_simplification.test
# description: Test OuterJoinSimplification optimizer
# group: [optimizer]

statement ok
PRAGMA explain_output = OPTIMIZED_ONLY;

# First a bunch of plan checks
query II
EXPLAIN SELECT l.i, r.i
FROM range(3) l(i)
FULL OUTER JOIN range(2) r(i) ON l.i = r.i
WHERE r.i IS NOT NULL
ORDER BY 2;
----
logical_opt	<!REGEX>:.*FULL.*

query II
EXPLAIN SELECT l.i, r.i
FROM range(2) l(i)
FULL OUTER JOIN range(3) r(i) ON l.i = r.i
WHERE l.i IS NOT NULL
ORDER BY 1;
----
logical_opt	<!REGEX>:.*FULL.*

query II
EXPLAIN SELECT l.i, r.i
FROM range(3) l(i)
FULL OUTER JOIN range(3) r(i) ON l.i = r.i
WHERE l.i IS NOT NULL AND r.i IS NOT NULL
ORDER BY 1;
----
logical_opt	<REGEX>:.*INNER.*

query II
EXPLAIN SELECT l.i, r.i
FROM range(3) l(i)
LEFT JOIN range(3) r(i) ON l.i = r.i AND r.i = 1
ORDER BY 1;
----
logical_opt	<REGEX>:.*LEFT.*

query II
EXPLAIN SELECT t.li, x.j
FROM (
    SELECT l.i AS li, r.i AS ri
    FROM range(4) l(i)
    LEFT JOIN range(2) r(i) ON l.i = r.i
) t
INNER JOIN range(2) x(j) ON t.ri = x.j
ORDER BY 1;
----
logical_opt	<!REGEX>:.*LEFT.*

# Then a bunch of correct result checks
query II
SELECT l.i, r.i
FROM range(3) l(i)
FULL OUTER JOIN range(2) r(i) ON l.i = r.i
WHERE r.i IS NOT NULL
ORDER BY 2;
----
0	0
1	1

query II
SELECT l.i, r.i
FROM range(2) l(i)
FULL OUTER JOIN range(3) r(i) ON l.i = r.i
WHERE l.i IS NOT NULL
ORDER BY 1;
----
0	0
1	1

query II
SELECT l.i, r.i
FROM range(3) l(i)
FULL OUTER JOIN range(3) r(i) ON l.i = r.i
WHERE l.i IS NOT NULL AND r.i IS NOT NULL
ORDER BY 1;
----
0	0
1	1
2	2

query II
SELECT l.i, r.i
FROM range(3) l(i)
LEFT JOIN range(3) r(i) ON l.i = r.i AND r.i = 1
ORDER BY 1;
----
0	NULL
1	1
2	NULL

query II
SELECT t.li, x.j
FROM (
    SELECT l.i AS li, r.i AS ri
    FROM range(4) l(i)
    LEFT JOIN range(2) r(i) ON l.i = r.i
) t
INNER JOIN range(2) x(j) ON t.ri = x.j
ORDER BY 1;
----
0	0
1	1

require tpcds

statement ok
CALL dsdgen(sf=0.01);

# TPC-DS Q93
query II
EXPLAIN SELECT ss_customer_sk,
       sum(act_sales) sumsales
FROM
  (SELECT ss_item_sk,
          ss_ticket_number,
          ss_customer_sk,
          CASE
              WHEN sr_return_quantity IS NOT NULL THEN (ss_quantity-sr_return_quantity)*ss_sales_price
              ELSE (ss_quantity*ss_sales_price)
          END act_sales
   FROM store_sales
   LEFT OUTER JOIN store_returns ON (sr_item_sk = ss_item_sk
                                     AND sr_ticket_number = ss_ticket_number) ,reason
   WHERE sr_reason_sk = r_reason_sk
     AND r_reason_desc = 'reason 28') t
GROUP BY ss_customer_sk
ORDER BY sumsales NULLS FIRST,
         ss_customer_sk NULLS FIRST
LIMIT 100;
----
logical_opt	<!REGEX>:.*(LEFT|RIGHT).*
