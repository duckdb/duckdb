query II
EXPLAIN SELECT l.i
FROM (VALUES (1), (2), (3)) l(i)
LEFT JOIN (VALUES (1), (2)) r(i) ON l.i = r.i
WHERE CAST(r.i AS BIGINT) IS NULL
