----
logical_opt	<REGEX>:.*ANTI.*

query II
EXPLAIN SELECT l.i
FROM (VALUES (1), (2), (3)) l(i)
LEFT JOIN (VALUES (1), (2)) r(i) ON l.i = CAST(r.i AS BIGINT)
WHERE CAST(r.i AS BIGINT) IS NULL
