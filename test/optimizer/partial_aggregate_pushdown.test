# pushdown still fires on this fan-out
query II
EXPLAIN
SELECT a.keyid AS keyid, count(*) AS hits, sum(bytes_sent) AS total_bytes
FROM access_log a JOIN user_profile u USING (keyid) JOIN location l USING (keyid)
