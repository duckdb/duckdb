	SELECT * FROM pap_excluded_enabled
	EXCEPT ALL
	SELECT * FROM pap_excluded_disabled
)
----
0

query I
SELECT count(*) FROM (
	SELECT * FROM pap_excluded_disabled
	EXCEPT ALL
	SELECT * FROM pap_excluded_enabled
)
----
0

statement ok
RESET disabled_optimizers

# Double-eager (two-sided) pushdown: a fact x fact join through a shared key, where BOTH inputs have
# many rows per key. de_a and de_b both have 100 rows per key; the grouping column lives on the unique
# dimension de_dim. Double-eager pre-aggregates both facts by the key and reconstructs the aggregates
# with the other side's row count as a state-combine multiplicity.
statement ok
CREATE TABLE de_dim AS SELECT i AS k, (i % 7) AS g FROM range(50) _(i)

statement ok
CREATE TABLE de_a AS SELECT (i % 50) AS k FROM range(5000) _(i)

statement ok
CREATE TABLE de_b AS SELECT (i % 50) AS k, ((i * 13) % 100)::BIGINT AS m FROM range(5000) _(i)

statement ok
ANALYZE

# Integer measure -> count(*), sum, count, min, max and avg are all exact, so enabled and disabled must
# produce byte-identical results.
statement ok
CREATE TEMP TABLE de_enabled AS
SELECT g, count(*) AS ev, sum(b.m) AS s, count(b.m) AS c, min(b.m) AS mn, max(b.m) AS mx, avg(b.m) AS a
FROM de_a a JOIN de_dim d USING (k) JOIN de_b b USING (k)
GROUP BY g

statement ok
SET disabled_optimizers = 'partial_aggregate_pushdown'

statement ok
CREATE TEMP TABLE de_disabled AS
SELECT g, count(*) AS ev, sum(b.m) AS s, count(b.m) AS c, min(b.m) AS mn, max(b.m) AS mx, avg(b.m) AS a
FROM de_a a JOIN de_dim d USING (k) JOIN de_b b USING (k)
GROUP BY g

query I
SELECT count(*) FROM (
	SELECT * FROM de_enabled
	EXCEPT ALL
	SELECT * FROM de_disabled
)
----
0

query I
SELECT count(*) FROM (
	SELECT * FROM de_disabled
	EXCEPT ALL
	SELECT * FROM de_enabled
)
----
0

statement ok
RESET disabled_optimizers

# The double-eager rewrite reconstructs the aggregates above the join with combine_aggr(partial, count).
query II
EXPLAIN
SELECT g, count(*) AS ev, sum(b.m) AS s
FROM de_a a JOIN de_dim d USING (k) JOIN de_b b USING (k)
GROUP BY g
----
physical_plan	<REGEX>:.*combine_aggr.*

