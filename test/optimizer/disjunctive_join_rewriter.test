query II
EXPLAIN SELECT o.o_orderkey, l.l_partkey
FROM tiny_orders o JOIN tiny_lineitem l
ON o.o_orderkey = l.l_orderkey OR o.o_custkey = l.l_partkey;
----
physical_plan	<REGEX>:.*BLOCKWISE_NL_JOIN.*

query IIII rowsort
SELECT o.o_orderkey, o.o_custkey, l.l_orderkey, l.l_partkey
FROM tiny_orders o JOIN tiny_lineitem l ON o.o_orderkey = l.l_orderkey OR o.o_custkey = l.l_partkey;
----
1	10	1	99
2	20	88	20
3	30	3	30
4	NULL	4	77
6	60	6	60

statement ok
CREATE TABLE med_orders AS SELECT * FROM orders LIMIT 0;

statement ok
CREATE TABLE med_lineitem AS SELECT * FROM lineitem LIMIT 0;

statement ok
INSERT INTO med_orders
SELECT
    i AS o_orderkey,
    ((i - 1) % 100) + 1 AS o_custkey,
    'O' AS o_orderstatus,
    i * 100.0 AS o_totalprice,
    DATE('1996-01-01') AS o_orderdate,
    '1-URGENT' AS o_orderpriority,
    'Clerk#000000001' AS o_clerk,
    0 AS o_shippriority,
    'comment' AS o_comment
FROM generate_series(1, 4000) AS i;

statement ok
INSERT INTO med_lineitem
SELECT
    CASE WHEN i <= 2000 THEN i ELSE i + 10000 END AS l_orderkey,
    ((i - 1) % 80) + 1 AS l_partkey,
    1 AS l_suppkey,
    1 AS l_linenumber,
    1.0 AS l_quantity,
    10.0 AS l_extendedprice,
    0.0 AS l_discount,
    0.0 AS l_tax,
    'N' AS l_returnflag,
    'O' AS l_linestatus,
    DATE('1996-01-10') AS l_shipdate,
    DATE('1996-01-12') AS l_commitdate,
    DATE('1996-01-15') AS l_receiptdate,
    'DELIVER IN PERSON' AS l_shipinstruct,
    'TRUCK' AS l_shipmode,
    'comment' AS l_comment
FROM generate_series(1, 4000) AS i;

query II
EXPLAIN SELECT COUNT(*)
FROM med_orders o JOIN med_lineitem l
ON o.o_orderkey = l.l_orderkey OR o.o_custkey = l.l_partkey;
----
physical_plan	<!REGEX>:.*BLOCKWISE_NL_JOIN.*

query I
SELECT COUNT(*)
FROM med_orders o JOIN med_lineitem l
ON o.o_orderkey = l.l_orderkey OR o.o_custkey = l.l_partkey;
----
161600

