query II
EXPLAIN SELECT o.o_orderkey, o.o_custkey, l.l_orderkey, l.l_partkey, o.o_comment, l.l_comment
FROM orders o JOIN lineitem l
ON o.o_orderkey + 100 = l.l_orderkey
   OR o.o_custkey + 1000 = l.l_partkey
   OR SUBSTRING(o.o_comment, 1, 2) = SUBSTRING(l.l_comment, 1, 2);
----
physical_plan	<!REGEX>:.*BLOCKWISE_NL_JOIN.*

query IIIIII rowsort
SELECT o.o_orderkey, o.o_custkey, l.l_orderkey, l.l_partkey, o.o_comment, l.l_comment
FROM orders o JOIN lineitem l
ON o.o_orderkey + 100 = l.l_orderkey
   OR o.o_custkey + 1000 = l.l_partkey
   OR SUBSTRING(o.o_comment, 1, 2) = SUBSTRING(l.l_comment, 1, 2);
