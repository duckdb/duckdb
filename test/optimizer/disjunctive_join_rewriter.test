query IIII rowsort
SELECT o1.o_orderkey, l1.l_orderkey, o2.o_orderkey, l2.l_orderkey
FROM orders o1
JOIN lineitem l1 ON o1.o_orderkey = l1.l_orderkey OR o1.o_custkey = l1.l_partkey
JOIN orders o2 ON o1.o_orderkey = o2.o_orderkey
JOIN lineitem l2 ON o2.o_orderkey = l2.l_orderkey OR o2.o_custkey = l2.l_partkey;
----
1	1	1	1
2	88	2	88
3	3	3	3
4	4	4	4
6	6	6	6

query II
EXPLAIN SELECT o.o_orderkey, l.l_orderkey
FROM orders o JOIN lineitem l
ON o.o_orderkey > l.l_orderkey OR o.o_custkey = l.l_partkey;
----
physical_plan	<REGEX>:.*BLOCKWISE_NL_JOIN.*

query II
EXPLAIN SELECT o.o_orderkey, l.l_orderkey
FROM orders o JOIN lineitem l
ON o.o_orderkey = l.l_orderkey
   OR o.o_custkey = l.l_partkey
   OR o.o_orderkey + 1 = l.l_orderkey
   OR o.o_orderkey + 2 = l.l_orderkey
   OR o.o_orderkey + 3 = l.l_orderkey
   OR o.o_orderkey + 4 = l.l_orderkey
   OR o.o_orderkey + 5 = l.l_orderkey
   OR o.o_orderkey + 6 = l.l_orderkey
   OR o.o_orderkey + 7 = l.l_orderkey
   OR o.o_orderkey + 8 = l.l_orderkey;
----
physical_plan	<REGEX>:.*BLOCKWISE_NL_JOIN.*

