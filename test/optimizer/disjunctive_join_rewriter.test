statement ok
CREATE TABLE dups_a AS SELECT * FROM orders LIMIT 0;

statement ok
CREATE TABLE dups_b AS SELECT * FROM lineitem LIMIT 0;

statement ok
INSERT INTO dups_a(o_orderkey, o_custkey, o_totalprice, o_comment)
SELECT ((i-1) % 100) + 1, ((i-1) % 50) + 1, i * 1.0, 'x'
FROM generate_series(1, 4000) AS i;

statement ok
INSERT INTO dups_b(l_orderkey, l_partkey, l_extendedprice, l_comment)
SELECT ((i-1) % 100) + 1, ((i-1) % 50) + 1, i * 1.0, 'y'
FROM generate_series(1, 4000) AS i;

query II
EXPLAIN SELECT COUNT(*) FROM dups_a JOIN dups_b
ON dups_a.o_orderkey = dups_b.l_orderkey OR dups_a.o_custkey = dups_b.l_partkey;
----
physical_plan	<!REGEX>:.*BLOCKWISE_NL_JOIN.*

query I
SELECT COUNT(*) FROM dups_a JOIN dups_b
ON dups_a.o_orderkey = dups_b.l_orderkey OR dups_a.o_custkey = dups_b.l_partkey;
----
320000