query IIIIII rowsort
SELECT o.o_orderkey, o.o_custkey, l.l_orderkey, l.l_partkey, o.o_totalprice, l.l_extendedprice
FROM orders o JOIN lineitem l
ON o.o_orderkey = l.l_orderkey
   OR o.o_custkey = l.l_partkey
   OR o.o_totalprice = l.l_extendedprice
   OR o.o_orderkey + 100 = l.l_orderkey;
----
