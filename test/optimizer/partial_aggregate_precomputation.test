# name: test/optimizer/partial_aggregate_precomputation.test
# description: Test partial precomputation of aggregates (count_star, min, max)
# group: [optimizer]

statement ok
SET profiling_renderer_settings = MAP {'operator_casing': 'upper'};

require no_alternative_verify

statement ok
ATTACH '{TEST_DIR}/partial_agg.duckdb' AS db (ROW_GROUP_SIZE 2048)

statement ok
USE db

# 4 row groups: [0-2047], [2048-4095], [4096-6143], [6144-8191], j = i * 2
statement ok
CREATE TABLE t AS (SELECT * FROM range(8192) _(i), LATERAL (SELECT (i * 2) AS j));

# Reopen to clear version info
statement ok
ATTACH '{TEST_DIR}/tmp_partial.duckdb' AS tmp

statement ok
USE tmp

statement ok
DETACH db

statement ok
ATTACH '{TEST_DIR}/partial_agg.duckdb' AS db (ROW_GROUP_SIZE 2048)

statement ok
USE db

statement ok
DETACH tmp

# Full precompute: all row groups determined
query II
EXPLAIN SELECT count(*), min(i), max(i) FROM t WHERE i >= 2048
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query III
SELECT count(*), min(i), max(i) FROM t WHERE i >= 2048
----
6144	2048	8191

# Partial precompute: PROJECTION merges precomputed constants with aggregate results
query II
EXPLAIN SELECT count(*), min(i), max(i) FROM t WHERE i >= 2048 AND j > 5000
----
physical_plan	<REGEX>:.*COALESCE.*least.*UNGROUPED_AGGREGATE.*

query III
SELECT count(*), min(i), max(i) FROM t WHERE i >= 2048 AND j > 5000
----
5691	2501	8191

# Individual aggregates with partial precompute
query I
SELECT min(i) FROM t WHERE i >= 2048 AND j > 5000
----
2501

query I
SELECT max(i) FROM t WHERE i >= 2048 AND j > 5000
----
8191

query I
SELECT count(*) FROM t WHERE i >= 2048 AND j > 5000
----
5691

# Different filter boundary
query III
SELECT count(*), min(i), max(i) FROM t WHERE i >= 4096 AND j > 9000
----
3691	4501	8191

# Filter without row-group-aligned boundary
query III
SELECT count(*), min(i), max(i) FROM t WHERE j > 5000
----
5691	2501	8191

# Filter that excludes all data
query III
SELECT count(*), min(i), max(i) FROM t WHERE i > 99999
----
0	NULL	NULL

# Index scan disabled during partial precompute
statement ok
SET index_scan_percentage = 1.0

statement ok
CREATE INDEX idx_j ON t(j)

# Without statistics propagation, aggregate query uses index scan (single filter on indexed column)
statement ok
SET disabled_optimizers='statistics_propagation'

query II
EXPLAIN ANALYZE SELECT count(*), min(i), max(i) FROM t WHERE j > 5000
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*

# With statistics propagation, partial precompute disables index scan
statement ok
RESET disabled_optimizers

query II
EXPLAIN ANALYZE SELECT count(*), min(i), max(i) FROM t WHERE j > 5000
----
analyzed_plan	<REGEX>:.*Type: Sequential Scan.*

query III
SELECT count(*), min(i), max(i) FROM t WHERE j > 5000
----
5691	2501	8191

statement ok
SET index_scan_percentage = 0.001

# Grouped aggregate should not trigger precompute
query II
EXPLAIN SELECT count(*), min(i), max(i) FROM t WHERE i >= 2048 AND j > 5000 GROUP BY i % 10
----
physical_plan	<REGEX>:.*HASH_GROUP_BY.*

# Inexact statistics: updated/deleted row groups fall back to scanning, exact ones still precompute
statement ok
CREATE TABLE t2 AS (SELECT * FROM range(8192) _(i), LATERAL (SELECT (i * 2) AS j));

# Reopen to clear version info so all row group stats start exact
statement ok
ATTACH '{TEST_DIR}/tmp_partial2.duckdb' AS tmp2

statement ok
USE tmp2

statement ok
DETACH db

statement ok
ATTACH '{TEST_DIR}/partial_agg.duckdb' AS db (ROW_GROUP_SIZE 2048)

statement ok
USE db

statement ok
DETACH tmp2

# Prevent automatic checkpoints: a checkpoint rewrites the row group and re-tightens its statistics
statement ok
SET checkpoint_threshold = '1TB'

# An update marks row group 0 as changed: its min/max become inexact, its count stays exact
statement ok
UPDATE t2 SET j = 4000 WHERE i = 100

# count(*) alone is still fully precomputed - updates do not change row counts
query II
EXPLAIN SELECT count(*) FROM t2
----
physical_plan	<!REGEX>:.*UNGROUPED_AGGREGATE.*

query I
SELECT count(*) FROM t2
----
8192

# min/max must scan the updated row group - partial precompute without any filter
query II
EXPLAIN SELECT min(j), max(j) FROM t2
----
physical_plan	<REGEX>:.*COALESCE.*least.*UNGROUPED_AGGREGATE.*

query II
SELECT min(j), max(j) FROM t2
----
0	16382

# combined with max, count is scanned along with it and merged back
query II
EXPLAIN SELECT count(*), max(j) FROM t2
----
physical_plan	<REGEX>:.*UNGROUPED_AGGREGATE.*

query II
SELECT count(*), max(j) FROM t2
----
8192	16382

# Filter + inexact min/max: the updated row group cannot be trusted for the filter
# verdict at plan time, so it stays in the scan set; the scan-time zonemap then
# skips it anyway, so no row group is actually read
query II
EXPLAIN ANALYZE SELECT min(j), max(j) FROM t2 WHERE i >= 2048
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 0 / 4.*

query II
SELECT min(j), max(j) FROM t2 WHERE i >= 2048
----
4096	16382

# A delete creates version info: the count of row group 0 becomes approximate as well
statement ok
DELETE FROM t2 WHERE i = 100

# partial precompute: the 3 clean row groups fold into the constant 6144
query II
EXPLAIN SELECT count(*) FROM t2
----
physical_plan	<REGEX>:.*6144.*UNGROUPED_AGGREGATE.*

# only the deleted row group is scanned
query II
EXPLAIN ANALYZE SELECT count(*) FROM t2
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 4.*

query III
SELECT count(*), min(j), max(j) FROM t2
----
8191	0	16382

# Filter + approximate count: the deleted row group stays in the scan set at plan
# time, the scan-time zonemap skips it, and the count comes from the constant alone
query II
EXPLAIN ANALYZE SELECT count(*) FROM t2 WHERE i >= 2048
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 0 / 4.*

query I
SELECT count(*) FROM t2 WHERE i >= 2048
----
6144

# All actions at once: row group 0 scanned (inexact stats), row group 2 scanned
# (partial filter match), row group 3 pruned, row group 1 precomputed
query II
EXPLAIN ANALYZE SELECT count(*), min(j), max(j) FROM t2 WHERE i < 5000
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 2 / 4.*

query III
SELECT count(*), min(j), max(j) FROM t2 WHERE i < 5000
----
4999	0	9998

# Update and delete hitting different row groups
statement ok
CREATE TABLE t3 AS (SELECT * FROM range(8192) _(i), LATERAL (SELECT (i * 2) AS j));

# Reopen to clear version info
statement ok
ATTACH '{TEST_DIR}/tmp_partial3.duckdb' AS tmp3

statement ok
USE tmp3

statement ok
DETACH db

statement ok
ATTACH '{TEST_DIR}/partial_agg.duckdb' AS db (ROW_GROUP_SIZE 2048)

statement ok
USE db

statement ok
DETACH tmp3

# row group 0: update only; row group 1: delete only
statement ok
UPDATE t3 SET j = 4000 WHERE i = 100

statement ok
DELETE FROM t3 WHERE i = 3000

# count scans only the deleted row group - the updated one still precomputes its count
query II
EXPLAIN ANALYZE SELECT count(*) FROM t3
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 1 / 4.*

query I
SELECT count(*) FROM t3
----
8191

# min/max must scan both changed row groups
query II
EXPLAIN ANALYZE SELECT min(j), max(j) FROM t3
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 2 / 4.*

query II
SELECT min(j), max(j) FROM t3
----
0	16382

# all three aggregates with a filter partially matching yet another row group:
# row groups 0 (update) and 1 (delete) are scanned as untrusted, row group 3 is a
# partial filter match, row group 2 precomputes
query II
EXPLAIN ANALYZE SELECT count(*), min(j), max(j) FROM t3 WHERE i < 7000
----
analyzed_plan	<REGEX>:.*Row Groups Scanned: 3 / 4.*

query III
SELECT count(*), min(j), max(j) FROM t3 WHERE i < 7000
----
6999	0	13998
