# name: test/optimizer/pushdown/join_filter_pushdown_cast_variant.test
# description: Join filter pushdown through integral/variant up/downcasts
# group: [pushdown]

load {TEST_DIR}/join_filter_pushdown_cast.db readwrite v1.5.0

# Integral probe cast to VARIANT
statement ok
CREATE TABLE probe_int_variant AS SELECT range::INT AS a FROM range(100);

statement ok
CREATE TABLE build_variant_for_int AS SELECT b::VARIANT AS b FROM (VALUES (10), (20), (30), (50)) t(b);

query II
EXPLAIN ANALYZE SELECT COUNT(*) FROM (SELECT a::VARIANT AS a FROM probe_int_variant) t JOIN build_variant_for_int ON t.a = build_variant_for_int.b;
----
analyzed_plan	<REGEX>:.*Dynamic Filters:.*

query I
SELECT COUNT(*) FROM (SELECT a::VARIANT AS a FROM probe_int_variant) t JOIN build_variant_for_int ON t.a = build_variant_for_int.b;
----
4

# VARIANT probe cast to integral
statement ok
CREATE TABLE probe_variant_int AS SELECT range::INT::VARIANT AS a FROM range(100);

statement ok
CREATE TABLE build_int_for_variant AS SELECT b::INT AS b FROM (VALUES (10), (20), (30), (50)) t(b);

query II
EXPLAIN ANALYZE SELECT COUNT(*) FROM (SELECT a::INT AS a FROM probe_variant_int) t JOIN build_int_for_variant ON t.a = build_int_for_variant.b;
----
analyzed_plan	<REGEX>:.*Dynamic Filters:.*

query I
SELECT COUNT(*) FROM (SELECT a::INT AS a FROM probe_variant_int) t JOIN build_int_for_variant ON t.a = build_int_for_variant.b;
----
4

# Direct VARIANT joins still do not push plain VARIANT scan filters
statement ok
CREATE TABLE probe_direct_variant AS SELECT range::INT::VARIANT AS a FROM range(100);

statement ok
CREATE TABLE build_direct_variant AS SELECT b::VARIANT AS b FROM (VALUES (10), (20), (30), (50)) t(b);

query II
EXPLAIN ANALYZE SELECT COUNT(*) FROM probe_direct_variant JOIN build_direct_variant ON probe_direct_variant.a = build_direct_variant.b;
----
analyzed_plan	<!REGEX>:.*Dynamic Filters:.*

query I
SELECT COUNT(*) FROM probe_direct_variant JOIN build_direct_variant ON probe_direct_variant.a = build_direct_variant.b;
----
4
