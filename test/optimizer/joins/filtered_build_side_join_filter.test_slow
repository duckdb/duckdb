statement ok
COPY build_base TO '{TEST_DIR}/filtered_build_side_build.parquet' (FORMAT parquet, ROW_GROUP_SIZE 100000);

statement ok
CREATE VIEW probe_v AS SELECT * FROM read_parquet('{TEST_DIR}/filtered_build_side_probe.parquet') WHERE f = 1;

statement ok
CREATE VIEW build_v AS SELECT * FROM read_parquet('{TEST_DIR}/filtered_build_side_build.parquet') WHERE k BETWEEN 10 AND 15000;

query II
EXPLAIN SELECT p.k, b.payload FROM build_v b JOIN probe_v p ON b.k = p.k;
----
physical_plan	<REGEX>:.*Projections: k.*Projections:.*
