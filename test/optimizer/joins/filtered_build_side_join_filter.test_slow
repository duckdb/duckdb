# name: test/optimizer/joins/filtered_build_side_join_filter.test_slow
# description: Prefer filtered Parquet build sides when they enable join filter pushdown
# group: [joins]

require parquet

statement ok
CREATE TABLE probe_base AS SELECT i AS k, i % 10 AS f FROM range(5000000) tbl(i);

statement ok
COPY probe_base TO '{TEST_DIR}/filtered_build_side_probe.parquet' (FORMAT parquet, ROW_GROUP_SIZE 100000);

statement ok
