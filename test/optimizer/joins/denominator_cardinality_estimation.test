# name: test/optimizer/joins/denominator_cardinality_estimation.test
# description: Join cardinality denominator assembly and predicate grouping
# group: [joins]

statement ok
set disabled_optimizers='statistics_propagation';

# Two disconnected join components are merged by a cross product. The final
# denominator must include selectivity from both joined pairs.

statement ok
create table dc_a as select range::integer k from range(1000);

statement ok
create table dc_b as select range::integer k from range(100);

statement ok
create table dc_c as select range::integer k from range(500);

statement ok
create table dc_d as select range::integer k from range(50);

query II
explain select *
from dc_a
join dc_b using (k),
     dc_c
join dc_d using (k);
----
physical_plan	<REGEX>:.*~[0-9]+.[0-9][0-9][0-9] rows.*CROSS_PRODUCT.*

query I
select count(*)
from dc_a
join dc_b using (k),
     dc_c
join dc_d using (k);
----
5000

# Equality components can be discovered in an order that merges two existing
# components. All equality edges must receive the final component id.

statement ok
create table te_a as select range::integer k from range(1000);

statement ok
create table te_b as select range::integer k from range(1000);

statement ok
create table te_c as select range::integer k from range(1000);

statement ok
create table te_d as select range::integer k from range(1000);

query II
explain select *
from te_a, te_b, te_c, te_d
where te_a.k = te_b.k
  and te_c.k is not distinct from te_d.k
  and te_b.k = te_c.k
  and te_a.k = te_d.k;
----
physical_plan	<REGEX>:.*HASH_JOIN.*~[0-9]+.[0-9][0-9][0-9] rows.*

query I
select count(*)
from te_a, te_b, te_c, te_d
where te_a.k = te_b.k
  and te_c.k is not distinct from te_d.k
  and te_b.k = te_c.k
  and te_a.k = te_d.k;
----
1000

# Non-equality predicates get their own domain group. They should still add
# selectivity, but they must not merge into equality domains.

statement ok
create table ne_a as select range::integer x from range(1000);

statement ok
create table ne_b as select range::integer x, (range % 8)::integer y from range(1000);

statement ok
create table ne_c as select (range % 8)::integer y from range(1000);

query II
explain select *
from ne_a
join ne_b on ne_a.x = ne_b.x
join ne_c on ne_b.y < ne_c.y;
----
physical_plan	<REGEX>:.*PIECEWISE_MERGE_JOIN.*~[0-9]+.[0-9][0-9][0-9] rows.*

query I
select count(*)
from ne_a
join ne_b on ne_a.x = ne_b.x
join ne_c on ne_b.y < ne_c.y;
----
437500

# Expression equality predicates should remain graph/selectivity predicates,
# but should not become transitive equality-closure predicates. The expression
# edge still needs to participate in join ordering instead of being left as a
# post-join filter or cross product.

statement ok
create table ee_a as select range::integer x from range(1000);

statement ok
create table ee_b as select range::integer y from range(1000);

statement ok
create table ee_c as select range::integer z from range(1000);

query II
explain select *
from ee_a, ee_b, ee_c
where ee_a.x + 1 = ee_b.y
  and ee_b.y = ee_c.z;
----
physical_plan	<REGEX>:.*HASH_JOIN.*x \+ 1.*HASH_JOIN.*

query I
select count(*)
from ee_a, ee_b, ee_c
where ee_a.x + 1 = ee_b.y
  and ee_b.y = ee_c.z;
----
999

# A redundant edge in a transitive equality class must not be treated as an
# additional composite-key condition. Otherwise the estimator can replace a
# small domain with the full table cardinality and badly underestimate fanout.

statement ok
create table tr_customer as
select range::integer c_id, (range % 25)::integer c_nationkey
from range(1500);

statement ok
create table tr_supplier as
select range::integer s_id, (range % 25)::integer s_nationkey
from range(100);

statement ok
create table tr_nation as
select range::integer n_nationkey, (range / 5)::integer n_regionkey
from range(25);

statement ok
create table tr_region as
select range::integer r_regionkey, case when range = 2 then 'ASIA' else 'OTHER' end r_name
from range(5);

query II
explain select count(*)
from tr_customer, tr_supplier, tr_nation, tr_region
where c_nationkey = s_nationkey
  and s_nationkey = n_nationkey
  and n_regionkey = r_regionkey
  and r_name = 'ASIA';
----
physical_plan	<REGEX>:.*HASH_JOIN.*~[1-9],[0-9][0-9][0-9] rows.*

query I
select count(*)
from tr_customer, tr_supplier, tr_nation, tr_region
where c_nationkey = s_nationkey
  and s_nationkey = n_nationkey
  and n_regionkey = r_regionkey
  and r_name = 'ASIA';
----
1200
