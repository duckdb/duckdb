# name: test/optimizer/joins/fkpk_composite_key_ce.test
# description: Cardinality estimation for composite FK/PK joins with transitive equality conditions
# group: [joins]

statement ok
set disabled_optimizers='statistics_propagation';

# --------------------------------------------------------------------------
# Setup: mimic TPC-H Q9 structure (partsupp, supplier, lineitem).
#
# ps (partsupp): 200K rows, composite PK = (ps_suppkey, ps_partkey).
#   ps_partkey = range (unique), ps_suppkey = range % 10000.
#   Since range(200K) has ps_partkey unique, each (suppkey, partkey) pair
#   appears exactly once — a true composite PK.
#
# su (supplier): 10K rows, PK = s_suppkey.
#
# li (lineitem): 600K rows, FK (l_suppkey, l_partkey) -> ps composite PK.
#   For each li row i: l_suppkey = i%10000, l_partkey = i%200000.
#   By construction: l_partkey%10000 == l_suppkey (always), so each li row
#   matches exactly one ps row and one su row → join count = 600K.
# --------------------------------------------------------------------------

statement ok
create table ps as select
    range % 10000 ps_suppkey,
    range         ps_partkey
from range(200000);

statement ok
create table su as select range s_suppkey from range(10000);

statement ok
create table li as select
    range % 10000  l_suppkey,
    range % 200000 l_partkey
from range(600000);

# Same-pair composite equalities should not be counted as unused edges after
# the composite-key cap has already been applied. The estimate should remain
# at the one-to-one join size rather than being divided by an extra penalty.

statement ok
create table ck_a as select range::integer x, range::integer y from range(1000);

statement ok
create table ck_b as select range::integer x, range::integer y from range(1000);

query II
explain select count(*) from ck_a join ck_b on ck_a.x = ck_b.x and ck_a.y = ck_b.y;
----
physical_plan	<REGEX>:.*HASH_JOIN.*~1.000 rows.*

query I
select count(*) from ck_a join ck_b on ck_a.x = ck_b.x and ck_a.y = ck_b.y;
----
1000

# --------------------------------------------------------------------------
# Q9-like 3-way join: ps_suppkey=l_suppkey AND s_suppkey=l_suppkey AND
# ps_partkey=l_partkey. DuckDB derives the transitive condition
# ps_suppkey=s_suppkey, enabling the plan {ps JOIN su} JOIN li.
#
# Before the fix: MarkEdgeEquivalences was called before CreateHyperGraphEdges,
# so left_binding/right_binding were unset and all filters failed the validity
# check. No equivalence index was ever assigned. The transitive edge
# ps_suppkey=s_suppkey then landed in unused_edge_tdoms, doubling the
# denominator and halving the estimate (~300K instead of ~600K).
#
# After the fix: equivalence indices are correctly assigned, the transitive
# edge is recognised as redundant and skipped, and the FK/PK multi-key cap
# keeps the estimate at ~|li| rows (~600K).
# --------------------------------------------------------------------------

# Estimate for the 3-way join should be approximately |li| rows (~600K).
query II
explain select count(*) from ps, su, li
where su.s_suppkey = li.l_suppkey
  and ps.ps_suppkey = li.l_suppkey
  and ps.ps_partkey = li.l_partkey;
----
physical_plan	<REGEX>:.*~600.000 rows.*

# Correctness: actual join count (1 ps row + 1 su row per li row = 600K)
query I
select count(*) from ps, su, li
where su.s_suppkey = li.l_suppkey
  and ps.ps_suppkey = li.l_suppkey
  and ps.ps_partkey = li.l_partkey;
----
600000

# --------------------------------------------------------------------------
# Q9 can also expose the composite key indirectly. If ps joins su first, the
# final join to li can be written as li.partkey=ps.partkey and
# li.suppkey=su.suppkey. Since ps.suppkey=su.suppkey was already applied,
# this implies a second li<->ps equality and should still trigger the
# composite FK/PK floor. Without that, the estimate is roughly 4x too high
# because ps4 has four suppliers per part.
# --------------------------------------------------------------------------

statement ok
create table ps4 as select
    range // 4 ps_partkey,
    range % 1000 ps_suppkey
from range(80000);

statement ok
create table su4 as select range s_suppkey from range(1000);

statement ok
create table li4 as select
    range % 20000 l_partkey,
    ((range % 20000) * 4) % 1000 l_suppkey
from range(60000);

query II
explain select count(*) from ps4, su4, li4
where ps4.ps_suppkey = su4.s_suppkey
  and ps4.ps_partkey = li4.l_partkey
  and su4.s_suppkey = li4.l_suppkey;
----
physical_plan	<REGEX>:.*~6[0-9],[0-9]{3} rows.*

query I
select count(*) from ps4, su4, li4
where ps4.ps_suppkey = su4.s_suppkey
  and ps4.ps_partkey = li4.l_partkey
  and su4.s_suppkey = li4.l_suppkey;
----
60000
