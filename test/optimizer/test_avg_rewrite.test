# name: test/optimizer/test_avg_rewrite.test
# description: Test AVG rewrite
# group: [optimizer]

statement ok
CREATE TABLE lineitem AS
SELECT
    l_returnflag: range % 3,
    l_linestatus: (range + 1) % 2,
    l_quantity: CAST(1 + random() * 50 AS DECIMAL(15,2)),
    l_extendedprice: CAST(900 + random() * 100_000 AS DECIMAL(15, 2)),
    l_discount: CAST(random() * 0.1 AS DECIMAL(15, 2)),
    l_tax: CAST(random() * 0.08 AS DECIMAL(15, 2)),
    l_shipdate: '1993-05-30'::DATE + printf('%llu MONTHS', range)::INTERVAL
FROM range(100);

statement ok
PRAGMA explain_output = OPTIMIZED_ONLY;

# TPC-H Q1 - we rewrite all avg to sum divided by count(*)
query II
EXPLAIN SELECT
    l_returnflag,
    l_linestatus,
    sum(l_quantity) AS sum_qty,
    sum(l_extendedprice) AS sum_base_price,
    sum(l_extendedprice * (1 - l_discount)) AS sum_disc_price,
    sum(l_extendedprice * (1 - l_discount) * (1 + l_tax)) AS sum_charge,
    avg(l_quantity) AS avg_qty,
    avg(l_extendedprice) AS avg_price,
    avg(l_discount) AS avg_disc,
    count(*) AS count_order
FROM
    lineitem
WHERE
    l_shipdate <= CAST('1998-09-02' AS date)
GROUP BY
    l_returnflag,
    l_linestatus
ORDER BY
    l_returnflag,
    l_linestatus;
----
logical_opt	<!REGEX>:.*avg\([^)]*\).*
