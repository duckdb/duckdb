# name: test/extension/concurrent_load_extension.test
# description: Test concurrent load extension
# group: [extension]

statement skip_test_on_error
SELECT assert_true(platform NOT LIKE '%_mingw', 'requires a non-mingw platform') FROM pragma_platform()

require skip_reload

require allow_unsigned_extensions

concurrentloop i 0 20

statement ok
LOAD '{BUILD_DIRECTORY}/test/extension/loadable_extension_demo.duckdb_extension';

statement ok
FROM duckdb_extensions();

endloop
