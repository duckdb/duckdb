# name: test/drop_tests/rollback_drop_index.test
# description: DROP INDEX rolled back
# group: [drop_tests]

load {TEST_DIR}/test_drop_index_silent_removal_repro.db

statement ok
SET immediate_transaction_mode=true

statement ok
CREATE TABLE t1 (id INTEGER, val INTEGER)

statement ok
INSERT INTO t1 SELECT i, i * 10 FROM range(10) tbl(i)

statement ok
CREATE INDEX idx1 ON t1(id)

statement ok
CREATE TABLE t2 (id INTEGER)

statement ok
INSERT INTO t2 SELECT i FROM range(10) tbl(i)

query I
SELECT index_name FROM duckdb_indexes WHERE index_name = 'idx1'
----
idx1

query II
EXPLAIN ANALYZE SELECT id FROM t1 WHERE id = 5
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*

statement ok con1
BEGIN

statement ok con1
DROP INDEX idx1

statement ok con1
DELETE FROM t2 WHERE id < 5

statement ok
DROP TABLE t2

statement error con1
COMMIT
----
another transaction has dropped this table

query I
SELECT index_name FROM duckdb_indexes WHERE index_name = 'idx1'
----
idx1

query II
EXPLAIN ANALYZE SELECT id FROM t1 WHERE id = 5
----
analyzed_plan	<REGEX>:.*Type: Index Scan.*
