+// Pass-through dispatch for `CONNECT <quack_db>; <sql>` (and friends).
+// TODO: replace the eager materialization below with a QuackBufferedData-backed StreamQueryResult
+// so large remote results don't have to land fully in memory before the client can read them.
+// StatementType is INVALID because we don't know what the SQL is; the protocol could carry it
+// (extend PrepareResponseMessage with statement_type) if downstream consumers need finer info.
+// Returns the existing quack_query_by_name(catalog, sql) table function — already streams via
+// FetchRequest on result_uuid, supports projection pushdown, and tags chunks with BatchIndex.
+// Reusing it lets the CONNECT dispatcher feed bound SQL through the normal DuckDB pipeline
+// without writing a parallel implementation.
+optional_ptr<TableFunction> QuackCatalog::GetConnectFunction() {
+	static TableFunction connect_fn = QuackScanByNameFunction::GetFunction();
+	return &connect_fn;
+}
+
 shared_ptr<QuackClientConnection> QuackCatalog::GetClientConnection() {
 	return client_connection;
 }
