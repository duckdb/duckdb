+// CONNECT dispatch for `CONNECT <quack_db>; <sql>` (and friends). Returns the registered
+// name of quack_query_by_name(catalog, sql) — already streams via FetchRequest on result_uuid,
+// supports projection pushdown, and tags chunks with BatchIndex. The CONNECT chokepoint rewrites
+// routed SQL as `SELECT * FROM quack_query_by_name('<catalog>', '<sql>')` and looks the function
+// up in the catalog at bind time, so per-catalog state (server URI, client connection) is
+// reached via the catalog-name argument rather than baked into the function pointer.
+string QuackCatalog::GetConnectFunctionName(ClientContext &context) {
+	return "quack_query_by_name";
+}
+
 shared_ptr<QuackClientConnection> QuackCatalog::GetClientConnection() {
 	return client_connection;
 }
