From 708f8cd5cf3fef1019161faed9ece0390d742179 Mon Sep 17 00:00:00 2001
From: duckdb <x@x>
Date: Fri, 26 Jun 2026 11:34:19 +0200
Subject: [PATCH] 0008-setqualifiedname-getentry.patch

---
 src/hnsw/hnsw_index_macros.cpp  |  7 ++++---
 src/hnsw/hnsw_index_pragmas.cpp | 12 ++++++------
 2 files changed, 10 insertions(+), 9 deletions(-)

diff --git a/src/hnsw/hnsw_index_macros.cpp b/src/hnsw/hnsw_index_macros.cpp
index 5f76703..7bcb7bb 100644
--- a/src/hnsw/hnsw_index_macros.cpp
+++ b/src/hnsw/hnsw_index_macros.cpp
@@ -1,8 +1,8 @@
 #include "duckdb/function/table_macro_function.hpp"
 #include "duckdb/main/extension/extension_loader.hpp"
-#include "hnsw/hnsw.hpp"
-#include "duckdb/parser/parser.hpp"
 #include "duckdb/parser/parsed_data/create_macro_info.hpp"
+#include "duckdb/parser/parser.hpp"
+#include "hnsw/hnsw.hpp"
 
 namespace duckdb {
 
@@ -95,7 +95,8 @@ static void RegisterTableMacro(ExtensionLoader &loader, const string &name, cons
 	}
 
 	CreateMacroInfo info(CatalogType::TABLE_MACRO_ENTRY);
-	info.SchemaMutable() = Identifier::DefaultSchema();
+	info.SetQualifiedName(
+	    QualifiedName(info.GetQualifiedName().Catalog(), Identifier::DefaultSchema(), info.GetQualifiedName().Name()));
 	info.SetFunctionName(Identifier(name));
 	info.temporary = true;
 	info.internal = true;
diff --git a/src/hnsw/hnsw_index_pragmas.cpp b/src/hnsw/hnsw_index_pragmas.cpp
index eb6ca01..0354fab 100644
--- a/src/hnsw/hnsw_index_pragmas.cpp
+++ b/src/hnsw/hnsw_index_pragmas.cpp
@@ -30,7 +30,6 @@
 #include "duckdb/storage/table/table_index_list.hpp"
 #include "duckdb/transaction/duck_transaction.hpp"
 #include "duckdb/transaction/local_storage.hpp"
-
 #include "hnsw/hnsw.hpp"
 #include "hnsw/hnsw_index.hpp"
 #include "hnsw/hnsw_index_scan.hpp"
@@ -113,7 +112,8 @@ static void HNSWIndexInfoExecute(ClientContext &context, TableFunctionInput &dat
 	while (data.offset < data.entries.size() && row < STANDARD_VECTOR_SIZE) {
 		auto &index_entry = data.entries[data.offset++].get();
 		auto &table_entry = index_entry.schema.catalog.GetEntry<TableCatalogEntry>(
-		    context, index_entry.GetSchemaName(), index_entry.GetTableName());
+		    context, QualifiedName(index_entry.schema.catalog.GetName(), index_entry.GetSchemaName(),
+		                           index_entry.GetTableName()));
 		auto &storage = table_entry.GetStorage();
 		HNSWIndex *hnsw_index = nullptr;
 
@@ -189,11 +189,11 @@ static void CompactIndexPragma(ClientContext &context, const FunctionParameters
 
 	// look up the index name in the catalog
 	Binder::BindSchemaOrCatalog(context, qname.CatalogMutable(), qname.SchemaMutable());
-	auto &index_entry = Catalog::GetEntry(context, CatalogType::INDEX_ENTRY, qname.Catalog(), qname.Schema(), qname.Name())
-	                        .Cast<IndexCatalogEntry>();
+	auto &index_entry =
+	    Catalog::GetEntry(context, CatalogType::INDEX_ENTRY, qname.Catalog(), qname.Schema(), qname.Name())
+	        .Cast<IndexCatalogEntry>();
 	auto &table_entry = Catalog::GetEntry(context, CatalogType::TABLE_ENTRY, qname.Catalog(),
-	                                      index_entry.GetSchemaName(),
-	                                      index_entry.GetTableName())
+	                                      index_entry.GetSchemaName(), index_entry.GetTableName())
 	                        .Cast<TableCatalogEntry>();
 
 	auto &storage = table_entry.GetStorage();
-- 
