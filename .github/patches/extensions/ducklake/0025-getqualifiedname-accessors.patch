+			throw BinderException("Cannot use ALTER VIEW on entry %s - it is not a view", alter.GetQualifiedName().Name());
 		}
 		auto &view = view_entry->Cast<DuckLakeViewEntry>();
 		auto new_view = view.AlterEntry(context, alter);
@@ -229,7 +229,7 @@ void DuckLakeSchemaEntry::Alter(CatalogTransaction catalog_transaction, AlterInf
 			// We must check if this view name does not yet exist.
 			if (GetEntry(catalog_transaction, CatalogType::VIEW_ENTRY, new_view->name)) {
 				throw CatalogException(
-				    "Could not rename view \"%s\" to \"%s\": another entry with this name already exists!", alter.Name(),
+				    "Could not rename view \"%s\" to \"%s\": another entry with this name already exists!", alter.GetQualifiedName().Name(),
 				    new_view->name);
 			}
 		}
@@ -240,9 +240,9 @@ void DuckLakeSchemaEntry::Alter(CatalogTransaction catalog_transaction, AlterInf
 		auto &alter = info.Cast<SetCommentInfo>();
 		switch (alter.entry_catalog_type) {
