-			if (StringUtil::Lower(alter.Name().GetIdentifierName()) != StringUtil::Lower(new_table->name.GetIdentifierName()) && existing_table) {
-				throw BinderException("Cannot rename table %s to %s, since %s already exists.", alter.Name(),
+			if (StringUtil::Lower(alter.GetQualifiedName().Name().GetIdentifierName()) != StringUtil::Lower(new_table->name.GetIdentifierName()) && existing_table) {
+				throw BinderException("Cannot rename table %s to %s, since %s already exists.", alter.GetQualifiedName().Name(),
 				                      new_table->name, new_table->name);
