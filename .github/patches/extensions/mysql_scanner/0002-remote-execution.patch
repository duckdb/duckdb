diff --git a/test/sql/remote_pushdown/basic_remote_pushdown.test b/test/sql/remote_pushdown/basic_remote_pushdown.test
new file mode 100644
index 0000000..f198427
--- /dev/null
+++ b/test/sql/remote_pushdown/basic_remote_pushdown.test
@@ -0,0 +1,36 @@
+# name: test/sql/remote_pushdown/basic_remote_pushdown.test
+# description: Test basic remote pushdown into MySQL
+# group: [remote_pushdown]
+
+require mysql_scanner
+
+require-env MYSQL_TEST_DATABASE_AVAILABLE
+
+statement ok
+ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)
+
+# create a table
+statement ok
+CREATE OR REPLACE TABLE s.small_tbl AS FROM range(10) t(i)
+
+# basic aggregates are pushed down
+query I
+SELECT SUM(i) FROM s.small_tbl
+----
+45
+
+query II
+explain SELECT SUM(i) FROM s.small_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+# unsupported aggregates are executed DuckDB side
+query I
+SELECT median(i) FROM s.small_tbl
+----
+4.5
+
+query II
+explain SELECT MEDIAN(i) FROM s.small_tbl
+----
+physical_plan	<REGEX>:.*AGGREGATE.*
diff --git a/test/sql/remote_pushdown/remote_pushdown_case.test b/test/sql/remote_pushdown/remote_pushdown_case.test
new file mode 100644
index 0000000..c855a8a
--- /dev/null
+++ b/test/sql/remote_pushdown/remote_pushdown_case.test
@@ -0,0 +1,108 @@
+# name: test/sql/remote_pushdown/remote_pushdown_case.test
+# description: CASE expressions with type coercions that differ between DuckDB and MySQL
+# group: [remote_pushdown]
+
+require mysql_scanner
+
+require-env MYSQL_TEST_DATABASE_AVAILABLE
+
+statement ok
+ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)
+
+statement ok
+CREATE OR REPLACE TABLE s.case_tbl AS SELECT i FROM range(10) t(i)
+
+# ---- standard CASE: same semantics in MySQL -- should push ----
+query I
+SELECT SUM(CASE WHEN i < 5 THEN i ELSE 0 END) FROM s.case_tbl
+----
+10
+
+query II
+explain SELECT SUM(CASE WHEN i < 5 THEN i ELSE 0 END) FROM s.case_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+# CASE with NULL branch
+query I
+SELECT COUNT(*) FROM s.case_tbl WHERE (CASE WHEN i % 2 = 0 THEN i ELSE NULL END) IS NOT NULL
+----
+5
+
+# ---- CASE returning INTERVAL: MySQL cannot use INTERVAL as a result type ----
+# MySQL's INTERVAL keyword is only valid in date arithmetic (date + INTERVAL n DAY),
+# not as a standalone value -- if pushed, MySQL returns a syntax/type error
+query I
+SELECT CASE WHEN i = 0 THEN INTERVAL '1' DAY ELSE INTERVAL '2' DAY END
+FROM s.case_tbl WHERE i = 0
+----
+1 day
+
+query II
+explain SELECT SUM(i) FROM s.case_tbl
+    WHERE (CASE WHEN i < 5 THEN INTERVAL '1' DAY ELSE INTERVAL '2' DAY END) = INTERVAL '1' DAY
+----
+physical_plan	<REGEX>:.*AGGREGATE.*
+
+# ---- CASE with HUGEINT branch: MySQL has no HUGEINT type ----
+# 99999999999999999999 exceeds BIGINT range; DuckDB stores it as HUGEINT
+# if pushed, MySQL would receive this literal and either overflow or error
+
+query I
+SELECT CASE WHEN i = 0 THEN 99999999999999999999 ELSE i END FROM s.case_tbl WHERE i = 0
+----
+99999999999999999999
+
+query II
+explain SELECT SUM(CASE WHEN i = 0 THEN 99999999999999999999 ELSE i END) FROM s.case_tbl
+----
+physical_plan	<REGEX>:.*AGGREGATE.*
+
+# ---- CASE with LIST branch: list_value() is not in MySQL ----
+# list_value is not in the whitelist → should not push; DuckDB handles it locally
+query I
+SELECT CASE WHEN i = 0 THEN [1, 2, 3] ELSE [4, 5, 6] END FROM s.case_tbl WHERE i = 0
+----
+[1, 2, 3]
+
+query II
+explain SELECT COUNT(*) FROM s.case_tbl
+    WHERE list_sum(CASE WHEN i < 5 THEN [1, 2] ELSE [3, 4] END) > 3
+----
+physical_plan	<REGEX>:.*AGGREGATE.*
+
+# ---- CASE implicit integer/varchar coercion ----
+# both MySQL and DuckDB coerce i to VARCHAR when mixing int and string branches
+# result type is VARCHAR in both engines -- safe to push
+query I
+SELECT SUM(CASE WHEN i < 5 THEN 1 ELSE 0 END) FROM s.case_tbl
+----
+5
+
+query II
+explain SELECT SUM(CASE WHEN i < 5 THEN 1 ELSE 0 END) FROM s.case_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+# ---- case sensitivity: MySQL string equality is collation-dependent ----
+# MySQL default collation (utf8mb4_0900_ai_ci) is case-insensitive;
+# DuckDB string comparison is case-sensitive.
+# Pushing a query with string equality to MySQL can change the number of rows returned.
+
+statement ok
+CREATE OR REPLACE TABLE s.names_tbl AS
+    SELECT CASE i WHEN 0 THEN 'Alice' WHEN 1 THEN 'ALICE' ELSE 'alice' END AS name
+    FROM range(3) t(i)
+
+# MySQL's default collation (utf8mb4_0900_ai_ci) is case-insensitive and would match 3 rows;
+# the pushdown attaches an explicit binary collation to string literals, so the pushed
+# comparison is byte-wise like DuckDB and matches exactly 1 row
+query I
+SELECT COUNT(name) FROM s.names_tbl WHERE name = 'alice'
+----
+1
+
+query II
+explain SELECT COUNT(name) FROM s.names_tbl WHERE name = 'alice'
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
diff --git a/test/sql/remote_pushdown/remote_pushdown_cast.test b/test/sql/remote_pushdown/remote_pushdown_cast.test
new file mode 100644
index 0000000..b84c501
--- /dev/null
+++ b/test/sql/remote_pushdown/remote_pushdown_cast.test
@@ -0,0 +1,92 @@
+# name: test/sql/remote_pushdown/remote_pushdown_cast.test
+# description: Test basic remote pushdown of casts into MySQL
+# group: [remote_pushdown]
+
+require mysql_scanner
+
+require-env MYSQL_TEST_DATABASE_AVAILABLE
+
+statement ok
+ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)
+
+# create a table
+statement ok
+CREATE OR REPLACE TABLE s.small_tbl AS SELECT i::INTEGER i, concat(2000 + i, '-01-01') d FROM range(10) t(i)
+
+# we can pushdown in some situations
+query I
+SELECT MIN(CAST(d AS DATE)) FROM s.small_tbl
+----
+2000-01-01
+
+query II
+explain SELECT MIN(CAST(d AS DATE)) FROM s.small_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+# not many though!
+query I
+SELECT SUM(CAST(i AS BIGINT)) FROM s.small_tbl
+----
+45
+
+query I
+SELECT MIN(CAST(i AS VARCHAR)) FROM s.small_tbl
+----
+0
+
+# the serializer remaps cast types to their MySQL spellings:
+# BIGINT -> SIGNED, VARCHAR -> CHAR, DOUBLE -> DOUBLE, DECIMAL(w,s) -> DECIMAL(w,s)
+query II
+explain SELECT SUM(CAST(i AS BIGINT)) FROM s.small_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+query II
+explain SELECT MIN(CAST(i AS VARCHAR)) FROM s.small_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+query I
+SELECT SUM(CAST(i AS DOUBLE)) FROM s.small_tbl
+----
+45.0
+
+query II
+explain SELECT SUM(CAST(i AS DOUBLE)) FROM s.small_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+query I
+SELECT SUM(CAST(i AS DECIMAL(8,2))) FROM s.small_tbl
+----
+45.00
+
+query II
+explain SELECT SUM(CAST(i AS DECIMAL(8,2))) FROM s.small_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+# casting a string LITERAL to BLOB is constant-folded locally (DuckDB's backslash
+# interpretation is applied before serialization), so it can be pushed
+query I
+SELECT COUNT(CAST('ab' AS BLOB)) FROM s.small_tbl WHERE i = 0
+----
+1
+
+query II
+explain SELECT COUNT(CAST('ab' AS BLOB)) FROM s.small_tbl
+----
+physical_plan	<!REGEX>:.*AGGREGATE.*
+
+# casting a string COLUMN to BLOB cannot be folded and is not pushed -
+# DuckDB's VARCHAR -> BLOB cast interprets backslash escapes, MySQL's CAST AS BINARY does not
+query I
+SELECT COUNT(CAST(d AS BLOB)) FROM s.small_tbl
+----
+10
+
+query II
+explain SELECT COUNT(CAST(d AS BLOB)) FROM s.small_tbl
+----
+physical_plan	<REGEX>:.*AGGREGATE.*
diff --git a/test/sql/remote_pushdown/remote_pushdown_constant_folding.test b/test/sql/remote_pushdown/remote_pushdown_constant_folding.test
new file mode 100644
index 0000000..34655e7
--- /dev/null
+++ b/test/sql/remote_pushdown/remote_pushdown_constant_folding.test
@@ -0,0 +1,147 @@
+# name: test/sql/remote_pushdown/remote_pushdown_constant_folding.test
+# description: Column-free expressions are constant-folded locally before pushdown, so the
+#              remote system only sees DuckDB-evaluated literals
+# group: [remote_pushdown]
+
+require mysql_scanner
+
+require-env MYSQL_TEST_DATABASE_AVAILABLE
+
+statement ok
+ATTACH 'host=localhost user=root port=0 database=mysqlscanner' AS s (TYPE MYSQL_SCANNER)
+
+statement ok
+CREATE OR REPLACE TABLE s.cf_tbl AS
+    SELECT i, TIMESTAMP '2026-06-01 00:00:00' + i * INTERVAL 1 DAY AS ts FROM range(10) t(i)
+
+# ---- functions with diverging remote semantics are folded into their DuckDB result ----
+
+# sqrt() is normally vetoed (MySQL returns NULL on domain errors) - constant arguments fold
+query I
+SELECT COUNT(*) FROM s.cf_tbl WHERE i < sqrt(16)
+----
+4
+
+query II
+explain SELECT COUNT(*) FROM s.cf_tbl WHERE i < sqrt(16)
+----
+physical_plan	<!REGEX>:.*MYSQL_SCAN.*
+
+# division is normally vetoed (division by zero: inf vs NULL) - constant operands fold
+query I
+SELECT COUNT(*) FROM s.cf_tbl WHERE i > 8 / 2
+----
+5
+
+query II
+explain SELECT COUNT(*) FROM s.cf_tbl WHERE i > 8 / 2
+----
+physical_plan	<!REGEX>:.*MYSQL_SCAN.*
+
+# ---- time-window filters: now()/today() with interval arithmetic fold to plain literals ----
+query I
+SELECT COUNT(*) FROM s.cf_tbl WHERE ts > now()::TIMESTAMP - INTERVAL 100 YEAR
+----
+10
+
+query II
+explain SELECT COUNT(*) FROM s.cf_tbl WHERE ts > now()::TIMESTAMP - INTERVAL 100 YEAR
+----
+physical_plan	<!REGEX>:.*MYSQL_SCAN.*
+
+query II
+explain SELECT COUNT(*) FROM s.cf_tbl WHERE ts::DATE >= (now()::TIMESTAMP - INTERVAL 100 YEAR)::DATE
+----
+physical_plan	<!REGEX>:.*MYSQL_SCAN.*
+
+# now() itself returns TIMESTAMP WITH TIME ZONE, which cannot be represented in MySQL -
+# the folded constant is vetoed and the query stays local
+query II
+explain SELECT i, now() FROM s.cf_tbl
+----
+physical_plan	<REGEX>:.*MYSQL_SCAN.*
+
+# ---- volatile functions are not folded ----
+# random() must be evaluated per row; it is also vetoed from pushdown
+query I
+SELECT COUNT(*) FROM (SELECT random() AS r FROM s.cf_tbl) t WHERE r >= 0 AND r < 1
+----
+10
+
+query II
+explain SELECT random() FROM s.cf_tbl
+----
+physical_plan	<REGEX>:.*MYSQL_SCAN.*
+
+# ---- constant expressions that error during folding keep the query local, so the user
+# ---- sees DuckDB's error message instead of a remote error
+statement error
+SELECT 9223372036854775807 + 1 FROM s.cf_tbl
+----
+<REGEX>:Out of Range Error.*Overflow in addition.*
+
+statement error
+SELECT COUNT(*) FROM s.cf_tbl WHERE i < sqrt(4) + (9223372036854775807 + 1)
+----
+<REGEX>:Out of Range Error.*Overflow in addition.*
+
+# ---- positional contexts are not folded ----
+# GROUP BY 1 + 1 groups by the constant expression; folding it to 2 would turn it into a
+# positional reference to the (non-existent) second select-list item
+query I
+SELECT COUNT(*) FROM s.cf_tbl GROUP BY 1 + 1
+----
+10
+
+# ORDER BY 1 + 1 is a constant expression, not a positional reference
+query I
+SELECT COUNT(*) FROM (SELECT i FROM s.cf_tbl ORDER BY 1 + 1) t
+----
+10
+
+# ---- LIMIT / OFFSET expressions fold to literals and can be pushed ----
+query I
+SELECT COUNT(*) FROM (SELECT i FROM s.cf_tbl ORDER BY i LIMIT 2 + 3) t
+----
+5
+
+query II
+explain SELECT i FROM s.cf_tbl ORDER BY i LIMIT 2 + 3
+----
+physical_plan	<!REGEX>:.*MYSQL_SCAN.*
+
+# ---- aggregates over constants are not folded but remain correct ----
+# count(5) counts rows - the constant binder rejects it, the regular path pushes it
+query I
+SELECT COUNT(5) FROM s.cf_tbl
+----
+10
+
+query II
+explain SELECT COUNT(5) FROM s.cf_tbl
+----
+physical_plan	<!REGEX>:.*MYSQL_SCAN.*
+
+# ---- the folded value keeps DuckDB's semantics, not MySQL's ----
+# MySQL's CAST would truncate '7.6' to 7; DuckDB rounds to 8
+query I
+SELECT COUNT(*) FROM s.cf_tbl WHERE i > CAST('7.6' AS BIGINT) - 1 + 1
+----
+1
+
+# prepared statements containing folded now() are re-folded on every execution
+statement ok
+PREPARE cf_prep AS SELECT COUNT(*) FROM s.cf_tbl WHERE ts > now()::TIMESTAMP - INTERVAL 100 YEAR
+
+query I
+EXECUTE cf_prep
+----
+10
+
+query I
+EXECUTE cf_prep
+----
+10
+
+statement ok
+DEALLOCATE cf_prep
diff --git a/test/sql/remote_pushdown/remote_pushdown_constants.test b/test/sql/remote_pushdown/remote_pushdown_constants.test
