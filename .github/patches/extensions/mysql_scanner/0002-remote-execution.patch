+unique_ptr<TableRef> MySQLCatalog::RemoteExecute(ClientContext &context, unique_ptr<QueryNode> node) {
+	return RemoteExecute(context, node->ToString());
+}
+
+unique_ptr<TableRef> MySQLCatalog::RemoteExecute(ClientContext &context, const string &sql) {
+	vector<unique_ptr<ParsedExpression>> args;
+	args.push_back(make_uniq<ConstantExpression>(Value(GetName())));
+	args.push_back(make_uniq<ConstantExpression>(Value(sql)));
+	auto func_ref = make_uniq<TableFunctionRef>();
+	func_ref->function = make_uniq<FunctionExpression>("mysql_query", std::move(args));
+	return func_ref;
+}
+
+bool MySQLSupportsType(const LogicalType &type, bool for_cast) {
+	switch(type.id()) {
+	case LogicalTypeId::BOOLEAN: // not supported for cast
+	case LogicalTypeId::BIGINT: // not supported for cast
+		// FIXME: need to rewrite for CAST, but supported as literal
+	case LogicalTypeId::INTEGER: // SIGNED
+	case LogicalTypeId::VARCHAR: // CHAR
+	case LogicalTypeId::UINTEGER: // UNSIGNED
+	case LogicalTypeId::TIMESTAMP: // TIMESTAMP -> DATETIME
+		// mysql is extremely strict in types accepted in casts for some reason
+		return !for_cast;
+	case LogicalTypeId::DATE:
+	case LogicalTypeId::TIME:
+	case LogicalTypeId::DECIMAL:
+	case LogicalTypeId::FLOAT:
+	case LogicalTypeId::DOUBLE:
+		return true;
+	case LogicalTypeId::UNBOUND: {
+		auto try_bind = UnboundType::TryDefaultBind(type);
+		if (try_bind.id() == LogicalTypeId::UNBOUND) {
+			return false;
+		}
+		return MySQLSupportsType(try_bind, for_cast);
+	}
+	default:
+		return false;
+	}
+}
+
+bool MySQLSupportsFunction(const FunctionExpression &func) {
+	auto &function_name = func.FunctionName();
+
+	// Whitelist of functions with identical name and semantics in MySQL 8.0+ and DuckDB.
+	// Excluded:
+	//   "length"     — MySQL counts bytes, DuckDB counts characters (multibyte differs)
+	//   "log"        — DuckDB log(x) = log10; MySQL log(x) = ln(x)
+	//   "trunc"      — MySQL spells it truncate(x, d)
+	//   "truncate"   — DuckDB doesn't register this name (uses trunc)
+	//   "random"     — MySQL uses rand()
+	//   "translate"  — not available in MySQL
+	//   "format"     — different semantics (MySQL: number formatting; DuckDB: printf-style)
+	//   "ln"         — DuckDB name for natural log; MySQL spells it log(x)
+	//   "make_date"/"make_time"/"make_timestamp" — MySQL spells these makedate/maketime
+	static const case_insensitive_set_t MYSQL_SCALAR_FUNCTIONS = {
+	    // String
+	    "concat",     "concat_ws",        "char_length",   "character_length",
+	    "octet_length", "bit_length",     "substring",     "substr",
+	    "upper",      "ucase",            "lower",         "lcase",
+	    "trim",       "ltrim",            "rtrim",         "left",
+	    "right",      "repeat",           "replace",       "reverse",
+	    "lpad",       "rpad",             "instr",         "ascii",
+	    "hex",        "unhex",            "bin",           "md5",
+	    "sha1",       "regexp_replace",
+	    // Math
+	    "abs",        "ceil",             "ceiling",       "floor",
+	    "round",      "sqrt",             "pow",           "power",
+	    "exp",        "log10",            "log2",
+	    "sin",        "cos",              "tan",           "cot",
+	    "asin",       "acos",             "atan",          "atan2",
+	    "degrees",    "radians",          "pi",            "sign",
+	    "mod",        "greatest",         "least",
+		"+", "-", "*", "/",
+	    // Date / time
+	    "year",       "month",            "day",           "hour",
+	    "minute",     "second",           "microsecond",
+	    "dayofweek",  "dayofmonth",       "dayofyear",
+	    "weekday",    "weekofyear",       "week",          "quarter",
+	    "monthname",  "dayname",          "last_day",      "now",
+	    // Conditional / NULL handling
+	    "coalesce",   "nullif",           "ifnull",        "if",
+	    // Aggregate
+	    "count",      "sum",              "avg",           "min",
+	    "max",        "group_concat",
+	    "stddev",     "stddev_pop",       "stddev_samp",
+	    "variance",   "var_pop",          "var_samp",
+	    "bit_and",    "bit_or",           "bit_xor",
+	    "any_value",  "corr",             "covar_pop",     "covar_samp",
+	    // Window (MySQL 8.0+)
+	    "row_number", "rank",             "dense_rank",    "percent_rank",
+	    "cume_dist",  "ntile",
+	    "lag",        "lead",             "first_value",   "last_value",
+	    "nth_value",
+	};
+	return MYSQL_SCALAR_FUNCTIONS.count(function_name) > 0;
+}
+
+bool MySQLCatalog::SupportsPushdown(const ParsedExpression &expr) {
+	switch(expr.GetExpressionClass()) {
+	case ExpressionClass::CAST: {
+		auto &cast_expr = expr.Cast<CastExpression>();
+		if (!MySQLSupportsType(cast_expr.TargetType(), true)) {
+			return false;
+		}
+		// FIXME: try cast
+		return true;
+	}
+	case ExpressionClass::CONSTANT: {
+		auto &constant = expr.Cast<ConstantExpression>();
+		return MySQLSupportsType(constant.GetValue().type(), false);
+	}
+	case ExpressionClass::FUNCTION: {
+		auto &func = expr.Cast<FunctionExpression>();
+		return MySQLSupportsFunction(func);
+	}
+	default:
+		return true;
+	}
+}
+
+bool MySQLCatalog::SupportsPushdown(const TableRef &ref) {
+	switch(ref.type) {
+	case TableReferenceType::TABLE_FUNCTION:
+		// mysql doesn't support any table functions
+		return false;
+	default:
+		return true;
+	}
+}
