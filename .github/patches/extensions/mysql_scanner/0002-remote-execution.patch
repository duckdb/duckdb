+//! DuckDB defaults to NULLS LAST while MySQL always sorts NULLs first when ascending -
+//! we prepend an "expr IS NULL" sort key to replicate DuckDB's NULL placement.
+static void MySQLRewriteOrderEntries(ClientContext &context, vector<OrderByNode> &orders,
+                                     optional_ptr<const vector<unique_ptr<ParsedExpression>>> select_list) {
+	auto &config = DBConfig::GetConfig(context);
+	vector<OrderByNode> new_orders;
+	for (auto &order : orders) {
+		auto order_type = config.ResolveOrder(context, order.type);
+		auto null_order = config.ResolveNullOrder(context, order_type, order.null_order);
+		// figure out the expression whose NULL ordering we need to make explicit
+		unique_ptr<ParsedExpression> null_key_target;
+		if (order.expression->GetExpressionClass() == ExpressionClass::CONSTANT) {
+			auto &val = order.expression->Cast<ConstantExpression>().GetValue();
+			if (val.type().IsIntegral() && !val.IsNull() && select_list) {
+				// positional reference (e.g. ORDER BY 1) - resolve it against the select list
+				// SupportsPushdown verifies that this resolution is possible
+				Value bigint_value;
+				string error;
+				if (val.DefaultTryCastAs(LogicalType::BIGINT, bigint_value, &error) && !bigint_value.IsNull()) {
+					auto index = BigIntValue::Get(bigint_value);
+					if (index >= 1 && idx_t(index) <= select_list->size()) {
+						auto &target = *(*select_list)[idx_t(index) - 1];
+						if (!target.GetAlias().empty()) {
+							// reference the output column by its alias - expressions over output columns
+							// satisfy MySQL's ONLY_FULL_GROUP_BY checks where raw expression copies may not
+							null_key_target = make_uniq<ColumnRefExpression>(target.GetAlias());
+						} else {
+							null_key_target = target.Copy();
+						}
+					}
+				}
+			}
+			// other constants do not influence the ordering - no NULL ordering key required
+		} else {
+			null_key_target = order.expression->Copy();
+		}
+		if (null_key_target) {
+			auto is_null = make_uniq<OperatorExpression>(ExpressionType::OPERATOR_IS_NULL, std::move(null_key_target));
+			// NULLS LAST -> "expr IS NULL" ascending (false sorts before true)
+			// NULLS FIRST -> "expr IS NULL" descending
+			auto key_order = null_order == OrderByNullType::NULLS_FIRST ? OrderType::DESCENDING : OrderType::ASCENDING;
+			new_orders.emplace_back(key_order, OrderByNullType::ORDER_DEFAULT, std::move(is_null));
+		}
+		// make the ordering explicit and strip the NULL ordering (MySQL cannot parse NULLS FIRST/LAST)
+		new_orders.emplace_back(order_type, OrderByNullType::ORDER_DEFAULT, std::move(order.expression));
+	}
+	orders = std::move(new_orders);
+}
+
+static void MySQLNormalizeModifiers(ClientContext &context, QueryNode &node,
+                                    optional_ptr<const vector<unique_ptr<ParsedExpression>>> select_list) {
+	for (auto &modifier : node.modifiers) {
+		switch (modifier->type) {
+		case ResultModifierType::ORDER_MODIFIER: {
+			auto &order_mod = modifier->Cast<OrderModifier>();
+			MySQLRewriteOrderEntries(context, order_mod.orders, select_list);
+			for (auto &order : order_mod.orders) {
+				MySQLNormalizeExpression(context, *order.expression);
+			}
+			break;
+		}
+		case ResultModifierType::LIMIT_MODIFIER: {
+			auto &limit_mod = modifier->Cast<LimitModifier>();
+			if (limit_mod.limit) {
+				MySQLNormalizeExpression(context, *limit_mod.limit);
+			}
+			if (limit_mod.offset) {
+				MySQLNormalizeExpression(context, *limit_mod.offset);
+			}
+			break;
+		}
+		case ResultModifierType::DISTINCT_MODIFIER: {
+			auto &distinct_mod = modifier->Cast<DistinctModifier>();
+			for (auto &expr : distinct_mod.distinct_on_targets) {
+				MySQLNormalizeExpression(context, *expr);
+			}
+			break;
+		}
+		default:
+			break;
+		}
+	}
+}
+
+static void MySQLNormalizeExpression(ClientContext &context, ParsedExpression &expr) {
+	switch (expr.GetExpressionClass()) {
+	case ExpressionClass::FUNCTION: {
+		auto &func = expr.Cast<FunctionExpression>();
+		if (StringUtil::CIEquals(func.FunctionName(), "count_star") && func.GetChildren().empty()) {
+			// MySQL does not know count_star() - serialize it as count(*)
+			func.FunctionNameMutable() = "count";
+			func.GetChildrenMutable().push_back(make_uniq<StarExpression>());
+		}
+		break;
+	}
+	case ExpressionClass::WINDOW: {
+		auto &window = expr.Cast<WindowExpression>();
+		// COUNT(*) OVER (...) is parsed as a zero-argument count - serialize it as count(*)
+		if (window.GetChildren().empty() && (StringUtil::CIEquals(window.FunctionName(), "count_star") ||
+		                                     StringUtil::CIEquals(window.FunctionName(), "count"))) {
+			window.SetFunctionName("count");
+			window.GetChildrenMutable().push_back(make_uniq<StarExpression>());
+		}
+		// make the NULL ordering of the window ORDER BY explicit
+		MySQLRewriteOrderEntries(context, window.OrderByMutable(), nullptr);
+		break;
+	}
+	case ExpressionClass::SUBQUERY: {
+		auto &subquery = expr.Cast<SubqueryExpression>();
+		MySQLNormalizeQueryNode(context, *subquery.SubqueryMutable()->node);
+		break;
+	}
+	default:
+		break;
+	}
+	ParsedExpressionIterator::EnumerateChildren(
+	    expr, [&](ParsedExpression &child) { MySQLNormalizeExpression(context, child); });
+}
+
+static void MySQLNormalizeTableRef(ClientContext &context, TableRef &ref) {
+	switch (ref.type) {
+	case TableReferenceType::JOIN: {
+		auto &join = ref.Cast<JoinRef>();
+		MySQLNormalizeTableRef(context, *join.left);
+		MySQLNormalizeTableRef(context, *join.right);
+		if (join.condition) {
+			MySQLNormalizeExpression(context, *join.condition);
+		}
+		break;
+	}
+	case TableReferenceType::SUBQUERY: {
+		auto &subquery = ref.Cast<SubqueryRef>();
+		MySQLNormalizeQueryNode(context, *subquery.subquery->node);
+		break;
+	}
+	case TableReferenceType::EXPRESSION_LIST: {
+		auto &expr_list = ref.Cast<ExpressionListRef>();
+		for (auto &row : expr_list.values) {
+			for (auto &expr : row) {
+				MySQLNormalizeExpression(context, *expr);
+			}
+		}
+		break;
+	}
+	default:
+		break;
+	}
+}
+
+static void MySQLNormalizeQueryNode(ClientContext &context, QueryNode &node) {
+	for (auto &cte_pair : node.cte_map.map) {
+		auto &cte_info = *cte_pair.second;
+		if (cte_info.query_node) {
+			MySQLNormalizeQueryNode(context, *cte_info.query_node);
+		}
+		for (auto &key : cte_info.key_targets) {
+			MySQLNormalizeExpression(context, *key);
+		}
+	}
+	switch (node.type) {
+	case QueryNodeType::SELECT_NODE: {
+		auto &select = node.Cast<SelectNode>();
+		if (select.from_table) {
+			MySQLNormalizeTableRef(context, *select.from_table);
+		}
+		for (auto &expr : select.select_list) {
+			MySQLNormalizeExpression(context, *expr);
+		}
+		if (select.where_clause) {
+			MySQLNormalizeExpression(context, *select.where_clause);
+		}
+		for (auto &expr : select.groups.group_expressions) {
+			MySQLNormalizeExpression(context, *expr);
+		}
+		if (select.having) {
+			MySQLNormalizeExpression(context, *select.having);
+		}
+		if (select.qualify) {
+			MySQLNormalizeExpression(context, *select.qualify);
+		}
+		MySQLNormalizeModifiers(context, node, &select.select_list);
+		break;
+	}
+	case QueryNodeType::SET_OPERATION_NODE: {
+		auto &setop = node.Cast<SetOperationNode>();
+		for (auto &child : setop.children) {
+			MySQLNormalizeQueryNode(context, *child);
+		}
+		MySQLNormalizeModifiers(context, node, nullptr);
+		break;
+	}
+	case QueryNodeType::RECURSIVE_CTE_NODE: {
+		auto &cte = node.Cast<RecursiveCTENode>();
+		if (cte.left) {
+			MySQLNormalizeQueryNode(context, *cte.left);
+		}
+		if (cte.right) {
+			MySQLNormalizeQueryNode(context, *cte.right);
+		}
+		MySQLNormalizeModifiers(context, node, nullptr);
+		break;
+	}
+	case QueryNodeType::INSERT_QUERY_NODE: {
+		auto &insert = node.Cast<InsertQueryNode>();
+		if (insert.select_statement) {
+			MySQLNormalizeQueryNode(context, *insert.select_statement->node);
+		}
+		break;
+	}
+	case QueryNodeType::DELETE_QUERY_NODE: {
+		auto &del = node.Cast<DeleteQueryNode>();
+		if (del.table) {
+			MySQLNormalizeTableRef(context, *del.table);
+		}
+		if (del.condition) {
+			MySQLNormalizeExpression(context, *del.condition);
+		}
+		break;
+	}
+	case QueryNodeType::UPDATE_QUERY_NODE: {
+		auto &update = node.Cast<UpdateQueryNode>();
+		if (update.table) {
+			MySQLNormalizeTableRef(context, *update.table);
+		}
+		if (update.set_info) {
+			if (update.set_info->condition) {
+				MySQLNormalizeExpression(context, *update.set_info->condition);
+			}
+			for (auto &expr : update.set_info->expressions) {
+				MySQLNormalizeExpression(context, *expr);
+			}
+		}
+		break;
+	}
+	default:
+		break;
+	}
+}
+
+unique_ptr<TableRef> MySQLCatalog::RemoteExecute(ClientContext &context, unique_ptr<QueryNode> node) {
+	// rewrite constructs whose serialization MySQL cannot parse or would interpret differently
+	// (count_star(), implicit NULL ordering of ORDER BY)
+	MySQLNormalizeQueryNode(context, *node);
+	return RemoteExecute(context, node->ToString());
+}
+
+unique_ptr<TableRef> MySQLCatalog::RemoteExecute(ClientContext &context, const string &sql) {
+	vector<unique_ptr<ParsedExpression>> args;
+	args.push_back(make_uniq<ConstantExpression>(Value(GetName())));
+	args.push_back(make_uniq<ConstantExpression>(Value(sql)));
+	auto func_ref = make_uniq<TableFunctionRef>();
+	func_ref->function = make_uniq<FunctionExpression>("mysql_query", std::move(args));
+	return func_ref;
+}
+
+bool MySQLSupportsType(const LogicalType &type, bool for_cast) {
+	switch (type.id()) {
+	case LogicalTypeId::BOOLEAN:   // not supported for cast
+	case LogicalTypeId::BIGINT:    // not supported for cast
+	                               // FIXME: need to rewrite for CAST, but supported as literal
+	case LogicalTypeId::INTEGER:   // SIGNED
+	case LogicalTypeId::VARCHAR:   // CHAR
+	case LogicalTypeId::UINTEGER:  // UNSIGNED
+	case LogicalTypeId::TIMESTAMP: // TIMESTAMP -> DATETIME
+	case LogicalTypeId::SQLNULL:   // NULL literal
+		// mysql is extremely strict in types accepted in casts for some reason
+		return !for_cast;
+	case LogicalTypeId::DATE:
+	case LogicalTypeId::TIME:
+	case LogicalTypeId::DECIMAL:
+	case LogicalTypeId::FLOAT:
+	case LogicalTypeId::DOUBLE:
+		return true;
+	case LogicalTypeId::UNBOUND: {
+		auto try_bind = UnboundType::TryDefaultBind(type);
+		if (try_bind.id() == LogicalTypeId::UNBOUND) {
+			return false;
+		}
+		return MySQLSupportsType(try_bind, for_cast);
+	}
+	default:
+		return false;
+	}
+}
+
+bool MySQLSupportsFunction(const FunctionExpression &func) {
+	auto &function_name = func.FunctionName();
+
+	// Whitelist of functions with identical name and semantics in MySQL 8.0+ and DuckDB.
+	// Excluded (verified mismatches):
+	//   "length"      — MySQL counts bytes, DuckDB counts characters (multibyte differs)
+	//   "log"         — DuckDB log(x) = log10; MySQL log(x) = ln(x)
+	//   "trunc"       — MySQL spells it truncate(x, d)
+	//   "truncate"    — DuckDB doesn't register this name (uses trunc)
+	//   "random"      — MySQL uses rand()
+	//   "translate"   — not available in MySQL
+	//   "format"      — different semantics (MySQL: number formatting; DuckDB: printf-style)
+	//   "ln"          — DuckDB name for natural log; MySQL spells it log(x)
+	//   "make_date"/"make_time"/"make_timestamp" — MySQL spells these makedate/maketime
+	//   "concat"      — MySQL returns NULL if any argument is NULL, DuckDB skips NULLs
+	//   "/"           — DuckDB integer division yields DOUBLE; MySQL yields DECIMAL with 4 fractional digits
+	//   "substring"/"substr"/"left"/"right" — negative/zero offsets behave differently
+	//   "instr"       — MySQL matches case-insensitively under the default collation
+	//   "ascii"       — MySQL returns the first byte, DuckDB the first code point
+	//   "md5"/"sha1"  — removed in MySQL 9.0
+	//   "regexp_replace" — different regex dialect; MySQL replaces all matches, DuckDB only the first
+	//   "greatest"/"least" — MySQL returns NULL if any argument is NULL, DuckDB skips NULLs
+	//   "dayofweek"/"weekday"/"week" — different day/week numbering
+	//   "microsecond" — DuckDB includes the seconds component, MySQL does not
+	//   "now"         — DuckDB returns the transaction timestamp with time zone; MySQL the statement time
+	//   "stddev"/"variance" — sample variants in DuckDB, population variants in MySQL
+	//   "bit_and"/"bit_or"/"bit_xor" — MySQL operates on (and returns) unsigned 64-bit integers
+	//   "avg"         — MySQL returns DECIMAL with 4 fractional digits, DuckDB returns DOUBLE
+	//   "corr"/"covar_pop"/"covar_samp" — not available in MySQL
+	//   "if"/"lcase"/"ucase" — not available in DuckDB (pushing would mask a binder error)
+	static const case_insensitive_set_t MYSQL_SCALAR_FUNCTIONS = {
+	    // String
+	    "concat_ws",
+	    "char_length",
+	    "character_length",
+	    "bit_length",
+	    "upper",
+	    "lower",
+	    "trim",
+	    "ltrim",
+	    "rtrim",
+	    "repeat",
+	    "replace",
+	    "reverse",
+	    "lpad",
+	    "rpad",
+	    "hex",
+	    "unhex",
+	    "bin",
+	    // Math
+	    "abs",
+	    "ceil",
+	    "ceiling",
+	    "floor",
+	    "round",
+	    "sqrt",
+	    "pow",
+	    "power",
+	    "exp",
+	    "log10",
+	    "log2",
+	    "sin",
+	    "cos",
+	    "tan",
+	    "cot",
+	    "asin",
+	    "acos",
+	    "atan",
+	    "atan2",
+	    "degrees",
+	    "radians",
+	    "pi",
+	    "sign",
+	    "mod",
+	    "+",
+	    "-",
+	    "*",
+	    "%",
+	    // Date / time
+	    "year",
+	    "month",
+	    "day",
+	    "hour",
+	    "minute",
+	    "second",
+	    "dayofmonth",
+	    "dayofyear",
+	    "weekofyear",
+	    "quarter",
+	    "monthname",
+	    "dayname",
+	    "last_day",
+	    // Conditional / NULL handling
+	    "coalesce",
+	    "nullif",
+	    "ifnull",
+	    // Aggregate
+	    "count",
+	    "count_star",
+	    "sum",
+	    "min",
+	    "max",
+	    "group_concat",
+	    "stddev_pop",
+	    "stddev_samp",
+	    "var_pop",
+	    "var_samp",
+	    "any_value",
+	};
+	return MYSQL_SCALAR_FUNCTIONS.count(function_name) > 0;
+}
+
+//! Collect the binding names of all tables within a join tree - MySQL requires unique
+//! table names/aliases within a join, while DuckDB can disambiguate duplicates
+static void MySQLCollectJoinTableNames(const TableRef &ref, case_insensitive_set_t &names, bool &duplicate) {
+	switch (ref.type) {
+	case TableReferenceType::JOIN: {
+		auto &join = ref.Cast<JoinRef>();
+		MySQLCollectJoinTableNames(*join.left, names, duplicate);
+		MySQLCollectJoinTableNames(*join.right, names, duplicate);
+		break;
+	}
+	case TableReferenceType::BASE_TABLE: {
+		auto &base = ref.Cast<BaseTableRef>();
+		const auto &name = base.alias.empty() ? base.table_name : base.alias;
+		if (!names.insert(name).second) {
+			duplicate = true;
+		}
+		break;
+	}
+	case TableReferenceType::SUBQUERY: {
+		if (!ref.alias.empty() && !names.insert(ref.alias).second) {
+			duplicate = true;
+		}
+		break;
+	}
+	default:
+		break;
+	}
+}
+
+//! Operand check for comparisons: MySQL string comparisons are collation-dependent
+//! (case-insensitive, by default) while DuckDB compares bytes - block comparisons
+//! against string literals.
+static bool MySQLComparisonOperandIsString(const ParsedExpression &expr) {
+	if (expr.GetExpressionClass() != ExpressionClass::CONSTANT) {
+		return false;
+	}
+	auto &constant = expr.Cast<ConstantExpression>();
+	return constant.GetValue().type().id() == LogicalTypeId::VARCHAR;
+}
+
+//! Check whether a list of ORDER BY entries can be rewritten for MySQL (see MySQLRewriteOrderEntries)
+static bool MySQLSupportsOrderEntries(const vector<OrderByNode> &orders,
+                                      optional_ptr<const vector<unique_ptr<ParsedExpression>>> select_list) {
+	for (auto &order : orders) {
+		if (order.null_order != OrderByNullType::ORDER_DEFAULT) {
+			// MySQL cannot parse NULLS FIRST / NULLS LAST
+			return false;
+		}
+		auto &expr = *order.expression;
+		if (expr.GetExpressionClass() == ExpressionClass::STAR) {
+			// ORDER BY ALL is DuckDB-specific
+			return false;
+		}
+		if (expr.GetExpressionClass() == ExpressionClass::CONSTANT) {
+			auto &val = expr.Cast<ConstantExpression>().GetValue();
+			if (val.type().IsIntegral()) {
+				// positional reference - it must be resolvable against the select list so that
+				// the NULL ordering can be made explicit when serializing
+				if (!select_list || val.IsNull()) {
+					return false;
+				}
+				Value bigint_value;
+				string error;
+				if (!val.DefaultTryCastAs(LogicalType::BIGINT, bigint_value, &error) || bigint_value.IsNull()) {
+					return false;
+				}
+				auto index = BigIntValue::Get(bigint_value);
+				if (index < 1 || idx_t(index) > select_list->size()) {
+					return false;
+				}
+				auto &target = *(*select_list)[idx_t(index) - 1];
+				if (target.GetAlias().empty() && target.GetExpressionClass() != ExpressionClass::COLUMN_REF) {
+					// without an alias we would have to copy the expression into the NULL ordering key,
+					// which can violate MySQL's ONLY_FULL_GROUP_BY checks for positional GROUP BY
+					return false;
+				}
+			}
+		}
+	}
+	return true;
+}
+
+static bool MySQLIsIntegerLiteral(const ParsedExpression &expr) {
+	if (expr.GetExpressionClass() != ExpressionClass::CONSTANT) {
+		return false;
+	}
+	auto &val = expr.Cast<ConstantExpression>().GetValue();
+	return val.type().IsIntegral() && !val.IsNull();
+}
+
+static bool MySQLSupportsResultModifiers(const QueryNode &node,
+                                         optional_ptr<const vector<unique_ptr<ParsedExpression>>> select_list) {
+	for (auto &modifier : node.modifiers) {
+		switch (modifier->type) {
+		case ResultModifierType::ORDER_MODIFIER: {
+			auto &order_mod = modifier->Cast<OrderModifier>();
+			if (!MySQLSupportsOrderEntries(order_mod.orders, select_list)) {
+				return false;
+			}
+			break;
+		}
+		case ResultModifierType::LIMIT_MODIFIER: {
+			auto &limit_mod = modifier->Cast<LimitModifier>();
+			if (limit_mod.limit_type != LimitValueType::ROW_COUNT) {
+				// MySQL has no LIMIT n PERCENT
+				return false;
+			}
+			if (limit_mod.offset && !limit_mod.limit) {
+				// MySQL cannot parse OFFSET without LIMIT
+				return false;
+			}
+			// MySQL only supports integer literals in LIMIT / OFFSET
+			if (limit_mod.limit && !MySQLIsIntegerLiteral(*limit_mod.limit)) {
+				return false;
+			}
+			if (limit_mod.offset && !MySQLIsIntegerLiteral(*limit_mod.offset)) {
+				return false;
+			}
+			break;
+		}
+		case ResultModifierType::DISTINCT_MODIFIER: {
+			auto &distinct_mod = modifier->Cast<DistinctModifier>();
+			if (!distinct_mod.distinct_on_targets.empty()) {
+				// MySQL has no DISTINCT ON
+				return false;
+			}
+			break;
+		}
+		default:
+			// unknown result modifier
+			return false;
+		}
+	}
+	return true;
+}
+
+static bool MySQLSupportsCTEMap(const CommonTableExpressionMap &cte_map) {
+	for (auto &cte_pair : cte_map.map) {
+		auto &cte_info = *cte_pair.second;
+		if (cte_info.materialized != CTEMaterialize::CTE_MATERIALIZE_DEFAULT) {
+			// AS [NOT] MATERIALIZED is not supported in MySQL
+			return false;
+		}
+		if (!cte_info.key_targets.empty()) {
+			// USING KEY is DuckDB-specific
+			return false;
+		}
+	}
+	return true;
+}
+
+static bool MySQLSupportsWindow(const WindowExpression &window) {
+	if (window.IgnoreNulls()) {
+		// MySQL has no IGNORE NULLS
+		return false;
+	}
+	if (window.Filter()) {
+		// MySQL has no FILTER on window functions
+		return false;
+	}
+	if (window.Distinct()) {
+		// MySQL window functions do not support DISTINCT
+		return false;
+	}
+	if (!window.ArgOrders().empty()) {
+		// ORDER BY within the argument list is DuckDB-specific
+		return false;
+	}
+	if (window.WindowExclude() != WindowExcludeMode::NO_OTHER) {
+		// MySQL has no EXCLUDE clause
+		return false;
+	}
+	for (auto boundary : {window.WindowStart(), window.WindowEnd()}) {
+		switch (boundary) {
+		case WindowBoundary::CURRENT_ROW_GROUPS:
+		case WindowBoundary::EXPR_PRECEDING_GROUPS:
+		case WindowBoundary::EXPR_FOLLOWING_GROUPS:
+			// MySQL has no GROUPS frame mode
+			return false;
+		case WindowBoundary::EXPR_PRECEDING_RANGE:
+		case WindowBoundary::EXPR_FOLLOWING_RANGE:
+			// RANGE frames with an offset require a single numeric ORDER BY key in MySQL,
+			// which conflicts with making the NULL ordering explicit
+			return false;
+		default:
+			break;
+		}
+	}
+	// frame offsets must be literals in MySQL
+	if (window.StartExpr() && window.StartExpr()->GetExpressionClass() != ExpressionClass::CONSTANT) {
+		return false;
+	}
+	if (window.EndExpr() && window.EndExpr()->GetExpressionClass() != ExpressionClass::CONSTANT) {
+		return false;
+	}
+	// the NULL ordering of the window ORDER BY must be made explicit when serializing
+	if (!MySQLSupportsOrderEntries(window.OrderBy(), nullptr)) {
+		return false;
+	}
+	// whitelist of window functions supported by MySQL 8.0+ with identical semantics
+	// (count_star is rewritten to count(*) during serialization)
+	static const case_insensitive_set_t MYSQL_WINDOW_FUNCTIONS = {
+	    "row_number", "rank",        "dense_rank", "percent_rank", "cume_dist", "ntile",      "lead",
+	    "lag",        "first_value", "last_value", "nth_value",    "count",     "count_star", "sum",
+	    "min",        "max",         "stddev_pop", "stddev_samp",  "var_pop",   "var_samp",
+	};
+	return MYSQL_WINDOW_FUNCTIONS.count(window.FunctionName()) > 0;
+}
+
+bool MySQLCatalog::SupportsPushdown(const ParsedExpression &expr) {
+	switch (expr.GetExpressionClass()) {
+	case ExpressionClass::CAST: {
+		auto &cast_expr = expr.Cast<CastExpression>();
+		if (cast_expr.IsTryCast()) {
+			// MySQL has no TRY_CAST
+			return false;
+		}
+		return MySQLSupportsType(cast_expr.TargetType(), true);
+	}
+	case ExpressionClass::CONSTANT: {
+		auto &constant = expr.Cast<ConstantExpression>();
+		auto &value = constant.GetValue();
+		if (!MySQLSupportsType(value.type(), false)) {
+			return false;
+		}
+		if (!value.IsNull()) {
+			// MySQL has no infinity / NaN
+			if (value.type().id() == LogicalTypeId::FLOAT && !Value::FloatIsFinite(FloatValue::Get(value))) {
+				return false;
+			}
+			if (value.type().id() == LogicalTypeId::DOUBLE && !Value::DoubleIsFinite(DoubleValue::Get(value))) {
+				return false;
+			}
+		}
+		return true;
+	}
+	case ExpressionClass::FUNCTION: {
+		auto &func = expr.Cast<FunctionExpression>();
+		if (func.Filter()) {
+			// FILTER (WHERE ...) on aggregates is not supported in MySQL
+			return false;
+		}
+		if (func.OrderBy() && !func.OrderBy()->orders.empty()) {
+			// ORDER BY within an aggregate requires function-specific syntax in MySQL
+			return false;
+		}
+		if (func.ExportState()) {
+			return false;
+		}
+		if (func.Distinct()) {
+			// DISTINCT within aggregates is only supported for a small set of functions in MySQL
+			static const case_insensitive_set_t MYSQL_DISTINCT_AGGREGATES = {"count", "sum", "min",
+			                                                                 "max",   "avg", "group_concat"};
+			if (MYSQL_DISTINCT_AGGREGATES.count(func.FunctionName()) == 0) {
+				return false;
+			}
+		}
+		if (StringUtil::CIEquals(func.FunctionName(), "group_concat") && func.GetChildren().size() > 1) {
+			// DuckDB's group_concat(x, sep) separator argument translates to GROUP_CONCAT(x SEPARATOR sep)
+			// in MySQL - the serialized form would concatenate columns instead
+			return false;
+		}
+		if (func.GetChildren().size() > 1 &&
+		    (StringUtil::CIEquals(func.FunctionName(), "trim") || StringUtil::CIEquals(func.FunctionName(), "ltrim") ||
+		     StringUtil::CIEquals(func.FunctionName(), "rtrim"))) {
+			// the two-argument variants of trim/ltrim/rtrim are not supported in MySQL
+			return false;
+		}
+		return MySQLSupportsFunction(func);
+	}
+	case ExpressionClass::WINDOW: {
+		auto &window = expr.Cast<WindowExpression>();
+		return MySQLSupportsWindow(window);
+	}
+	case ExpressionClass::COMPARISON: {
+		auto &comparison = expr.Cast<ComparisonExpression>();
+		switch (expr.GetExpressionType()) {
+		case ExpressionType::COMPARE_EQUAL:
+		case ExpressionType::COMPARE_NOTEQUAL:
+		case ExpressionType::COMPARE_LESSTHAN:
+		case ExpressionType::COMPARE_GREATERTHAN:
+		case ExpressionType::COMPARE_LESSTHANOREQUALTO:
+		case ExpressionType::COMPARE_GREATERTHANOREQUALTO:
+			break;
+		default:
+			// IS [NOT] DISTINCT FROM and other comparisons have different syntax in MySQL
+			return false;
+		}
+		return !MySQLComparisonOperandIsString(comparison.Left()) &&
+		       !MySQLComparisonOperandIsString(comparison.Right());
+	}
+	case ExpressionClass::BETWEEN: {
+		auto &between = expr.Cast<BetweenExpression>();
+		return !MySQLComparisonOperandIsString(between.Input()) &&
+		       !MySQLComparisonOperandIsString(between.LowerBound()) &&
+		       !MySQLComparisonOperandIsString(between.UpperBound());
+	}
+	case ExpressionClass::OPERATOR: {
+		switch (expr.GetExpressionType()) {
+		case ExpressionType::OPERATOR_IS_NULL:
+		case ExpressionType::OPERATOR_IS_NOT_NULL:
+		case ExpressionType::OPERATOR_NOT:
+		case ExpressionType::OPERATOR_COALESCE:
+		case ExpressionType::OPERATOR_NULLIF:
+			return true;
+		case ExpressionType::COMPARE_IN:
+		case ExpressionType::COMPARE_NOT_IN: {
+			auto &op = expr.Cast<OperatorExpression>();
+			for (auto &child : op.GetChildren()) {
+				if (MySQLComparisonOperandIsString(*child)) {
+					return false;
+				}
+			}
+			return true;
+		}
+		default:
+			// TRY(...), array indexing and other operators are DuckDB-specific
+			return false;
+		}
+	}
+	case ExpressionClass::SUBQUERY: {
+		auto &subquery = expr.Cast<SubqueryExpression>();
+		if (subquery.GetChild() && MySQLComparisonOperandIsString(*subquery.GetChild())) {
+			// e.g. 'literal' = ANY(...) - MySQL string comparisons are collation-dependent
+			return false;
+		}
+		switch (subquery.GetComparisonType()) {
+		case ExpressionType::INVALID: // EXISTS / scalar subqueries
+		case ExpressionType::COMPARE_EQUAL:
+		case ExpressionType::COMPARE_NOTEQUAL:
+		case ExpressionType::COMPARE_LESSTHAN:
+		case ExpressionType::COMPARE_GREATERTHAN:
+		case ExpressionType::COMPARE_LESSTHANOREQUALTO:
+		case ExpressionType::COMPARE_GREATERTHANOREQUALTO:
+			return true;
+		default:
+			return false;
+		}
+	}
+	case ExpressionClass::STAR: {
+		auto &star = expr.Cast<StarExpression>();
+		if (!star.ExcludeList().empty() || !star.ReplaceList().empty() || !star.RenameList().empty()) {
+			// EXCLUDE / REPLACE / RENAME are DuckDB-specific
+			return false;
+		}
+		if (star.Expression() || star.IsColumns()) {
+			// COLUMNS(...) expressions are DuckDB-specific
+			return false;
+		}
+		return true;
+	}
+	case ExpressionClass::CASE:
+	case ExpressionClass::CONJUNCTION:
+	case ExpressionClass::COLUMN_REF:
+	case ExpressionClass::TYPE:
+		return true;
+	default:
+		// parameters, COLLATE, lambdas, positional references, ... - not supported
+		return false;
+	}
+}
+
+bool MySQLCatalog::SupportsPushdown(const QueryNode &node) {
+	if (!MySQLSupportsCTEMap(node.cte_map)) {
+		return false;
+	}
+	switch (node.type) {
+	case QueryNodeType::SELECT_NODE: {
+		auto &select = node.Cast<SelectNode>();
+		if (select.qualify) {
+			// MySQL cannot execute QUALIFY
+			return false;
+		}
+		if (select.aggregate_handling == AggregateHandling::FORCE_AGGREGATES) {
+			// GROUP BY ALL is DuckDB-specific and would be serialized verbatim
+			return false;
+		}
+		if (select.groups.grouping_sets.size() > 1) {
+			// ROLLUP / CUBE / GROUPING SETS are serialized as GROUP BY GROUPING SETS,
+			// which MySQL only supports with a secondary engine (HeatWave)
+			return false;
+		}
+		if (select.sample) {
+			// MySQL has no USING SAMPLE
+			return false;
+		}
+		return MySQLSupportsResultModifiers(node, &select.select_list);
+	}
+	case QueryNodeType::SET_OPERATION_NODE: {
+		auto &setop = node.Cast<SetOperationNode>();
+		if (setop.setop_type == SetOperationType::UNION_BY_NAME) {
+			// UNION BY NAME is DuckDB-specific
+			return false;
+		}
+		// there is no select list to resolve positional ORDER BY references against
+		return MySQLSupportsResultModifiers(node, nullptr);
+	}
+	case QueryNodeType::RECURSIVE_CTE_NODE: {
+		auto &cte = node.Cast<RecursiveCTENode>();
+		if (!cte.key_targets.empty()) {
+			// USING KEY is DuckDB-specific
+			return false;
+		}
+		return MySQLSupportsResultModifiers(node, nullptr);
+	}
+	case QueryNodeType::INSERT_QUERY_NODE:
+	case QueryNodeType::DELETE_QUERY_NODE:
+	case QueryNodeType::UPDATE_QUERY_NODE:
+		// DML cannot be executed through mysql_query - these statements are handled by the
+		// regular catalog insert/update/delete paths instead (the SELECT part of an INSERT
+		// can still be pushed down separately)
+		return false;
+	default:
+		// unknown query node type
+		return false;
+	}
+}
+
+bool MySQLCatalog::SupportsPushdown(const TableRef &ref) {
+	if (ref.sample) {
+		// MySQL has no TABLESAMPLE
+		return false;
+	}
+	switch (ref.type) {
+	case TableReferenceType::BASE_TABLE: {
+		auto &base = ref.Cast<BaseTableRef>();
+		if (base.at_clause) {
+			// AT (...) time travel clauses are DuckDB-specific
+			return false;
+		}
+		return true;
+	}
+	case TableReferenceType::JOIN: {
+		auto &join = ref.Cast<JoinRef>();
+		switch (join.ref_type) {
+		case JoinRefType::REGULAR:
+		case JoinRefType::NATURAL:
+		case JoinRefType::CROSS:
+			break;
+		default:
+			// ASOF / POSITIONAL joins are DuckDB-specific
+			return false;
+		}
+		switch (join.type) {
+		case JoinType::INNER:
+		case JoinType::LEFT:
+		case JoinType::RIGHT:
+			break;
+		default:
+			// SEMI / ANTI / FULL OUTER joins are not supported in MySQL - worse, MySQL parses
+			// "x SEMI JOIN y" as "x AS semi JOIN y" and silently computes an inner join instead
+			return false;
+		}
+		// MySQL requires unique table names/aliases within a join (e.g. a self-join without
+		// aliases fails with "Not unique table/alias")
+		case_insensitive_set_t join_table_names;
+		bool duplicate_table_name = false;
+		MySQLCollectJoinTableNames(join, join_table_names, duplicate_table_name);
+		if (duplicate_table_name) {
+			return false;
+		}
+		return true;
+	}
+	case TableReferenceType::SUBQUERY:
+	case TableReferenceType::EMPTY_FROM:
+		return true;
+	case TableReferenceType::TABLE_FUNCTION:
+		// mysql doesn't support any table functions
+		return false;
+	case TableReferenceType::EXPRESSION_LIST:
+		// VALUES lists are serialized without the ROW(...) keyword MySQL requires in a FROM clause
+		return false;
+	default:
+		// pivot references, column data references, ... - not supported
+		return false;
+	}
+}
