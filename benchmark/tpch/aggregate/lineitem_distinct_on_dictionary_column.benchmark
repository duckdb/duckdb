# name: benchmark/tpch/aggregate/lineitem_distinct_on_dictionary_column.benchmark
# description: DISTINCT ON over Lineitem
# group: [aggregate]

include benchmark/tpch/tpch_load.benchmark.in

name Lineitem Distinct On (Dictionary Compressed Column)
group aggregate
subgroup tpch

run
SELECT DISTINCT l_shipinstruct FROM lineitem ORDER BY l_shipinstruct;

result I sf=1
COLLECT COD
DELIVER IN PERSON
NONE
TAKE BACK RETURN
