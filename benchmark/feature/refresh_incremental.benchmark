# name: benchmark/feature/refresh_incremental.benchmark
# description: Time an INCREMENTAL feature refresh (watermark + window tail recompute)
# group: [feature]

template benchmark/feature/feature.benchmark.in
BENCH_NAME=FeatureRefreshIncremental
RUN_QUERY=REFRESH FEATURE user_activity_incr AT '2016-01-01 00:00:00';
