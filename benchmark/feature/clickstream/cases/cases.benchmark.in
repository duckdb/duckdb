# Parameterized multi-step "case" benchmark template for the clickstream feature-store workload.
# Concrete .benchmark files (generated by scripts/generate_feature_benchmarks.py) provide
# BENCH_NAME, PARQUET_COUNT, SETUP_SQL and RUN_QUERY via a `template` block.
# Unlike serve/refresh, RUN_QUERY here is a MULTI-statement sequence (e.g. interleaved REFRESH +
# SERVE) on a single line, timed as one unit.
# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [feature]

require parquet load_only

require httpfs load_only

# Source data cached per scale (see serve.benchmark.in for the caching / init-vs-load rationale).
cache feature_src_${PARQUET_COUNT}.db

load
CREATE TABLE hits_raw AS SELECT CAST(UserID AS BIGINT) AS UserID, epoch_ms(EventTime * 1000) AS EventTime, CAST(RegionID AS INTEGER) AS RegionID, CAST(CounterID AS INTEGER) AS CounterID FROM read_parquet([format('https://datasets.clickhouse.com/hits_compatible/athena_partitioned/hits_{}.parquet', x) for x in range(0, ${PARQUET_COUNT})], binary_as_string = True);
CREATE TABLE users (UserID BIGINT PRIMARY KEY);
INSERT INTO users SELECT DISTINCT UserID FROM hits_raw;
CREATE TABLE hits (UserID BIGINT, EventTime TIMESTAMP, RegionID INTEGER, CounterID INTEGER, FOREIGN KEY (UserID) REFERENCES users(UserID));
INSERT INTO hits SELECT UserID, EventTime, RegionID, CounterID FROM hits_raw;
DROP TABLE hits_raw;
${SETUP_SQL}

reload
${SETUP_SQL}

name ${BENCH_NAME}
group feature

# The timed run mutates state (REFRESH appends versions), so re-initialise before every hot run:
# reload rebuilds a clean feature setup from the cached source, keeping timings independent.
require_reinit

# Features are created (version 0) in SETUP_SQL; the timed run performs the refreshes, so the
# assert only checks that the source is populated.
assert I
SELECT COUNT(*) > 0 FROM hits;
----
true

run
${RUN_QUERY}
