# name: benchmark/feature/clickstream/cases/case_gc_pressure_refresh_s100.benchmark
# description: 8 refreshes with RETAIN 2 -- every refresh past v2 triggers in-place eviction (GC pressure) (seed=42)
# group: [cases]

template benchmark/feature/clickstream/cases/cases.benchmark.in
BENCH_NAME=Case_gc_pressure_refresh_s100
PARQUET_COUNT=100
SETUP_SQL=DROP FEATURE IF EXISTS f; DROP FEATURE IF EXISTS f2; DROP FEATURE IF EXISTS f3; CREATE FEATURE f ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 2 AS (SELECT UserID, COUNT(*) AS event_count FROM hits GROUP BY UserID);
RUN_QUERY=REFRESH FEATURE f AT '2015-06-05 00:00:00'; REFRESH FEATURE f AT '2015-07-05 00:00:00'; REFRESH FEATURE f AT '2015-08-04 00:00:00'; REFRESH FEATURE f AT '2015-09-03 00:00:00'; REFRESH FEATURE f AT '2015-10-03 00:00:00'; REFRESH FEATURE f AT '2015-11-02 00:00:00'; REFRESH FEATURE f AT '2015-12-02 00:00:00'; REFRESH FEATURE f AT '2016-01-01 00:00:00';
