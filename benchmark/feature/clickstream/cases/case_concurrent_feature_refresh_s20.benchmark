# name: benchmark/feature/clickstream/cases/case_concurrent_feature_refresh_s20.benchmark
# description: Refresh three features sharing the same entity key in one timed unit (seed=42)
# group: [cases]

template benchmark/feature/clickstream/cases/cases.benchmark.in
BENCH_NAME=Case_concurrent_feature_refresh_s20
PARQUET_COUNT=20
SETUP_SQL=DROP FEATURE IF EXISTS f; DROP FEATURE IF EXISTS f2; DROP FEATURE IF EXISTS f3; CREATE FEATURE f ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count FROM hits GROUP BY UserID); CREATE FEATURE f2 ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count_2, AVG(RegionID) AS avg_region_2 FROM hits GROUP BY UserID); CREATE FEATURE f3 ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count_3 FROM hits GROUP BY UserID);
RUN_QUERY=REFRESH FEATURE f AT '2016-01-01 00:00:00'; REFRESH FEATURE f2 AT '2016-01-01 00:00:00'; REFRESH FEATURE f3 AT '2016-01-01 00:00:00';
