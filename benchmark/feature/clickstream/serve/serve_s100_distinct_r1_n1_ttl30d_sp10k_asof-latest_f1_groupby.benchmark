# name: benchmark/feature/clickstream/serve/serve_s100_distinct_r1_n1_ttl30d_sp10k_asof-latest_f1_groupby.benchmark
# description: Generated SERVE scenario s100_distinct_r1_n1_ttl30d_sp10k_asof-latest_f1_groupby (seed=42)
# group: [feature]

template benchmark/feature/clickstream/serve/serve.benchmark.in
BENCH_NAME=Serve_s100_distinct_r1_n1_ttl30d_sp10k_asof-latest_f1_groupby
PARQUET_COUNT=100
SETUP_SQL=DROP FEATURE IF EXISTS f; DROP FEATURE IF EXISTS f2; DROP FEATURE IF EXISTS f3; CREATE FEATURE f ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS TTL 30 DAYS RETAIN 1 AS (SELECT UserID, COUNT(DISTINCT RegionID) AS distinct_regions, COUNT(*) AS event_count FROM hits GROUP BY UserID); CREATE OR REPLACE TABLE serve_requests AS SELECT DISTINCT UserID, TIMESTAMP '2016-12-31 00:00:00' AS EventTime FROM hits USING SAMPLE 10000 ROWS; REFRESH FEATURE f AT '2016-01-01 00:00:00';
RUN_QUERY=SELECT event_count IS NULL AS missing, count(*) AS n FROM SERVE FEATURE f FOR serve_requests ASOF EventTime GROUP BY event_count IS NULL;
