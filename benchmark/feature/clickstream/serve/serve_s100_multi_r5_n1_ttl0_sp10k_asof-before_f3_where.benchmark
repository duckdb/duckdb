# name: benchmark/feature/clickstream/serve/serve_s100_multi_r5_n1_ttl0_sp10k_asof-before_f3_where.benchmark
# description: Generated SERVE scenario s100_multi_r5_n1_ttl0_sp10k_asof-before_f3_where (seed=42)
# group: [feature]

template benchmark/feature/clickstream/serve/serve.benchmark.in
BENCH_NAME=Serve_s100_multi_r5_n1_ttl0_sp10k_asof-before_f3_where
PARQUET_COUNT=100
SETUP_SQL=DROP FEATURE IF EXISTS f; DROP FEATURE IF EXISTS f2; DROP FEATURE IF EXISTS f3; CREATE FEATURE f ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count, AVG(RegionID) AS avg_region, MIN(RegionID) AS min_region, MAX(RegionID) AS max_region FROM hits GROUP BY UserID); CREATE FEATURE f2 ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count_2, AVG(RegionID) AS avg_region_2 FROM hits GROUP BY UserID); CREATE FEATURE f3 ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count_3 FROM hits GROUP BY UserID); CREATE OR REPLACE TABLE serve_requests AS SELECT DISTINCT UserID, TIMESTAMP '2015-12-02 00:00:00' AS EventTime FROM hits USING SAMPLE 10000 ROWS; REFRESH FEATURE f AT '2016-01-01 00:00:00'; REFRESH FEATURE f2 AT '2016-01-01 00:00:00'; REFRESH FEATURE f3 AT '2016-01-01 00:00:00';
RUN_QUERY=SELECT * FROM SERVE FEATURES f, f2, f3 FOR serve_requests ASOF EventTime WHERE event_count IS NOT NULL;
