# name: benchmark/feature/clickstream/serve/serve_s20_window_r5_n5_ttl30d_sp10k_asof-latest_f3_bare.benchmark
# description: Generated SERVE scenario s20_window_r5_n5_ttl30d_sp10k_asof-latest_f3_bare (seed=42)
# group: [serve]

template benchmark/feature/clickstream/serve/serve.benchmark.in
BENCH_NAME=Serve_s20_window_r5_n5_ttl30d_sp10k_asof-latest_f3_bare
PARQUET_COUNT=20
SETUP_SQL=DROP FEATURE IF EXISTS f; DROP FEATURE IF EXISTS f2; DROP FEATURE IF EXISTS f3; CREATE FEATURE f ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS TTL 30 DAYS RETAIN 5 AS (SELECT DISTINCT UserID, COUNT(*) OVER (PARTITION BY UserID) AS event_count, AVG(RegionID) OVER (PARTITION BY UserID) AS avg_region FROM hits); CREATE FEATURE f2 ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS TTL 30 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count_2, AVG(RegionID) AS avg_region_2 FROM hits GROUP BY UserID); CREATE FEATURE f3 ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS TTL 30 DAYS RETAIN 5 AS (SELECT UserID, COUNT(*) AS event_count_3 FROM hits GROUP BY UserID); CREATE OR REPLACE TABLE serve_requests AS SELECT DISTINCT UserID, TIMESTAMP '2016-12-31 00:00:00' AS EventTime FROM hits USING SAMPLE 10000 ROWS; REFRESH FEATURE f AT '2015-09-03 00:00:00'; REFRESH FEATURE f2 AT '2015-09-03 00:00:00'; REFRESH FEATURE f3 AT '2015-09-03 00:00:00'; REFRESH FEATURE f AT '2015-10-03 00:00:00'; REFRESH FEATURE f2 AT '2015-10-03 00:00:00'; REFRESH FEATURE f3 AT '2015-10-03 00:00:00'; REFRESH FEATURE f AT '2015-11-02 00:00:00'; REFRESH FEATURE f2 AT '2015-11-02 00:00:00'; REFRESH FEATURE f3 AT '2015-11-02 00:00:00'; REFRESH FEATURE f AT '2015-12-02 00:00:00'; REFRESH FEATURE f2 AT '2015-12-02 00:00:00'; REFRESH FEATURE f3 AT '2015-12-02 00:00:00'; REFRESH FEATURE f AT '2016-01-01 00:00:00'; REFRESH FEATURE f2 AT '2016-01-01 00:00:00'; REFRESH FEATURE f3 AT '2016-01-01 00:00:00';
RUN_QUERY=SELECT * FROM SERVE FEATURES f, f2, f3 FOR serve_requests ASOF EventTime;
