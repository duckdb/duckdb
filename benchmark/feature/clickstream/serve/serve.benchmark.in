# Parameterized SERVE benchmark template for the clickstream feature-store workload.
# Concrete .benchmark files (generated by scripts/generate_feature_benchmarks.py) provide
# BENCH_NAME, PARQUET_COUNT, SETUP_SQL and RUN_QUERY via a `template` block.
# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [serve]

include benchmark/feature/clickstream/data/clickstream_load.benchmark.in

name ${BENCH_NAME}
group feature

# Sanity check (runs once, before the timed loop): source, feature store and serving spine
# must be populated, otherwise the timings would be meaningless.
assert I
SELECT COUNT(*) > 0 AND (SELECT COUNT(*) FROM f) > 0 AND (SELECT COUNT(*) FROM serve_requests) > 0 FROM hits;
----
true

run
${RUN_QUERY}
