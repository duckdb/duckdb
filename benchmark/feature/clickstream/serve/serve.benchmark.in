# Parameterized SERVE benchmark template for the clickstream feature-store workload.
# Concrete .benchmark files (generated by scripts/generate_feature_benchmarks.py) provide
# BENCH_NAME, PARQUET_COUNT, SETUP_SQL and RUN_QUERY via a `template` block.
# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [feature]

require parquet load_only

require httpfs load_only

# Cache the source data per scale. The cache key MUST include PARQUET_COUNT, otherwise the
# 20-file and 100-file datasets would collide in a single db file.
cache feature_src_${PARQUET_COUNT}.db

# First run for a given scale: build the source (cached), then materialise the feature setup.
# Inline SQL is ${VAR}-substituted line by line, so PARQUET_COUNT / SETUP_SQL expand here.
# NOTE: no SQL "--" comments inside this block; the interpreter joins lines with a space, which
# would comment out everything that follows on the same joined line.
load
CREATE TABLE hits_raw AS SELECT CAST(UserID AS BIGINT) AS UserID, epoch_ms(EventTime * 1000) AS EventTime, CAST(RegionID AS INTEGER) AS RegionID, CAST(CounterID AS INTEGER) AS CounterID FROM read_parquet([format('https://datasets.clickhouse.com/hits_compatible/athena_partitioned/hits_{}.parquet', x) for x in range(0, ${PARQUET_COUNT})], binary_as_string = True);
CREATE TABLE users (UserID BIGINT PRIMARY KEY);
INSERT INTO users SELECT DISTINCT UserID FROM hits_raw;
CREATE TABLE hits (UserID BIGINT, EventTime TIMESTAMP, RegionID INTEGER, CounterID INTEGER, FOREIGN KEY (UserID) REFERENCES users(UserID));
INSERT INTO hits SELECT UserID, EventTime, RegionID, CounterID FROM hits_raw;
DROP TABLE hits_raw;
${SETUP_SQL}

# Subsequent runs for the same scale: source is already cached, so only (re)build the
# scenario-specific feature setup. SETUP_SQL is idempotent (DROP FEATURE IF EXISTS first).
reload
${SETUP_SQL}

name ${BENCH_NAME}
group feature

# Sanity check (runs once, before the timed loop): source, feature store and serving spine
# must be populated, otherwise the timings would be meaningless.
assert I
SELECT COUNT(*) > 0 AND (SELECT COUNT(*) FROM f) > 0 AND (SELECT COUNT(*) FROM serve_requests) > 0 FROM hits;
----
true

run
${RUN_QUERY}
