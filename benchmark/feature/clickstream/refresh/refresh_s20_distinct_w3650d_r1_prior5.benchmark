# name: benchmark/feature/clickstream/refresh/refresh_s20_distinct_w3650d_r1_prior5.benchmark
# description: Generated REFRESH scenario s20_distinct_w3650d_r1_prior5 (seed=42)
# group: [feature]

template benchmark/feature/clickstream/refresh/refresh.benchmark.in
BENCH_NAME=Refresh_s20_distinct_w3650d_r1_prior5
PARQUET_COUNT=20
SETUP_SQL=DROP FEATURE IF EXISTS f; DROP FEATURE IF EXISTS f2; DROP FEATURE IF EXISTS f3; CREATE FEATURE f ENTITY users TIMESTAMP EventTime WINDOW 3650 DAYS RETAIN 1 AS (SELECT UserID, COUNT(DISTINCT RegionID) AS distinct_regions, COUNT(*) AS event_count FROM hits GROUP BY UserID); REFRESH FEATURE f AT '2015-08-04 00:00:00'; REFRESH FEATURE f AT '2015-09-03 00:00:00'; REFRESH FEATURE f AT '2015-10-03 00:00:00'; REFRESH FEATURE f AT '2015-11-02 00:00:00'; REFRESH FEATURE f AT '2015-12-02 00:00:00';
RUN_QUERY=REFRESH FEATURE f AT '2016-01-01 00:00:00';
