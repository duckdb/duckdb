# name: benchmark/feature/clickstream/refresh/refresh_s20_distinct_w30d_r5_prior0.benchmark
# description: Generated REFRESH scenario s20_distinct_w30d_r5_prior0 (seed=42)
# group: [feature]

template benchmark/feature/clickstream/refresh/refresh.benchmark.in
BENCH_NAME=Refresh_s20_distinct_w30d_r5_prior0
PARQUET_COUNT=20
SETUP_SQL=DROP FEATURE IF EXISTS f; DROP FEATURE IF EXISTS f2; DROP FEATURE IF EXISTS f3; CREATE FEATURE f ENTITY users TIMESTAMP EventTime WINDOW 30 DAYS RETAIN 5 AS (SELECT UserID, COUNT(DISTINCT RegionID) AS distinct_regions, COUNT(*) AS event_count FROM hits GROUP BY UserID);
RUN_QUERY=REFRESH FEATURE f AT '2016-01-01 00:00:00';
