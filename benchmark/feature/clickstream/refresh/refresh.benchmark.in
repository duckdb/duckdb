# Parameterized REFRESH benchmark template for the clickstream feature-store workload.
# Concrete .benchmark files (generated by scripts/generate_feature_benchmarks.py) provide
# BENCH_NAME, PARQUET_COUNT, SETUP_SQL and RUN_QUERY via a `template` block.
# The timed statement (RUN_QUERY) is a REFRESH: a windowed group-by snapshot materialization.
# name: ${FILE_PATH}
# description: ${DESCRIPTION}
# group: [feature]

include benchmark/feature/clickstream/data/clickstream_load.benchmark.in

name ${BENCH_NAME}
group feature

# Only the source needs to exist before timing; the feature may be at version 0 when PRIOR_VERSIONS=0,
# so the assert deliberately does not read the feature store.
assert I
SELECT COUNT(*) > 0 FROM hits;
----
true

run
${RUN_QUERY}
