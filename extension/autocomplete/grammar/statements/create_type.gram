CreateTypeStmt[unique_ptr<CreateStatement>] <- 'TYPE' IfNotExists? QualifiedName 'AS' CreateType
CreateType[unique_ptr<CreateTypeInfo>] <- EnumSelectType / EnumStringLiteralList / Type
EnumSelectType[unique_ptr<SelectStatement>] <- 'ENUM' Parens(SelectStatementInternal)
EnumStringLiteralList[LogicalType] <- 'ENUM' Parens(List(StringLiteral)?)
