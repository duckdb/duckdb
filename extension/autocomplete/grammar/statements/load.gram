LoadStatement[unique_ptr<SQLStatement>] <- 'LOAD' ColIdOrString
InstallStatement[unique_ptr<SQLStatement>] <- 'FORCE'? 'INSTALL' IdentifierOrStringLiteral FromSource? VersionNumber?
UpdateExtensionsStatement[unique_ptr<SQLStatement>] <- 'UPDATE' 'EXTENSIONS' Parens(List(Identifier))?
FromSource[ExtensionRepositoryInfo] <- 'FROM' (Identifier / StringLiteral)
VersionNumber[string] <- 'VERSION' IdentifierOrStringLiteral