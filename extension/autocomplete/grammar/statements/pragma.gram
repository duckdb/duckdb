PragmaStatement[unique_ptr<SQLStatement>] <- 'PRAGMA' (PragmaAssign / PragmaFunction)

PragmaAssign[unique_ptr<SQLStatement>] <- SettingName '=' VariableList
PragmaFunction[unique_ptr<SQLStatement>] <- PragmaName PragmaParameters?
PragmaParameters[vector<unique_ptr<ParsedExpression>>] <- Parens(List(Expression))
