AttachStatement[unique_ptr<SQLStatement>] <- 'ATTACH' OrReplace? IfNotExists? Database? DatabasePath AttachAlias? AttachOptions?

Database <- 'DATABASE'
DatabasePath[unique_ptr<ParsedExpression>] <- Expression
AttachAlias[string] <- 'AS' ColId
AttachOptions[vector<GenericCopyOption>] <- GenericCopyOptionList
