LoadStatement <- 'LOAD' ColIdOrString
InstallStatement <- 'FORCE'? 'INSTALL' IdentifierOrStringLiteral FromSource? VersionNumber?
UpdateExtensionsStatement <- 'UPDATE' 'EXTENSIONS' Parens(List(Identifier))?
FromSource <- 'FROM' (Identifier / StringLiteral)
VersionNumber <- 'VERSION' IdentifierOrStringLiteral