[
	{
		"name": "variant_array_length",
		"variants": [
			{
				"parameters": [
					{
						"name": "input_variant",
						"type": "VARIANT"
					}
				],
				"description": "Returns the number of elements in the variant, or `0` if not an array.",
				"example": "variant_array_length(['duck', 'goose']::VARIANT)",
				"categories": [
					"variant"
				]
			},
			{
				"parameters": [
					{
						"name": "input_variant",
						"type": "VARIANT"
					},
					{
						"name": "path",
						"type": "VARCHAR"
					}
				],
				"description": "Returns the number of elements in the array at the specified path in the variant, or `0` if not an array.",
				"example": "variant_array_length({'a': ['duck', 'goose']}::VARIANT, 'a')",
				"categories": [
					"variant"
				]
			},
			{
				"parameters": [
					{
						"name": "input_variant",
						"type": "VARIANT"
					},
					{
						"name": "path",
						"type": "VARCHAR[]"
					}
				],
				"description": "Returns the number of elements in the array for each specified path in the variant, or `0` if not an array.",
				"example": "variant_array_length({'a': 1, 'b': ['duck', 'goose']}::VARIANT, ['a', 'b'])",
				"categories": [
					"variant"
				]
			}
		],
		"type": "scalar_function_set"
	},
	{
		"name": "variant_exists",
		"variants": [
			{
				"parameters": [
					{
						"name": "input_variant",
						"type": "VARIANT"
					},
					{
						"name": "path",
						"type": "VARCHAR"
					}
				],
				"description": "Returns whether the specified path exists in the variant.",
				"example": "variant_exists({'a': { 'a': 1, 'b': 2}}::VARIANT, 'a')",
				"categories": [
					"variant"
				]
			},
			{
				"parameters": [
					{
						"name": "input_variant",
						"type": "VARIANT"
					},
					{
						"name": "path",
						"type": "VARCHAR[]"
					}
				],
				"description": "Returns a boolean for each specified path, indicating whether that path exists in the variant.",
				"example": "variant_exists({'a': 1, 'b': 2}::VARIANT, ['a', 'c'])",
				"categories": [
					"variant"
				]
			}
		],
		"type": "scalar_function_set"
	},
	{
